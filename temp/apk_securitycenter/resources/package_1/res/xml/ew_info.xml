<?xml version='1.0' encoding='utf-8' ?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <PreferenceCategory android:title="@string/ew_main_detail_title"
                      android:key="category_settings">
    <Preference android:title="@string/ew_main_settings"
                android:key="settings" />
    <Preference android:title="@string/ew_info_rule_warning"
                android:key="container_warning_desc" />
    <Preference android:title="@string/ew_main_warning_list_title"
                android:key="history">
      <intent android:targetPackage="com.miui.securitycenter"
              android:targetClass="com.miui.earthquakewarning.ui.EarthquakeWarningListActivity" />
    </Preference>
  </PreferenceCategory>
  <PreferenceCategory android:title="@string/ew_info_other">
    <Preference android:title="@string/menu_item_about_privacy_title"
                android:key="container_warning_privacy" />
    <Preference android:title="@string/ew_info_agreement"
                android:key="container_warning_agreement" />
    <Preference android:title="@string/eew_privacy_revoke_title"
                android:key="earthquake_warning_revoke"
                app:isPreferenceVisible="false" />
    <Preference android:title="@string/ew_monitor_privacy_revoke_title"
                android:key="earthquake_monitor_revoke"
                app:isPreferenceVisible="false" />
    <Preference android:title="@string/ew_user_feedback"
                android:key="container_warning_feedback"
                app:isPreferenceVisible="false" />
  </PreferenceCategory>
</PreferenceScreen>