<?xml version='1.0' encoding='utf-8' ?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <com.miui.permcenter.permissions.PermTipsPreference android:key="permission_desc"
                        app:isPreferenceVisible="false" />
  <miuix.preference.PreferenceCategory>
    <miuix.preference.SingleChoicePreferenceCategory android:key="permission_change_radio_group">
      <miuix.preference.SingleChoicePreference android:persistent="false"
                            android:title="@string/permission_action_reject"
                            android:key="permission_deny" />
      <miuix.preference.SingleChoicePreference android:persistent="false"
                            android:title="@string/permission_action_prompt"
                            android:key="permission_prompt" />
      <miuix.preference.SingleChoicePreference android:persistent="false"
                            android:title="@string/permission_action_foreground"
                            android:key="permission_foreground" />
      <miuix.preference.SingleChoicePreference android:persistent="false"
                            android:title="@string/permission_action_always"
                            android:key="permission_always" />
    </miuix.preference.SingleChoicePreferenceCategory>
  </miuix.preference.PreferenceCategory>
  <PreferenceCategory android:key="category"
                      app:isPreferenceVisible="false">
    <miuix.preference.CheckBoxPreference android:title="@string/permission_precise_location"
                          android:key="perm_detail_checkbox"
                          app:isPreferenceVisible="false" />
    <miuix.preference.CheckBoxPreference android:title="@string/app_management_for_independent_storage"
                          android:key="app_management_for_independent_storage"
                          android:summary="@string/app_management_for_independent_storage_desc"
                          app:isPreferenceVisible="false" />
  </PreferenceCategory>
  <com.miui.permcenter.permissions.SecurityAccessTipPreference android:key="security_access_tip"
                        app:isPreferenceVisible="false" />
</PreferenceScreen>