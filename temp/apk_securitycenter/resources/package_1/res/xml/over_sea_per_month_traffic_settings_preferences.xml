<?xml version='1.0' encoding='utf-8' ?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <PreferenceCategory android:title="@string/pref_category_package_type_title"
                      android:key="pref_key_package_type_category">
    <miuix.preference.TextPreference android:title="@string/pref_title_traffic_package_type"
                          android:key="pref_key_package_type_old"
                          android:summary="@string/modify_cellular_type" />
    <miuix.preference.DropDownPreference android:title="@string/pref_title_traffic_package_type"
                          android:key="pref_key_package_type"
                          android:summary="@string/modify_cellular_type"
                          app:entries="@array/cellular_package_type"
                          app:entryValues="@array/cellular_package_type" />
  </PreferenceCategory>
  <PreferenceCategory android:title="@string/daily_card_setting_fragment_month_package"
                      android:key="pref_key_monthly_package">
    <miuix.preference.DropDownPreference android:title="@string/pref_traffic_daily_package_brand"
                          android:key="pref_daily_card_brand"
                          app:entries="@array/daily_rent_card_brands"
                          app:entryValues="@array/daily_rent_card_brands" />
    <miuix.preference.TextPreference android:title="@string/pref_traffic_daily_package_brand"
                          android:key="pref_daily_card_brand_old" />
    <miuix.preference.TextPreference android:title="@string/daily_card_setting_fragment_daily_package"
                          android:key="pref_daily_card_package" />
    <miuix.preference.TextPreference android:title="@string/fixed_cellular_data_quota_monthly"
                          android:key="pref_normal_package_setting" />
    <miuix.preference.TextPreference android:title="@string/traffic_usage_warning_limit"
                          android:key="pref_not_limit_traffic_limit" />
    <miuix.preference.TextPreference android:title="@string/pref_daily_adjust"
                          android:key="pref_daily_adjust_traffic" />
    <miuix.preference.TextPreference android:title="@string/pref_free_adjust"
                          android:key="pref_leisure_adjust_traffic" />
    <miuix.preference.TextPreference android:title="@string/pref_normal_traffic_limit"
                          android:key="pref_normal_traffic_limit_old" />
    <miuix.preference.DropDownPreference android:title="@string/pref_normal_traffic_limit"
                          android:key="pref_normal_traffic_limit"
                          app:entries="@array/over_limit_traffic_waring_style"
                          app:entryValues="@array/over_limit_traffic_waring_style" />
    <miuix.preference.TextPreference android:title="@string/pref_special_package_setting"
                          android:key="pref_key_special_package_setting"
                          android:summary="@string/pref_special_package_setting_summary" />
  </PreferenceCategory>
  <PreferenceCategory android:title="@string/pref_more_settings"
                      android:key="pref_more_settings">
    <miuix.preference.TextPreference android:title="@string/pref_warning_values"
                          android:key="pref_month_warning" />
    <miuix.preference.TextPreference android:title="@string/pref_pkg_begin_date"
                          android:key="pref_package_begin_date" />
    <CheckBoxPreference android:title="@string/traffic_config_alert_auto_modify"
                        android:key="pref_key_auto_modify_package"
                        android:summary="@string/traffic_alert_auto_modify_package_summary" />
  </PreferenceCategory>
</PreferenceScreen>