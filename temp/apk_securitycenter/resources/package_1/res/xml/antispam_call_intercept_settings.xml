<?xml version='1.0' encoding='utf-8' ?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <PreferenceCategory android:title="@string/st_call_stranger_group"
                      android:key="call_stranger_group">
    <CheckBoxPreference android:title="@string/st_call_intercept_all"
                        android:key="key_call_all"
                        android:disableDependentsState="true" />
    <CheckBoxPreference android:title="@string/st_call_intercept_stranger"
                        android:key="key_call_stranger"
                        android:dependency="key_call_all"
                        android:disableDependentsState="true" />
    <CheckBoxPreference android:persistent="false"
                        android:title="@string/st_call_intercept_forwarding"
                        android:key="key_call_forwarding"
                        android:dependency="key_call_stranger" />
    <CheckBoxPreference android:title="@string/st_call_intercept_oversea"
                        android:key="key_call_oversea"
                        android:dependency="key_call_stranger" />
    <CheckBoxPreference android:persistent="false"
                        android:title="@string/st_call_intercept_unknown"
                        android:key="key_call_unknown"
                        android:dependency="key_call_all"
                        android:disableDependentsState="true" />
  </PreferenceCategory>
  <PreferenceCategory android:title="@string/st_mark_number_group"
                      android:key="mark_settings_group">
    <CheckBoxPreference android:persistent="false"
                        android:title="@string/st_call_intercept_mark_fraud"
                        android:key="key_mark_fraud" />
    <CheckBoxPreference android:persistent="false"
                        android:title="@string/st_call_intercept_mark_agent"
                        android:key="key_mark_agent" />
    <CheckBoxPreference android:persistent="false"
                        android:title="@string/st_call_intercept_mark_sell"
                        android:key="key_mark_sell" />
  </PreferenceCategory>
  <PreferenceCategory android:title="@string/st_title_settings_other_group"
                      android:key="key_repeated_group">
    <CheckBoxPreference android:persistent="false"
                        android:title="@string/repeated_marked_number_title"
                        android:key="key_repeated_marked_number"
                        android:summary="@string/repeated_marked_number_summary" />
  </PreferenceCategory>
  <PreferenceCategory android:title="@string/st_call_backsound_group"
                      android:key="backsound_group">
    <miuix.preference.TextPreference android:title="@string/st_call_intercept_reported"
                          android:key="backsound_1"
                          app:isPreferenceVisible="false" />
    <miuix.preference.TextPreference android:title="@string/st_call_intercept_reported"
                          android:key="backsound_2"
                          app:isPreferenceVisible="false" />
  </PreferenceCategory>
</PreferenceScreen>