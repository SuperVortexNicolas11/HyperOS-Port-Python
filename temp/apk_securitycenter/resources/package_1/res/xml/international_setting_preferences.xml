<?xml version='1.0' encoding='utf-8' ?>
<PreferenceScreen android:title="setting_preferences" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <PreferenceCategory android:title="@string/pref_about_traffic_title"
                      android:key="category_key_traffic">
    <CheckBoxPreference android:title="@string/pref_traffic_manage_title"
                        android:key="pref_traffic_manage" />
    <Preference android:title="@string/pref_mi_sim_settings"
                android:key="pref_key_mi_sim_settings" />
    <miuix.preference.TextPreference android:title="@string/pref_package_traffic_settings"
                          android:key="pref_key_package_traffic" />
    <miuix.preference.TextPreference android:title="@string/pref_adjust_traffic_data"
                          android:key="pref_key_traffic_correction" />
    <Preference android:title="@string/daily_limit_and_lock_screen"
                android:key="pref_key_limit_traffic_per_day" />
    <Preference android:title="@string/bh_home_to_set_phone_number"
                android:key="pref_key_set_phone_number_slot1"
                app:isPreferenceVisible="false" />
  </PreferenceCategory>
  <PreferenceCategory android:title="@string/pref_about_traffic_title"
                      android:key="category_key_traffic2">
    <CheckBoxPreference android:title="@string/pref_traffic_manage_title"
                        android:key="pref_traffic_manage2" />
    <Preference android:title="@string/pref_mi_sim_settings"
                android:key="pref_key_mi_sim_settings2" />
    <miuix.preference.TextPreference android:title="@string/pref_package_traffic_settings"
                          android:key="pref_key_package_traffic2" />
    <miuix.preference.TextPreference android:title="@string/pref_adjust_traffic_data"
                          android:key="pref_key_traffic_correction2" />
    <Preference android:title="@string/daily_limit_and_lock_screen"
                android:key="pref_key_limit_traffic_per_day2" />
    <Preference android:title="@string/bh_home_to_set_phone_number"
                android:key="pref_key_set_phone_number_slot2"
                app:isPreferenceVisible="false" />
  </PreferenceCategory>
  <PreferenceCategory android:title="@string/pref_category_title_other"
                      android:key="category_key_other">
    <CheckBoxPreference android:title="@string/pref_title_update_notification"
                        android:key="pref_show_traffic_notification"
                        android:defaultValue="false" />
    <CheckBoxPreference android:title="@string/pref_title_traffic_speed_state"
                        android:key="pref_show_traffic_speed_state"
                        android:defaultValue="false" />
    <Preference android:title="@string/pref_title_declaration"
                android:key="pref_key_declaration" />
    <Preference android:title="@string/bh_settings_user_agreement"
                android:key="pref_key_user_agreement"
                app:isPreferenceVisible="false" />
    <Preference android:title="@string/bh_settings_policy_text"
                android:key="pref_key_privacy_policy"
                app:isPreferenceVisible="false" />
    <Preference android:title="@string/bh_settings_withdrawal_text"
                android:key="pref_key_withdrawal_consent"
                android:summary="@string/bh_settings_withdrawal_yulore"
                app:isPreferenceVisible="false" />
  </PreferenceCategory>
</PreferenceScreen>