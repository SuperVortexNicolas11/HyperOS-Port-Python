<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:layout_width="fill_parent"
              android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <RelativeLayout android:id="@id/actionBar"
                  android:layout_width="fill_parent"
                  android:layout_height="@dimen/gb_action_bar_height_land">
    <ImageView android:id="@id/backBtn"
               android:padding="@dimen/dp_6"
               android:layout_width="@dimen/dp_36"
               android:layout_height="@dimen/dp_36"
               android:src="@drawable/gb_action_bar_back_light_land_selector"
               android:scaleType="fitCenter"
               android:layout_centerVertical="true"
               android:contentDescription="@string/game_toolbox_btn_back_talkback"
               android:layout_marginStart="@dimen/dp_6_35"
               android:layout_alignParentStart="true" />
    <FrameLayout android:id="@id/search_view"
                 android:layout_width="wrap_content"
                 android:layout_height="wrap_content"
                 android:layout_centerVertical="true"
                 android:importantForAccessibility="no"
                 android:layout_marginEnd="@dimen/dp_14_55"
                 android:layout_alignParentEnd="true">
      <EditText android:textSize="@dimen/sp_13"
                android:textColor="@color/white"
                android:textColorHint="@color/whitealpha50"
                android:id="@id/input"
                android:background="@drawable/bg_gb_settings_search"
                android:layout_width="@dimen/gb_setting_search_bar_width"
                android:layout_height="@dimen/gb_setting_search_bar_height"
                android:inputType="text"
                android:imeOptions="flagNoExtractUi"
                android:drawableStart="@drawable/gb_settings_search_thumb"
                android:textDirection="locale"
                android:paddingStart="@dimen/dp_40"
                android:paddingEnd="@dimen/dp_5" />
    </FrameLayout>
    <TextView android:textSize="@dimen/sp_17_45"
              android:textColor="@color/gb_settings_second_title_color"
              android:ellipsize="end"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/gs_anto_clean_memory_whitelist"
              android:singleLine="true"
              android:layout_centerVertical="true"
              android:textDirection="locale"
              android:layout_toStartOf="@id/search_view"
              android:layout_toEndOf="@id/backBtn" />
  </RelativeLayout>
  <miuix.springback.view.SpringBackLayout android:layout_width="fill_parent"
                        android:layout_height="fill_parent"
                        app:scrollableView="@id/list_view">
    <miuix.recyclerview.widget.RecyclerView android:id="@id/list_view"
                          android:layout_width="fill_parent"
                          android:layout_height="fill_parent" />
  </miuix.springback.view.SpringBackLayout>
  <TextView android:layout_gravity="center"
            android:id="@id/empty_view"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
</LinearLayout>