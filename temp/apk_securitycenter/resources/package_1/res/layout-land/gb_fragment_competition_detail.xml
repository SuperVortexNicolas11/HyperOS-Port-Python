<?xml version='1.0' encoding='utf-8' ?>
<RelativeLayout android:layout_width="fill_parent"
                android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <include layout="@layout/gb_settings_second_level_action_bar" />
  <miuix.springback.view.SpringBackLayout android:layout_width="fill_parent"
                        android:layout_height="fill_parent"
                        android:layout_below="@id/actionBar"
                        app:scrollableView="@id/scroll_view">
    <androidx.core.widget.NestedScrollView android:id="@id/scroll_view"
                          android:layout_width="fill_parent"
                          android:layout_height="fill_parent">
      <LinearLayout android:orientation="vertical"
                    android:id="@id/layout_competition"
                    android:paddingBottom="@dimen/view_dimen_100"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">
        <TextView android:textSize="@dimen/sp_13"
                  android:textColor="@color/whitealpha50"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="@dimen/dp_6_73"
                  android:text="@string/gs_performance_mode_detail"
                  android:layout_marginStart="@dimen/dp_44"
                  android:layout_marginEnd="@dimen/dp_44"
                  style="@style/GBSettingItemSubtitle" />
        <View android:background="@drawable/gb_settings_divider_land"
              android:layout_width="fill_parent"
              android:layout_height="@dimen/dp_1"
              android:layout_marginTop="@dimen/dp_7_30"
              android:layout_marginBottom="@dimen/dp_15_27"
              android:layout_marginStart="@dimen/dp_44"
              android:layout_marginEnd="@dimen/dp_44" />
        <LinearLayout android:orientation="horizontal"
                      android:id="@id/wlan_optimization"
                      android:paddingTop="@dimen/dp_18"
                      android:paddingBottom="@dimen/dp_18"
                      android:focusable="true"
                      android:focusableInTouchMode="true"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content"
                      android:paddingStart="@dimen/dp_44"
                      android:paddingEnd="@dimen/dp_44"
                      android:paddingVertical="@dimen/dp_18">
          <ImageView android:layout_width="@dimen/dp_40"
                     android:layout_height="@dimen/dp_40"
                     android:src="@drawable/gb_competition_wlan" />
          <LinearLayout android:orientation="vertical"
                        android:layout_width="0.0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.0"
                        android:layout_marginStart="@dimen/dp_16_36"
                        android:layout_marginEnd="@dimen/dp_16_36">
            <TextView android:textSize="@dimen/sp_15_27"
                      android:id="@id/wlan_optimization_title"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:text="@string/wlan_optimization_title"
                      style="@style/GBSettingItemTitle" />
            <TextView android:textSize="@dimen/sp_13_82"
                      android:textColor="@color/color_white_50"
                      android:id="@id/wlan_optimization_summary"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:layout_marginTop="@dimen/dp_2_91"
                      android:text="@string/wlan_optimization_summary"
                      style="@style/GBSettingItemSubtitle" />
          </LinearLayout>
          <com.miui.gamebooster.widget.SwitchButton android:layout_gravity="center_vertical"
                                android:id="@id/sliding_wifi"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:importantForAccessibility="no"
                                app:thumbMargin="@dimen/dp_3" />
        </LinearLayout>
        <LinearLayout android:orientation="horizontal"
                      android:id="@id/doze_optimization"
                      android:paddingTop="@dimen/dp_18"
                      android:paddingBottom="@dimen/dp_18"
                      android:focusable="true"
                      android:focusableInTouchMode="true"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content"
                      android:paddingStart="@dimen/dp_44"
                      android:paddingEnd="@dimen/dp_44"
                      android:paddingVertical="@dimen/dp_18">
          <ImageView android:layout_width="@dimen/dp_40"
                     android:layout_height="@dimen/dp_40"
                     android:src="@drawable/gb_competition_doze" />
          <LinearLayout android:orientation="vertical"
                        android:layout_width="0.0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.0"
                        android:layout_marginStart="@dimen/dp_16_36"
                        android:layout_marginEnd="@dimen/dp_16_36">
            <TextView android:textSize="@dimen/sp_15_27"
                      android:id="@id/doze_optimization_title"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:text="@string/doze_optimization_title"
                      style="@style/GBSettingItemTitle" />
            <TextView android:textSize="@dimen/sp_13_82"
                      android:textColor="@color/whitealpha50"
                      android:id="@id/doze_optimization_summary"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:layout_marginTop="@dimen/dp_2_91"
                      android:text="@string/doze_optimization_summary"
                      style="@style/GBSettingItemSubtitle" />
          </LinearLayout>
          <com.miui.gamebooster.widget.SwitchButton android:layout_gravity="center_vertical"
                                android:id="@id/sliding_touch"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:importantForAccessibility="no"
                                app:thumbMargin="@dimen/dp_3" />
        </LinearLayout>
        <LinearLayout android:orientation="horizontal"
                      android:id="@id/audio_optimization"
                      android:paddingTop="@dimen/dp_18"
                      android:paddingBottom="@dimen/dp_18"
                      android:focusable="true"
                      android:focusableInTouchMode="true"
                      android:visibility="gone"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content"
                      android:paddingStart="@dimen/dp_44"
                      android:paddingEnd="@dimen/dp_44"
                      android:paddingVertical="@dimen/dp_18">
          <ImageView android:layout_width="@dimen/dp_40"
                     android:layout_height="@dimen/dp_40"
                     android:src="@drawable/gb_competition_audio" />
          <LinearLayout android:orientation="vertical"
                        android:layout_width="0.0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.0"
                        android:layout_marginStart="@dimen/dp_16_36"
                        android:layout_marginEnd="@dimen/dp_16_36">
            <TextView android:textSize="@dimen/sp_15_27"
                      android:id="@id/audio_optimization_title"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:text="@string/audio_optimization_title"
                      style="@style/GBSettingItemTitle" />
            <TextView android:textSize="@dimen/sp_13_82"
                      android:textColor="@color/color_white_50"
                      android:id="@id/tv_audio_optimization_summary"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:layout_marginTop="@dimen/dp_2_91"
                      android:text="@string/audio_optimization_summary_new"
                      style="@style/GBSettingItemSubtitle" />
          </LinearLayout>
          <com.miui.gamebooster.widget.SwitchButton android:layout_gravity="center_vertical"
                                android:id="@id/sliding_audio"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:importantForAccessibility="no"
                                app:thumbMargin="@dimen/dp_3" />
        </LinearLayout>
        <LinearLayout android:orientation="horizontal"
                      android:id="@id/dynamic_performance"
                      android:paddingTop="@dimen/dp_18"
                      android:paddingBottom="@dimen/dp_18"
                      android:focusable="true"
                      android:focusableInTouchMode="true"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content"
                      android:paddingStart="@dimen/dp_44"
                      android:paddingEnd="@dimen/dp_44"
                      android:paddingVertical="@dimen/dp_18">
          <ImageView android:layout_width="@dimen/dp_40"
                     android:layout_height="@dimen/dp_40"
                     android:src="@drawable/gb_competition_dynamic" />
          <LinearLayout android:orientation="vertical"
                        android:layout_width="0.0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.0"
                        android:layout_marginStart="@dimen/dp_16_36"
                        android:layout_marginEnd="@dimen/dp_16_36">
            <TextView android:textSize="@dimen/sp_15_27"
                      android:id="@id/dynamic_performance_title"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:text="@string/dynamic_performance_optimization_title"
                      style="@style/GBSettingItemTitle" />
            <TextView android:textSize="@dimen/sp_13_82"
                      android:textColor="@color/color_white_50"
                      android:id="@id/dynamic_performance_summary"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:layout_marginTop="@dimen/dp_2_91"
                      android:text="@string/dynamic_performance_optimization_summary"
                      style="@style/GBSettingItemSubtitle" />
          </LinearLayout>
          <com.miui.gamebooster.widget.SwitchButton android:layout_gravity="center_vertical"
                                android:id="@id/sliding_dynamic_performance"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:importantForAccessibility="no"
                                app:thumbMargin="@dimen/dp_3" />
        </LinearLayout>
      </LinearLayout>
    </androidx.core.widget.NestedScrollView>
  </miuix.springback.view.SpringBackLayout>
</RelativeLayout>