<?xml version='1.0' encoding='utf-8' ?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">
  <LinearLayout android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
    <ImageView android:id="@id/startBandage"
               android:layout_width="0.0dp"
               android:layout_height="wrap_content"
               android:src="@drawable/hardware_info_bandage_start"
               android:scaleType="fitEnd"
               android:tint="@color/gamebooster_hardware"
               android:layout_weight="1.0" />
    <LinearLayout android:gravity="center_vertical"
                  android:orientation="horizontal"
                  android:id="@id/startWidgetsContainer"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:paddingStart="@dimen/gb_view_dimen_26"
                  android:paddingEnd="@dimen/gb_view_dimen_26">
      <RelativeLayout android:id="@id/cpuInfoContainer"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:minWidth="@dimen/view_dimen_106"
                      android:layout_marginEnd="@dimen/view_dimen_11">
        <ImageView android:id="@id/cpuInfo_icon"
                   android:layout_width="wrap_content"
                   android:layout_height="wrap_content"
                   android:src="@drawable/home_page_hi_cpu"
                   android:tint="@color/gamebooster_hardware"
                   android:layout_centerVertical="true" />
        <TextView android:textSize="@dimen/gb_fontsize_32"
                  android:textStyle="bold"
                  android:textColor="@color/gamebooster_hardware"
                  android:gravity="end"
                  android:id="@id/cpuInfo"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:minWidth="@dimen/view_dimen_58"
                  android:maxLines="1"
                  android:layout_centerVertical="true"
                  android:alpha="0.5"
                  android:fontFamily="sans-serif-medium"
                  android:layout_toEndOf="@id/cpuInfo_icon" />
      </RelativeLayout>
      <RelativeLayout android:id="@id/gpuInfoContainer"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:minWidth="@dimen/view_dimen_106"
                      android:layout_marginStart="8.0dp">
        <ImageView android:id="@id/gpuInfo_icon"
                   android:layout_width="wrap_content"
                   android:layout_height="wrap_content"
                   android:src="@drawable/home_page_hi_gpu"
                   android:tint="@color/gamebooster_hardware"
                   android:layout_centerVertical="true" />
        <TextView android:textSize="@dimen/gb_fontsize_32"
                  android:textStyle="bold"
                  android:textColor="@color/gamebooster_hardware"
                  android:gravity="end"
                  android:id="@id/gpuInfo"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:minWidth="@dimen/view_dimen_58"
                  android:maxLines="1"
                  android:layout_centerVertical="true"
                  android:alpha="0.5"
                  android:fontFamily="sans-serif-medium"
                  android:layout_toEndOf="@id/gpuInfo_icon"
                  android:letterSpacing="0.08" />
      </RelativeLayout>
    </LinearLayout>
    <ImageView android:id="@id/endBandage"
               android:layout_width="0.0dp"
               android:layout_height="wrap_content"
               android:src="@drawable/hardware_info_bandage_start"
               android:scaleType="fitEnd"
               android:tint="@color/gamebooster_hardware"
               android:layout_weight="1.0"
               android:scaleX="-1.0" />
  </LinearLayout>
</merge>