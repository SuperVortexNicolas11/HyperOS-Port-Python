<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="horizontal"
              android:id="@id/handle_item_residual"
              android:background="@null"
              android:paddingTop="16.0dp"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:minHeight="68.3dp"
              style="@style/Widget.ListView.Item.DoubleLine" xmlns:android="http://schemas.android.com/apk/res/android">
  <RelativeLayout android:layout_gravity="center_vertical"
                  android:layout_width="0.0dp"
                  android:layout_height="wrap_content"
                  android:layout_weight="1.0"
                  android:layout_marginStart="@dimen/view_fix_issue_button_margin_start"
                  android:layout_marginEnd="@dimen/view_fix_issue_button_margin_end">
    <TextView android:textSize="17.5sp"
              android:textStyle="bold"
              android:textColor="@color/na_nd_text"
              android:id="@id/title"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content" />
    <TextView android:textSize="13.7sp"
              android:textColor="@color/na_nd_space_text"
              android:id="@id/summary"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginTop="1.5dp"
              android:layout_below="@id/title" />
  </RelativeLayout>
  <Button android:textSize="12.0sp"
          android:textColor="@color/na_nd_text"
          android:layout_gravity="center_vertical"
          android:id="@id/fix_button"
          android:background="@drawable/na_button_corners"
          android:paddingTop="5.0dp"
          android:paddingBottom="5.0dp"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:maxWidth="150.0dp"
          android:paddingStart="10.0dp"
          android:paddingEnd="10.0dp"
          android:layout_marginEnd="@dimen/dp_24" />
  <ProgressBar android:layout_gravity="center_vertical"
               android:id="@id/item_waiting"
               android:visibility="gone"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:indeterminate="true"
               android:layout_marginEnd="20.0dp"
               style="?android:attr/progressBarStyleSmall" />
  <ImageView android:id="@id/item_success"
             android:visibility="gone"
             android:layout_width="14.0dp"
             android:layout_height="14.0dp"
             android:src="@drawable/progress_succeed"
             android:scaleType="centerInside"
             android:layout_marginEnd="10.0dp" />
</LinearLayout>