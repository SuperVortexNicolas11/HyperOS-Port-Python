<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:clipChildren="false"
              android:layout_width="fill_parent"
              android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android">
  <com.miui.gamebooster.view.hardwareinfo.HardwareInfoView android:id="@id/hardwareInfo"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content" />
  <RelativeLayout android:orientation="horizontal"
                  android:layout_width="fill_parent"
                  android:layout_height="@dimen/view_dimen_157"
                  android:layout_marginTop="@dimen/gb_booster_func_mt">
    <com.miui.gamebooster.ui.MainTopContentFrame android:id="@id/content_frame"
                          android:layout_width="@dimen/view_dimen_410"
                          android:layout_height="@dimen/view_dimen_157"
                          android:layout_centerVertical="true"
                          android:layout_marginStart="@dimen/gb_booster_func_ms" />
    <TextView android:textSize="@dimen/view_dimen_49"
              android:textStyle="bold"
              android:textColor="@color/gb_booster_page_text"
              android:gravity="center"
              android:id="@id/boostTitle"
              android:layout_width="wrap_content"
              android:layout_height="fill_parent"
              android:text="@string/game_booster_title"
              android:textAllCaps="true"
              android:fontFamily="sans-serif-condensed-medium"
              android:layout_marginStart="@dimen/view_dimen_80"
              android:letterSpacing="0.01" />
    <ImageView android:id="@id/addGame"
               android:layout_width="@dimen/view_dimen_64"
               android:layout_height="@dimen/view_dimen_64"
               android:src="@drawable/gb_add_game"
               android:tint="@color/color_14b9c7"
               android:layout_centerVertical="true"
               android:layout_marginEnd="@dimen/view_dimen_88"
               android:layout_toStartOf="@id/setting" />
    <ImageView android:id="@id/setting"
               android:layout_width="@dimen/view_dimen_64"
               android:layout_height="@dimen/view_dimen_64"
               android:src="@drawable/gb_setting"
               android:tint="@color/color_14b9c7"
               android:layout_centerVertical="true"
               android:layout_marginEnd="@dimen/view_dimen_80"
               android:layout_alignParentEnd="true" />
  </RelativeLayout>
  <FrameLayout android:layout_gravity="center_horizontal"
               android:id="@id/viewPagerContainer"
               android:clipChildren="false"
               android:layout_width="fill_parent"
               android:layout_height="@dimen/game_top_content_frame">
    <View android:layout_gravity="center"
          android:id="@id/viewPagerFrame"
          android:background="@drawable/gb_icon_outline_border"
          android:layout_width="fill_parent"
          android:layout_height="fill_parent" />
    <com.miui.gamebooster.view.ViewPagerFixed android:layout_gravity="center"
                          android:id="@id/viewPager"
                          android:clipChildren="false"
                          android:layout_width="fill_parent"
                          android:layout_height="fill_parent" />
  </FrameLayout>
  <FrameLayout android:layout_width="fill_parent"
               android:layout_height="wrap_content"
               android:layout_marginTop="@dimen/view_dimen_67">
    <ImageView android:layout_gravity="bottom|center|start"
               android:id="@id/nameStartBandage"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:src="@drawable/gb_game_name_bandage" />
    <ImageView android:layout_gravity="bottom|center|end"
               android:id="@id/nameEndBandage"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:src="@drawable/gb_game_name_bandage"
               android:scaleX="-1.0" />
    <TextView android:textSize="@dimen/gb_game_textsize"
              android:textStyle="bold"
              android:textColor="@color/white"
              android:ellipsize="end"
              android:gravity="center"
              android:layout_gravity="center"
              android:id="@id/gameName"
              android:padding="@dimen/view_dimen_5"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/view_dimen_20"
              android:layout_marginBottom="@dimen/dp_5dp"
              android:maxLines="1"
              android:textAllCaps="true"
              android:fontFamily="sans-serif-condensed-medium"
              android:paddingStart="@dimen/view_dimen_247"
              android:paddingEnd="@dimen/view_dimen_247" />
  </FrameLayout>
  <TextView android:textSize="@dimen/gb_fontsize_44"
            android:textStyle="bold"
            android:textColor="@color/gb_booster_page_text"
            android:gravity="center"
            android:layout_gravity="center_horizontal"
            android:id="@id/playButton"
            android:background="@drawable/gb_play_button_frame"
            android:layout_width="@dimen/view_dimen_472"
            android:layout_height="@dimen/view_dimen_139"
            android:text="@string/open_app" />
</LinearLayout>