<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:gravity="center_horizontal"
              android:orientation="vertical"
              android:id="@id/pc_main_root"
              android:paddingTop="@dimen/dp_4"
              android:paddingBottom="@dimen/view_dimen_17"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <miuix.miuixbasewidget.widget.MessageView android:id="@id/pc_mv_top_reminder"
                        android:visibility="gone"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/dp_12"
                        app:closeBackground="@drawable/am_message_view_arrow_right"
                        style="@style/power_main_top_reminder" />
  <RelativeLayout android:id="@id/pc_battery_view_layout"
                  android:layout_width="fill_parent"
                  android:layout_height="@dimen/pc_power_background_height">
    <com.miui.powercenter.mainui.MainBatteryView android:id="@id/pc_power_view"
                          android:layout_width="fill_parent"
                          android:layout_height="fill_parent">
      <TextView android:textSize="53.33dp"
                android:textColor="@color/white"
                android:gravity="center"
                android:id="@id/number"
                android:focusable="true"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/pc_power_main_battery_view_number_height"
                android:layout_marginTop="@dimen/pc_power_main_view_battery_text_margin_top"
                android:layout_marginStart="22.22dp" />
      <LinearLayout android:orientation="horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/pc_power_main_view_battery_summary_margin_top"
                    android:layout_marginStart="22.22dp">
        <ImageView android:textColor="@color/white"
                   android:layout_gravity="center_vertical"
                   android:id="@id/flag_charging"
                   android:background="@drawable/svg_pc_charging_flag"
                   android:layout_width="8.6dp"
                   android:layout_height="14.0dp"
                   android:layout_marginRight="5.7dp" />
        <TextView android:textSize="13.33dp"
                  android:textColor="@color/white"
                  android:id="@id/power_status_summary"
                  android:focusable="true"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content" />
        <TextView android:textSize="13.33dp"
                  android:textColor="@color/white"
                  android:id="@id/power_last_level"
                  android:focusable="true"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content" />
      </LinearLayout>
    </com.miui.powercenter.mainui.MainBatteryView>
  </RelativeLayout>
  <LinearLayout android:orientation="vertical"
                android:id="@id/switch_battery_layout"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/pc_power_main_view_save_mode_margin_top">
    <ViewStub android:id="@id/vs_performance_mode"
              android:layout="@layout/pc_main_fragment_performance_viewstub"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:layout_marginStart="@dimen/view_dimen_80"
              android:layout_marginEnd="@dimen/view_dimen_80" />
    <RelativeLayout android:id="@id/rl_save_mode"
                    android:background="?android:attr/selectableItemBackground"
                    android:focusable="true"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="@dimen/pc_power_main_view_save_mode_item_height"
                    android:contentDescription="@string/power_center_power_save_title_text">
      <RelativeLayout android:id="@id/rl_power_save_mode"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:layout_centerVertical="true"
                      android:layout_marginEnd="@dimen/pc_power_main_view_save_mode_text_padding_start">
        <ImageView android:background="@drawable/ic_savemode_icon"
                   android:layout_width="wrap_content"
                   android:layout_height="wrap_content"
                   android:scaleType="center"
                   android:layout_centerInParent="true" />
        <ImageView android:background="@drawable/ic_savemode_icon_mid"
                   android:layout_width="wrap_content"
                   android:layout_height="wrap_content"
                   android:scaleType="center"
                   android:layout_centerInParent="true" />
      </RelativeLayout>
      <RelativeLayout android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:layout_weight="1.0"
                      android:layout_centerVertical="true"
                      android:layout_toEndOf="@id/rl_power_save_mode">
        <LinearLayout android:orientation="vertical"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:layout_centerVertical="true"
                      android:layout_toStartOf="@id/slide_power_save_mode"
                      android:layout_alignParentStart="true">
          <TextView android:textSize="16.89sp"
                    android:textStyle="bold"
                    android:textColor="@color/pc_main_power_card_text_color"
                    android:id="@id/pc_activity_textview0"
                    android:paddingTop="@dimen/view_dimen_7"
                    android:focusable="true"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/power_center_power_save_title_text" />
          <TextView android:textSize="13.33sp"
                    android:textColor="@color/pc_main_power_card_summary_text_color"
                    android:id="@id/power_save_summary"
                    android:focusable="true"
                    android:visibility="visible"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/pc_main_card_item_title_summary_padding" />
        </LinearLayout>
        <com.miui.common.ui.HoverSlidingSwitch android:id="@id/slide_power_save_mode"
                              android:focusable="true"
                              android:clickable="true"
                              android:layout_width="wrap_content"
                              android:layout_height="wrap_content"
                              android:layout_centerVertical="true"
                              android:layout_alignParentEnd="true" />
      </RelativeLayout>
    </RelativeLayout>
    <RelativeLayout android:id="@id/super_save_container"
                    android:background="?android:attr/selectableItemBackground"
                    android:focusable="true"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="@dimen/pc_power_main_view_save_mode_item_height"
                    android:contentDescription="@string/power_center_super_save_title_text">
      <RelativeLayout android:id="@id/rl_super_save_mode"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:layout_centerVertical="true"
                      android:layout_marginEnd="@dimen/pc_power_main_view_save_mode_text_padding_start">
        <ImageView android:background="@drawable/ic_superpower_icon"
                   android:layout_width="wrap_content"
                   android:layout_height="wrap_content"
                   android:scaleType="center"
                   android:layout_centerInParent="true" />
        <ImageView android:background="@drawable/ic_superpower_icon_mid"
                   android:layout_width="wrap_content"
                   android:layout_height="wrap_content"
                   android:scaleType="center"
                   android:layout_centerInParent="true" />
      </RelativeLayout>
      <RelativeLayout android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:layout_weight="1.0"
                      android:layout_centerVertical="true"
                      android:layout_toEndOf="@id/rl_super_save_mode">
        <LinearLayout android:orientation="vertical"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:layout_centerVertical="true"
                      android:layout_toStartOf="@id/slide_super_save_mode"
                      android:layout_alignParentStart="true">
          <TextView android:textSize="16.89sp"
                    android:textStyle="bold"
                    android:textColor="@color/pc_main_power_card_text_color"
                    android:id="@id/pc_activity_textview1"
                    android:paddingTop="@dimen/view_dimen_7"
                    android:focusable="true"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/power_center_super_save_title_text" />
          <TextView android:textSize="13.33sp"
                    android:textColor="@color/pc_main_power_card_summary_text_color"
                    android:id="@id/super_save_summary"
                    android:focusable="true"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/pc_main_card_item_title_summary_padding" />
        </LinearLayout>
        <com.miui.common.ui.HoverSlidingSwitch android:id="@id/slide_super_save_mode"
                              android:focusable="true"
                              android:clickable="true"
                              android:layout_width="wrap_content"
                              android:layout_height="wrap_content"
                              android:layout_centerVertical="true"
                              android:layout_alignParentEnd="true" />
        <CheckBox android:id="@android:id/checkbox"
                  android:focusable="false"
                  android:visibility="gone"
                  android:clickable="false"
                  android:duplicateParentState="true"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_centerVertical="true"
                  android:layout_alignParentEnd="true" />
      </RelativeLayout>
    </RelativeLayout>
    <View android:background="@color/pc_main_card_split_line_color"
          android:layout_width="fill_parent"
          android:layout_height="@dimen/view_dimen_2"
          android:layout_marginTop="@dimen/pc_power_main_view_divider_margin_top"
          android:layout_marginBottom="20.44dp" />
  </LinearLayout>
  <LinearLayout android:textSize="@dimen/text_font_size_48"
                android:orientation="horizontal"
                android:id="@id/battery_scan_layout"
                android:background="@drawable/pc_button_scan_selector_scaning"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/pc_power_main_view_battery_scan_margin_top"
                android:layout_marginBottom="@dimen/pc_power_main_view_battery_scan_margin_bottom"
                android:minHeight="@dimen/pc_battery_scan_layout_min_height">
    <TextView android:textSize="@dimen/pc_main_battery_scan_text_size"
              android:textColor="@color/pc_main_power_card_text_color"
              android:layout_gravity="center_vertical"
              android:id="@id/battery_scan_text"
              android:layout_width="0.0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1.0"
              android:textAlignment="viewStart"
              android:layout_marginStart="16.0dp" />
    <miuix.androidbasewidget.widget.ProgressBar android:layout_gravity="center_vertical"
                          android:id="@id/battery_scan_progress"
                          android:layout_width="14.5dp"
                          android:layout_height="14.5dp"
                          android:indeterminate="true"
                          android:indeterminateDrawable="@drawable/progressbar_loading_black"
                          android:layout_marginEnd="19.3dp"
                          style="?android:attr/progressBarStyleSmall" />
    <ImageView android:layout_gravity="center_vertical"
               android:id="@id/battery_scan_image"
               android:visibility="gone"
               android:layout_width="7.0dp"
               android:layout_height="11.8dp"
               android:src="@drawable/ic_pc_sacn_right_arrow_orange"
               android:layout_marginEnd="21.8dp" />
  </LinearLayout>
</LinearLayout>