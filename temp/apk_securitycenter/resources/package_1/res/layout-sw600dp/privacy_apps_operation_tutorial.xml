<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:layout_width="fill_parent"
              android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android">
  <androidx.viewpager.widget.ViewPager android:layout_gravity="center"
                        android:id="@id/view_pager"
                        android:clipChildren="false"
                        android:layout_width="fill_parent"
                        android:layout_height="fill_parent"
                        android:layout_weight="1.0" />
  <com.miui.privacyapps.view.ViewPagerIndicator android:layout_gravity="center"
                        android:id="@id/indicator"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="2.0dp" />
  <Button android:textSize="@dimen/ew_single_btn_text_size"
          android:layout_gravity="bottom|center"
          android:id="@id/use_privacy_apps"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginTop="@dimen/ew_double_btn_margin_top"
          android:layout_marginBottom="@dimen/ew_double_btn_margin_fotter"
          android:minWidth="@dimen/ew_single_btn_min_width"
          android:minHeight="@dimen/ew_single_btn_min_height"
          android:text="@string/privacy_apps_go_to_use"
          android:fontFamily="mipro-medium"
          android:layout_marginStart="27.0dp"
          android:layout_marginEnd="27.0dp"
          style="@style/Widget.Button.Warning" />
</LinearLayout>