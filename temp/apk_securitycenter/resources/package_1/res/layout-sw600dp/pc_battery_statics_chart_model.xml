<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:id="@id/pc_battery_chart_root"
              android:paddingLeft="@dimen/power_main_view_common_padding"
              android:paddingRight="@dimen/power_main_view_common_padding"
              android:focusable="true"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:contentDescription="@string/pc_battery_history_item_chart"
              android:importantForAccessibility="yes"
              android:paddingHorizontal="@dimen/power_main_view_common_padding" xmlns:android="http://schemas.android.com/apk/res/android">
  <include layout="@layout/pc_battery_statics_usedtime_model_pad" />
  <include layout="@layout/pc_battery_statics_chart_model_chart_pad" />
  <View android:background="@color/pc_main_card_border_whole_color"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/pc_battery_statics_split_height"
        android:layout_marginTop="@dimen/pc_power_main_view_second_cutoff_line_margin_top"
        android:layout_marginBottom="@dimen/pc_power_main_view_second_cutoff_line_margin_bottom" />
  <TextView android:textSize="@dimen/pc_power_main_view_spinner_choice_text_size"
            android:textColor="@color/tab_sort_text"
            android:gravity="center_vertical"
            android:id="@id/spinner_choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/view_dimen_100"
            android:text="@string/pc_battery_history_consume_rank_menu_item"
            android:drawableEnd="@drawable/fw_expand_indicator" />
</LinearLayout>