<?xml version='1.0' encoding='utf-8' ?>
<merge android:layout_width="fill_parent"
       android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android">
  <RelativeLayout android:id="@id/xunyou_netbooster"
                  android:clickable="false"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content">
    <ImageView android:textSize="@dimen/font_size_36"
               android:id="@id/xunyou_netbooster_text"
               android:layout_width="@dimen/gb_booster_xunyou_width"
               android:layout_height="@dimen/gb_booster_xunyou_height"
               android:layout_marginTop="@dimen/gb_booster_xunyou_mt"
               android:src="@drawable/gb_speed_off" />
    <TextView android:textSize="@dimen/gb_fontsize_25"
              android:textColor="#00fffb"
              android:ellipsize="end"
              android:gravity="center"
              android:id="@id/xunyou_business"
              android:background="@drawable/gb_speeding_activity_frame"
              android:padding="@dimen/view_dimen_5"
              android:visibility="gone"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:minWidth="@dimen/view_dimen_131"
              android:lines="1"
              android:shadowColor="#006b6a"
              android:shadowDy="2.0"
              android:shadowRadius="4.0"
              android:layout_marginStart="@dimen/view_dimen_18"
              android:layout_marginEnd="@dimen/view_dimen_18"
              android:layout_alignEnd="@id/xunyou_netbooster_text" />
    <LinearLayout android:gravity="center"
                  android:orientation="vertical"
                  android:id="@id/sign_gift"
                  android:paddingTop="@dimen/view_dimen_18"
                  android:visibility="gone"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_alignBottom="@id/xunyou_netbooster_text"
                  android:layout_centerVertical="true"
                  android:layout_marginStart="@dimen/view_dimen_25"
                  android:layout_marginEnd="@dimen/view_dimen_20"
                  android:layout_toEndOf="@id/xunyou_netbooster_text">
      <RelativeLayout android:layout_width="wrap_content"
                      android:layout_height="wrap_content">
        <ImageView android:id="@id/sign_status"
                   android:background="@drawable/gb_sign_gift_icon"
                   android:layout_width="@dimen/view_dimen_60"
                   android:layout_height="@dimen/view_dimen_64" />
        <ImageView android:id="@id/sign_red_point"
                   android:layout_width="@dimen/main_padding_12"
                   android:layout_height="@dimen/main_padding_12"
                   android:src="@drawable/shape_tab_red_point"
                   android:layout_toRightOf="@id/sign_status"
                   android:layout_alignTop="@id/sign_status"
                   android:layout_marginStart="@dimen/main_padding_10_minus" />
      </RelativeLayout>
      <TextView android:textSize="@dimen/gb_fontsize_24"
                android:textColor="@color/gb_booster_page_text"
                android:ellipsize="end"
                android:gravity="center_horizontal"
                android:id="@id/sign_summary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="@dimen/view_dimen_114"
                android:text="@string/gb_sign_gift"
                android:lines="1" />
    </LinearLayout>
  </RelativeLayout>
</merge>