<?xml version='1.0' encoding='utf-8' ?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
  <item android:state_enabled="true"
        android:state_selected="true">
    <shape android:shape="line">
      <stroke android:width="@dimen/view_dimen_3"
              android:color="@color/MediumAquamarine" />
      <size android:height="@dimen/view_dimen_3" />
    </shape>
  </item>
  <item android:state_enabled="true"
        android:state_selected="false">
    <shape android:shape="line">
      <stroke android:width="@dimen/view_dimen_3"
              android:color="@color/MediumAquamarine"
              android:dashWidth="@dimen/view_dimen_12"
              android:dashGap="@dimen/view_dimen_12" />
      <size android:height="@dimen/view_dimen_3" />
    </shape>
  </item>
  <item android:state_enabled="false">
    <shape android:shape="line">
      <stroke android:width="@dimen/view_dimen_3"
              android:color="@color/applock_next_btn_disable"
              android:dashWidth="@dimen/view_dimen_12"
              android:dashGap="@dimen/view_dimen_12" />
      <size android:height="@dimen/view_dimen_3" />
    </shape>
  </item>
</selector>