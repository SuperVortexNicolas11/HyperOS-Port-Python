<?xml version='1.0' encoding='utf-8' ?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
  <item android:state_enabled="true"
        android:state_selected="true">
    <shape android:shape="oval">
      <solid android:color="@color/MediumAquamarine" />
    </shape>
  </item>
  <item android:state_enabled="true"
        android:state_selected="false">
    <shape android:shape="oval">
      <solid android:color="@color/applock_guide_anim_bg_color" />
      <stroke android:width="@dimen/view_dimen_3"
              android:color="@color/MediumAquamarine" />
    </shape>
  </item>
  <item android:state_enabled="false">
    <shape android:shape="oval">
      <solid android:color="@color/applock_guide_anim_bg_color" />
      <stroke android:width="@dimen/view_dimen_3"
              android:color="@color/applock_next_btn_disable" />
    </shape>
  </item>
</selector>