<?xml version='1.0' encoding='utf-8' ?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
  <item android:state_pressed="true">
    <shape>
      <solid android:color="@color/ew_alert_close_solid_press_color" />
      <corners android:radius="@dimen/view_dimen_80" />
      <padding android:left="@dimen/dp_20"
               android:top="@dimen/dp_8"
               android:right="@dimen/dp_20"
               android:bottom="@dimen/dp_8" />
    </shape>
  </item>
  <item>
    <shape>
      <solid android:color="@color/ew_alert_close_solid_normal_color" />
      <corners android:radius="@dimen/view_dimen_80" />
      <padding android:left="@dimen/dp_20"
               android:top="@dimen/dp_8"
               android:right="@dimen/dp_20"
               android:bottom="@dimen/dp_8" />
    </shape>
  </item>
</selector>