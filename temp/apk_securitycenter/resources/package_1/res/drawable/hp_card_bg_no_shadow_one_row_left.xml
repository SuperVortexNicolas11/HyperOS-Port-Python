<?xml version='1.0' encoding='utf-8' ?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
  <item>
    <shape android:shape="rectangle">
      <solid android:color="@color/card_bg_tb_color" />
      <padding android:top="@dimen/hp_card_layout_line_height_half"
               android:bottom="@dimen/hp_card_layout_line_height_half" />
    </shape>
  </item>
  <item>
    <shape android:shape="rectangle">
      <solid android:color="@color/card_bg_stroke_color" />
      <corners android:topLeftRadius="@dimen/hp_card_bg_radius"
               android:topRightRadius="0.0dp"
               android:bottomLeftRadius="@dimen/hp_card_bg_radius"
               android:bottomRightRadius="0.0dp" />
    </shape>
  </item>
  <item android:left="@dimen/card_bg_no_shadow_stroke_width"
        android:top="@dimen/card_bg_no_shadow_stroke_width"
        android:bottom="@dimen/card_bg_no_shadow_stroke_width">
    <shape android:shape="rectangle">
      <corners android:topLeftRadius="@dimen/hp_card_bg_radius"
               android:topRightRadius="0.0dp"
               android:bottomLeftRadius="@dimen/hp_card_bg_radius"
               android:bottomRightRadius="0.0dp" />
      <solid android:color="@color/card_bg_color" />
    </shape>
  </item>
</layer-list>