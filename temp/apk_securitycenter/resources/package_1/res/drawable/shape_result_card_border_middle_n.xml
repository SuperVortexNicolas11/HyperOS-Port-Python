<?xml version='1.0' encoding='utf-8' ?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
  <item>
    <shape android:shape="rectangle">
      <solid android:color="#1a000000" />
      <corners android:topLeftRadius="0.0dp"
               android:topRightRadius="0.0dp"
               android:bottomLeftRadius="0.0dp"
               android:bottomRightRadius="0.0dp" />
    </shape>
  </item>
  <item android:left="@dimen/card_bg_no_shadow_stroke_width"
        android:right="@dimen/card_bg_no_shadow_stroke_width">
    <shape android:shape="rectangle">
      <corners android:topLeftRadius="0.0dp"
               android:topRightRadius="0.0dp"
               android:bottomLeftRadius="0.0dp"
               android:bottomRightRadius="0.0dp" />
      <solid android:color="@color/v_bg_color" />
    </shape>
  </item>
</layer-list>