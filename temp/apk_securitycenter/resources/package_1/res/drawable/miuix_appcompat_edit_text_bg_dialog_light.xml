<?xml version='1.0' encoding='utf-8' ?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
  <item>
    <shape android:shape="rectangle">
      <corners android:radius="@dimen/miuix_appcompat_edit_text_radius_size" />
      <solid android:color="@color/miuix_appcompat_edit_text_bg_color_light" />
    </shape>
  </item>
  <item>
    <selector android:enterFadeDuration="200"
              android:exitFadeDuration="200">
      <item android:state_focused="true">
        <shape android:shape="rectangle">
          <corners android:radius="@dimen/miuix_appcompat_edit_text_border_radius_size" />
          <stroke android:width="@dimen/miuix_appcompat_edit_text_border_stroke_width"
                  android:color="@color/miuix_appcompat_edit_text_border_color_light" />
          <solid android:color="@color/miuix_appcompat_transparent" />
          <padding android:top="@dimen/miuix_appcompat_edit_text_padding_vertical"
                   android:bottom="@dimen/miuix_appcompat_edit_text_padding_vertical" />
        </shape>
      </item>
    </selector>
  </item>
</layer-list>