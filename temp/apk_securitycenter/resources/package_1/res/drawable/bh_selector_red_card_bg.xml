<?xml version='1.0' encoding='utf-8' ?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
  <item android:state_pressed="true">
    <shape android:shape="rectangle">
      <solid android:color="@color/bh_red_fb4_10" />
      <corners android:radius="13.9dp" />
      <stroke android:width="0.7dp"
              android:color="@color/bh_red_fb4_60" />
    </shape>
  </item>
  <item android:state_enabled="false">
    <shape android:shape="rectangle">
      <stroke android:width="0.7dp"
              android:color="@color/bh_red_fb4_30" />
    </shape>
  </item>
  <item android:drawable="@drawable/bh_ic_bg_red_card" />
</selector>