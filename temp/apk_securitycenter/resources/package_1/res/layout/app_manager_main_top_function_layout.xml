<?xml version='1.0' encoding='utf-8' ?>
<FrameLayout android:gravity="center"
             android:layout_width="fill_parent"
             android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android">
  <LinearLayout android:gravity="center"
                android:orientation="vertical"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
    <ImageView android:layout_gravity="center"
               android:id="@id/icon"
               android:layout_width="@dimen/am_main_top_icon_size"
               android:layout_height="@dimen/am_main_top_icon_size" />
    <TextView android:textSize="@dimen/am_main_top_text_size"
              android:textColor="@color/app_manager_main_top_text_color"
              android:gravity="center"
              android:id="@id/title"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/dp_6"
              android:layout_marginStart="@dimen/dp_5"
              android:layout_marginEnd="@dimen/dp_5" />
  </LinearLayout>
</FrameLayout>