<?xml version='1.0' encoding='utf-8' ?>
<androidx.constraintlayout.widget.ConstraintLayout android:background="@drawable/bg_gb_wonderful_moment_item"
                      android:padding="@dimen/dp_15"
                      android:descendantFocusability="blocksDescendants"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <com.miui.gamebooster.globalgame.view.RoundedImageView android:id="@id/iv_video"
                        android:layout_width="@dimen/dp_151"
                        android:layout_height="@dimen/dp_84"
                        android:scaleType="centerCrop"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:riv_corner_radius="@dimen/dp_3" />
  <ImageView android:id="@id/btn_play"
             android:layout_width="@dimen/dp_26"
             android:layout_height="@dimen/dp_26"
             android:src="@drawable/ic_gb_wonderful_video_play"
             android:scaleType="fitXY"
             app:layout_constraintBottom_toBottomOf="@id/iv_video"
             app:layout_constraintEnd_toEndOf="@id/iv_video"
             app:layout_constraintStart_toStartOf="@id/iv_video"
             app:layout_constraintTop_toTopOf="@id/iv_video" />
  <TextView android:textSize="@dimen/sp_11"
            android:textColor="@color/whitealpha50"
            android:id="@id/tv_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_14"
            android:fontFamily="sans-serif"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/iv_video" />
  <ImageView android:layout_gravity="center"
             android:id="@id/btn_save"
             android:background="@drawable/ic_gb_wonderful_video_big_download"
             android:visibility="visible"
             android:layout_width="@dimen/dp_18"
             android:layout_height="@dimen/dp_18"
             app:layout_constraintBottom_toBottomOf="@id/tv_duration"
             app:layout_constraintEnd_toEndOf="parent"
             app:layout_constraintTop_toTopOf="@id/tv_duration" />
</androidx.constraintlayout.widget.ConstraintLayout>