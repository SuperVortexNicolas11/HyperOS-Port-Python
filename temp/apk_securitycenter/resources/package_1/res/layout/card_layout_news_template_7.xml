<?xml version='1.0' encoding='utf-8' ?>
<FrameLayout android:orientation="horizontal"
             android:layout_width="fill_parent"
             android:layout_height="wrap_content"
             android:paddingStart="@dimen/result_card_margin_left"
             android:paddingEnd="@dimen/result_card_margin_left" xmlns:android="http://schemas.android.com/apk/res/android">
  <LinearLayout android:id="@id/news_item_layout"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/dp_72">
    <ImageView android:layout_gravity="center_vertical"
               android:id="@id/icon"
               android:src="@drawable/card_icon_default"
               style="@style/ResultListIconStyle" />
    <TextView android:ellipsize="end"
              android:gravity="start"
              android:layout_gravity="center_vertical"
              android:id="@id/title"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:maxLines="2"
              android:drawablePadding="10.0dp"
              android:drawableEnd="@drawable/miuix_appcompat_arrow_right"
              style="@style/CardTitleTextViewStyle" />
  </LinearLayout>
</FrameLayout>