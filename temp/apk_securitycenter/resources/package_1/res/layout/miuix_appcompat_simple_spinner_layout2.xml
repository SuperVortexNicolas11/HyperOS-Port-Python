<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:gravity="center|end"
              android:orientation="horizontal"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              style="@style/Widget.DropdownSelector.Spinner.Power" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <TextView android:textColor="@color/pc_battery_statics_rank_summary_color"
            android:gravity="end"
            android:id="@android:id/text1"
            android:layout_width="0.0dp"
            android:layout_height="wrap_content"
