<?xml version='1.0' encoding='utf-8' ?>
<RelativeLayout android:paddingLeft="@dimen/miuix_theme_padding_horizontal_common"
                android:paddingRight="@dimen/miuix_theme_padding_horizontal_common"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/dp_64"
                android:paddingHorizontal="@dimen/miuix_theme_padding_horizontal_common" xmlns:android="http://schemas.android.com/apk/res/android">
  <ImageView android:id="@id/image_view"
             android:layout_centerVertical="true"
             style="@style/ListIconNoMargin" />
  <miuix.slidingwidget.widget.SlidingButton android:id="@id/check_view"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:importantForAccessibility="no"
                        android:layout_alignParentEnd="true" />
  <TextView android:ellipsize="end"
            android:id="@id/name_tv"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:maxLines="2"
            android:layout_centerVertical="true"
            android:textDirection="locale"
            android:paddingStart="@dimen/dp_16"
            android:paddingEnd="@dimen/dp_16"
            android:layout_toStartOf="@id/check_view"
            android:layout_toEndOf="@id/image_view"
            style="@style/ListItemTitle" />
</RelativeLayout>