<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:layout_width="fill_parent"
              android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android">
  <ImageView android:layout_gravity="center_horizontal"
             android:id="@id/mode_icon"
             android:layout_width="@dimen/gb_vc_mode_icon_bg_size"
             android:layout_height="@dimen/gb_vc_mode_icon_bg_size"
             android:scaleType="fitCenter" />
  <TextView android:textSize="@dimen/gb_vc_mode_title_size"
            android:textColor="@drawable/gb_voice_change_title_color"
            android:gravity="center_horizontal"
            android:layout_gravity="center_horizontal"
            android:id="@id/mode_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/gb_vc_mode_title_margin_top" />
</LinearLayout>