<?xml version='1.0' encoding='utf-8' ?>
<RelativeLayout android:gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android">
  <ImageView android:id="@id/function_image"
             android:layout_width="wrap_content"
             android:layout_height="wrap_content"
             android:layout_centerHorizontal="true" />
  <TextView android:textSize="14.55sp"
            android:textColor="#ff000000"
            android:gravity="center"
            android:id="@id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6.9dp"
            android:singleLine="true"
            android:layout_below="@id/function_image"
            android:layout_centerHorizontal="true" />
  <TextView android:textSize="13.09sp"
            android:textColor="#cd000000"
            android:gravity="center"
            android:id="@id/summary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:layout_below="@id/title"
            android:layout_centerHorizontal="true" />
  <miuix.slidingwidget.widget.SlidingButton android:id="@id/sliding_button"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:layout_below="@id/summary"
                        android:layout_centerHorizontal="true" />
</RelativeLayout>