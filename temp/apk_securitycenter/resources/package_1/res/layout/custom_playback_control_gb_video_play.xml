<?xml version='1.0' encoding='utf-8' ?>
<merge android:layout_width="fill_parent"
       android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android">
  <FrameLayout android:background="@color/color_black_trans_30"
               android:layout_width="fill_parent"
               android:layout_height="fill_parent">
    <ImageView android:id="@id/btn_close"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:layout_marginTop="@dimen/gb_video_controls_back_icon_size"
               android:src="@drawable/gamebox_arrow_expand_h"
               android:layout_marginStart="@dimen/gb_video_controls_back_icon_size" />
    <RelativeLayout android:layout_gravity="center"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">
      <FrameLayout android:id="@id/view_play_pause"
                   android:layout_width="wrap_content"
                   android:layout_height="wrap_content"
                   android:layout_centerHorizontal="true"
                   android:layout_marginStart="@dimen/gb_video_controls_margin"
                   android:layout_marginEnd="@dimen/gb_video_controls_margin">
        <ImageView android:layout_gravity="center"
                   android:id="@id/exo_play"
                   android:layout_width="@dimen/gb_wonderful_video_play_btn_size"
                   android:layout_height="@dimen/gb_wonderful_video_play_btn_size"
                   style="@style/ExoMediaButton.Play" />
        <ImageView android:layout_gravity="center"
                   android:id="@id/exo_pause"
                   android:layout_width="@dimen/gb_wonderful_video_play_btn_size"
                   android:layout_height="@dimen/gb_wonderful_video_play_btn_size"
                   style="@style/ExoMediaButton.Pause" />
      </FrameLayout>
      <ImageView android:layout_gravity="center"
                 android:id="@id/exo_prev"
                 android:layout_width="@dimen/gb_wonderful_video_play_btn_size"
                 android:layout_height="@dimen/gb_wonderful_video_play_btn_size"
                 android:layout_toStartOf="@id/view_play_pause"
                 style="@style/ExoMediaButton.Previous" />
      <ImageView android:layout_gravity="center"
                 android:id="@id/exo_next"
                 android:layout_width="@dimen/gb_wonderful_video_play_btn_size"
                 android:layout_height="@dimen/gb_wonderful_video_play_btn_size"
                 android:layout_toEndOf="@id/view_play_pause"
                 style="@style/ExoMediaButton.Next" />
    </RelativeLayout>
    <LinearLayout android:gravity="center_vertical"
                  android:layout_gravity="bottom"
                  android:orientation="horizontal"
                  android:id="@id/layout_bottom_control"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content"
                  android:layout_marginBottom="@dimen/dp_18"
                  android:layout_marginStart="@dimen/gb_wonderful_content_margin"
                  android:layout_marginEnd="@dimen/gb_wonderful_content_margin">
      <ImageView android:id="@id/sounds_btn"
                 android:layout_width="@dimen/dp_30"
                 android:layout_height="@dimen/dp_30"
                 android:src="@drawable/ic_video_play_controls_volume"
                 android:layout_marginEnd="@dimen/gb_wonderful_video_play_duration_size_margin" />
      <com.miui.gamebooster.widget.CustomTimeBar android:id="@id/exo_progress"
                            android:layout_width="0.0dp"
                            android:layout_height="@dimen/dp_15"
                            android:layout_weight="1.0"
                            style="@style/CustomExoMediaTimeBar" />
      <TextView android:textSize="@dimen/gb_wonderful_video_play_pos_textsize"
                android:textColor="@color/gb_wonderful_video_play_duration_pos_textcolor"
                android:gravity="center|end"
                android:id="@id/exo_position"
                android:layout_width="@dimen/dp_65"
                android:layout_height="wrap_content"
                android:includeFontPadding="false" />
      <TextView android:textSize="@dimen/gb_wonderful_video_play_pos_textsize"
                android:textColor="@color/gb_wonderful_video_play_duration_pos_textcolor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/exo_player_time_seperate"
                android:includeFontPadding="false" />
      <TextView android:textSize="@dimen/gb_wonderful_video_play_pos_textsize"
                android:textColor="@color/gb_wonderful_video_play_duration_pos_textcolor"
                android:gravity="center|start"
                android:id="@id/exo_duration"
                android:layout_width="@dimen/dp_65"
                android:layout_height="wrap_content"
                android:includeFontPadding="false" />
      <ImageView android:id="@id/exo_download"
                 android:layout_width="@dimen/dp_30"
                 android:layout_height="@dimen/dp_30"
                 android:src="@drawable/ic_video_play_controls_download" />
    </LinearLayout>
  </FrameLayout>
</merge>