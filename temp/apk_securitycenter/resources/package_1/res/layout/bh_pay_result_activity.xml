<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:layout_width="fill_parent"
              android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android">
  <ScrollView android:layout_width="fill_parent"
              android:layout_height="0.0dp"
              android:layout_weight="1.0">
    <LinearLayout android:orientation="vertical"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content">
      <LinearLayout android:orientation="vertical"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">
        <miuix.androidbasewidget.widget.ProgressBar android:layout_gravity="center"
                              android:id="@id/progress_bar"
                              android:layout_width="wrap_content"
                              android:layout_height="wrap_content"
                              android:layout_marginTop="181.18dp" />
        <ImageView android:layout_gravity="center"
                   android:id="@id/pay_failed"
                   android:visibility="gone"
                   android:layout_width="54.55dp"
                   android:layout_height="54.55dp"
                   android:layout_marginTop="76.36dp"
                   android:src="@drawable/traffic_pay_fail"
                   android:contentDescription="@null" />
        <TextView android:textSize="20.36dp"
                  android:layout_gravity="center"
                  android:id="@id/tv_result_confirm"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="10.91dp"
                  android:text="@string/bh_pay_status_success_text" />
      </LinearLayout>
      <LinearLayout android:orientation="vertical"
                    android:id="@id/pay_success_state"
                    android:visibility="gone"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">
        <ImageView android:layout_gravity="center"
                   android:id="@id/iv_imsage_result"
                   android:layout_width="54.55dp"
                   android:layout_height="54.55dp"
                   android:layout_marginTop="76.36dp"
                   android:src="@drawable/bh_icon_success"
                   android:contentDescription="@null" />
        <TextView android:textSize="20.36dp"
                  android:layout_gravity="center"
                  android:id="@id/tv_result"
                  android:visibility="gone"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="10.91dp"
                  android:text="@string/bh_pay_status_success_text" />
        <TextView android:textSize="14.55dp"
                  android:layout_gravity="center"
                  android:id="@id/tv_resultDesc"
                  android:visibility="gone"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="5.45dp"
                  android:text="@string/bh_pay_status_success_tips_text"
                  android:alpha="0.4" />
        <LinearLayout android:orientation="vertical"
                      android:id="@id/viewgroup_order_detail"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content">
          <RelativeLayout android:orientation="horizontal"
                          android:layout_width="fill_parent"
                          android:layout_height="wrap_content"
                          android:layout_marginTop="54.55dp">
            <TextView android:textSize="14.55dp"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:text="@string/bh_create_order_fee_item_text"
                      android:alpha="0.4"
                      android:layout_marginStart="29.09dp" />
            <TextView android:textSize="14.55dp"
                      android:id="@id/tv_price"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:alpha="0.8"
                      android:layout_marginEnd="29.09dp"
                      android:layout_alignParentEnd="true" />
          </RelativeLayout>
          <RelativeLayout android:orientation="horizontal"
                          android:layout_width="fill_parent"
                          android:layout_height="wrap_content"
                          android:layout_marginTop="17.45dp">
            <TextView android:textSize="14.55dp"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:text="@string/bh_create_order_id_item_text"
                      android:alpha="0.4"
                      android:layout_marginStart="29.09dp" />
            <TextView android:textSize="14.55dp"
                      android:id="@id/tv_orderId"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:alpha="0.8"
                      android:layout_marginEnd="29.09dp"
                      android:layout_alignParentEnd="true" />
          </RelativeLayout>
          <RelativeLayout android:orientation="horizontal"
                          android:layout_width="fill_parent"
                          android:layout_height="wrap_content"
                          android:layout_marginTop="17.45dp">
            <TextView android:textSize="14.55dp"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:text="@string/bh_create_order_time_item_text"
                      android:alpha="0.4"
                      android:layout_marginStart="29.09dp" />
            <TextView android:textSize="14.55dp"
                      android:id="@id/tv_time"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:alpha="0.8"
                      android:layout_marginEnd="29.09dp"
                      android:layout_alignParentEnd="true" />
          </RelativeLayout>
        </LinearLayout>
        <ImageView android:id="@id/iv_pic"
                   android:visibility="gone"
                   android:layout_width="fill_parent"
                   android:layout_height="wrap_content"
                   android:layout_marginLeft="13.09dp"
                   android:layout_marginTop="43.64dp"
                   android:layout_marginRight="13.09dp"
                   android:scaleType="centerCrop"
                   android:adjustViewBounds="true"
                   android:layout_marginHorizontal="13.09dp" />
      </LinearLayout>
    </LinearLayout>
  </ScrollView>
  <Button android:textSize="18.18dp"
          android:textColor="@color/bh_white_daynight"
          android:id="@id/btn_finish"
          android:background="@drawable/bh_blue_button"
          android:visibility="gone"
          android:layout_width="fill_parent"
          android:layout_height="50.91dp"
          android:layout_marginLeft="43.64dp"
          android:layout_marginRight="43.64dp"
          android:layout_marginBottom="21.82dp"
          android:text="@string/gd_app_edit_done"
          android:layout_alignParentBottom="true"
          android:layout_marginHorizontal="43.64dp" />
</LinearLayout>