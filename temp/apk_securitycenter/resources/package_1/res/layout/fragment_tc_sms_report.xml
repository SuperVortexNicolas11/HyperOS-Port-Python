<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:background="@color/line_card_bg"
              android:clipChildren="false"
              android:layout_width="fill_parent"
              android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android">
  <com.miui.networkassistant.ui.view.ToolbarItemView android:id="@id/layout_upload_type"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="12.0dp"
                        android:layout_marginRight="12.0dp"
                        android:layout_marginHorizontal="12.0dp" />
  <com.miui.networkassistant.ui.view.ToolbarItemView android:id="@id/layout_sms_direction"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="12.0dp"
                        android:layout_marginRight="12.0dp"
                        android:layout_marginHorizontal="12.0dp" />
  <com.miui.networkassistant.ui.view.ToolbarItemView android:id="@id/layout_sms_number"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="12.0dp"
                        android:layout_marginRight="12.0dp"
                        android:layout_marginHorizontal="12.0dp" />
  <com.miui.networkassistant.ui.view.ToolbarItemView android:id="@id/layout_sms_receive_num"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="12.0dp"
                        android:layout_marginRight="12.0dp"
                        android:layout_marginHorizontal="12.0dp" />
  <RelativeLayout android:layout_width="fill_parent"
                  android:layout_height="fill_parent">
    <FrameLayout android:id="@id/layout_buttons"
                 android:layout_width="fill_parent"
                 android:layout_height="wrap_content"
                 android:layout_alignParentBottom="true">
      <LinearLayout android:orientation="vertical"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">
        <TextView android:textSize="10.0sp"
                  android:textColor="@color/tips_text_color"
                  android:layout_gravity="center_horizontal"
                  android:id="@id/tips_textview"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:text="@string/tc_sms_report_get_default"
                  android:layout_marginStart="23.0dp"
                  android:layout_marginEnd="23.0dp"
                  style="@style/Miuix.AppCompat.TextAppearance.List.Secondary" />
        <Button android:id="@id/button_get_sms"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10.0dp"
                android:layout_marginBottom="18.33dp"
                android:text="@string/tc_sms_report_get_sms"
                android:layout_marginStart="23.0dp"
                android:layout_marginEnd="23.0dp" />
      </LinearLayout>
      <LinearLayout android:orientation="horizontal"
                    android:id="@id/layout_buttons_again_and_report"
                    android:visibility="gone"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="20.0dp">
        <Button android:id="@id/button_get_sms_again"
                android:layout_width="0.0dp"
                android:layout_height="wrap_content"
                android:text="@string/tc_sms_report_get_sms_again"
                android:lines="1"
                android:layout_weight="1.0" />
        <Button android:id="@id/button_report_sms"
                android:layout_width="0.0dp"
                android:layout_height="wrap_content"
                android:text="@string/tc_sms_report_do_report"
                android:lines="1"
                android:layout_weight="1.0"
                android:layout_marginStart="@dimen/dp_40" />
      </LinearLayout>
    </FrameLayout>
    <LinearLayout android:orientation="vertical"
                  android:layout_width="fill_parent"
                  android:layout_height="fill_parent"
                  android:layout_above="@id/layout_buttons"
                  android:layout_alignParentTop="true">
      <FrameLayout android:background="@drawable/preference_item_bg"
                   android:layout_width="fill_parent"
                   android:layout_height="wrap_content"
                   android:paddingStart="23.3dp"
                   android:paddingEnd="23.3dp">
        <TextView android:textAppearance="@style/Miuix.AppCompat.TextAppearance.List.Secondary"
                  android:layout_gravity="bottom"
                  android:paddingTop="10.0dp"
                  android:paddingBottom="10.0dp"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:text="@string/tc_sms_report_receive_content" />
      </FrameLayout>
      <ScrollView android:background="@drawable/preference_item_bg"
                  android:layout_width="fill_parent"
                  android:layout_height="fill_parent"
                  android:paddingStart="23.3dp"
                  android:paddingEnd="23.3dp">
        <TextView android:textAppearance="@style/Miuix.AppCompat.TextAppearance.List.Secondary"
                  android:id="@id/textview_sms_receive_content"
                  android:paddingTop="10.0dp"
                  android:paddingBottom="10.0dp"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content"
                  android:text="@string/tc_sms_report_receive_content_null"
                  android:singleLine="false"
                  android:textIsSelectable="true" />
      </ScrollView>
    </LinearLayout>
  </RelativeLayout>
</LinearLayout>