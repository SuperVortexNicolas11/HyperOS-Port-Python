<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:importantForAccessibility="no" xmlns:android="http://schemas.android.com/apk/res/android">
  <FrameLayout android:id="@id/fl_title_container"
               android:background="@drawable/hp_card_bg_no_shadow_top"
               android:paddingTop="@dimen/dp_23"
               android:paddingBottom="@dimen/dp_11"
               android:layout_width="fill_parent"
               android:layout_height="wrap_content"
               android:paddingStart="@dimen/phone_manage_list_title_pad_lr"
               android:paddingEnd="@dimen/phone_manage_list_title_pad_lr">
    <LinearLayout android:orientation="horizontal"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content">
      <TextView android:gravity="center_vertical"
                android:id="@id/title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"
                style="@style/PhoneManageTitleStyle" />
      <View android:layout_gravity="center_vertical"
            android:id="@id/line"
            android:background="@color/phone_manage_card_text_line_bg"
            android:layout_width="@dimen/phone_manage_card_text_line_width"
            android:layout_height="@dimen/phone_manage_card_text_line_height"
            android:layout_toRightOf="@id/title"
            android:layout_marginStart="@dimen/phone_manage_card_line_margin_rl"
            android:layout_marginEnd="@dimen/phone_manage_card_line_margin_rl" />
      <TextView android:layout_gravity="center_vertical"
                android:id="@id/summary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"
                style="@style/PhoneManageSummaryStyle" />
    </LinearLayout>
  </FrameLayout>
  <GridLayout android:id="@id/gl_pm_sub_function_list"
              android:background="@drawable/hp_card_bg_no_shadow_bottom"
              android:paddingBottom="@dimen/dp_19"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:columnCount="3" />
</LinearLayout>