<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:gravity="center_vertical"
              android:orientation="horizontal"
              android:id="@id/container"
              android:paddingTop="@dimen/dp_14"
              android:paddingBottom="@dimen/dp_14"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:paddingStart="@dimen/dp_16"
              android:paddingEnd="@dimen/dp_16" xmlns:android="http://schemas.android.com/apk/res/android">
  <ImageView android:id="@id/icon"
             android:layout_width="@dimen/dp_24"
             android:layout_height="@dimen/dp_24" />
  <TextView android:textSize="@dimen/text_font_size_42"
            android:textStyle="bold"
            android:textColor="@color/pa_bottom_title_color"
            android:id="@id/title"
            android:layout_width="0.0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.0"
            android:textAlignment="viewStart"
            android:layout_marginStart="@dimen/view_dimen_32" />
  <com.miui.gamebooster.view.QRSlidingButton android:id="@id/slide_button"
                        android:focusable="false"
                        android:clickable="false"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:contentDescription="@null"
                        android:importantForAccessibility="no" />
</LinearLayout>