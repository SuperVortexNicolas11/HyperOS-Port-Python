<?xml version='1.0' encoding='utf-8' ?>
<androidx.constraintlayout.widget.ConstraintLayout android:id="@id/item_bg"
                      android:focusable="true"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <androidx.constraintlayout.widget.ConstraintLayout android:background="@drawable/selector_pickup_item_style"
                        android:layout_width="fill_parent"
                        android:layout_height="@dimen/dp_46"
                        android:layout_marginStart="@dimen/dp_12"
                        android:layout_marginEnd="@dimen/dp_12"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">
    <ImageView android:id="@id/img_check"
               android:background="@drawable/selector_pickup_checked_style"
               android:layout_width="@dimen/dp_20"
               android:layout_height="@dimen/dp_20"
               android:layout_marginEnd="@dimen/dp_19"
               app:layout_constraintBottom_toBottomOf="parent"
               app:layout_constraintEnd_toEndOf="parent"
               app:layout_constraintTop_toTopOf="parent" />
    <ImageView android:id="@id/iv_icon"
               android:layout_width="@dimen/dp_22"
               android:layout_height="@dimen/dp_22"
               android:layout_marginStart="@dimen/dp_16"
               app:layout_constraintBottom_toBottomOf="parent"
               app:layout_constraintStart_toStartOf="parent"
               app:layout_constraintTop_toTopOf="parent" />
    <TextView android:textSize="@dimen/dp_14"
              android:textColor="@color/conversation_light_label_selector"
              android:id="@id/tv_title"
              android:layout_width="0.0dp"
              android:layout_height="wrap_content"
              android:layout_marginStart="@dimen/dp_8"
              app:layout_constraintBottom_toBottomOf="parent"
              app:layout_constraintEnd_toStartOf="@id/img_check"
              app:layout_constraintStart_toEndOf="@id/iv_icon"
              app:layout_constraintTop_toTopOf="parent" />
  </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>