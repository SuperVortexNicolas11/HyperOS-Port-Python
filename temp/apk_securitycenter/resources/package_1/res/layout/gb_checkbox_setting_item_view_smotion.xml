<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:gravity="center_vertical"
              android:orientation="vertical"
              android:id="@id/rootView"
              android:focusable="true"
              android:focusableInTouchMode="true"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android">
  <LinearLayout android:orientation="horizontal"
                android:id="@id/second_root"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
    <LinearLayout android:orientation="vertical"
                  android:layout_width="@dimen/gb_wonderful_video_zero_size"
                  android:layout_height="wrap_content"
                  android:layout_weight="1.0"
                  android:layout_marginEnd="@dimen/dp_22">
      <TextView android:textSize="@dimen/gb_wonderful_dialog_title_textsize"
                android:textColor="@color/gb_record_dialog_title_color"
                android:id="@id/title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="3"
                android:textDirection="locale" />
      <TextView android:textSize="@dimen/gb_wonderful_record_way_dialog_subtitle_textsize"
                android:textColor="@color/gb_record_dialog_subtitle_color"
                android:id="@id/subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gb_record_item_spacing_between_title_and_subtitle"
                style="@style/GBWonderfulItemTitleRoot" />
    </LinearLayout>
    <miuix.slidingwidget.widget.SlidingButton android:layout_gravity="center_vertical"
                          android:id="@id/switchBtn"
                          android:focusable="false"
                          android:focusableInTouchMode="false"
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:importantForAccessibility="no"
                          style="@style/Widget.SlidingButton.Dark" />
  </LinearLayout>
  <ImageView android:id="@id/bottomImg"
             android:background="@drawable/gb_wifi_settings_bg"
             android:paddingTop="@dimen/view_dimen_36"
             android:paddingBottom="@dimen/view_dimen_36"
             android:visibility="gone"
             android:layout_width="wrap_content"
             android:layout_height="wrap_content"
             android:layout_marginBottom="@dimen/view_dimen_24"
             android:paddingStart="@dimen/view_dimen_50"
             android:paddingEnd="@dimen/view_dimen_50" />
</LinearLayout>