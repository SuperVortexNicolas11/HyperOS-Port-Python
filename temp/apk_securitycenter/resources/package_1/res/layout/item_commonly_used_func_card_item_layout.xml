<?xml version='1.0' encoding='utf-8' ?>
<RelativeLayout android:id="@id/item_container"
                android:paddingBottom="@dimen/dp_8dp"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_rowWeight="1.0"
                android:layout_columnWeight="1.0" xmlns:android="http://schemas.android.com/apk/res/android">
  <ImageView android:id="@id/icon"
             android:layout_width="@dimen/dp_24"
             android:layout_height="@dimen/dp_24"
             android:layout_marginTop="@dimen/dp_12"
             android:layout_centerHorizontal="true" />
  <TextView android:textSize="@dimen/sp_13"
            android:textColor="@color/phone_manage_item_text_color"
            android:ellipsize="end"
            android:gravity="center"
            android:id="@id/title"
            android:layout_width="@dimen/commonly_used_func_card_card_item_title_width"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_8"
            android:layout_marginBottom="@dimen/dp_4"
            android:layout_below="@id/icon"
            android:layout_centerHorizontal="true" />
  <ImageView android:id="@id/user_set_flag"
             android:visibility="gone"
             android:layout_width="@dimen/view_dimen_16"
             android:layout_height="@dimen/view_dimen_20"
             android:layout_marginTop="@dimen/dp_12"
             android:src="@drawable/commonly_used_user_set_flag_icon"
             android:layout_marginStart="@dimen/commonly_used_func_card_flag_margin_start"
             android:layout_toEndOf="@id/icon" />
</RelativeLayout>