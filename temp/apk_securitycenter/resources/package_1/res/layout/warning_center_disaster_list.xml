<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:layout_width="fill_parent"
              android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <include android:id="@id/search_view"
           android:layout_width="fill_parent"
           android:layout_height="wrap_content"
           android:layout_marginTop="@dimen/view_dimen_10"
           layout="@layout/miuix_appcompat_search_stub" />
  <LinearLayout android:orientation="vertical"
                android:id="@id/content_container"
                android:layout_width="fill_parent"
                android:layout_height="0.0dp"
                android:layout_weight="1.0">
    <LinearLayout android:id="@id/spinner_container"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content">
      <miuix.appcompat.widget.Spinner android:layout_gravity="center"
                            android:id="@id/spinner_area"
                            android:layout_width="0.0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1.0"
                            app:spinnerModeCompat="dropdown" />
      <miuix.appcompat.widget.Spinner android:gravity="center"
                            android:layout_gravity="center"
                            android:id="@id/spinner_type"
                            android:layout_width="0.0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1.0"
                            app:spinnerModeCompat="dropdown" />
      <miuix.appcompat.widget.Spinner android:layout_gravity="center"
                            android:id="@id/spinner_level"
                            android:layout_width="0.0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1.0"
                            app:spinnerModeCompat="dropdown" />
    </LinearLayout>
    <miuix.springback.view.SpringBackLayout android:layout_width="fill_parent"
                          android:layout_height="fill_parent"
                          app:scrollOrientation="vertical|angle"
                          app:scrollableView="@id/recycler_view">
      <miuix.recyclerview.widget.RecyclerView android:orientation="vertical"
                            android:id="@id/recycler_view"
                            android:layout_width="fill_parent"
                            android:layout_height="fill_parent"
                            android:overScrollMode="ifContentScrolls"
                            android:paddingStart="@dimen/miuix_theme_margin_horizontal_common"
                            android:paddingEnd="@dimen/miuix_theme_margin_horizontal_common"
                            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
    </miuix.springback.view.SpringBackLayout>
    <include android:id="@id/empty_view"
             layout="@layout/ew_data_empty" />
  </LinearLayout>
</LinearLayout>