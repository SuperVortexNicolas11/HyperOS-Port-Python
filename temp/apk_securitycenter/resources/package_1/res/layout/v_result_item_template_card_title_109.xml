<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:paddingTop="@dimen/card_layout_line_height_half"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android">
  <LinearLayout android:orientation="horizontal"
                android:id="@id/inner_layout"
                android:background="@drawable/shape_result_card_border_up"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
    <TextView android:textSize="@dimen/sp_14"
              android:textColor="#8c93b0"
              android:gravity="center_vertical"
              android:id="@id/title"
              android:layout_width="0.0dp"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/dp_14"
              android:layout_marginBottom="@dimen/dp_8"
              android:layout_weight="1.0"
              android:layout_marginStart="@dimen/dp_16"
              android:layout_marginEnd="@dimen/dp_6" />
    <TextView android:id="@id/tv_adx"
              android:layout_marginTop="@dimen/dp_18"
              android:layout_marginEnd="@dimen/dp_16"
              style="@style/AdxViewStyle" />
  </LinearLayout>
</LinearLayout>