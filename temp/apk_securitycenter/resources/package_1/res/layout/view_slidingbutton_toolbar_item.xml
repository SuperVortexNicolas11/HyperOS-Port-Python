<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="horizontal"
              android:paddingTop="2.0dp"
              android:paddingBottom="2.0dp"
              android:focusable="false"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:minHeight="@dimen/miuix_appcompat_list_preferred_item_height_small"
              style="@style/Widget.ListView.Item.DoubleLine" xmlns:android="http://schemas.android.com/apk/res/android">
  <LinearLayout android:layout_gravity="center_vertical"
                android:orientation="vertical"
                android:focusable="false"
                android:layout_width="0.0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.0">
    <TextView android:textAppearance="@style/Miuix.AppCompat.TextAppearance.List.Primary"
              android:id="@id/name"
              android:focusable="false"
              android:duplicateParentState="true"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:maxLines="2" />
    <TextView android:textAppearance="@style/Miuix.AppCompat.TextAppearance.List.Secondary"
              android:id="@id/summary"
              android:focusable="false"
              android:visibility="gone"
              android:duplicateParentState="true"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:maxLines="2" />
  </LinearLayout>
  <miuix.slidingwidget.widget.SlidingSwitch android:layout_gravity="center_vertical"
                        android:id="@id/sliding_button"
                        android:padding="2.0dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:importantForAccessibility="no" />
</LinearLayout>