<?xml version='1.0' encoding='utf-8' ?>
<RelativeLayout android:background="@drawable/preference_item_bg_with_top_bottom"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/miuix_appcompat_list_preferred_item_height" xmlns:android="http://schemas.android.com/apk/res/android">
  <ImageView android:id="@id/icon"
             android:layout_width="@dimen/view_dimen_168"
             android:layout_height="@dimen/view_dimen_168"
             android:scaleType="centerCrop"
             android:layout_centerVertical="true" />
  <RelativeLayout android:layout_width="fill_parent"
                  android:layout_height="wrap_content"
                  android:layout_centerVertical="true"
                  android:layout_marginStart="@dimen/view_dimen_44"
                  android:layout_toEndOf="@id/icon">
    <RelativeLayout android:id="@id/rl"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">
      <TextView android:textAppearance="@style/Miuix.AppCompat.TextAppearance.PreferenceList"
                android:id="@id/title"
                android:paddingBottom="@dimen/view_dimen_10"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:textAlignment="viewStart"
                android:paddingEnd="10.0dp"
                android:lineHeight="@dimen/view_dimen_66" />
      <LinearLayout android:orientation="horizontal"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/title">
        <TextView android:textSize="@dimen/text_font_size_39"
                  android:textColor="@color/pc_battery_card_subtitle_color"
                  android:id="@id/summary"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_weight="1.0"
                  android:lineSpacingExtra="2.0dp"
                  android:textAlignment="viewStart" />
        <TextView android:textSize="@dimen/text_font_size_39"
                  android:textColor="@color/pc_battery_card_subtitle_color"
                  android:gravity="right"
                  android:layout_gravity="center_vertical"
                  android:id="@id/content"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:singleLine="true" />
      </LinearLayout>
    </RelativeLayout>
    <miuix.androidbasewidget.widget.ProgressBar android:id="@id/progress"
                          android:layout_width="fill_parent"
                          android:layout_height="@dimen/pc_battery_statics_rank_progress_height"
                          android:layout_marginTop="@dimen/pc_battery_statics_rank_progress_height"
                          android:max="100"
                          android:progressDrawable="@drawable/pc_battery_statics_progressbar"
                          android:layout_below="@id/rl"
                          android:layout_alignStart="@id/rl"
                          style="?android:attr/progressBarStyleHorizontal" />
  </RelativeLayout>
</RelativeLayout>