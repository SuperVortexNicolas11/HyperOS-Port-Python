<?xml version='1.0' encoding='utf-8' ?>
<FrameLayout android:layout_gravity="bottom"
             android:id="@id/sidekick_view_content"
             android:background="@drawable/sidekick_guide_bg"
             android:visibility="gone"
             android:layout_width="fill_parent"
             android:layout_height="@dimen/sidekick_group_height"
             android:layout_alignBottom="@id/content_frame"
             android:backgroundTint="@color/card_bg_color" xmlns:android="http://schemas.android.com/apk/res/android">
  <LinearLayout android:gravity="center_vertical"
                android:orientation="horizontal"
                android:id="@id/sidekick_click_area"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:layout_marginTop="@dimen/sidekick_group_margin_top">
    <ImageView android:id="@id/sidekick_icon"
               android:layout_width="@dimen/sidekick_icon_width"
               android:layout_height="@dimen/sidekick_icon_height"
               android:src="@drawable/icon_def"
               android:layout_marginStart="20.0dp"
               android:layout_marginEnd="10.0dp" />
    <TextView android:id="@id/sidekick_title"
              android:layout_weight="1.0"
              android:layout_marginEnd="10.0dp"
              style="@style/SideKickTextStyle" />
    <View android:background="@color/v_sidekick_divider_color"
          android:layout_width="1.0dp"
          android:layout_height="14.0dp"
          android:layout_marginEnd="10.0dp" />
    <TextView android:id="@id/sidekick_ok"
              android:minWidth="28.0dp"
              android:layout_marginEnd="35.33dp"
              style="@style/SideKickTextStyle" />
  </LinearLayout>
</FrameLayout>