<?xml version='1.0' encoding='utf-8' ?>
<FrameLayout android:id="@id/item_bg"
             android:background="@android:color/transparent"
             android:layout_width="fill_parent"
             android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android">
  <FrameLayout android:layout_gravity="center|top"
               android:id="@id/item_content"
               android:layout_width="fill_parent"
               android:layout_height="wrap_content">
    <RelativeLayout android:layout_gravity="center|top"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/gb_active_red_point_half_size"
                    android:layout_marginEnd="@dimen/gb_active_red_point_half_size">
      <com.miui.common.widgets.gif.GifImageView android:id="@id/item_image"
                            android:layout_width="@dimen/gb_active_icon_size"
                            android:layout_height="@dimen/gb_active_icon_size"
                            android:scaleType="fitCenter"
                            android:layout_centerHorizontal="true" />
      <TextView android:textSize="8.0dp"
                android:textColor="@color/gamebox_func_text"
                android:ellipsize="end"
                android:gravity="center"
                android:id="@id/label"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/view_dimen_16"
                android:maxLines="2"
                android:layout_below="@id/item_image"
                android:layout_centerHorizontal="true" />
      <ImageView android:id="@id/stick_point"
                 android:background="@drawable/shape_game_box_white_point"
                 android:visibility="gone"
                 android:layout_width="@dimen/main_padding_12"
                 android:layout_height="@dimen/main_padding_12"
                 android:layout_marginTop="@dimen/view_dimen_20_minus"
                 android:layout_below="@id/item_image"
                 android:layout_centerHorizontal="true" />
    </RelativeLayout>
    <TextView android:textSize="@dimen/view_dimen_15"
              android:textColor="@color/white"
              android:ellipsize="end"
              android:gravity="center"
              android:layout_gravity="center|top"
              android:id="@id/red_point"
              android:background="@drawable/shape_game_box_red_point"
              android:visibility="gone"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:singleLine="true" />
  </FrameLayout>
</FrameLayout>