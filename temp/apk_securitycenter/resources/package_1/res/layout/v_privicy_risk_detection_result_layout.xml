<?xml version='1.0' encoding='utf-8' ?>
<RelativeLayout android:gravity="center_horizontal"
                android:id="@id/ll_top_result"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android">
  <FrameLayout android:id="@id/fl_result"
               android:layout_width="fill_parent"
               android:layout_height="wrap_content"
               android:layout_marginTop="@dimen/view_dimen_50">
    <ImageView android:layout_gravity="center_horizontal"
               android:id="@id/iv_circle"
               android:layout_width="@dimen/view_dimen_441"
               android:layout_height="@dimen/view_dimen_441" />
    <ImageView android:layout_gravity="center"
               android:id="@id/result_score_icon"
               android:layout_width="@dimen/view_dimen_130"
               android:layout_height="@dimen/view_dimen_130"
               android:layout_marginBottom="@dimen/view_dimen_20"
               android:scaleType="fitCenter" />
  </FrameLayout>
  <TextView android:textSize="@dimen/sp_17"
            android:textColor="@color/first_aid_box_summary_textcolor"
            android:gravity="center_horizontal"
            android:id="@id/tv_summary_result"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/fl_result"
            android:layout_centerHorizontal="true"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="@dimen/view_dimen_30"
            android:paddingEnd="@dimen/view_dimen_30" />
</RelativeLayout>