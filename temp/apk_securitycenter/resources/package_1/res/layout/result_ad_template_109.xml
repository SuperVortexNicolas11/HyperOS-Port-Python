<?xml version='1.0' encoding='utf-8' ?>
<FrameLayout android:layout_width="fill_parent"
             android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android">
  <LinearLayout android:orientation="horizontal"
                android:id="@id/inner"
                android:background="@drawable/am_card_bg_selector"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
    <com.miui.securitycenter.ad.view.AdImageView android:layout_gravity="center_vertical"
                          android:id="@id/icon"
                          android:scaleType="centerInside"
                          android:layout_marginStart="@dimen/dp_16"
                          style="@style/ResultListIconStyle" />
    <LinearLayout android:layout_gravity="center_vertical"
                  android:orientation="vertical"
                  android:layout_width="0.0dp"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="@dimen/dp_12"
                  android:layout_marginBottom="@dimen/dp_12"
                  android:layout_weight="1.0">
      <TextView android:id="@id/title"
                android:singleLine="true"
                android:layout_weight="1.0"
                style="@style/ListItemTitle" />
      <TextView android:textSize="@dimen/sp_13"
                android:textColor="@color/color_black_trans_60"
                android:id="@id/tv_developer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true" />
      <LinearLayout android:orientation="horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_2">
        <TextView android:textSize="@dimen/sp_10"
                  android:textColor="@color/color_black_trans_40"
                  android:ellipsize="marquee"
                  android:id="@id/tv_version"
                  android:layout_width="0.0dp"
                  android:layout_height="wrap_content"
                  android:singleLine="true"
                  android:layout_weight="1.0"
                  android:marqueeRepeatLimit="1" />
        <View android:layout_gravity="center_vertical"
              android:id="@id/divider1"
              android:background="@color/color_black_trans_40"
              android:layout_width="@dimen/am_list_item_adv_line_width"
              android:layout_height="@dimen/am_list_item_adv_line_height"
              android:layout_marginStart="@dimen/dp_5"
              android:layout_marginEnd="@dimen/dp_5" />
        <TextView android:textSize="@dimen/sp_10"
                  android:textColor="@color/color_black_trans_40"
                  android:id="@id/tv_introduce"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:text="@string/ad_text_introduce"
                  android:singleLine="true" />
        <View android:layout_gravity="center_vertical"
              android:background="@color/color_black_trans_40"
              android:layout_width="@dimen/am_list_item_adv_line_width"
              android:layout_height="@dimen/am_list_item_adv_line_height"
              android:layout_marginStart="@dimen/dp_5"
              android:layout_marginEnd="@dimen/dp_5" />
        <TextView android:textSize="@dimen/sp_10"
                  android:textColor="@color/color_black_trans_40"
                  android:id="@id/tv_privacy"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:text="@string/adv_privacy_text"
                  android:singleLine="true" />
        <View android:layout_gravity="center_vertical"
              android:id="@id/divider2"
              android:background="@color/color_black_trans_40"
              android:layout_width="@dimen/am_list_item_adv_line_width"
              android:layout_height="@dimen/am_list_item_adv_line_height"
              android:layout_marginStart="@dimen/dp_5"
              android:layout_marginEnd="@dimen/dp_5" />
        <TextView android:textSize="@dimen/sp_10"
                  android:textColor="@color/color_black_trans_40"
                  android:id="@id/tv_permission"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:text="@string/adv_permission_text"
                  android:singleLine="true" />
      </LinearLayout>
    </LinearLayout>
    <LinearLayout android:layout_gravity="center_vertical"
                  android:orientation="vertical"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:paddingEnd="@dimen/dp_16">
      <Button android:textSize="@dimen/am_adv_button_text_size"
              android:textColor="@color/color_blue_primary_default"
              android:id="@id/button"
              android:background="@drawable/list_card_btn_bule"
              android:layout_width="@dimen/am_adv_button_width"
              android:layout_height="@dimen/am_adv_button_height"
              style="@style/Widget.Button.Positive" />
      <TextView android:textSize="@dimen/am_list_adv_item_summary_size"
                android:textColor="@color/app_manager_adv_list_summary_color"
                android:layout_gravity="center_horizontal"
                android:id="@id/tv_cancel"
                android:paddingTop="@dimen/dp_6"
                android:paddingBottom="@dimen/dp_6"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ad_text_btn_cancel"
                android:paddingStart="@dimen/dp_12"
                android:paddingEnd="@dimen/dp_12" />
    </LinearLayout>
  </LinearLayout>
</FrameLayout>