<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:layout_width="fill_parent"
              android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android">
  <LinearLayout android:background="@drawable/warningcenter_disaster_level_bg"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:layout_marginTop="@dimen/dp_16"
                android:layout_marginBottom="@dimen/dp_16"
                android:layout_marginStart="?attr/preferenceItemPaddingStart"
                android:layout_marginEnd="?attr/preferenceItemPaddingEnd"
                android:layout_marginVertical="@dimen/dp_16">
    <TextView android:textSize="@dimen/dp_13"
              android:textColor="@color/white"
              android:gravity="center"
              android:id="@id/level_4"
              android:layout_width="0.0dp"
              android:layout_height="fill_parent"
              android:text="@string/warningcenter_disaster_level_1"
              android:layout_weight="1.1"
              android:fontFamily="mipro-medium" />
    <TextView android:textSize="@dimen/dp_13"
              android:textColor="@color/white"
              android:gravity="center"
              android:id="@id/level_3"
              android:layout_width="0.0dp"
              android:layout_height="fill_parent"
              android:text="@string/warningcenter_disaster_level_2"
              android:layout_weight="1.0"
              android:fontFamily="mipro-medium" />
    <TextView android:textSize="@dimen/dp_13"
              android:textColor="@color/white"
              android:gravity="center"
              android:id="@id/level_2"
              android:layout_width="0.0dp"
              android:layout_height="fill_parent"
              android:text="@string/warningcenter_disaster_level_3"
              android:layout_weight="1.0"
              android:fontFamily="mipro-medium" />
    <TextView android:textSize="@dimen/dp_13"
              android:textColor="@color/white"
              android:gravity="center"
              android:id="@id/level_1"
              android:layout_width="0.0dp"
              android:layout_height="fill_parent"
              android:text="@string/warningcenter_disaster_level_4"
              android:layout_weight="1.0"
              android:fontFamily="mipro-medium" />
  </LinearLayout>
</LinearLayout>