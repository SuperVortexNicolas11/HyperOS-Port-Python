<?xml version='1.0' encoding='utf-8' ?>
<RelativeLayout android:layout_width="fill_parent"
                android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android">
  <com.miui.common.customview.ScoreTextView android:textSize="@dimen/scan_result_score_text_size"
                        android:textColor="@color/m_activity_main_score"
                        android:id="@id/result_score"
                        android:focusable="false"
                        android:focusableInTouchMode="false"
                        android:visibility="invisible"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/securityscan_result_score_lite_margin_top"
                        android:singleLine="true"
                        android:includeFontPadding="false"
                        android:layout_centerHorizontal="true"
                        android:importantForAccessibility="no" />
  <TextView android:textSize="@dimen/status_bar_bottom_textsize"
            android:textStyle="bold"
            android:textColor="@color/status_bar_bottom_textcolor_blue"
            android:id="@id/status_bar_bottom"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/status_bar_bottom_lite_margin_top"
            android:layout_centerHorizontal="true"
            android:importantForAccessibility="no" />
</RelativeLayout>