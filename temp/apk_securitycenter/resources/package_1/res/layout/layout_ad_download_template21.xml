  <include layout="@layout/layout_ad_head02" />
  <com.miui.securitycenter.ad.view.RoundResizeFrameLayout android:id="@id/image_layout"
                        android:layout_width="0.0dp"
                        android:layout_height="0.0dp"
                        android:layout_marginTop="@dimen/v_dimens_38"
                        android:contentDescription="@null"
                        app:layout_constraintDimensionRatio="920:440"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_title"
                        app:roundCornerRadius="@dimen/v_dimens_26">
    <com.miui.securitycenter.ad.view.AdImageView android:id="@id/iv_img_big"
