<?xml version='1.0' encoding='utf-8' ?>
<androidx.constraintlayout.widget.ConstraintLayout android:layout_width="@dimen/game_toolbox_wild_mode_toast_width"
                      android:layout_height="@dimen/game_toolbox_wild_mode_toast_height" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <ImageView android:id="@id/wild_mode_toast_head"
             android:layout_width="@dimen/dp_89"
             android:layout_height="@dimen/dp_19"
             android:src="@drawable/game_wild_mode_toast_head_png"
             app:layout_constraintEnd_toEndOf="parent"
             app:layout_constraintStart_toStartOf="parent"
             app:layout_constraintTop_toTopOf="parent" />
  <ImageView android:id="@id/wild_mode_toast_border"
             android:layout_width="@dimen/game_toolbox_wild_mode_toast_width"
             android:layout_height="@dimen/game_toolbox_wild_mode_toast_height"
             android:src="@drawable/game_wild_mode_toast_bg_border"
             app:layout_constraintEnd_toEndOf="parent"
             app:layout_constraintStart_toStartOf="parent"
             app:layout_constraintTop_toTopOf="parent" />
  <ImageView android:id="@id/wild_mode_toast_main_image"
             android:layout_width="@dimen/dp_126"
             android:layout_height="@dimen/dp_68"
             android:layout_marginTop="@dimen/dp_14"
             android:src="@drawable/game_wild_mode_toast_main_webp"
             app:layout_constraintEnd_toEndOf="parent"
             app:layout_constraintStart_toStartOf="parent"
             app:layout_constraintTop_toBottomOf="@id/wild_mode_toast_head" />
  <com.miui.gamebooster.videobox.view.MarqueeTextView android:textSize="@dimen/dp_16"
                        android:textColor="@color/game_toolbox_wild_mode_toast_theme_color"
                        android:ellipsize="marquee"
                        android:id="@id/tv_wild_mode_toast_title"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dp_11"
                        android:text="@string/game_toolbox_wild_mode_toast_title"
                        android:singleLine="true"
                        android:marqueeRepeatLimit="marquee_forever"
                        android:textAlignment="center"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/wild_mode_toast_main_image" />
  <ImageView android:id="@id/tv_wild_mode_toast_tip_bg"
             android:layout_width="wrap_content"
             android:layout_height="wrap_content"
             android:src="@drawable/bg_wild_performance_logan"
             app:layout_constraintBottom_toBottomOf="@id/tv_wild_mode_toast_tip"
             app:layout_constraintEnd_toEndOf="parent"
             app:layout_constraintStart_toStartOf="parent"
             app:layout_constraintTop_toTopOf="@id/tv_wild_mode_toast_tip" />
  <com.miui.gamebooster.videobox.view.MarqueeTextView android:textSize="@dimen/dp_8"
                        android:textColor="@color/game_toolbox_wild_mode_toast_theme_color"
                        android:ellipsize="marquee"
                        android:id="@id/tv_wild_mode_toast_tip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dp_6"
                        android:text="@string/game_toolbox_wild_mode_toast_tip"
                        android:singleLine="true"
                        android:drawablePadding="@dimen/dp_1"
                        android:marqueeRepeatLimit="marquee_forever"
                        android:drawableStart="@drawable/wild_mode_toast_tip_icon"
                        android:textAlignment="center"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_wild_mode_toast_title" />
</androidx.constraintlayout.widget.ConstraintLayout>