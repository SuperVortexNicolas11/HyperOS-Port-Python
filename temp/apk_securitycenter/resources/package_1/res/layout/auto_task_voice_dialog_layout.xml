<?xml version='1.0' encoding='utf-8' ?>
<ScrollView android:layout_width="fill_parent"
            android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android">
  <LinearLayout android:orientation="vertical"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:paddingStart="@dimen/view_dimen_80"
                android:paddingEnd="@dimen/view_dimen_80">
    <androidx.appcompat.widget.AppCompatTextView android:textSize="@dimen/text_font_size_50"
                          android:textColor="@color/task_title_color"
                          android:gravity="center"
                          android:id="@id/call_text"
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:text="@string/auto_task_voice_dialog_call_title"
                          android:drawablePadding="@dimen/view_dimen_32"
                          android:drawableStart="@drawable/auto_task_dialog_icon_call"
                          android:fontFamily="mipro-medium" />
    <miuix.androidbasewidget.widget.SeekBar android:id="@id/call_voice"
                          android:layout_width="fill_parent"
                          android:layout_height="wrap_content"
                          android:layout_marginTop="@dimen/view_dimen_32" />
    <androidx.appcompat.widget.AppCompatTextView android:textSize="@dimen/text_font_size_50"
                          android:textColor="@color/task_title_color"
                          android:gravity="center"
                          android:id="@id/alarm_text"
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:layout_marginTop="@dimen/view_dimen_90"
                          android:text="@string/auto_task_voice_dialog_alarm_title"
                          android:drawablePadding="@dimen/view_dimen_32"
                          android:drawableStart="@drawable/auto_task_dialog_icon_alarm"
                          android:fontFamily="mipro-medium" />
    <miuix.androidbasewidget.widget.SeekBar android:id="@id/alarm_voice"
                          android:layout_width="fill_parent"
                          android:layout_height="wrap_content"
                          android:layout_marginTop="@dimen/view_dimen_32" />
    <androidx.appcompat.widget.AppCompatTextView android:textSize="@dimen/text_font_size_50"
                          android:textColor="@color/task_title_color"
                          android:gravity="center"
                          android:id="@id/media_text"
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:layout_marginTop="@dimen/view_dimen_90"
                          android:text="@string/auto_task_voice_dialog_media_title"
                          android:drawablePadding="@dimen/view_dimen_32"
                          android:drawableStart="@drawable/auto_task_dialog_icon_media"
                          android:fontFamily="mipro-medium" />
    <miuix.androidbasewidget.widget.SeekBar android:id="@id/media_voice"
                          android:layout_width="fill_parent"
                          android:layout_height="wrap_content"
                          android:layout_marginTop="@dimen/view_dimen_32" />
  </LinearLayout>
</ScrollView>