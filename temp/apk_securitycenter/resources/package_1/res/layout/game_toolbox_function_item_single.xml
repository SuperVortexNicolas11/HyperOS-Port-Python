<?xml version='1.0' encoding='utf-8' ?>
<androidx.constraintlayout.widget.ConstraintLayout android:background="@color/transparent"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content"
                      android:layout_marginTop="@dimen/game_toolbox_function_item_margin_top" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <com.miui.common.widgets.gif.GifImageView android:id="@id/function_icon"
                        android:layout_width="@dimen/game_toolbox_function_single_icon_edge"
                        android:layout_height="@dimen/game_toolbox_function_single_icon_edge"
                        android:scaleType="centerInside"
                        app:layout_constraintBottom_toTopOf="@id/function_title"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
  <com.miui.gamebooster.videobox.view.MarqueeTextView android:textSize="@dimen/game_toolbox_function_single_text_size"
                        android:textColor="@color/game_toolbox_function_single_title_color"
                        android:ellipsize="marquee"
                        android:gravity="center"
                        android:id="@id/function_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/game_toolbox_function_single_text_margin_top"
                        android:singleLine="true"
                        android:layout_centerHorizontal="true"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="@id/function_icon"
                        app:layout_constraintStart_toStartOf="@id/function_icon"
                        app:layout_constraintTop_toBottomOf="@id/function_icon" />
  <TextView android:textSize="@dimen/game_toolbox_function_single_red_point_text_size"
            android:textColor="@color/game_toolbox_function_single_red_point_color"
            android:ellipsize="end"
            android:gravity="center"
            android:id="@id/function_red_point"
            android:background="@drawable/shape_game_toolbox_function_red_point_bg"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/game_toolbox_function_single_red_point_margin_top"
            android:singleLine="true"
            android:layout_marginEnd="@dimen/game_toolbox_function_single_red_point_margin_end"
            app:layout_constraintEnd_toEndOf="@id/function_icon"
            app:layout_constraintTop_toTopOf="@id/function_icon" />
</androidx.constraintlayout.widget.ConstraintLayout>