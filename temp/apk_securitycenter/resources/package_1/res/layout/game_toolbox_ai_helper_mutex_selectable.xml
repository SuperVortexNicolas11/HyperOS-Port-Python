<?xml version='1.0' encoding='utf-8' ?>
<androidx.constraintlayout.widget.ConstraintLayout android:background="@drawable/game_toolbox_ai_helper_mutex_selectable"
                      android:paddingLeft="@dimen/dp_16"
                      android:paddingTop="@dimen/dp_12"
                      android:paddingRight="@dimen/dp_16"
                      android:paddingBottom="@dimen/dp_12"
                      android:focusable="true"
                      android:clickable="true"
                      android:layout_width="fill_parent"
                      android:layout_height="fill_parent"
                      android:paddingHorizontal="@dimen/dp_16"
                      android:paddingVertical="@dimen/dp_12" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <ImageView android:id="@id/check_icon"
             android:duplicateParentState="true"
             android:layout_width="wrap_content"
             android:layout_height="wrap_content"
             android:src="@drawable/game_toolbox_ai_helper_check_icon"
             app:layout_constraintBottom_toBottomOf="parent"
             app:layout_constraintLeft_toLeftOf="parent"
             app:layout_constraintTop_toTopOf="parent" />
  <TextView android:textSize="@dimen/dp_14"
            android:textColor="@color/game_toolbox_ai_helper_text_color_selector"
            android:id="@id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dp_8"
            android:singleLine="true"
            app:layout_constraintBottom_toTopOf="@id/desc"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintLeft_toRightOf="@id/check_icon"
            app:layout_constraintTop_toTopOf="parent" />
  <TextView android:textSize="@dimen/dp_12"
            android:textColor="@color/game_toolbox_ai_helper_text_color_selector"
            android:id="@id/desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dp_8"
            android:maxLines="2"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintLeft_toRightOf="@id/check_icon"
            app:layout_constraintTop_toBottomOf="@id/title" />
</androidx.constraintlayout.widget.ConstraintLayout>