<?xml version='1.0' encoding='utf-8' ?>
<androidx.constraintlayout.motion.widget.MotionLayout android:layout_width="fill_parent"
                      android:layout_height="fill_parent"
                      app:layoutDescription="@xml/virus_scan_fragment_result_scene" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <LinearLayout android:orientation="vertical"
                android:id="@id/header"
                android:paddingLeft="@dimen/dp_16"
                android:paddingRight="@dimen/dp_16"
                android:layout_width="fill_parent"
                android:layout_height="0.0dp"
                android:paddingHorizontal="@dimen/dp_16"
                app:layout_constraintTop_toTopOf="parent">
    <ImageView android:layout_gravity="center"
               android:id="@id/result_icon"
               android:background="@drawable/scan_result_ball"
               android:layout_width="@dimen/antivirus_scan_result_ball_size"
               android:layout_height="@dimen/antivirus_scan_result_ball_size"
               android:src="@drawable/scan_result_risk"
               android:scaleType="centerInside"
               android:foregroundGravity="bottom|center"
               android:importantForAccessibility="no"
               android:transitionName="ball" />
    <ImageView android:layout_gravity="center_horizontal"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:layout_marginTop="@dimen/antivirus_scan_result_ball_shadow_margin"
               android:src="@drawable/scan_result_shadow"
               android:importantForAccessibility="no" />
    <androidx.appcompat.widget.AppCompatTextView android:textSize="@dimen/sp_17"
                          android:textColor="@color/v_activity_main_title_text"
                          android:ellipsize="end"
                          android:gravity="center"
                          android:layout_gravity="center_horizontal"
                          android:id="@id/result_title"
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:maxLines="2"
                          android:drawablePadding="2.0dp"
                          android:fontFamily="mipro-medium" />
    <TextView android:textSize="@dimen/text_font_size_36"
              android:textColor="@color/v_scan_support_text_color"
              android:ellipsize="end"
              android:gravity="center"
              android:id="@id/subtitle"
              android:paddingBottom="4.0dp"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:layout_marginTop="4.0dp"
              android:singleLine="true" />
  </LinearLayout>
  <miuix.springback.view.SpringBackLayout android:id="@android:id/content"
                        android:layout_width="0.0dp"
                        android:layout_height="0.0dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:scrollableView="@id/result_list">
    <miuix.recyclerview.widget.RecyclerView android:orientation="vertical"
                          android:id="@id/result_list"
                          android:paddingLeft="16.0dp"
                          android:paddingRight="16.0dp"
                          android:clipToPadding="false"
                          android:layout_width="fill_parent"
                          android:layout_height="fill_parent"
                          android:paddingHorizontal="16.0dp"
                          app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
  </miuix.springback.view.SpringBackLayout>
</androidx.constraintlayout.motion.widget.MotionLayout>