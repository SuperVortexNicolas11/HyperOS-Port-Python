<?xml version='1.0' encoding='utf-8' ?>
<RelativeLayout android:paddingTop="@dimen/view_dimen_40"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android">
  <View android:id="@id/pc_preference_view"
        android:background="@drawable/pc_preference_task_edit_bg"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/view_dimen_160"
        android:layout_marginTop="@dimen/view_dimen_10"
        android:layout_marginBottom="@dimen/view_dimen_10"
        android:layout_marginStart="@dimen/pc_autotask_taskname_padding"
        android:layout_marginEnd="@dimen/pc_autotask_taskname_padding" />
  <LinearLayout android:gravity="center_vertical"
                android:orientation="horizontal"
                android:id="@id/pc_pc_preference_task_edit"
                android:layout_width="fill_parent"
                android:layout_height="@dimen/view_dimen_180"
                android:paddingStart="@dimen/auto_task_edit_task_name_padding_left"
                android:paddingEnd="@dimen/auto_task_edit_task_name_padding_left">
    <TextView android:textSize="@dimen/text_font_size_50"
              android:textStyle="bold"
              android:textColor="@color/pc_main_power_card_summary_text_color"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/auto_task_edit_task_name" />
    <EditText android:textSize="@dimen/text_font_size_42"
              android:textColor="@color/pc_autotask_title_edit_view_hint_color"
              android:textColorHint="@color/pc_autotask_title_edit_view_hint_color"
              android:id="@id/edit"
              android:background="@null"
              android:layout_width="0.0dp"
              android:layout_height="wrap_content"
              android:hint="@string/auto_task_edit_my_custom_task"
              android:singleLine="true"
              android:maxLength="100"
              android:layout_weight="1.0"
              android:inputType="text"
              android:imeOptions="actionDone"
              android:textAlignment="viewEnd"
              android:layout_marginStart="24.0dp" />
  </LinearLayout>
</RelativeLayout>