<?xml version='1.0' encoding='utf-8' ?>
<miuix.flexible.view.HyperCellLayout android:gravity="center_vertical"
                      android:background="@drawable/miuix_appcompat_list_item_bg"
                      android:paddingTop="@dimen/dp_14"
                      android:paddingBottom="@dimen/dp_14"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content"
                      android:minHeight="@dimen/dp_72"
                      android:paddingStart="@dimen/miuix_preference_item_padding_start"
                      android:paddingEnd="@dimen/miuix_preference_item_padding_end"
                      app:template="standard_button" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <ImageView android:id="@id/usage_item_app_icon"
             android:layout_width="@dimen/dp_40"
             android:layout_height="@dimen/dp_40"
             app:area_id="@id/area_head" />
  <LinearLayout android:orientation="vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:area_id="@id/area_title">
    <TextView android:textSize="@dimen/sp_17"
              android:textColor="@color/os2_main_title_color"
              android:id="@id/usage_item_app_name"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:fontFamily="@string/miuix_font_style_misans_medium_font_family" />
    <TextView android:textSize="@dimen/sp_14"
              android:textColor="@color/os2_sub_title_color"
              android:id="@id/usage_item_app_content"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:fontFamily="@string/miuix_font_style_misans_font_family"
              android:textDirection="locale"
              app:area_id="@id/area_content" />
  </LinearLayout>
  <ImageView android:id="@id/usage_item_arrow_right"
             android:layout_width="wrap_content"
             android:layout_height="wrap_content"
             android:src="@drawable/miuix_appcompat_arrow_right"
             app:area_id="@id/area_end" />
</miuix.flexible.view.HyperCellLayout>