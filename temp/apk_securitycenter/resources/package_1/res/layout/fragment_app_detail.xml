<?xml version='1.0' encoding='utf-8' ?>
<miuix.springback.view.SpringBackLayout android:layout_width="fill_parent"
                      android:layout_height="fill_parent"
                      app:scrollableView="@id/scroll_view" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <androidx.core.widget.NestedScrollView android:id="@id/scroll_view"
                        android:paddingTop="@dimen/view_dimen_20"
                        android:layout_width="fill_parent"
                        android:layout_height="fill_parent">
    <LinearLayout android:orientation="vertical"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content">
      <RelativeLayout android:layout_width="fill_parent"
                      android:layout_height="wrap_content"
                      android:paddingStart="?android:attr/listPreferredItemPaddingLeft">
        <ImageView android:id="@id/imageview_icon"
                   android:layout_width="40.0dp"
                   android:layout_height="40.0dp"
                   android:layout_marginTop="9.3dp"
                   android:layout_centerVertical="true"
                   android:layout_marginEnd="11.6dp"
                   android:layout_alignParentStart="true" />
        <LinearLayout android:orientation="vertical"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:layout_centerVertical="true"
                      android:layout_toEndOf="@id/imageview_icon">
          <TextView android:textAppearance="@style/Miuix.AppCompat.TextAppearance.List.Primary"
                    android:id="@id/textview_appname"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="2" />
          <TextView android:textAppearance="@style/Miuix.AppCompat.TextAppearance.List.Secondary"
                    android:id="@id/textview_version"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2.0dp" />
        </LinearLayout>
      </RelativeLayout>
      <LinearLayout android:orientation="horizontal"
                    android:id="@id/layout_show"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20.0dp"
                    android:minHeight="39.67dp"
                    android:layout_marginStart="?android:attr/listPreferredItemPaddingLeft"
                    android:layout_marginEnd="?android:attr/listPreferredItemPaddingLeft">
        <TextView android:textAppearance="@style/Miuix.AppCompat.TextAppearance.List.Secondary"
                  android:textColor="@color/applock_list_header_text"
                  android:ellipsize="end"
                  android:layout_gravity="center_vertical"
                  android:id="@id/list_spinner_title"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:maxLines="1" />
        <ImageView android:layout_gravity="center_vertical"
                   android:id="@id/imageview_arrow_open"
                   android:layout_width="wrap_content"
                   android:layout_height="wrap_content"
                   android:src="@drawable/am_sort_drop_icon"
                   android:layout_marginStart="8.0dp" />
      </LinearLayout>
      <com.miui.networkassistant.ui.view.AppDetailTrafficView android:id="@id/detail_view"
                            android:layout_width="fill_parent"
                            android:layout_height="310.0dp"
                            android:layout_marginTop="20.0dp"
                            android:layout_marginStart="@dimen/item_left_right"
                            android:layout_marginEnd="@dimen/item_left_right" />
      <LinearLayout android:orientation="vertical"
                    android:id="@id/network_traffic_warning_layout"
                    android:visibility="gone"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18.0dp"
                    android:layout_marginStart="29.1dp"
                    android:layout_marginEnd="29.1dp">
        <RelativeLayout android:layout_width="fill_parent"
                        android:layout_height="wrap_content">
          <TextView android:textSize="12.0dp"
                    android:textStyle="bold"
                    android:textColor="#343434"
                    android:id="@id/network_traffic_warning_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/network_traffic_warning_title"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="4.67dp"
                    android:layout_alignParentStart="true" />
          <ImageView android:id="@id/imageview_traffic_statistic_warning"
                     android:layout_width="wrap_content"
                     android:layout_height="wrap_content"
                     android:src="@drawable/ic_traffic_statistic_warning"
                     android:layout_centerVertical="true"
                     android:layout_toEndOf="@id/network_traffic_warning_title" />
        </RelativeLayout>
        <TextView android:textSize="12.0dp"
                  android:textColor="#777777"
                  android:id="@id/network_traffic_warning_text"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="8.33dp"
                  android:layout_marginBottom="24.0dp"
                  android:text="@string/network_traffic_warning_text"
                  android:lineSpacingExtra="8.67dp" />
      </LinearLayout>
      <com.miui.networkassistant.ui.view.ToolbarItemView android:id="@id/mi_service_app_detail"
                            android:visibility="gone"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content" />
      <RelativeLayout android:background="@drawable/preference_item_bg"
                      android:paddingBottom="6.0dp"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content"
                      android:paddingStart="?android:attr/listPreferredItemPaddingLeft">
        <TextView android:textAppearance="@style/Miuix.AppCompat.TextAppearance.List.Secondary"
                  android:id="@id/tv_link_ctrl_title"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:text="@string/network_control"
                  android:layout_alignParentBottom="true" />
      </RelativeLayout>
      <com.miui.networkassistant.ui.view.SlideButtonToolbarItemView android:id="@id/layout_mobile_setting1"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content" />
      <com.miui.networkassistant.ui.view.SlideButtonToolbarItemView android:id="@id/layout_mobile_setting2"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content" />
      <com.miui.networkassistant.ui.view.SlideButtonToolbarItemView android:id="@id/layout_wifi_setting"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content" />
      <com.miui.networkassistant.ui.view.SlideButtonToolbarItemView android:id="@id/layout_network_setting"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content" />
    </LinearLayout>
  </androidx.core.widget.NestedScrollView>
</miuix.springback.view.SpringBackLayout>