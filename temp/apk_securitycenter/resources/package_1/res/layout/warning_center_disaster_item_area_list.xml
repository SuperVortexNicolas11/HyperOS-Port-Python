<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="horizontal"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:screenReaderFocusable="true" xmlns:android="http://schemas.android.com/apk/res/android">
  <TextView android:textSize="@dimen/text_font_size_50"
            android:textStyle="bold"
            android:textColor="@color/ew_text_black_color"
