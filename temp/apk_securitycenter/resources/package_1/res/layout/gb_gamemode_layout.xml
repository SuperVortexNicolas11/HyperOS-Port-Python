<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:layout_gravity="center_vertical"
              android:orientation="vertical"
              android:id="@id/view_layout"
              android:layout_width="fill_parent"
              android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <com.miui.gamebooster.windowmanager.GBTopbarLayout android:id="@id/topview"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        app:turboTitleCenter="@string/gb_game_mode_new" />
  <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="fill_parent"
                        android:layout_height="@dimen/dp_60"
                        android:layout_marginTop="@dimen/dp_10"
                        android:layout_marginStart="@dimen/dp_16"
                        android:layout_marginEnd="@dimen/dp_16">
    <ImageView android:id="@id/iv_fill"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:layout_marginTop="@dimen/dp_10"
               android:src="@drawable/game_toolbox_fill_icon"
               android:layout_marginEnd="@dimen/dp_7"
               app:layout_constraintStart_toStartOf="parent"
               app:layout_constraintTop_toTopOf="parent" />
    <TextView android:textSize="@dimen/dp_14"
              android:textColor="@color/whitealpha90"
              android:id="@id/tv_title"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/gb_game_mode_fill_type"
              android:layout_marginStart="@dimen/dp_7"
              app:layout_constraintBottom_toBottomOf="@id/iv_fill"
              app:layout_constraintStart_toEndOf="@id/iv_fill"
              app:layout_constraintTop_toTopOf="@id/iv_fill" />
    <TextView android:textSize="@dimen/dp_11"
              android:textColor="@color/whitealpha50"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/dp_5"
              android:text="@string/gb_game_fill_desc"
              app:layout_constraintStart_toStartOf="@id/iv_fill"
              app:layout_constraintTop_toBottomOf="@id/iv_fill" />
    <ImageView android:id="@id/radio_fill"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:src="@drawable/gb_game_radio_selector"
               app:layout_constraintBottom_toBottomOf="parent"
               app:layout_constraintEnd_toEndOf="parent"
               app:layout_constraintTop_toTopOf="parent" />
  </androidx.constraintlayout.widget.ConstraintLayout>
  <View android:background="@color/whitealpha10"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/dp_1"
        android:layout_marginStart="@dimen/dp_18"
        android:layout_marginEnd="@dimen/dp_18" />
  <androidx.constraintlayout.widget.ConstraintLayout android:paddingBottom="@dimen/dp_8"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dp_16"
                        android:layout_marginStart="@dimen/dp_16"
                        android:layout_marginEnd="@dimen/dp_16">
    <ImageView android:id="@id/iv_ratio"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:src="@drawable/gameturbo_game_ratio_button"
               android:layout_marginEnd="@dimen/dp_7"
               app:layout_constraintStart_toStartOf="parent"
               app:layout_constraintTop_toTopOf="parent" />
    <TextView android:textSize="@dimen/dp_14"
              android:textColor="@color/whitealpha90"
              android:id="@id/tv_ratio"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/gb_game_mode_ratio_type"
              android:layout_marginStart="@dimen/dp_5"
              app:layout_constraintBottom_toBottomOf="@id/iv_ratio"
              app:layout_constraintStart_toEndOf="@id/iv_ratio"
              app:layout_constraintTop_toTopOf="@id/iv_ratio" />
    <TextView android:textSize="@dimen/dp_11"
              android:textColor="@color/whitealpha50"
              android:id="@id/ratio_desc"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/dp_5"
              android:layout_marginEnd="@dimen/view_dimen_84"
              app:layout_constraintStart_toStartOf="@id/iv_ratio"
              app:layout_constraintTop_toBottomOf="@id/iv_ratio" />
    <ImageView android:id="@id/radio_ratio"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:src="@drawable/gb_game_radio_selector"
               app:layout_constraintBottom_toBottomOf="parent"
               app:layout_constraintEnd_toEndOf="parent"
               app:layout_constraintTop_toTopOf="parent" />
  </androidx.constraintlayout.widget.ConstraintLayout>
  <LinearLayout android:orientation="horizontal"
                android:id="@id/container_ratio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dp_16" />
</LinearLayout>