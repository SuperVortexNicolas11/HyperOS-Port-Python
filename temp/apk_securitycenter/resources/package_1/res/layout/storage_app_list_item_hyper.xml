<?xml version='1.0' encoding='utf-8' ?>
<miuix.flexible.view.HyperCellLayout android:gravity="center_vertical"
                      android:paddingLeft="@dimen/miuix_item_padding_start"
                      android:paddingTop="@dimen/miuix_item_padding_top"
                      android:paddingRight="@dimen/miuix_item_padding_start"
                      android:paddingBottom="@dimen/miuix_item_padding_top"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content"
                      android:minHeight="@dimen/storage_app_list_item_h"
                      android:paddingHorizontal="@dimen/miuix_item_padding_start"
                      android:paddingVertical="@dimen/miuix_item_padding_top"
                      app:template="standard" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <ImageView android:id="@id/app_icon"
             android:layout_width="@dimen/dp_40"
             android:layout_height="@dimen/dp_40"
             android:layout_centerVertical="true"
             app:area_id="@id/area_head" />
  <TextView android:textSize="@dimen/storage_app_list_item_name_text"
            android:textStyle="bold"
            android:textColor="@color/storage_list_item_name"
            android:id="@id/app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxWidth="@dimen/storage_app_list_name_w"
            app:area_id="@id/area_title" />
  <TextView android:textSize="@dimen/storage_app_list_item_name_desc"
            android:textColor="@color/storage_list_item_desc"
            android:ellipsize="end"
            android:id="@id/app_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="0.0dp"
            android:maxLines="2"
            app:area_id="@id/area_content"
            app:custom_params="marginTop" />
  <ImageView android:id="@id/arrow"
             android:layout_width="wrap_content"
             android:layout_height="wrap_content"
             android:src="@drawable/miuix_appcompat_arrow_right"
             android:layout_centerVertical="true"
             android:layout_alignParentEnd="true"
             app:area_id="@id/area_end" />
</miuix.flexible.view.HyperCellLayout>