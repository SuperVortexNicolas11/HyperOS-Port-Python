<?xml version='1.0' encoding='utf-8' ?>
<androidx.constraintlayout.widget.ConstraintLayout android:layout_width="fill_parent"
                      android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <miuix.springback.view.SpringBackLayout android:id="@id/springbacklayout"
                        android:layout_width="fill_parent"
                        android:layout_height="0.0dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:scrollOrientation="vertical|angle"
                        app:scrollableView="@id/permission_usage_list">
    <miuix.recyclerview.widget.RecyclerView android:id="@id/permission_usage_list"
                          android:scrollbars="none"
                          android:clipToPadding="false"
                          android:layout_width="fill_parent"
                          android:layout_height="fill_parent"
                          android:overScrollMode="never" />
  </miuix.springback.view.SpringBackLayout>
  <TextView android:textSize="@dimen/sp_14"
            android:textColor="@color/os2_spinner_text_color"
            android:gravity="center_vertical"
            android:id="@id/usage_float_time_title"
            android:background="@color/app_behavior_list_head_bg"
            android:paddingTop="@dimen/dp_8"
            android:paddingBottom="@dimen/dp_8"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/dp_35"
            android:fontFamily="@string/miuix_font_style_misans_medium_font_family"
            android:paddingStart="@dimen/miuix_appcompat_list_preferred_item_padding_left"
            android:paddingEnd="@dimen/miuix_appcompat_list_preferred_item_padding_right"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
  <miuix.androidbasewidget.widget.ProgressBar android:id="@id/behavior_loading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
  <TextView android:textSize="@dimen/app_behavior_perm_desc_text"
            android:textColor="@color/app_behavior_empty_text_color"
            android:gravity="center"
            android:id="@id/behavior_empty_view"
            android:paddingBottom="@dimen/app_behavior_empty_bottom"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_behavior_no_recorder"
            android:drawableTop="@drawable/pm_behavior_empty"
            android:drawablePadding="@dimen/view_dimen_52"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>