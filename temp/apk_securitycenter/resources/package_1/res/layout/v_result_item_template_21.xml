<?xml version='1.0' encoding='utf-8' ?>
<RelativeLayout android:paddingTop="@dimen/card_layout_line_height_half"
                android:paddingBottom="@dimen/card_layout_line_height_half"
                android:descendantFocusability="blocksDescendants"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:clean="http://schemas.android.com/apk/res/com.miui.securitycenter">
  <LinearLayout android:orientation="vertical"
                android:id="@id/inner_layout"
                android:background="@drawable/shape_result_card_border_whole"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
    <com.miui.optimizemanage.view.OMRoundResizeFrameLayout android:layout_width="fill_parent"
                          android:layout_height="@dimen/antivirus_card_21_img_height"
                          android:layout_marginTop="@dimen/dp_18"
                          android:layout_marginStart="@dimen/dp_16"
                          android:layout_marginEnd="@dimen/dp_16"
                          clean:ratioXY="0.48"
                          clean:roundCornerRadius="6.5dp">
      <ImageView android:id="@id/img"
                 android:layout_width="fill_parent"
                 android:layout_height="fill_parent"
                 android:scaleType="centerCrop" />
    </com.miui.optimizemanage.view.OMRoundResizeFrameLayout>
    <LinearLayout android:orientation="vertical"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="@dimen/dp_14"
                  android:layout_marginBottom="@dimen/dp_18"
                  android:layout_marginStart="@dimen/dp_16"
                  android:layout_marginEnd="@dimen/dp_16">
      <TextView android:textColor="@color/v_title_color"
                android:id="@id/title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/AntivirusResultActivityTitleStyle" />
      <TextView android:textSize="@dimen/sp_11"
                android:textColor="@color/v_summary_color"
                android:id="@id/summary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_1"
                style="@style/ResultBottomText" />
    </LinearLayout>
    <LinearLayout android:orientation="horizontal"
                  android:visibility="gone"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="@dimen/vartical_margin_pic_text"
                  android:layout_marginBottom="@dimen/adds_item_bottom_margin">
      <TextView android:id="@id/market"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/recommended"
                style="@style/MarketText" />
      <Button android:id="@id/button"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/go_to"
              style="@style/ResultButton" />
    </LinearLayout>
  </LinearLayout>
  <FrameLayout android:paddingBottom="@dimen/dp_18"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:layout_alignParentBottom="true"
               android:paddingEnd="@dimen/dp_16"
               android:layout_alignParentEnd="true">
    <include android:visibility="invisible"
             layout="@layout/adv_close_layout" />
  </FrameLayout>
</RelativeLayout>