<?xml version='1.0' encoding='utf-8' ?>
<miuix.springback.view.SpringBackLayout android:layout_width="fill_parent"
                      android:layout_height="fill_parent"
                      app:scrollableView="@id/scroll_view" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <androidx.core.widget.NestedScrollView android:id="@id/scroll_view"
                        android:layout_width="fill_parent"
                        android:layout_height="fill_parent">
    <LinearLayout android:orientation="vertical"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content">
      <LinearLayout android:orientation="horizontal"
                    android:id="@id/wlan_optimization"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_37"
                    style="@style/GBCompetitionItem">
        <ImageView android:layout_width="wrap_content"
                   android:layout_height="wrap_content"
                   android:src="@drawable/gb_competition_wlan" />
        <LinearLayout android:orientation="vertical"
                      android:layout_width="0.0dp"
                      android:layout_height="wrap_content"
                      android:layout_weight="1.0"
                      android:layout_marginStart="@dimen/view_dimen_73"
                      android:layout_marginEnd="@dimen/view_dimen_107">
          <TextView android:textAppearance="@style/Miuix.AppCompat.TextAppearance.List.Primary"
                    android:id="@id/wlan_optimization_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/wlan_optimization_title"
                    android:layout_weight="1.0" />
          <TextView android:textAppearance="@style/Miuix.AppCompat.TextAppearance.List.Secondary"
                    android:id="@id/wlan_optimization_summary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/wlan_optimization_summary"
                    android:layout_weight="1.0" />
        </LinearLayout>
        <miuix.slidingwidget.widget.SlidingButton android:layout_gravity="center_vertical"
                              android:id="@id/sliding_wifi"
                              android:clickable="true"
                              android:layout_width="wrap_content"
                              android:layout_height="wrap_content" />
      </LinearLayout>
      <LinearLayout android:orientation="horizontal"
                    android:id="@id/doze_optimization"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/view_dimen_123"
                    style="@style/GBCompetitionItem">
        <ImageView android:layout_width="wrap_content"
                   android:layout_height="wrap_content"
                   android:src="@drawable/gb_competition_doze" />
        <LinearLayout android:orientation="vertical"
                      android:layout_width="0.0dp"
                      android:layout_height="wrap_content"
                      android:layout_weight="1.0"
                      android:layout_marginStart="@dimen/view_dimen_73"
                      android:layout_marginEnd="@dimen/view_dimen_107">
          <TextView android:textAppearance="@style/Miuix.AppCompat.TextAppearance.List.Primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/doze_optimization_title"
                    android:layout_weight="1.0" />
          <TextView android:textAppearance="@style/Miuix.AppCompat.TextAppearance.List.Secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/doze_optimization_summary"
                    android:layout_weight="1.0" />
        </LinearLayout>
        <miuix.slidingwidget.widget.SlidingButton android:layout_gravity="center_vertical"
                              android:id="@id/sliding_touch"
                              android:clickable="true"
                              android:layout_width="wrap_content"
                              android:layout_height="wrap_content" />
      </LinearLayout>
      <LinearLayout android:orientation="horizontal"
                    android:id="@id/audio_optimization"
                    android:visibility="gone"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/view_dimen_123"
                    style="@style/GBCompetitionItem">
        <ImageView android:layout_width="wrap_content"
                   android:layout_height="wrap_content"
                   android:src="@drawable/gb_competition_audio" />
        <LinearLayout android:layout_gravity="center_vertical"
                      android:orientation="vertical"
                      android:layout_width="0.0dp"
                      android:layout_height="wrap_content"
                      android:layout_weight="1.0"
                      android:layout_marginStart="@dimen/view_dimen_73"
                      android:layout_marginEnd="@dimen/view_dimen_107">
          <TextView android:textAppearance="@style/Miuix.AppCompat.TextAppearance.List.Primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/audio_optimization_title"
                    android:layout_weight="1.0" />
          <TextView android:textAppearance="@style/Miuix.AppCompat.TextAppearance.List.Secondary"
                    android:id="@id/tv_audio_optimization_summary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/audio_optimization_summary_new"
                    android:layout_weight="1.0" />
        </LinearLayout>
        <miuix.slidingwidget.widget.SlidingButton android:layout_gravity="center_vertical"
                              android:id="@id/sliding_audio"
                              android:clickable="true"
                              android:layout_width="wrap_content"
                              android:layout_height="wrap_content" />
      </LinearLayout>
      <LinearLayout android:orientation="horizontal"
                    android:id="@id/dynamic_performance"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/view_dimen_123"
                    style="@style/GBCompetitionItem">
        <ImageView android:layout_width="wrap_content"
                   android:layout_height="wrap_content"
                   android:src="@drawable/gb_competition_dy_icon" />
        <LinearLayout android:layout_gravity="center_vertical"
                      android:orientation="vertical"
                      android:layout_width="0.0dp"
                      android:layout_height="wrap_content"
                      android:layout_weight="1.0"
                      android:layout_marginStart="@dimen/view_dimen_73"
                      android:layout_marginEnd="@dimen/view_dimen_107">
          <TextView android:textAppearance="@style/Miuix.AppCompat.TextAppearance.List.Primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/dynamic_performance_optimization_title"
                    android:layout_weight="1.0" />
          <TextView android:textAppearance="@style/Miuix.AppCompat.TextAppearance.List.Secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/dynamic_performance_optimization_summary"
                    android:layout_weight="1.0" />
        </LinearLayout>
        <miuix.slidingwidget.widget.SlidingButton android:layout_gravity="center_vertical"
                              android:id="@id/sliding_dynamic_performance"
                              android:clickable="true"
                              android:layout_width="wrap_content"
                              android:layout_height="wrap_content" />
      </LinearLayout>
    </LinearLayout>
  </androidx.core.widget.NestedScrollView>
</miuix.springback.view.SpringBackLayout>