<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="horizontal"
              android:background="?attr/preferenceItemBackground"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android">
  <ImageView android:layout_gravity="center"
             android:id="@id/app_manager_details_appicon"
             android:layout_width="@dimen/am_details_top_icon_size"
             android:layout_height="@dimen/am_details_top_icon_size"
             android:layout_marginTop="@dimen/dp_14dp"
             android:layout_marginBottom="@dimen/dp_14dp"
             android:layout_marginEnd="@dimen/am_details_top_icon_margin_end"
             android:layout_marginVertical="@dimen/dp_14dp" />
  <LinearLayout android:layout_gravity="center_vertical"
                android:orientation="vertical"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
    <TextView android:textSize="@dimen/am_details_top_label_text_size"
              android:textStyle="bold"
              android:textColor="@color/app_manager_detail_title_color"
              android:id="@id/app_manager_details_applabel"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:textAlignment="viewStart" />
    <TextView android:textSize="@dimen/am_details_top_version_text_size"
              android:textColor="@color/app_manager_black_99"
              android:id="@id/app_manager_details_appversion"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/am_details_top_version_margin_top"
              android:textAlignment="viewStart" />
    <ViewStub android:id="@id/vs_instant_label"
              android:layout="@layout/app_manager_instant_app_label_vs_layout"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/dp_2" />
  </LinearLayout>
</LinearLayout>