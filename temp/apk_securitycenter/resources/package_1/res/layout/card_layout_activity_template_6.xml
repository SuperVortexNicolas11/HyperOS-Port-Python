<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:background="@drawable/card_bg_no_shadow_selector"
              android:paddingTop="@dimen/dp_24"
              android:paddingBottom="@dimen/dp_24"
              android:descendantFocusability="blocksDescendants"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:paddingStart="@dimen/result_card_margin_left"
              android:paddingEnd="@dimen/result_card_margin_left" xmlns:android="http://schemas.android.com/apk/res/android">
  <LinearLayout android:orientation="horizontal"
                android:paddingBottom="@dimen/dp_14"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
    <ImageView android:layout_gravity="top"
               android:id="@id/icon"
               android:src="@drawable/card_icon_default"
               style="@style/ResultListIconStyle" />
    <LinearLayout android:layout_gravity="center_vertical"
                  android:orientation="vertical"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content">
      <TextView android:gravity="center_vertical"
                android:id="@id/title"
                style="@style/CardTitleTextViewStyle" />
      <TextView android:layout_gravity="center_vertical"
                android:id="@id/summary"
                style="@style/CardSummaryTextViewStyle" />
    </LinearLayout>
  </LinearLayout>
  <Button android:layout_gravity="end"
          android:id="@id/button"
          android:singleLine="true"
          style="@style/ResultBlueButtonStyle" />
</LinearLayout>