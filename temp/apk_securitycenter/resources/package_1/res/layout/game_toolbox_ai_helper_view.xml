<?xml version='1.0' encoding='utf-8' ?>
<androidx.constraintlayout.widget.ConstraintLayout android:padding="@dimen/dp_12"
                      android:layout_width="fill_parent"
                      android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <androidx.constraintlayout.widget.ConstraintLayout android:id="@id/layout_ai_helper_title"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">
    <ImageView android:id="@id/icon_go_back"
               android:layout_width="@dimen/game_toolbox_settings_go_back_icon_size"
               android:layout_height="@dimen/game_toolbox_settings_go_back_icon_size"
               android:layout_marginTop="@dimen/game_toolbox_settings_go_back_margin_top"
               android:layout_marginBottom="@dimen/game_toolbox_settings_go_back_margin_top"
               android:src="@drawable/iv_game_toolbox_go_back"
               android:contentDescription="@string/game_toolbox_btn_back_talkback"
               android:layout_marginStart="@dimen/game_toolbox_settings_go_back_margin_start"
               app:layout_constraintBottom_toBottomOf="parent"
               app:layout_constraintStart_toStartOf="parent"
               app:layout_constraintTop_toTopOf="parent" />
    <TextView android:textSize="@dimen/game_toolbox_settings_title_text_size"
              android:textColor="@color/game_toolbox_title_color"
              android:gravity="center"
              android:id="@id/game_toolbox_settings_title"
              android:focusable="true"
              android:focusableInTouchMode="true"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/game_toolbox_ai_service_title"
              android:maxLines="2"
              android:fontFamily="mipro-semibold"
              android:textAlignment="center"
              app:layout_constraintBottom_toBottomOf="parent"
              app:layout_constraintEnd_toEndOf="parent"
              app:layout_constraintStart_toStartOf="parent"
              app:layout_constraintTop_toTopOf="parent" />
  </androidx.constraintlayout.widget.ConstraintLayout>
  <androidx.recyclerview.widget.RecyclerView android:id="@id/recycler_view"
                        android:paddingLeft="@dimen/dp_12"
                        android:paddingRight="@dimen/dp_12"
                        android:layout_width="fill_parent"
                        android:layout_height="0.0dp"
                        android:paddingHorizontal="@dimen/dp_12"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/layout_ai_helper_title" />
</androidx.constraintlayout.widget.ConstraintLayout>