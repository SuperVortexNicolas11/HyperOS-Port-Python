<?xml version='1.0' encoding='utf-8' ?>
<RelativeLayout android:id="@id/activity_guide"
                android:background="@drawable/guide_activity_bg"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android">
  <View android:background="@drawable/guide_activity_bg_above"
        android:layout_width="@dimen/guide_page_bg_above_width"
        android:layout_height="@dimen/guide_page_bg_above_height"
        android:layout_marginTop="@dimen/guide_page_bg_above_margin_top"
        android:layout_marginBottom="@dimen/guide_page_bg_above_margin_bottom"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true" />
  <TextView android:textSize="@dimen/guide_page_app_name_text_size"
            android:textColor="#ffffff"
            android:gravity="center"
            android:id="@id/appName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/spacing_35"
            android:layout_marginRight="@dimen/spacing_35"
            android:text="@string/hongbao_name"
            android:layout_above="@id/appSummary"
            android:layout_centerHorizontal="true"
            android:fontFamily="mipro-semibold"
            android:layout_marginHorizontal="@dimen/spacing_35" />
  <TextView android:textSize="@dimen/guide_page_app_summary_text_size"
            android:textColor="#ffffff"
            android:gravity="center"
            android:id="@id/appSummary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/guide_page_app_summary_margin_top"
            android:layout_marginBottom="@dimen/guide_page_app_summary_margin_bottom"
            android:text="@string/app_summary"
            android:layout_above="@id/appRights"
            android:layout_centerHorizontal="true"
            android:lineSpacingExtra="@dimen/dp_2_91" />
  <LinearLayout android:gravity="center_vertical"
                android:orientation="horizontal"
                android:id="@id/appRights"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/guide_page_app_rights_margin_bottom"
                android:layout_above="@id/btnOpen"
                android:layout_centerHorizontal="true">
    <View android:background="#4cffffff"
          android:layout_width="@dimen/guide_page_app_rights_divider_width"
          android:layout_height="1.0px" />
    <TextView android:textSize="@dimen/guide_page_app_rights_text_size"
              android:textColor="#4cffffff"
              android:id="@id/appRight"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/app_right"
              android:layout_marginStart="11.54dp"
              android:layout_marginEnd="11.54dp" />
    <View android:background="#4cffffff"
          android:layout_width="@dimen/guide_page_app_rights_divider_width"
          android:layout_height="1.0px" />
  </LinearLayout>
  <Button android:textSize="@dimen/guide_page_button_text_size"
          android:textColor="#fa6000"
          android:id="@id/btnOpen"
          android:background="@drawable/guide_btn_selector"
          android:layout_width="@dimen/guide_page_button_bottom_width"
          android:layout_height="@dimen/guide_page_button_bottom_height"
          android:layout_marginBottom="@dimen/guide_page_button_margin_bottom"
          android:text="@string/open_lucky"
          android:layout_alignParentBottom="true"
          android:layout_centerHorizontal="true"
          android:textAlignment="center"
          android:layout_marginStart="@dimen/guide_page_button_margin_horizontal"
          android:layout_marginEnd="@dimen/guide_page_button_margin_horizontal" />
</RelativeLayout>