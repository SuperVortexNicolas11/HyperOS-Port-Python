<?xml version='1.0' encoding='utf-8' ?>
<RelativeLayout android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/scan_result_bottom_title_item_height" xmlns:android="http://schemas.android.com/apk/res/android">
  <ImageView android:id="@id/iv_icon"
             android:layout_width="@dimen/result_bottom_card_icon_size"
             android:layout_height="@dimen/result_bottom_card_icon_size"
             android:layout_centerVertical="true"
             android:layout_alignParentStart="true" />
  <TextView android:id="@id/tv_title"
            android:layout_weight="1.0"
            android:layout_centerVertical="true"
            android:textAlignment="viewStart"
            android:layout_marginStart="@dimen/result_bottom_card_title_margin_s"
            android:layout_marginEnd="12.0dp"
            android:layout_toEndOf="@id/iv_icon"
            style="@style/CardTitleTextViewStyle" />
</RelativeLayout>