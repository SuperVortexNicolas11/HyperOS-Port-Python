                      android:layout_marginBottom="@dimen/miuix_theme_margin_horizontal_common"
                      android:layout_marginStart="@dimen/miuix_theme_margin_horizontal_common"
                      android:layout_marginEnd="@dimen/miuix_theme_margin_horizontal_common"
