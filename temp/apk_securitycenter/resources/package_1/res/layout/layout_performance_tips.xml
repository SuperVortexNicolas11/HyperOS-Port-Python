<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:gravity="center_vertical"
              android:orientation="horizontal"
              android:background="@drawable/gtb_shape_performance_tips_bg"
              android:layout_width="wrap_content"
              android:layout_height="@dimen/dp_51"
              android:baselineAligned="false"
              android:layoutDirection="ltr" xmlns:android="http://schemas.android.com/apk/res/android">
  <TextView android:textSize="@dimen/dp_13"
            android:textStyle="bold"
            android:textColor="@color/gb_performance_tips_title"
            android:ellipsize="end"
            android:layout_width="@dimen/dp_167"
            android:layout_height="wrap_content"
            android:text="@string/gb_performace_tips_title"
            android:lines="1"
            android:singleLine="true"
            android:layout_marginStart="@dimen/dp_16" />
  <TextView android:textSize="@dimen/dp_11"
            android:textColor="@color/gb_performance_tips_button"
            android:gravity="center"
            android:id="@id/btn_switch"
            android:background="@drawable/gtb_shape_performance_tips_btn_bg"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/dp_32"
            android:layout_marginTop="@dimen/dp_9"
            android:layout_marginBottom="@dimen/dp_9"
            android:minWidth="@dimen/dp_63"
            android:text="@string/gb_performace_tips_button"
            android:layout_marginStart="@dimen/dp_9" />
  <View android:id="@id/btn_x"
        android:background="@drawable/gtb_ic_performance_tips_x"
        android:layout_width="@dimen/dp_26"
        android:layout_height="@dimen/dp_26"
        android:layout_marginStart="@dimen/dp_9"
        android:layout_marginEnd="@dimen/dp_8" />
</LinearLayout>