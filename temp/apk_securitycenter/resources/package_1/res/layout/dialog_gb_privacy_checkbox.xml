<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:gravity="center_vertical"
              android:orientation="horizontal"
              android:paddingLeft="@dimen/miuix_appcompat_dialog_panel_horizontal_padding"
              android:paddingRight="@dimen/miuix_appcompat_dialog_panel_horizontal_padding"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:paddingHorizontal="@dimen/miuix_appcompat_dialog_panel_horizontal_padding" xmlns:android="http://schemas.android.com/apk/res/android">
  <androidx.appcompat.widget.AppCompatCheckBox android:id="@id/custom_checkbox"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:drawablePadding="@dimen/miuix_appcompat_dialog_checkbox_inner_padding"
                        style="?attr/dialogCheckBoxStyle" />
  <TextView android:id="@id/custom_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="?android:attr/textAppearanceMedium" />
</LinearLayout>