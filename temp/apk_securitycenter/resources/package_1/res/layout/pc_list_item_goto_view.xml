<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:background="@drawable/shape_pc_main_card_border_whole"
              android:layout_width="fill_parent"
              android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android">
  <LinearLayout android:layout_width="fill_parent"
                android:layout_height="wrap_content">
    <ImageView android:id="@android:id/icon"
               android:layout_width="@dimen/pc_main_one_key_save_button_height"
               android:layout_height="@dimen/pc_main_one_key_save_button_height"
               android:layout_marginTop="@dimen/pc_list_item_goto_view_image_margin_top"
               android:layout_marginBottom="@dimen/pc_list_item_goto_view_image_margin_bottom"
               android:scaleType="centerCrop"
               android:layout_marginStart="@dimen/list_item_view_side_padding"
               android:layout_marginEnd="@dimen/pc_item_goto_view_linearlayout_startmargin" />
    <LinearLayout android:orientation="vertical"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="@dimen/pc_list_item_goto_view_image_margin_top"
                  android:layout_weight="1.0"
                  android:layout_marginEnd="@dimen/list_item_view_side_padding">
      <TextView android:textSize="@dimen/text_font_size_48"
                android:textStyle="bold"
                android:textColor="@color/pc_main_item_title_color"
                android:id="@android:id/title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/StyleListItemTitle" />
      <TextView android:textColor="@color/pc_battery_card_subtitle_color"
                android:id="@android:id/text1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/view_dimen_5"
                style="@style/StyleListItemSubTitle" />
    </LinearLayout>
  </LinearLayout>
  <RelativeLayout android:layout_width="fill_parent"
                  android:layout_height="wrap_content">
    <Button android:textSize="@dimen/pc_deep_saving_setting_text_size"
            android:textColor="@color/pc_deep_scan_result_item_header_text_color"
            android:id="@android:id/button1"
            android:background="@drawable/pc_scanresult_button_blue"
            android:paddingLeft="@dimen/pc_go_to_view_button_padding"
            android:paddingTop="@dimen/pc_go_to_view_button_padding_vertical"
            android:paddingRight="@dimen/pc_go_to_view_button_padding"
            android:paddingBottom="@dimen/pc_go_to_view_button_padding_vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/view_dimen_60"
            android:layout_marginTop="@dimen/view_dimen_20"
            android:layout_marginRight="@dimen/view_dimen_60"
            android:layout_marginBottom="@dimen/view_dimen_50"
            android:minWidth="@dimen/pc_go_to_view_button_width"
            android:minHeight="@dimen/pc_go_to_view_button_height"
            android:singleLine="true"
            android:layout_alignParentEnd="true"
            android:layout_marginHorizontal="@dimen/view_dimen_60"
            android:paddingHorizontal="@dimen/pc_go_to_view_button_padding"
            android:paddingVertical="@dimen/pc_go_to_view_button_padding_vertical" />
  </RelativeLayout>
</LinearLayout>