<?xml version='1.0' encoding='utf-8' ?>
<RelativeLayout android:background="@color/bh_white_daynight"
                android:paddingLeft="@dimen/bh_pad_extra_view_padding"
                android:paddingRight="@dimen/bh_pad_extra_view_padding"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/bh_pad_extra_view_padding" xmlns:android="http://schemas.android.com/apk/res/android">
  <RelativeLayout android:layout_width="fill_parent"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="33.5dp"
                  android:layout_alignParentTop="true">
    <LinearLayout android:orientation="horizontal"
                  android:id="@id/rl_tags"
                  android:visibility="gone"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_marginBottom="18.18dp">
      <androidx.recyclerview.widget.RecyclerView android:layout_gravity="center_vertical"
                            android:id="@id/rv_tags"
                            android:layout_width="0.0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1.0"
                            android:overScrollMode="never" />
      <ImageView android:layout_gravity="center_vertical"
                 android:id="@id/iv_edit"
                 android:layout_width="wrap_content"
                 android:layout_height="wrap_content"
                 android:src="@drawable/icon_dangerous"
                 android:layout_marginStart="13.27dp" />
    </LinearLayout>
    <TextView android:textSize="13.0dp"
              android:textColor="@color/bh_black_40_daynight"
              android:id="@id/tv_info"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginBottom="7.27dp"
              android:singleLine="true"
              android:layout_below="@id/rl_tags" />
    <RelativeLayout android:id="@id/rl_input"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/tv_info">
      <ImageView android:id="@id/iv_pick_contact"
                 android:layout_width="40.0dp"
                 android:layout_height="40.0dp"
                 android:src="@drawable/bh_ic_del"
                 android:scaleType="centerInside"
                 android:contentDescription="Delete phoneNum"
                 android:layout_alignParentEnd="true" />
      <EditText android:textSize="28.36sp"
                android:id="@id/et_number"
                android:background="@null"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:hint="@string/input_phone_num_hint"
                android:layout_centerVertical="true"
                android:inputType="number"
                android:layout_marginEnd="10.0dp"
                android:layout_toStartOf="@id/iv_pick_contact" />
    </RelativeLayout>
    <View android:id="@id/v_divider"
          android:background="@color/tab_unSelect_stroke_color"
          android:layout_width="fill_parent"
          android:layout_height="1.0px"
          android:layout_marginTop="14.54dp"
          android:layout_below="@id/rl_input" />
    <TextView android:textSize="12.0sp"
              android:id="@id/tv_wrong"
              android:visibility="gone"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginTop="10.0dp"
              android:layout_marginBottom="3.0dp"
              android:layout_below="@id/v_divider" />
    <androidx.recyclerview.widget.RecyclerView android:id="@id/rv_recent"
                          android:visibility="gone"
                          android:layout_width="fill_parent"
                          android:layout_height="wrap_content"
                          android:layout_below="@id/v_divider" />
  </RelativeLayout>
</RelativeLayout>