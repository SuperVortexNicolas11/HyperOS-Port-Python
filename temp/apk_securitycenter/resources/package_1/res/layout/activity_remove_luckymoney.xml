<?xml version='1.0' encoding='utf-8' ?>
<RelativeLayout android:background="#f7f7f7"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android">
  <ImageView android:id="@id/icon"
             android:layout_width="@dimen/lucky_remove_icon_size"
             android:layout_height="@dimen/lucky_remove_icon_size"
             android:src="@drawable/hongbao_launcher"
             android:scaleType="centerCrop"
             android:layout_centerHorizontal="true" />
  <TextView android:textSize="@dimen/lucky_remove_message_text_size"
            android:textColor="#b2000000"
            android:id="@id/message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/lucky_remove_message_margin_tip"
            android:text="@string/dialog_remove_luckymoney"
            android:layout_below="@id/icon"
            android:layout_centerHorizontal="true" />
</RelativeLayout>