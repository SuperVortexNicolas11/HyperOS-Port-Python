<?xml version='1.0' encoding='utf-8' ?>
<RelativeLayout android:background="@color/line_card_bg"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <TextView android:gravity="center"
            android:id="@id/text1"
            android:paddingTop="@dimen/list_item_padding"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_above="@id/text2"
            style="@style/Miuix.AppCompat.TextAppearance.List.Secondary" />
  <TextView android:gravity="center"
            android:id="@id/text2"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:text="@string/st_filter_keywords_setting_summary2"
            android:layout_alignParentBottom="true"
            style="@style/Miuix.AppCompat.TextAppearance.List.Secondary" />
  <miuix.springback.view.SpringBackLayout android:layout_width="fill_parent"
                        android:layout_height="fill_parent"
                        android:layout_above="@id/text1"
                        app:scrollableView="@android:id/list">
    <com.miui.antispam.ui.view.RecyclerViewExt android:id="@android:id/list"
                          android:paddingTop="@dimen/view_dimen_20"
                          android:paddingBottom="@dimen/view_dimen_40"
                          android:clipToPadding="false"
                          android:layout_width="fill_parent"
                          android:layout_height="fill_parent"
                          android:fastScrollEnabled="true" />
  </miuix.springback.view.SpringBackLayout>
</RelativeLayout>