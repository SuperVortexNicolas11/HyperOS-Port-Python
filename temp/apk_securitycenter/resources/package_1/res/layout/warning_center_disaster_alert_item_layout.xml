<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android">
  <RelativeLayout android:id="@id/container_card"
                  android:background="@drawable/warning_center_disaster_bg_blue"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="@dimen/dp_6"
                  android:layout_marginBottom="@dimen/dp_6"
                  android:paddingStart="@dimen/view_dimen_60"
                  android:paddingEnd="@dimen/view_dimen_60">
    <LinearLayout android:gravity="center_vertical"
                  android:orientation="horizontal"
                  android:id="@id/ll_title"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="@dimen/dp_24"
                  android:layout_toStartOf="@id/iv_type">
      <TextView android:textSize="@dimen/sp_24"
                android:textStyle="bold"
                android:textColor="#ffffff"
                android:id="@id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
      <TextView android:textSize="@dimen/sp_11"
                android:textColor="#ffffff"
                android:id="@id/tv_first"
                android:background="@drawable/warning_center_disaster_shape_publish"
                android:paddingTop="@dimen/dp_3"
                android:paddingBottom="@dimen/dp_3"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="@dimen/dp_6"
                android:paddingEnd="@dimen/dp_6"
                android:layout_marginStart="@dimen/dp_8" />
    </LinearLayout>
    <ImageView android:id="@id/iv_type"
               android:layout_width="@dimen/dp_74"
               android:layout_height="@dimen/dp_74"
               android:layout_marginTop="@dimen/dp_16"
               android:alpha="0.6"
               android:layout_alignParentEnd="true" />
    <TextView android:textSize="@dimen/wc_text_summary_text_size"
              android:textColor="#b3ffffff"
              android:id="@id/tv_date"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/dp_4"
              android:layout_below="@id/ll_title"
              android:layout_toStartOf="@id/iv_type"
              android:layout_alignStart="@id/ll_title" />
    <LinearLayout android:orientation="horizontal"
                  android:id="@id/ll_detail"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="@dimen/dp_18"
                  android:layout_below="@id/tv_date">
      <LinearLayout android:gravity="center"
                    android:orientation="vertical"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0">
        <TextView android:textSize="@dimen/wc_text_summary_text_size"
                  android:textColor="#a6ffffff"
                  android:id="@id/tv_area_title"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:text="@string/warningcenter_disaster_area_title" />
        <TextView android:textSize="@dimen/sp_17"
                  android:textStyle="bold"
                  android:textColor="#ffffff"
                  android:id="@id/tv_area"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="@dimen/dp_2" />
      </LinearLayout>
      <View android:background="@color/ew_alert_card_splite_selector"
            android:layout_width="@dimen/view_dimen_2"
            android:layout_height="@dimen/view_dimen_100"
            android:layout_marginTop="@dimen/view_dimen_20"
            android:layout_marginStart="@dimen/dp_9"
            android:layout_marginEnd="@dimen/dp_9" />
      <LinearLayout android:gravity="center"
                    android:orientation="vertical"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0">
        <TextView android:textSize="@dimen/wc_text_summary_text_size"
                  android:textColor="#a6ffffff"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:text="@string/warningcenter_disaster_level_title" />
        <TextView android:textSize="@dimen/sp_17"
                  android:textStyle="bold"
                  android:textColor="#ffffff"
                  android:id="@id/tv_level"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="@dimen/view_dimen_12" />
      </LinearLayout>
    </LinearLayout>
    <TextView android:textSize="@dimen/wc_text_summary_text_size"
              android:textColor="#b3ffffff"
              android:ellipsize="end"
              android:id="@id/tv_desc"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/dp_10"
              android:maxLines="2"
              android:layout_below="@id/ll_detail" />
    <TextView android:textSize="@dimen/wc_card_type_text_size"
              android:textColor="#99ffffff"
              android:id="@id/tv_warning_from"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/dp_10"
              android:layout_marginBottom="@dimen/dp_20"
              android:text="@string/warningcenter_disaster_info_from"
              android:layout_below="@id/tv_desc"
              android:layout_centerHorizontal="true" />
  </RelativeLayout>
  <RelativeLayout android:id="@id/rv_guide_container"
                  android:background="@drawable/warning_center_disaster_bg_gray"
                  android:visibility="gone"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="@dimen/dp_6"
                  android:layout_marginBottom="@dimen/dp_6">
    <ImageView android:id="@id/image2"
               android:layout_width="@dimen/dp_32"
               android:layout_height="@dimen/dp_32"
               android:layout_marginTop="@dimen/dp_10"
               android:src="@drawable/warningcenter_disaster_icon_guide"
               android:importantForAccessibility="no"
               android:layout_marginStart="@dimen/dp_12" />
    <TextView android:textSize="@dimen/sp_15"
              android:textStyle="bold"
              android:textColor="#000000"
              android:id="@id/title2"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/dp_10"
              android:text="@string/warningcenter_disaster_guide_title"
              android:layout_centerHorizontal="true"
              android:layout_marginStart="@dimen/dp_12"
              android:layout_toEndOf="@id/image2" />
    <TextView android:textSize="@dimen/text_font_size_40"
              android:textColor="#a6000000"
              android:ellipsize="end"
              android:id="@id/tv_guide"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/dp_2"
              android:layout_marginBottom="@dimen/dp_11"
              android:maxLines="2"
              android:layout_below="@id/title2"
              android:layout_centerHorizontal="true"
              android:layout_marginStart="@dimen/dp_12"
              android:layout_marginEnd="@dimen/dp_12"
              android:layout_toEndOf="@id/image2" />
  </RelativeLayout>
</LinearLayout>