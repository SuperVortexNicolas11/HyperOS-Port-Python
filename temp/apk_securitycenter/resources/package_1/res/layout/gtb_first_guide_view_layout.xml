<?xml version='1.0' encoding='utf-8' ?>
<com.miui.gamebooster.widget.GtbTipsView android:background="@android:color/transparent"
                      android:layout_width="fill_parent"
                      android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <View android:id="@id/iv_mask"
        android:background="@drawable/gtb_tips_rectangle"
        android:layout_width="@dimen/dp_px_184"
        android:layout_height="@dimen/dp_px_184"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
  <TextView android:textSize="@dimen/dp_15"
            android:textColor="@color/color_gtb_guide_desc"
            android:id="@id/tv_desc_new"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_24"
            app:layout_constraintBottom_toBottomOf="@id/iv_mask"
            app:layout_constraintStart_toEndOf="@id/iv_mask"
            app:layout_constraintTop_toTopOf="@id/iv_mask" />
  <TextView android:textSize="@dimen/view_dimen_44"
            android:textColor="@color/color_white_50"
            android:gravity="center"
            android:id="@id/tv_finish"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/view_dimen_100"
            android:text="@string/gtb_guide_finish"
            android:maxLines="2"
            android:fontFamily="sans-serif"
            android:layout_marginEnd="@dimen/view_dimen_90"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
  <TextView android:textSize="@dimen/view_dimen_72"
            android:textStyle="bold"
            android:textColor="@color/color_gtb_guide_title"
            android:id="@id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/view_dimen_452"
            android:text="@string/gtb_guide_small_window_app_title"
            android:layout_marginStart="@dimen/gt_guide_step_one_ml"
            app:layout_constraintStart_toEndOf="@id/iv_mask"
            app:layout_constraintTop_toTopOf="parent" />
  <TextView android:textSize="@dimen/view_dimen_40"
            android:textColor="@color/color_gtb_guide_desc"
            android:id="@id/tv_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/gt_guide_step_two_mt"
            android:text="@string/gtb_guide_small_window_app_desc"
            app:layout_constraintStart_toStartOf="@id/tv_title"
            app:layout_constraintTop_toBottomOf="@id/tv_title" />
</com.miui.gamebooster.widget.GtbTipsView>