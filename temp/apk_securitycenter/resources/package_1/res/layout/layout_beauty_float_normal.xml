<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:gravity="center_horizontal"
              android:orientation="vertical"
              android:background="@drawable/shape_beauty_normal_bg"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android">
  <LinearLayout android:gravity="center"
                android:orientation="vertical"
                android:id="@id/layout_face"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
    <ImageView android:layout_gravity="center"
               android:id="@id/iv_beauty_face"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:src="@drawable/gb_ic_beauty_face" />
    <com.miui.gamebooster.videobox.view.MarqueeTextView android:textAppearance="?android:attr/textAppearanceMedium"
                          android:textSize="@dimen/dp_12"
                          android:textColor="@color/gb_beauty_float_title"
                          android:ellipsize="marquee"
                          android:id="@id/tv_beauty_face"
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:layout_marginTop="@dimen/dp_11"
                          android:text="@string/gb_beauty_face"
                          android:singleLine="true" />
  </LinearLayout>
  <LinearLayout android:gravity="center"
                android:orientation="vertical"
                android:id="@id/layout_light"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_16">
    <ImageView android:layout_gravity="center"
               android:id="@id/iv_beauty_light"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:src="@drawable/gb_ic_beauty_light" />
    <com.miui.gamebooster.videobox.view.MarqueeTextView android:textAppearance="?android:attr/textAppearanceMedium"
                          android:textSize="@dimen/dp_12"
                          android:textColor="@color/gb_beauty_float_title"
                          android:ellipsize="marquee"
                          android:gravity="bottom"
                          android:id="@id/tv_beauty_light"
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:layout_marginTop="@dimen/dp_11"
                          android:text="@string/gb_beauty_light"
                          android:singleLine="true"
                          android:drawablePadding="@dimen/dp_2"
                          android:drawableEnd="@drawable/gb_ic_beauty_light_triangle"
                          android:layout_marginStart="@dimen/dp_8"
                          android:layout_marginEnd="@dimen/dp_8" />
  </LinearLayout>
  <LinearLayout android:gravity="center"
                android:orientation="vertical"
                android:id="@id/layout_privacy"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_16">
    <ImageView android:layout_gravity="center"
               android:id="@id/iv_beauty_privacy"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:src="@drawable/gb_ic_beauty_privacy" />
    <com.miui.gamebooster.videobox.view.MarqueeTextView android:textAppearance="?android:attr/textAppearanceMedium"
                          android:textSize="@dimen/dp_12"
                          android:textColor="@color/gb_beauty_float_title"
                          android:ellipsize="marquee"
                          android:id="@id/tv_beauty_privacy"
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:layout_marginTop="@dimen/dp_11"
                          android:text="@string/beauty_fun_privacy"
                          android:singleLine="true" />
  </LinearLayout>
  <LinearLayout android:gravity="center"
                android:orientation="vertical"
                android:id="@id/layout_pc"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_16">
    <ImageView android:layout_gravity="center"
               android:id="@id/iv_beauty_pc"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:src="@drawable/gb_ic_beauty_portrait_center" />
    <com.miui.gamebooster.videobox.view.MarqueeTextView android:textAppearance="?android:attr/textAppearanceMedium"
                          android:textSize="@dimen/dp_12"
                          android:textColor="@color/gb_beauty_float_title"
                          android:ellipsize="marquee"
                          android:id="@id/tv_beauty_pc"
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:layout_marginTop="@dimen/dp_11"
                          android:text="@string/beauty_portrait_center"
                          android:singleLine="true" />
  </LinearLayout>
  <View android:layout_gravity="center_horizontal"
        android:background="@color/whitealpha15"
        android:layout_width="@dimen/dp_50"
        android:layout_height="@dimen/dp_0_74"
        android:layout_marginTop="@dimen/dp_16"
        android:layout_marginBottom="@dimen/dp_10_67" />
  <ImageView android:id="@id/iv_beauty_settings"
             android:layout_width="wrap_content"
             android:layout_height="wrap_content"
             android:src="@drawable/ic_beauty_settings" />
</LinearLayout>