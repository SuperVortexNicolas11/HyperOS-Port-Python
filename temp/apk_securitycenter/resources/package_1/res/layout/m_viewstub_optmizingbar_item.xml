<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="horizontal"
              android:paddingTop="@dimen/dp_14"
              android:paddingBottom="@dimen/dp_14"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:baselineAligned="false"
              android:minHeight="@dimen/dp_70"
              android:paddingStart="@dimen/scan_optimizebar_margin_se"
              android:paddingEnd="@dimen/scan_optimizebar_margin_se" xmlns:android="http://schemas.android.com/apk/res/android">
  <ImageView android:id="@id/iv_bg"
             android:layout_width="wrap_content"
             android:layout_height="wrap_content" />
  <LinearLayout android:layout_gravity="center_vertical"
                android:orientation="vertical"
                android:layout_width="0.0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.0"
                android:layout_marginStart="@dimen/optimizingbar_item_textview_margin_start">
    <TextView android:id="@id/tv_title"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              style="@style/ScanItemTitleTextViewStyle" />
    <TextView android:id="@id/tv_summary"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              style="@style/ScanItemSummaryTextViewStyle" />
  </LinearLayout>
  <FrameLayout android:layout_width="@dimen/dp_26"
               android:layout_height="@dimen/dp_26">
    <com.miui.securityscan.ui.main.NoClassNameIconView android:id="@id/iv_progress"
                          android:visibility="gone"
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:src="@drawable/scan_state_safe"
                          android:contentDescription="@string/optmizingbar_item_img_description" />
    <miuix.androidbasewidget.widget.ProgressBar android:layout_gravity="center"
                          android:id="@id/progressbar_status"
                          android:layout_width="@dimen/optimizing_processbar_size"
                          android:layout_height="@dimen/optimizing_processbar_size"
                          android:indeterminate="true"
                          android:indeterminateDrawable="@drawable/progressbar_loading"
                          style="?android:attr/progressBarStyleSmall" />
  </FrameLayout>
</LinearLayout>