<?xml version='1.0' encoding='utf-8' ?>
<RelativeLayout android:id="@id/more_function_item"
                android:background="@drawable/shape_bg_inquiry"
                android:paddingLeft="@dimen/dp_14"
                android:paddingTop="@dimen/dp_16"
                android:paddingRight="@dimen/dp_14"
                android:paddingBottom="@dimen/dp_16"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/dp_14"
                android:paddingVertical="@dimen/dp_16" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:tool="http://schemas.android.com/apk/res-auto">
  <LinearLayout android:orientation="vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
    <TextView android:textSize="@dimen/font_size_16"
              android:textColor="@color/bh_black_daynight"
              android:id="@id/tv_more_function_1"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:fontFamily="sans-serif-medium" />
    <TextView android:textSize="@dimen/ad_sp_14"
              android:textColor="@color/bh_black_60_daynight"
              android:id="@id/tv_more_function_2"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:fontFamily="sans-serif" />
  </LinearLayout>
  <ImageView android:visibility="visible"
             android:layout_width="wrap_content"
             android:layout_height="wrap_content"
             android:src="@drawable/bh_preference_arrow_right"
             android:scaleType="fitEnd"
             android:tint="@color/color_black_trans_60"
             android:layout_centerVertical="true"
             android:layout_marginStart="@dimen/dp_14"
             android:layout_alignParentEnd="true" />
</RelativeLayout>