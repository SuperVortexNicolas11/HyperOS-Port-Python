<?xml version='1.0' encoding='utf-8' ?>
<androidx.constraintlayout.widget.ConstraintLayout android:layout_width="fill_parent"
                      android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <com.miui.common.widgets.gif.GifImageView android:id="@id/iv_application_icon"
                        android:layout_width="@dimen/dp_45"
                        android:layout_height="@dimen/dp_45"
                        android:layout_marginTop="@dimen/dp_7"
                        android:layout_marginStart="@dimen/dp_2"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
  <ImageView android:id="@id/iv_hot"
             android:layout_width="@dimen/dp_27"
             android:layout_height="@dimen/dp_15"
             android:src="@drawable/ic_casual_game_range_one"
             app:layout_constraintStart_toStartOf="parent"
             app:layout_constraintTop_toTopOf="parent" />
  <com.miui.gamecenter.casual_game.GameBoxRangeTextView android:id="@id/tv_range"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dp_3"
                        android:layout_marginStart="@dimen/dp_5"
                        app:layout_constraintStart_toStartOf="@id/iv_hot"
                        app:layout_constraintTop_toTopOf="@id/iv_hot" />
  <TextView android:textSize="@dimen/dp_12"
            android:textColor="#e6ffffff"
            android:ellipsize="end"
            android:id="@id/tv_app_name"
            android:layout_width="0.0dp"
            android:layout_height="wrap_content"
            android:lines="1"
            android:layout_marginStart="@dimen/dp_8"
            app:layout_constraintEnd_toStartOf="@id/tv_recomment"
            app:layout_constraintStart_toEndOf="@id/iv_application_icon"
            app:layout_constraintTop_toTopOf="@id/iv_application_icon" />
  <LinearLayout android:orientation="horizontal"
                android:id="@id/ll_desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_3"
                app:layout_constraintStart_toStartOf="@id/tv_app_name"
                app:layout_constraintTop_toBottomOf="@id/tv_app_name">
    <TextView android:id="@id/tv_app_version"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              style="@style/CasualGameAppTinyTextStyle" />
    <TextView android:textSize="@dimen/dp_8"
              android:textColor="#80b2b6cd"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="|"
              android:layout_marginStart="@dimen/dp_5"
              android:layout_marginEnd="@dimen/dp_5" />
    <TextView android:id="@id/tv_app_permission"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              style="@style/CasualGameAppTinyTextStyle" />
    <TextView android:textSize="@dimen/dp_8"
              android:textColor="#80b2b6cd"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="|"
              android:layout_marginStart="@dimen/dp_5"
              android:layout_marginEnd="@dimen/dp_5" />
    <TextView android:id="@id/tv_app_privacy"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              style="@style/CasualGameAppTinyTextStyle" />
  </LinearLayout>
  <LinearLayout android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_3"
                app:layout_constraintStart_toStartOf="@id/tv_app_name"
                app:layout_constraintTop_toBottomOf="@id/ll_desc">
    <TextView android:id="@id/tv_app_desc"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              style="@style/CasualGameAppTinyTextStyle" />
    <TextView android:textSize="@dimen/dp_8"
              android:textColor="#80b2b6cd"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="|"
              android:layout_marginStart="@dimen/dp_5"
              android:layout_marginEnd="@dimen/dp_5" />
    <TextView android:id="@id/tv_app_publish_company"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              style="@style/CasualGameAppTinyTextStyle" />
  </LinearLayout>
  <TextView android:textSize="@dimen/dp_8"
            android:textColor="#ffffff"
            android:gravity="center"
            android:id="@id/tv_recomment"
            android:background="@drawable/gamebox_application_recomment_bg"
            android:layout_width="@dimen/dp_40"
            android:layout_height="@dimen/dp_14"
            android:layout_marginStart="@dimen/dp_6"
            android:layout_marginEnd="@dimen/dp_8"
            app:layout_constraintBottom_toBottomOf="@id/tv_app_name"
            app:layout_constraintEnd_toStartOf="@id/tv_download"
            app:layout_constraintTop_toTopOf="@id/tv_app_name" />
  <TextView android:textSize="@dimen/dp_13"
            android:textColor="#ffffff"
            android:gravity="center"
            android:id="@id/tv_download"
            android:background="@drawable/gamebox_application_download_bg"
            android:layout_width="@dimen/dp_48"
            android:layout_height="@dimen/dp_28"
            android:layout_marginTop="@dimen/dp_6_35"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>