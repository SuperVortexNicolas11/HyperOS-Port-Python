<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:paddingTop="@dimen/dp_20"
              android:paddingBottom="@dimen/dp_20"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:importantForAccessibility="no"
              android:paddingStart="@dimen/am_main_item_padding_se"
              android:paddingEnd="@dimen/am_main_item_padding_se" xmlns:android="http://schemas.android.com/apk/res/android">
  <TextView android:textSize="@dimen/am_search_result_title_size"
            android:textColor="@color/app_manager_sort_title_color"
            android:gravity="center"
            android:id="@id/am_search_prompt"
            android:focusableInTouchMode="true"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/am_search_promotion_margin_top"
            android:text="@string/app_manager_search_prompt" />
  <TextView android:textSize="@dimen/am_search_result_title_size"
            android:textColor="@color/app_manager_search_prompt_text_color"
            android:gravity="center"
            android:id="@id/am_show_all_apps"
            android:focusableInTouchMode="true"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/am_search_promotion_margin_bottom"
            android:text="@string/app_manager_open_show_all_apps_immediate"
            android:paddingStart="@dimen/am_line_margin_lr"
            android:paddingEnd="@dimen/am_line_margin_lr" />
</LinearLayout>