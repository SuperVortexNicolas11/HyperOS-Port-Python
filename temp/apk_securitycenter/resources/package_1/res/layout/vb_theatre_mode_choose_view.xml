<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:layout_gravity="end"
              android:orientation="vertical"
              android:id="@id/tv_theatre_mode_chooser"
              android:background="@drawable/shape_new_theatre_switch_bg"
              android:visibility="visible"
              android:layout_width="@dimen/dp_158"
              android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <LinearLayout android:id="@id/tv_theatre_mode_btn1"
                android:background="@drawable/shape_new_theatre_switch_bg"
                android:paddingTop="@dimen/dp_20"
                android:paddingRight="@dimen/dp_20"
                android:paddingBottom="@dimen/dp_20"
                android:layout_width="fill_parent"
                android:layout_height="@dimen/dp_58"
                android:paddingStart="@dimen/dp_20">
    <LinearLayout android:layout_gravity="center_horizontal"
                  android:orientation="horizontal"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content">
      <com.miui.gamebooster.videobox.view.MarqueeTextView android:textSize="@dimen/dp_16"
                            android:textColor="@android:color/white"
                            android:ellipsize="marquee"
                            android:layout_width="@dimen/dp_80"
                            android:layout_height="fill_parent"
                            android:text="@string/vb_movie_mode"
                            android:singleLine="true"
                            android:marqueeRepeatLimit="marquee_forever"
                            android:textAlignment="center"
                            android:layout_marginEnd="@dimen/dp_12" />
      <ImageView android:id="@id/vtb_movie_tick"
                 android:visibility="visible"
                 android:layout_width="@dimen/dp_26"
                 android:layout_height="fill_parent"
                 android:src="@drawable/vtb_theatre_chooser_tick" />
    </LinearLayout>
  </LinearLayout>
  <ImageView android:layout_gravity="bottom|center"
             android:id="@id/mode_chooser_divider"
             android:background="@drawable/vtb_theatre_panel_divider_line"
             android:layout_width="fill_parent"
             android:layout_height="@dimen/view_dimen_6" />
  <LinearLayout android:id="@id/tv_theatre_mode_btn2"
                android:background="@drawable/shape_new_theatre_switch_bg"
                android:paddingTop="@dimen/dp_20"
                android:paddingRight="@dimen/dp_20"
                android:paddingBottom="@dimen/dp_20"
                android:layout_width="fill_parent"
                android:layout_height="@dimen/dp_58"
                android:paddingStart="@dimen/dp_20">
    <LinearLayout android:layout_gravity="center_horizontal"
                  android:orientation="horizontal"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content">
      <com.miui.gamebooster.videobox.view.MarqueeTextView android:textSize="@dimen/dp_16"
                            android:textColor="@android:color/white"
                            android:ellipsize="marquee"
                            android:layout_width="@dimen/dp_82"
                            android:layout_height="fill_parent"
                            android:text="@string/vb_default_mode"
                            android:singleLine="true"
                            android:marqueeRepeatLimit="marquee_forever"
                            android:textAlignment="center"
                            android:layout_marginEnd="@dimen/dp_10" />
      <ImageView android:id="@id/vtb_default_tick"
                 android:visibility="visible"
                 android:layout_width="@dimen/dp_26"
                 android:layout_height="fill_parent"
                 android:src="@drawable/vtb_theatre_chooser_tick" />
    </LinearLayout>
  </LinearLayout>
</LinearLayout>