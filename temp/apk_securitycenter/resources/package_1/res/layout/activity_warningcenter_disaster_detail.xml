<?xml version='1.0' encoding='utf-8' ?>
<androidx.constraintlayout.widget.ConstraintLayout android:layout_width="fill_parent"
                      android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <TextView android:textSize="@dimen/sp_23"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:id="@id/disaster_title"
            android:layout_width="0.0dp"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="@id/gl_end"
            app:layout_constraintStart_toStartOf="@id/gl_start"
            app:layout_constraintTop_toTopOf="parent" />
  <TextView android:textSize="14.0sp"
            android:textColor="@android:color/white"
            android:id="@id/time_line"
            android:layout_width="0.0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4.0dp"
            android:alpha="0.7"
            app:layout_constraintEnd_toStartOf="@id/icon_type"
            app:layout_constraintStart_toStartOf="@id/gl_start"
            app:layout_constraintTop_toBottomOf="@id/disaster_title" />
  <TextView android:textSize="14.0sp"
            android:textColor="@android:color/white"
            android:id="@id/location_line"
            android:layout_width="0.0dp"
            android:layout_height="wrap_content"
            android:alpha="0.7"
            app:layout_constraintEnd_toStartOf="@id/icon_type"
            app:layout_constraintStart_toStartOf="@id/gl_start"
            app:layout_constraintTop_toBottomOf="@id/time_line" />
  <TextView android:textSize="11.0sp"
            android:textColor="@android:color/white"
            android:gravity="center"
            android:id="@id/first_release"
            android:background="@drawable/warning_center_disaster_shape_publish"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="27.5dp"
            android:minWidth="62.0dp"
            android:minHeight="20.0dp"
            android:alpha="0.7"
            app:layout_constraintStart_toStartOf="@id/gl_start"
            app:layout_constraintTop_toBottomOf="@id/location_line" />
  <ImageView android:id="@id/icon_type"
             android:layout_width="@dimen/dp_74"
             android:layout_height="@dimen/dp_74"
             android:layout_marginTop="15.14dp"
             android:src="@drawable/warningcenter_disaster_icon_others"
             android:alpha="0.6"
             android:importantForAccessibility="no"
             app:layout_constraintEnd_toEndOf="@id/gl_end"
             app:layout_constraintTop_toBottomOf="@id/disaster_title" />
  <androidx.constraintlayout.widget.Guideline android:orientation="vertical"
                        android:id="@id/gl_start"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:layout_constraintGuide_begin="@dimen/disaster_detail_page_padding_horizontal" />
  <androidx.constraintlayout.widget.Guideline android:orientation="vertical"
                        android:id="@id/gl_end"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:layout_constraintGuide_end="@dimen/disaster_detail_page_padding_horizontal" />
  <androidx.constraintlayout.widget.Barrier android:id="@id/barrier"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:barrierDirection="bottom"
                        app:constraint_referenced_ids="icon_type,first_release" />
  <LinearLayout android:orientation="vertical"
                android:background="@drawable/warning_center_disaster_detail_bg"
                android:layout_width="fill_parent"
                android:layout_height="0.0dp"
                android:layout_marginTop="30.14dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/barrier">
    <View android:layout_gravity="center"
          android:id="@id/little_bar"
          android:background="@drawable/warning_center_disaster_shape_control"
          android:layout_width="@dimen/view_dimen_120"
          android:layout_height="@dimen/view_dimen_10"
          android:layout_marginTop="@dimen/view_dimen_24" />
    <androidx.core.widget.NestedScrollView android:layout_width="fill_parent"
                          android:layout_height="0.0dp"
                          android:layout_weight="1.0">
      <androidx.constraintlayout.widget.ConstraintLayout android:paddingLeft="@dimen/disaster_detail_page_padding_horizontal"
                            android:paddingRight="@dimen/disaster_detail_page_padding_horizontal"
                            android:layout_width="fill_parent"
                            android:layout_height="fill_parent"
                            android:paddingHorizontal="@dimen/disaster_detail_page_padding_horizontal">
        <androidx.appcompat.widget.AppCompatImageView android:id="@id/maker1"
                              android:layout_width="6.88dp"
                              android:layout_height="6.88dp"
                              android:src="@drawable/warning_center_disaster_detail_marker"
                              android:importantForAccessibility="no"
                              app:layout_constraintBottom_toBottomOf="@id/details_title"
                              app:layout_constraintEnd_toStartOf="@id/details_title"
                              app:layout_constraintStart_toStartOf="parent"
                              app:layout_constraintTop_toTopOf="@id/details_title" />
        <androidx.appcompat.widget.AppCompatTextView android:textSize="18.1sp"
                              android:textStyle="bold"
                              android:textColor="@color/wc_disaster_text_title_black_color"
                              android:id="@id/details_title"
                              android:layout_width="0.0dp"
                              android:layout_height="wrap_content"
                              android:layout_marginTop="32.0dp"
                              android:text="@string/warningcenter_disaster_detail_title"
                              android:layout_marginStart="10.0dp"
                              app:layout_constraintEnd_toEndOf="parent"
                              app:layout_constraintStart_toEndOf="@id/maker1"
                              app:layout_constraintTop_toTopOf="parent" />
        <androidx.appcompat.widget.AppCompatTextView android:textSize="14.0sp"
                              android:textColor="@color/wc_disaster_text_summary_color"
                              android:id="@id/detail"
                              android:layout_width="0.0dp"
                              android:layout_height="wrap_content"
                              android:layout_marginTop="12.0dp"
                              app:layout_constraintEnd_toEndOf="parent"
                              app:layout_constraintStart_toStartOf="parent"
                              app:layout_constraintTop_toBottomOf="@id/details_title" />
        <ImageView android:id="@id/maker2"
                   android:layout_width="6.88dp"
                   android:layout_height="6.88dp"
                   android:src="@drawable/warning_center_disaster_detail_marker"
                   android:importantForAccessibility="no"
                   app:layout_constraintBottom_toBottomOf="@id/guide_title"
                   app:layout_constraintEnd_toStartOf="@id/guide_title"
                   app:layout_constraintStart_toStartOf="parent"
                   app:layout_constraintTop_toTopOf="@id/guide_title" />
        <androidx.appcompat.widget.AppCompatTextView android:textSize="18.1sp"
                              android:textStyle="bold"
                              android:textColor="@color/wc_disaster_text_title_black_color"
                              android:id="@id/guide_title"
                              android:layout_width="0.0dp"
                              android:layout_height="wrap_content"
                              android:layout_marginTop="32.0dp"
                              android:text="@string/warningcenter_disaster_guide_title"
                              android:layout_marginStart="10.0dp"
                              app:layout_constraintEnd_toEndOf="parent"
                              app:layout_constraintStart_toEndOf="@id/maker2"
                              app:layout_constraintTop_toBottomOf="@id/detail" />
        <androidx.appcompat.widget.AppCompatTextView android:textSize="14.0sp"
                              android:textColor="@color/wc_disaster_text_summary_color"
                              android:id="@id/guide"
                              android:layout_width="0.0dp"
                              android:layout_height="wrap_content"
                              android:layout_marginTop="12.0dp"
                              app:layout_constraintEnd_toEndOf="parent"
                              app:layout_constraintStart_toStartOf="parent"
                              app:layout_constraintTop_toBottomOf="@id/guide_title" />
        <ImageView android:id="@id/maker3"
                   android:layout_width="6.88dp"
                   android:layout_height="6.88dp"
                   android:src="@drawable/warning_center_disaster_detail_marker"
                   android:importantForAccessibility="no"
                   app:layout_constraintBottom_toBottomOf="@id/icon_sample_title"
                   app:layout_constraintEnd_toStartOf="@id/icon_sample_title"
                   app:layout_constraintStart_toStartOf="parent"
                   app:layout_constraintTop_toTopOf="@id/icon_sample_title" />
        <androidx.appcompat.widget.AppCompatTextView android:textSize="18.1sp"
                              android:textStyle="bold"
                              android:textColor="@color/wc_disaster_text_title_black_color"
                              android:id="@id/icon_sample_title"
                              android:layout_width="0.0dp"
                              android:layout_height="wrap_content"
                              android:layout_marginTop="32.0dp"
                              android:text="@string/warningcenter_disaster_icon_title"
                              android:layout_marginStart="10.0dp"
                              app:layout_constraintEnd_toEndOf="parent"
                              app:layout_constraintStart_toEndOf="@id/maker3"
                              app:layout_constraintTop_toBottomOf="@id/guide" />
        <ImageView android:id="@id/icon_sample"
                   android:layout_width="70.0dp"
                   android:layout_height="60.0dp"
                   android:layout_marginTop="12.0dp"
                   android:layout_marginBottom="12.0dp"
                   android:importantForAccessibility="no"
                   app:layout_constraintBottom_toBottomOf="parent"
                   app:layout_constraintStart_toStartOf="parent"
                   app:layout_constraintTop_toBottomOf="@id/icon_sample_title" />
      </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
    <TextView android:textSize="11.0sp"
              android:textColor="@color/wc_disaster_text_summary_color"
              android:gravity="center"
              android:layout_gravity="bottom|center"
              android:id="@id/tv_warning_from"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginLeft="@dimen/disaster_detail_page_padding_horizontal"
              android:layout_marginRight="@dimen/disaster_detail_page_padding_horizontal"
              android:layout_marginBottom="29.0dp"
              android:text="@string/warningcenter_disaster_info_from"
              android:layout_marginHorizontal="@dimen/disaster_detail_page_padding_horizontal" />
  </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>