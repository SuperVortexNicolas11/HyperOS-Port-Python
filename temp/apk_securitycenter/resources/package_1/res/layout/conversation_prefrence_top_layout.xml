<?xml version='1.0' encoding='utf-8' ?>
<FrameLayout android:paddingBottom="@dimen/dp_20"
             android:layout_width="fill_parent"
             android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android">
  <LinearLayout android:gravity="center"
                android:layout_gravity="center|top"
                android:orientation="vertical"
                android:id="@id/fl_content"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_21">
    <ImageView android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:layout_marginBottom="@dimen/dp_45"
               android:src="@drawable/icon_conversation_setting_top" />
    <TextView android:textSize="@dimen/dp_13"
              android:textColor="@color/cb_settings_desc_text"
              android:id="@id/tv_desc"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/conversation_settings_top" />
  </LinearLayout>
</FrameLayout>