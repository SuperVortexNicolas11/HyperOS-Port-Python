                      android:layout_marginEnd="@dimen/na_main_horizontal_margin" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <RelativeLayout android:orientation="vertical"
