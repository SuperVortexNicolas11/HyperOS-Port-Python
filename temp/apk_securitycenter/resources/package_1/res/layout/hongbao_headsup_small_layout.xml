<?xml version='1.0' encoding='utf-8' ?>
<RelativeLayout android:layout_width="380.0dp"
                android:layout_height="96.0dp" xmlns:android="http://schemas.android.com/apk/res/android">
  <FrameLayout android:id="@id/content"
               android:layout_width="380.0dp"
               android:layout_height="96.0dp"
               android:layout_centerHorizontal="true">
    <RelativeLayout android:id="@id/container_view"
                    android:background="@drawable/heads_up_hongbao_message_little_bg"
                    android:layout_width="fill_parent"
                    android:layout_height="fill_parent"
                    android:paddingStart="10.0dp"
                    android:paddingEnd="16.0dp">
      <ImageView android:id="@id/icon"
                 android:layout_width="48.0dp"
                 android:layout_height="48.0dp"
                 android:src="@drawable/icon_headsup_luckymoney"
                 android:layout_centerVertical="true"
                 android:layout_marginStart="14.7dp"
                 android:layout_marginEnd="11.7dp"
                 android:layout_alignParentStart="true" />
      <LinearLayout android:orientation="vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_toEndOf="@id/icon">
        <TextView android:textSize="@dimen/heads_up_hongbao_message_size"
                  android:textColor="@android:color/white"
                  android:ellipsize="end"
                  android:id="@id/title"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:singleLine="true" />
        <RelativeLayout android:gravity="center_vertical"
                        android:id="@id/layoutAds"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2.0dp">
          <ImageView android:id="@id/imgAdsLogo"
                     android:layout_width="wrap_content"
                     android:layout_height="wrap_content"
                     android:src="@drawable/heads_up_message_logo1"
                     android:adjustViewBounds="true"
                     android:maxWidth="36.0dp"
                     android:maxHeight="13.0dp"
                     android:layout_centerVertical="true"
                     android:layout_alignParentStart="true" />
          <TextView android:textSize="13.0dp"
                    android:textColor="@color/lock_screen_hongbao_message_color"
                    android:id="@id/txvAdsText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/hongbao_message_slogon"
                    android:layout_marginStart="4.0dp"
                    android:layout_toEndOf="@id/imgAdsLogo" />
        </RelativeLayout>
      </LinearLayout>
      <TextView android:textSize="13.0dp"
                android:textColor="@color/lucky_text_open_color"
                android:gravity="center"
                android:id="@id/ok"
                android:background="@drawable/selector_alarm_headsup_btn"
                android:layout_width="67.0dp"
                android:layout_height="28.0dp"
                android:text="@string/open_right_now_short"
                android:layout_centerVertical="true"
                android:layout_marginEnd="4.0dp"
                android:layout_alignParentEnd="true" />
    </RelativeLayout>
    <LinearLayout android:layout_gravity="center|end|top"
                  android:orientation="horizontal"
                  android:visibility="gone"
                  android:layout_width="0.0dp"
                  android:layout_height="0.0dp">
      <ImageView android:id="@id/settings"
                 android:visibility="gone"
                 android:layout_width="0.0dp"
                 android:layout_height="0.0dp"
                 android:src="@drawable/selector_noti_setting" />
      <ImageView android:id="@id/later"
                 android:visibility="gone"
                 android:layout_width="0.0dp"
                 android:layout_height="0.0dp"
                 android:src="@drawable/bg_hongbao_headsup_later" />
    </LinearLayout>
  </FrameLayout>
</RelativeLayout>