<?xml version='1.0' encoding='utf-8' ?>
<FrameLayout android:layout_width="fill_parent"
             android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android">
  <ImageView android:layout_gravity="center|end|top"
             android:id="@id/btn_close"
             android:padding="@dimen/dp_6"
             android:layout_width="@dimen/dp_42"
             android:layout_height="@dimen/dp_42"
             android:layout_marginTop="@dimen/dp_23"
             android:src="@drawable/ic_gb_wonderful_video_close"
             android:layout_marginEnd="@dimen/dp_21_5" />
  <LinearLayout android:layout_gravity="center_vertical"
                android:orientation="vertical"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
    <ImageView android:layout_gravity="center_horizontal"
               android:id="@id/iv_title"
               android:layout_width="@dimen/dp_138"
               android:layout_height="@dimen/dp_50_47"
               android:layout_marginTop="@dimen/gb_wonderful_moment_page_title_top"
               android:src="@drawable/gamebox_wonderful_title" />
    <HorizontalScrollView android:layout_gravity="center"
                          android:scrollbars="none"
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:layout_marginTop="@dimen/dp_24"
                          android:layout_marginStart="@dimen/dp_8"
                          android:layout_marginEnd="@dimen/dp_8">
      <LinearLayout android:orientation="horizontal"
                    android:id="@id/container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
    </HorizontalScrollView>
    <TextView android:textSize="@dimen/sp_12"
              android:textColor="@color/whitealpha60"
              android:layout_gravity="center_horizontal"
              android:id="@id/gb_game_video_bottom_tips"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginLeft="@dimen/dp_10"
              android:layout_marginTop="@dimen/dp_24"
              android:layout_marginRight="@dimen/dp_10"
              android:layout_marginBottom="@dimen/dp_24"
              android:text="@string/gb_game_video_bottom_tips"
              android:layout_marginHorizontal="@dimen/dp_10" />
    <TextView android:textSize="@dimen/font_size_38"
              android:textColor="@color/whitealpha90"
              android:gravity="center"
              android:layout_gravity="center"
              android:id="@id/goto_wonderful"
              android:background="@drawable/gb_wonderful_video_bg"
              android:paddingLeft="@dimen/dp_15"
              android:paddingRight="@dimen/dp_15"
              android:layout_width="wrap_content"
              android:layout_height="@dimen/dp_40"
              android:minWidth="@dimen/dp_144"
              android:text="@string/gb_wonderful_video_goto_box"
              android:paddingHorizontal="@dimen/dp_15" />
  </LinearLayout>
</FrameLayout>