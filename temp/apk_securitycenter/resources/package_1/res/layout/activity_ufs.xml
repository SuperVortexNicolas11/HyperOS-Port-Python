<?xml version='1.0' encoding='utf-8' ?>
<miuix.core.widget.NestedScrollView android:layout_width="fill_parent"
                      android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android">
  <LinearLayout android:orientation="vertical"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:paddingStart="@dimen/dp_28"
                android:paddingEnd="@dimen/dp_28">
    <TextView android:textSize="@dimen/sp_30"
              android:textColor="@color/storage_list_item_name"
              android:id="@id/number_tv"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content" />
    <TextView android:textSize="@dimen/sp_14"
              android:textColor="@color/storage_list_item_desc"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/storage_ufs_tip" />
    <TextView android:textSize="@dimen/sp_14"
              android:textColor="@color/storage_list_item_desc"
              android:id="@id/msg_tv"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/dp_36"
              android:text="@string/storage_ufs_msg" />
  </LinearLayout>
</miuix.core.widget.NestedScrollView>