<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:layout_gravity="center"
              android:orientation="horizontal"
              android:paddingTop="@dimen/padding_common_notification_l18"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:paddingStart="@dimen/padding_common_notification_l18" xmlns:android="http://schemas.android.com/apk/res/android">
  <RelativeLayout android:layout_gravity="center"
                  android:orientation="vertical"
                  android:layout_width="0.0dp"
                  android:layout_height="wrap_content"
                  android:layout_weight="1.0">
    <ImageView android:id="@id/notification_icon"
               android:layout_width="@dimen/size_icon_common_notification_l18"
               android:layout_height="@dimen/size_icon_common_notification_l18"
               android:src="@drawable/app_icon_securitycenter"
               android:contentDescription="@null" />
    <TextView android:textSize="@dimen/sp_16"
              android:textColor="@color/notification_memory_text"
              android:ellipsize="end"
              android:id="@id/notification_text"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:maxLines="1"
              android:fontFamily="mipro-medium"
              android:textAlignment="viewStart"
              android:layout_marginStart="@dimen/padding_content_common_notification_l18"
              android:layout_toEndOf="@id/notification_icon" />
    <TextView android:textSize="@dimen/sp_15"
              android:textColor="@color/notification_memory_summary"
              android:ellipsize="end"
              android:id="@id/notification_summary"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/padding_top_common_notification_l18"
              android:text="@string/notification_garbage_clean_hint"
              android:maxLines="2"
              android:layout_below="@id/notification_text"
              android:textAlignment="viewStart"
              android:layout_marginStart="@dimen/padding_content_common_notification_l18"
              android:layout_toEndOf="@id/notification_icon" />
  </RelativeLayout>
  <TextView android:textSize="@dimen/sp_13"
            android:textColor="@color/notification_common_action_btn"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@id/notification_button"
            android:background="@drawable/shape_notification_common_button"
            android:paddingTop="@dimen/dp_4"
            android:paddingBottom="@dimen/dp_4"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:clickable="false"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/dp_28"
            android:textAllCaps="true"
            android:fontFamily="mipro-medium"
            android:paddingStart="@dimen/dp_14"
            android:paddingEnd="@dimen/dp_14"
            android:layout_marginStart="@dimen/padding_start_textview_common_notification_l18"
            android:layout_marginEnd="@dimen/padding_start_textview_common_notification_l18" />
  <ImageView android:layout_gravity="center"
             android:id="@id/large_icon"
             android:visibility="gone"
             android:layout_width="@dimen/size_large_icon_common_notification_l18"
             android:layout_height="@dimen/size_large_icon_common_notification_l18"
             android:src="@drawable/app_icon_securitycenter"
             android:layout_marginStart="@dimen/padding_start_textview_common_notification_l18" />
  <LinearLayout android:layout_width="@dimen/dp_8"
                android:layout_height="@dimen/dp_8" />
</LinearLayout>