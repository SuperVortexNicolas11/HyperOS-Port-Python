<?xml version='1.0' encoding='utf-8' ?>
<ScrollView android:id="@id/padding"
            android:scrollbars="none"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="true" xmlns:android="http://schemas.android.com/apk/res/android">
  <LinearLayout android:gravity="center"
                android:orientation="vertical"
                android:paddingLeft="@dimen/miuix_appcompat_dialog_panel_horizontal_padding"
                android:paddingRight="@dimen/miuix_appcompat_dialog_panel_horizontal_padding"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
    <ImageView android:id="@id/image"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:layout_marginTop="@dimen/pc_power_save_image_margin_top_dialog"
               android:src="@drawable/battery_low"
               style="?android:attr/textAppearanceMedium" />
    <TextView android:textStyle="bold"
              android:textColor="@color/battery_low_title_color"
              android:gravity="center_horizontal"
              android:id="@id/title"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/pc_power_save_title_margin_top_dialog"
              style="?android:attr/textAppearanceMedium" />
    <TextView android:textSize="16.0sp"
              android:textColor="@color/battery_low_percent_color"
              android:id="@id/level_percent"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/pc_power_save_summary_margin_top_dialog"
              android:layout_marginBottom="8.0dp" />
  </LinearLayout>
</ScrollView>