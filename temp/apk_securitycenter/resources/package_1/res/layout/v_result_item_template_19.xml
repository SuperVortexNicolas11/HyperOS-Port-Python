<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:paddingTop="@dimen/card_layout_line_height_half"
              android:paddingBottom="@dimen/card_layout_line_height_half"
              android:descendantFocusability="blocksDescendants"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android">
  <LinearLayout android:orientation="vertical"
                android:id="@id/inner_layout"
                android:background="@drawable/shape_result_card_border_whole"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
    <LinearLayout android:orientation="horizontal"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="13.3dp"
                  android:layout_marginStart="13.3dp"
                  android:layout_marginEnd="15.67dp">
      <ImageView android:id="@id/icon"
                 style="@style/ResultItemIconStyle" />
      <LinearLayout android:layout_gravity="center_vertical"
                    android:orientation="vertical"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="13.33dp">
        <TextView android:id="@id/title"
                  style="@style/ResultItemAdTitleStyle" />
        <TextView android:layout_gravity="center_vertical"
                  android:id="@id/summary"
                  android:layout_marginTop="2.67dp"
                  style="@style/ResultItemAdSummaryStyle" />
      </LinearLayout>
    </LinearLayout>
    <FrameLayout android:layout_width="fill_parent"
                 android:layout_height="wrap_content"
                 android:layout_marginTop="10.0dp"
                 android:layout_marginBottom="13.33dp"
                 android:layout_marginStart="13.3dp"
                 android:layout_marginEnd="@dimen/result_item_margin_space">
      <Button android:layout_gravity="center|end"
              android:id="@id/button"
              style="@style/ResultItemSmallButtonStyle" />
    </FrameLayout>
  </LinearLayout>
</LinearLayout>