<?xml version='1.0' encoding='utf-8' ?>
<ScrollView android:layout_width="fill_parent"
            android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <LinearLayout android:orientation="vertical"
                android:paddingLeft="12.0dp"
                android:paddingTop="@dimen/ew_alert_margin_top"
                android:paddingRight="12.0dp"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="12.0dp">
    <TextView android:textSize="@dimen/wc_text_summary_text_size"
              android:textColor="@color/ew_alert_white_color"
              android:layout_gravity="end"
              android:id="@id/warning_close"
              android:background="@drawable/ew_alert_close_bg"
              android:paddingLeft="@dimen/ew_alert_close_padding_left"
              android:paddingTop="@dimen/ew_alert_close_padding_top"
              android:paddingRight="@dimen/ew_alert_close_padding_left"
              android:paddingBottom="@dimen/ew_alert_close_padding_top"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/ew_close"
              android:singleLine="true" />
    <include android:id="@id/alert_card"
             android:layout_width="fill_parent"
             android:layout_height="wrap_content"
             android:layout_marginTop="@dimen/ew_alert_card_margin_top"
             layout="@layout/earthquake_warning_view_alert_card" />
    <include android:id="@id/help_card"
             android:visibility="gone"
             android:layout_width="fill_parent"
             android:layout_height="wrap_content"
             android:layout_marginTop="@dimen/ew_alert_card_margin_top"
             layout="@layout/earthquake_warning_view_help_card" />
    <androidx.constraintlayout.widget.ConstraintLayout android:id="@id/ll_refuge"
                          android:background="@drawable/ew_alert_card_tip_bg"
                          android:paddingLeft="@dimen/ew_alert_card_tip_padding_start"
                          android:paddingTop="@dimen/ew_alert_card_tip_padding_top"
                          android:paddingRight="@dimen/ew_alert_card_tip_padding_start"
                          android:paddingBottom="@dimen/ew_alert_card_tip_padding_top"
                          android:layout_width="fill_parent"
                          android:layout_height="wrap_content"
                          android:layout_marginTop="12.0dp"
                          android:paddingHorizontal="@dimen/ew_alert_card_tip_padding_start"
                          android:paddingVertical="@dimen/ew_alert_card_tip_padding_top">
      <ImageView android:id="@id/alert_icon"
                 android:layout_width="wrap_content"
                 android:layout_height="wrap_content"
                 android:src="@drawable/ew_alert_icon_tip_red"
                 android:importantForAccessibility="no"
                 app:layout_constraintBottom_toBottomOf="parent"
                 app:layout_constraintStart_toStartOf="parent"
                 app:layout_constraintTop_toTopOf="parent" />
      <TextView android:textSize="@dimen/text_font_size_38"
                android:textColor="@color/ew_text_black_color"
                android:id="@id/alert_tips"
                android:layout_width="0.0dp"
                android:layout_height="wrap_content"
                android:text="@string/ew_alert_help_tips"
                android:layout_marginStart="@dimen/ew_alert_card_broadcast_margin_start"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/alert_icon"
                app:layout_constraintTop_toTopOf="parent" />
      <TextView android:textSize="14.0sp"
                android:textColor="#3b9bff"
                android:id="@id/help_place_navi"
                android:layout_width="0.0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12.0dp"
                android:text="@string/ew_alert_help_place_navigation"
                app:layout_constraintEnd_toEndOf="@id/alert_tips"
                app:layout_constraintStart_toStartOf="@id/alert_tips"
                app:layout_constraintTop_toBottomOf="@id/alert_tips" />
    </androidx.constraintlayout.widget.ConstraintLayout>
    <LinearLayout android:orientation="horizontal"
                  android:id="@id/other_card"
                  android:visibility="gone"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="@dimen/ew_alert_card_margin_bottom">
      <LinearLayout android:orientation="vertical"
                    android:id="@id/view_call_phone"
                    android:background="@drawable/ew_alert_card_tip_bg"
                    android:paddingTop="@dimen/ew_alert_card_tip_padding_start"
                    android:paddingBottom="@dimen/ew_alert_card_title_margin_start"
                    android:layout_width="0.0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="@dimen/ew_help_call_contact_height"
                    android:layout_weight="1.0"
                    android:paddingStart="@dimen/ew_alert_card_title_margin_start"
                    android:paddingEnd="@dimen/ew_alert_card_title_margin_start">
        <ImageView android:layout_width="wrap_content"
                   android:layout_height="wrap_content"
                   android:src="@drawable/ew_alert_icon_call"
                   android:importantForAccessibility="no" />
        <TextView android:textSize="@dimen/ew_main_text_title_size"
                  android:textStyle="bold"
                  android:textColor="@color/ew_text_black_color"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="@dimen/ew_help_call_contact_margin_top"
                  android:text="@string/ew_alert_dial_text" />
      </LinearLayout>
      <View android:id="@id/view_other_card_blank"
            android:layout_width="@dimen/ew_alert_card_margin_bottom"
            android:layout_height="@dimen/ew_help_call_contact_height" />
      <LinearLayout android:orientation="vertical"
                    android:id="@id/view_show_emergency"
                    android:background="@drawable/ew_alert_card_tip_bg"
                    android:paddingTop="@dimen/ew_alert_card_tip_padding_start"
                    android:paddingBottom="@dimen/ew_alert_card_title_margin_start"
                    android:layout_width="0.0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="@dimen/ew_help_call_contact_height"
                    android:layout_weight="1.0"
                    android:paddingStart="@dimen/ew_alert_card_title_margin_start"
                    android:paddingEnd="@dimen/ew_alert_card_title_margin_start">
        <ImageView android:layout_width="@dimen/dp_32"
                   android:layout_height="@dimen/dp_32"
                   android:src="@drawable/ew_alert_icon_show_medical"
                   android:importantForAccessibility="no" />
        <TextView android:textSize="@dimen/ew_main_text_title_size"
                  android:textStyle="bold"
                  android:textColor="@color/ew_text_black_color"
                  android:id="@id/tv_show_emergency"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="@dimen/ew_help_call_contact_margin_top"
                  android:text="@string/ew_alert_emergency_text" />
      </LinearLayout>
    </LinearLayout>
    <FrameLayout android:id="@id/card_eqm_entry"
                 android:background="@drawable/ew_alert_card_tip_bg"
                 android:layout_width="fill_parent"
                 android:layout_height="wrap_content"
                 android:layout_marginTop="12.0dp"
                 android:layout_marginBottom="12.0dp"
                 android:alpha="0.9"
                 android:layout_marginVertical="12.0dp">
      <TextView android:textSize="18.0sp"
                android:textStyle="bold"
                android:textColor="@color/ew_text_black_color"
                android:gravity="center_vertical"
                android:background="@drawable/eqm_entry_card_bg"
                android:paddingLeft="24.0dp"
                android:paddingRight="24.0dp"
                android:layout_width="fill_parent"
                android:layout_height="109.0dp"
                android:text="@string/ew_monitor_slogan"
                android:paddingHorizontal="24.0dp" />
    </FrameLayout>
  </LinearLayout>
</ScrollView>