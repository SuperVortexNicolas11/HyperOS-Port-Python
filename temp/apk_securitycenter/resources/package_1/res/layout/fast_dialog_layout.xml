<?xml version='1.0' encoding='utf-8' ?>
<ScrollView android:layout_width="fill_parent"
            android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android">
  <LinearLayout android:orientation="vertical"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:paddingStart="@dimen/miuix_appcompat_dialog_panel_horizontal_padding"
                android:paddingEnd="@dimen/miuix_appcompat_dialog_panel_horizontal_padding">
    <TextView android:textSize="@dimen/text_title_size"
              android:textStyle="bold"
              android:gravity="center"
              android:layout_gravity="center"
              android:id="@id/dialog_title"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:layout_marginBottom="@dimen/dp_10" />
    <TextView android:textSize="@dimen/text_title_size"
              android:layout_gravity="center"
              android:id="@id/dialog_message"
              android:paddingBottom="12.0dp"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content" />
    <TextView android:textSize="@dimen/text_summary_size"
              android:layout_gravity="center"
              android:id="@id/dialog_message_summary"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content" />
  </LinearLayout>
</ScrollView>