<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:paddingTop="@dimen/card_layout_line_height_half"
              android:paddingBottom="@dimen/card_layout_line_height_half"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android">
  <LinearLayout android:orientation="vertical"
                android:id="@id/inner_layout"
                android:background="@drawable/shape_result_card_border_whole"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:paddingStart="10.0dp"
                android:paddingEnd="10.0dp">
    <LinearLayout android:gravity="center_vertical"
                  android:orientation="horizontal"
                  android:paddingTop="10.0dp"
                  android:paddingBottom="10.0dp"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content">
      <LinearLayout android:gravity="center_vertical"
                    android:layout_gravity="center_vertical"
                    android:orientation="vertical"
                    android:layout_width="0.0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="75.0dp"
                    android:layout_weight="1.0">
        <TextView android:textSize="@dimen/result_title_text"
                  android:ellipsize="end"
                  android:id="@id/title"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content"
                  android:maxLines="2" />
        <TextView android:ellipsize="end"
                  android:id="@id/views"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="9.0dp"
                  style="@style/ViewsStyle" />
      </LinearLayout>
      <com.miui.securitycenter.ad.view.AdImageView android:id="@id/icon"
                            android:layout_width="108.0dp"
                            android:layout_height="72.0dp"
                            android:scaleType="centerCrop"
                            android:layout_marginStart="10.0dp" />
    </LinearLayout>
  </LinearLayout>
  <View android:id="@id/divider"
        android:background="#e5e5e5"
        android:layout_width="fill_parent"
        android:layout_height="1.0px" />
</LinearLayout>