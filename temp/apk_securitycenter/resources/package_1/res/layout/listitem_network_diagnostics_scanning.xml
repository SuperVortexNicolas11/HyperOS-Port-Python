<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:gravity="center_vertical"
              android:orientation="horizontal"
              android:background="@null"
              android:paddingTop="17.0dp"
              android:paddingBottom="17.0dp"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:paddingStart="@dimen/am_line_margin_lr"
              android:paddingEnd="@dimen/am_line_margin_lr"
              style="@style/Widget.ListView.Item.SingleLine" xmlns:android="http://schemas.android.com/apk/res/android">
  <TextView android:textAppearance="@style/Miuix.AppCompat.TextAppearance.List.Primary"
            android:textSize="17.4sp"
            android:id="@id/scanning_item_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxWidth="270.0dp"
            android:singleLine="true"
            android:layout_marginEnd="10.0dp" />
  <Space android:layout_width="0.0dp"
         android:layout_height="wrap_content"
         android:layout_weight="1.0" />
  <ProgressBar android:layout_gravity="center"
               android:id="@id/scanning_item_waitting"
               android:layout_width="@dimen/antivirus_scan_status_icon_size"
               android:layout_height="@dimen/antivirus_scan_status_icon_size"
               android:indeterminate="true"
               android:indeterminateDrawable="@drawable/progressbar_loading"
               style="?android:attr/progressBarStyleSmall" />
  <ImageView android:layout_gravity="center"
             android:id="@id/scanning_item_success"
             android:visibility="gone"
             android:layout_width="@dimen/antivirus_scan_status_icon_size"
             android:layout_height="@dimen/antivirus_scan_status_icon_size"
             android:src="@drawable/progress_succeed"
             android:scaleType="centerInside" />
</LinearLayout>