<?xml version='1.0' encoding='utf-8' ?>
<androidx.constraintlayout.widget.ConstraintLayout android:orientation="vertical"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <LinearLayout android:orientation="vertical"
                android:id="@id/layout_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">
    <TextView android:textSize="18.18dp"
              android:textStyle="bold"
              android:textColor="@color/bh_black_daynight"
              android:layout_gravity="center_horizontal"
              android:id="@id/tv_title"
              android:visibility="visible"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginBottom="17.09dp"
              android:text="标题" />
    <TextView android:textSize="17.45dp"
              android:textColor="@color/bh_black_daynight"
              android:gravity="center|start|top"
              android:id="@id/tv_content"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="内容"
              android:lineSpacingExtra="3.0dp"
              android:layout_marginStart="40.0dp"
              android:layout_marginEnd="40.0dp" />
  </LinearLayout>
  <androidx.constraintlayout.widget.Barrier android:id="@id/barrier"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:barrierDirection="bottom"
                        app:constraint_referenced_ids="layout_title" />
  <TextView android:textSize="17.45dp"
            android:textStyle="bold"
            android:textColor="@color/bh_black_80_daynight"
            android:gravity="center"
            android:id="@id/view_cancel"
            android:background="@drawable/bh_selector_dark_gray_round_25"
            android:paddingTop="13.82dp"
            android:paddingBottom="13.82dp"
            android:layout_width="0.0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="32.73dp"
            android:minHeight="50.91dp"
            android:text="@string/cancel"
            android:paddingStart="5.0dp"
            android:paddingEnd="5.0dp"
            android:layout_marginStart="29.09dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/view_confirm"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintHorizontal_weight="1.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/barrier" />
  <TextView android:textSize="17.45dp"
            android:textStyle="bold"
            android:textColor="@color/bh_color_main_text_white"
            android:gravity="center"
            android:id="@id/view_confirm"
            android:background="@drawable/bh_selector_dark_disable_round_25"
            android:paddingTop="13.82dp"
            android:paddingBottom="13.82dp"
            android:layout_width="0.0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="32.73dp"
            android:minHeight="50.91dp"
            android:text="@string/ok"
            android:paddingStart="5.0dp"
            android:paddingEnd="5.0dp"
            android:layout_marginStart="14.55dp"
            android:layout_marginEnd="29.09dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintHorizontal_weight="1.0"
            app:layout_constraintStart_toEndOf="@id/view_cancel"
            app:layout_constraintTop_toBottomOf="@id/barrier" />
</androidx.constraintlayout.widget.ConstraintLayout>