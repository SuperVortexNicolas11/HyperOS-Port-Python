<?xml version='1.0' encoding='utf-8' ?>
<RelativeLayout android:paddingTop="@dimen/card_layout_line_height_half"
                android:paddingBottom="@dimen/card_layout_line_height_half"
                android:descendantFocusability="blocksDescendants"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android">
  <LinearLayout android:orientation="vertical"
                android:id="@id/inner_layout"
                android:background="@drawable/shape_result_card_border_whole"
                android:paddingTop="@dimen/dp_18"
                android:paddingBottom="@dimen/dp_18"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:paddingStart="@dimen/dp_16"
                android:paddingEnd="@dimen/dp_16">
    <LinearLayout android:orientation="horizontal"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content">
      <ImageView android:id="@id/img"
                 style="@style/NewResultItemIconStyle" />
      <LinearLayout android:layout_gravity="center_vertical"
                    android:orientation="vertical"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/view_dimen_16">
        <TextView android:id="@id/title"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content"
                  style="@style/CardTitleTextViewStyle" />
        <TextView android:layout_gravity="center_vertical"
                  android:id="@id/summary"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content"
                  style="@style/CardSummaryTextViewStyle" />
      </LinearLayout>
    </LinearLayout>
    <FrameLayout android:layout_width="fill_parent"
                 android:layout_height="wrap_content"
                 android:layout_marginTop="@dimen/dp_14">
      <Button android:layout_gravity="end"
              android:id="@id/button"
              style="@style/ResultBlueButtonStyle" />
    </FrameLayout>
  </LinearLayout>
  <FrameLayout android:paddingTop="@dimen/adv_close_padding_top"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:paddingEnd="@dimen/adv_close_padding_end"
               android:layout_alignParentEnd="true">
    <include layout="@layout/adv_close_layout" />
  </FrameLayout>
</RelativeLayout>