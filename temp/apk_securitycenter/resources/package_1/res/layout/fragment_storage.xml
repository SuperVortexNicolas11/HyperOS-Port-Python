<?xml version='1.0' encoding='utf-8' ?>
<FrameLayout android:background="@color/storage_activity_main_bg"
             android:paddingTop="@dimen/storage_action_bar_pt"
             android:layout_width="fill_parent"
             android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <miuix.springback.view.SpringBackLayout android:id="@id/sbl"
                        android:layout_width="fill_parent"
                        android:layout_height="fill_parent"
                        app:scrollableView="@id/scroll">
    <com.miui.optimizecenter.storage.view.StorageScrollView android:id="@id/scroll"
                          android:scrollbars="none"
                          android:layout_width="fill_parent"
                          android:layout_height="fill_parent"
                          android:fillViewport="true"
                          android:overScrollMode="always">
      <LinearLayout android:orientation="vertical"
                    android:id="@id/main_container"
                    android:layout_width="fill_parent"
                    android:layout_height="fill_parent">
        <TextView android:textSize="@dimen/sp_14"
                  android:textColor="@color/storage_actionbar_summary1"
                  android:gravity="start"
                  android:id="@id/storage_size"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="@dimen/dp_8"
                  android:layout_marginBottom="@dimen/dp_30"
                  android:layout_marginStart="@dimen/device_common_margin_start"
                  android:layout_marginEnd="@dimen/device_common_margin_start" />
        <include layout="@layout/storage_main_ui" />
        <com.miui.optimizecenter.storage.view.PreferenceListView android:orientation="vertical"
                              android:id="@id/external_panel"
                              android:layout_width="fill_parent"
                              android:layout_height="wrap_content" />
        <androidx.constraintlayout.widget.ConstraintLayout android:id="@id/button_layout"
                              android:paddingTop="@dimen/storage_clean_btn_margin_top"
                              android:paddingBottom="@dimen/view_dimen_80"
                              android:layout_width="fill_parent"
                              android:layout_height="wrap_content">
          <Button android:textSize="@dimen/sp_17"
                  android:textColor="@color/clean_btn_text_color"
                  android:layout_gravity="center_horizontal"
                  android:id="@id/cleanup_btn"
                  android:layout_width="0.0dp"
                  android:layout_height="wrap_content"
                  android:layout_marginStart="@dimen/dp_12"
                  android:layout_marginEnd="@dimen/dp_12"
                  app:layout_constraintEnd_toEndOf="parent"
                  app:layout_constraintStart_toStartOf="parent"
                  app:layout_constraintTop_toTopOf="parent"
                  app:layout_constraintWidth_max="@dimen/dp_336"
                  style="@style/StorageButtonStyle" />
        </androidx.constraintlayout.widget.ConstraintLayout>
        <include layout="@layout/storage_main_item1" />
      </LinearLayout>
    </com.miui.optimizecenter.storage.view.StorageScrollView>
  </miuix.springback.view.SpringBackLayout>
</FrameLayout>