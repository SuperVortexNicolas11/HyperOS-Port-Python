<?xml version='1.0' encoding='utf-8' ?>
<androidx.constraintlayout.widget.ConstraintLayout android:layout_gravity="center"
                      android:orientation="vertical"
                      android:id="@id/ad_root"
                      android:background="@drawable/shape_vtb_item_ad_bg"
                      android:layout_width="fill_parent"
                      android:layout_height="@dimen/vb_main_item_ad_h" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <ImageView android:id="@id/img_icon"
             android:layout_width="@dimen/view_dimen_36"
             android:layout_height="@dimen/view_dimen_36"
             android:layout_marginTop="@dimen/dp_px_21"
             android:contentDescription="@null"
             android:layout_marginStart="@dimen/dp_px_24"
             app:layout_constraintStart_toStartOf="parent"
             app:layout_constraintTop_toTopOf="parent" />
  <TextView android:textSize="@dimen/dp_px_36"
            android:textStyle="bold"
            android:textColor="@color/vtb_main_ad_item_title1"
            android:ellipsize="end"
            android:id="@id/tv_title"
            android:layout_width="0.0dp"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:layout_marginStart="@dimen/dp_px_14"
            app:layout_constrainedWidth="true"
            app:layout_constraintBottom_toBottomOf="@id/img_icon"
            app:layout_constraintEnd_toStartOf="@id/tv_ad_x"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toEndOf="@id/img_icon"
            app:layout_constraintTop_toTopOf="@id/img_icon"
            app:layout_constraintWidth_default="wrap" />
  <TextView android:id="@id/tv_ad_x"
            android:layout_marginStart="@dimen/dp_px_16"
            android:layout_marginEnd="@dimen/dp_px_21"
            app:layout_constraintBottom_toBottomOf="@id/img_icon"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/tv_title"
            app:layout_constraintTop_toTopOf="@id/img_icon"
            style="@style/ActiveAdXTextView" />
  <TextView android:textSize="@dimen/dp_px_34"
            android:textColor="@color/vtb_main_ad_item_title1"
            android:ellipsize="end"
            android:id="@id/tv_summary"
            android:layout_width="0.0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/vb_main_item_ad_summary_mt"
            android:layout_marginBottom="@dimen/view_dimen_25"
            android:maxLines="1"
            android:layout_marginStart="@dimen/dp_px_24"
            app:layout_constrainedWidth="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/img_arrow"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintWidth_default="wrap" />
  <ImageView android:id="@id/img_arrow"
             android:layout_width="@dimen/dp_px_15_16"
             android:layout_height="@dimen/dp_px_27"
             android:src="@drawable/ic_vtb_ad_template_right_arrow"
             android:contentDescription="@null"
             android:layout_marginStart="@dimen/dp_px_11"
             android:layout_marginEnd="@dimen/dp_px_21"
             app:layout_constraintBottom_toBottomOf="@id/tv_summary"
             app:layout_constraintEnd_toEndOf="parent"
             app:layout_constraintStart_toEndOf="@id/tv_summary"
             app:layout_constraintTop_toTopOf="@id/tv_summary" />
</androidx.constraintlayout.widget.ConstraintLayout>