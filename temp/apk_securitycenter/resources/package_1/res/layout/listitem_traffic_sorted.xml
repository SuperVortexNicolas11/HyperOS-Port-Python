<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:gravity="center_vertical"
              android:orientation="horizontal"
              android:paddingLeft="@dimen/na_main_horizontal_padding"
              android:paddingTop="14.0dp"
              android:paddingRight="@dimen/na_main_horizontal_padding"
              android:paddingBottom="14.0dp"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:layout_marginLeft="@dimen/na_main_horizontal_margin"
              android:layout_marginRight="@dimen/na_main_horizontal_margin"
              android:layout_marginHorizontal="@dimen/na_main_horizontal_margin"
              android:paddingHorizontal="@dimen/na_main_horizontal_padding"
              android:paddingVertical="14.0dp" xmlns:android="http://schemas.android.com/apk/res/android">
  <ImageView android:id="@id/imageview_icon"
             android:layout_width="@dimen/na_traffic_item_icon_width"
             android:layout_height="@dimen/na_traffic_item_icon_width"
             android:scaleType="fitXY" />
  <RelativeLayout android:orientation="vertical"
                  android:layout_width="0.0dp"
                  android:layout_height="wrap_content"
                  android:layout_weight="1.0"
                  android:layout_marginStart="@dimen/na_traffic_item_appname_margin_left">
    <LinearLayout android:id="@id/text_container"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content">
      <TextView android:textAppearance="@style/Miuix.AppCompat.TextAppearance.List.Primary"
                android:textSize="17.0sp"
                android:textStyle="normal"
                android:layout_gravity="center_vertical"
                android:id="@id/textview_appname"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1.0"
                android:fontFamily="sans-serif-medium"
                android:textAlignment="viewStart" />
      <TextView android:textAppearance="@style/Miuix.AppCompat.TextAppearance.List.Secondary"
                android:gravity="center_vertical"
                android:id="@id/text_traffic_values"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
    </LinearLayout>
    <miuix.androidbasewidget.widget.ProgressBar android:id="@id/progress_bar_traffic"
                          android:visibility="gone"
                          android:layout_width="fill_parent"
                          android:layout_height="@dimen/na_traffic_progress_height"
                          android:layout_marginTop="6.0dp"
                          android:max="100"
                          android:progress="0"
                          android:progressDrawable="@drawable/na_traffic_mobile_progress"
                          android:layout_below="@id/text_container"
                          android:layout_alignParentEnd="true"
                          style="?attr/progressBarHorizontalStyle" />
    <TextView android:textAppearance="@style/Miuix.AppCompat.TextAppearance.List.Secondary"
              android:id="@id/text_traffic_none"
              android:visibility="gone"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginTop="4.0dp"
              android:text="@string/traffic_none"
              android:layout_below="@id/text_container" />
  </RelativeLayout>
  <ImageView android:id="@id/image_netoff"
             android:background="@drawable/net_off"
             android:visibility="gone"
             android:layout_width="wrap_content"
             android:layout_height="wrap_content"
             android:layout_marginStart="4.0dp" />
</LinearLayout>