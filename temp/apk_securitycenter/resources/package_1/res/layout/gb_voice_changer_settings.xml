<?xml version='1.0' encoding='utf-8' ?>
<merge android:layout_width="fill_parent"
       android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <TextView android:textSize="@dimen/game_toolbox_voice_changer_title_text_size"
            android:textColor="@color/whitealpha90"
            android:gravity="center"
            android:layout_gravity="center_vertical"
            android:id="@id/title"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/view_dimen_50"
            android:text="@string/gb_voice_changer_recommend"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
  <ImageView android:id="@id/btn_back"
             android:layout_width="wrap_content"
             android:layout_height="wrap_content"
             android:src="@drawable/ic_gamebox_change_voice_back"
             android:contentDescription="@string/game_toolbox_btn_back_talkback"
             android:layout_marginStart="@dimen/view_dimen_50"
             app:layout_constraintBottom_toBottomOf="@id/title"
             app:layout_constraintStart_toStartOf="parent"
             app:layout_constraintTop_toTopOf="@id/title" />
  <TextView android:textSize="@dimen/game_toolbox_voice_changer_title_text_size"
            android:textColor="@color/gb_voice_changer_setting_title_text_color"
            android:id="@id/tv_account_title"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/view_dimen_62"
            android:text="@string/gb_voice_changer_setting_account_title"
            android:layout_marginStart="@dimen/view_dimen_60"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/title" />
  <TextView android:textSize="@dimen/gb_voice_changer_subtitle_textsize"
            android:textColor="@color/gb_voice_changer_setting_subtitle_text_color"
            android:id="@id/tv_account"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/view_dimen_8"
            android:text="@string/gb_voice_changer_setting_account_title"
            app:layout_constraintStart_toStartOf="@id/tv_account_title"
            app:layout_constraintTop_toBottomOf="@id/tv_account_title" />
  <TextView android:textSize="@dimen/dp_11"
            android:textColor="@color/gb_voice_changer_setting_subtitle_text_color"
            android:id="@id/tv_vip"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/gb_voice_changer_setting_become_vip"
            android:drawablePadding="@dimen/gb_voice_changer_arrow_padding"
            android:drawableEnd="@drawable/gb_voice_changer_arrow"
            android:layout_marginEnd="@dimen/view_dimen_60"
            app:layout_constraintBottom_toBottomOf="@id/tv_account"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tv_account_title" />
  <TextView android:textSize="@dimen/game_toolbox_voice_changer_title_text_size"
            android:textColor="@color/gb_voice_changer_setting_title_text_color"
            android:id="@id/tv_gender_title"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/view_dimen_64"
            android:text="@string/gb_voice_changer_setting_gender_title"
            android:layout_marginStart="@dimen/view_dimen_60"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_account" />
  <TextView android:textSize="@dimen/gb_voice_changer_subtitle_textsize"
            android:textColor="@color/gb_voice_changer_setting_subtitle_text_color"
            android:id="@id/tv_gender_tip"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:layout_width="0.0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/view_dimen_8"
            android:text="@string/gb_voice_changer_setting_gender_subtitle"
            app:layout_constraintEnd_toStartOf="@id/spinner_gender"
            app:layout_constraintHorizontal_chainStyle="spread_inside"
            app:layout_constraintStart_toStartOf="@id/tv_gender_title"
            app:layout_constraintTop_toBottomOf="@id/tv_gender_title" />
  <miuix.appcompat.widget.Spinner android:theme="@style/voice_change_spinner"
                        android:textSize="@dimen/dp_11"
                        android:textColor="@color/gb_voice_changer_setting_subtitle_text_color"
                        android:entries="@array/gb_voice_change_gender"
                        android:id="@id/spinner_gender"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:spinnerMode="dropdown"
                        android:layout_marginEnd="@dimen/view_dimen_60"
                        app:layout_constraintBottom_toBottomOf="@id/tv_gender_tip"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/tv_gender_tip"
                        app:layout_constraintTop_toTopOf="@id/tv_gender_title" />
  <TextView android:textSize="@dimen/game_toolbox_voice_changer_title_text_size"
            android:textColor="@color/gb_voice_changer_setting_title_text_color"
            android:id="@id/tv_voice_title"
            android:layout_width="0.0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/view_dimen_64"
            android:text="@string/gb_voice_changer_setting_realtime_title"
            android:layout_marginStart="@dimen/view_dimen_60"
            android:layout_marginEnd="@dimen/view_dimen_60"
            app:layout_constraintEnd_toStartOf="@id/voice_toggle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_gender_tip" />
  <TextView android:textSize="@dimen/gb_voice_changer_subtitle_textsize"
            android:textColor="@color/gb_voice_changer_setting_subtitle_text_color"
            android:id="@id/tv_voice_tip"
            android:layout_width="0.0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/view_dimen_8"
            android:text="@string/gb_voice_changer_setting_realtime_subtitle"
            android:layout_marginEnd="@dimen/view_dimen_60"
            app:layout_constraintEnd_toStartOf="@id/voice_toggle"
            app:layout_constraintStart_toStartOf="@id/tv_voice_title"
            app:layout_constraintTop_toBottomOf="@id/tv_voice_title" />
  <com.miui.gamebooster.widget.SwitchButton android:id="@id/voice_toggle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_alignParentEnd="true"
                        app:layout_constraintBottom_toBottomOf="@id/tv_voice_tip"
                        app:layout_constraintEnd_toEndOf="@id/spinner_gender"
                        app:layout_constraintTop_toTopOf="@id/tv_voice_title" />
  <androidx.constraintlayout.widget.Group android:id="@id/voiceGroup"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:constraint_referenced_ids="tv_voice_tip,tv_voice_title,voice_toggle" />
  <TextView android:textSize="@dimen/gb_voice_changer_textsize"
            android:textColor="@color/gb_voice_changer_setting_rigths_text_color"
            android:id="@id/tv_rights"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/view_dimen_64"
            android:text="@string/gb_voice_changer_setting_rights"
            android:layout_marginStart="@dimen/view_dimen_60"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_voice_tip" />
</merge>