<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:id="@id/dialog_layout"
              android:layout_width="fill_parent"
              android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android">
  <TextView android:textSize="@dimen/sp_18"
            android:textColor="@color/fod_authentication_dialog_title"
            android:layout_gravity="center_horizontal"
            android:id="@id/confirm_fingerprint_view_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="110.0dp"
            android:text="@string/fingerprint_identify_msg"
            android:fontFamily="mipro-medium" />
  <TextView android:textSize="@dimen/sp_15"
            android:textColor="@color/lock_fod_fingerprint_subtitle"
            android:layout_gravity="center_horizontal"
            android:id="@id/confirm_fingerprint_view_msg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6.55dp"
            android:text="@string/confirm_fingerprint_msg"
            android:fontFamily="mipro-regular"
            style="?android:attr/textAppearanceMedium" />
  <Space android:layout_width="fill_parent"
         android:layout_height="fill_parent"
         android:layout_weight="1.0" />
  <LinearLayout android:gravity="center"
                android:layout_gravity="end"
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/view_dimen_160"
                android:layout_marginEnd="15.0dp">
    <TextView android:textSize="@dimen/sp_15"
              android:textColor="@color/lock_fod_fingerprint_subtitle"
              android:id="@id/cancel_finger_authenticate"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/fod_authentication_shift_button" />
    <ImageView android:id="@id/iv_arrow"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:src="@drawable/arrow_right_light"
               android:layout_marginStart="5.0dp" />
  </LinearLayout>
</LinearLayout>