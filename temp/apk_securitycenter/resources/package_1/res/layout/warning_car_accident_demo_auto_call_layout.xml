<?xml version='1.0' encoding='utf-8' ?>
<androidx.constraintlayout.widget.ConstraintLayout android:layout_width="fill_parent"
                      android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <include android:id="@id/top_layout"
           android:layout_width="fill_parent"
           android:layout_height="wrap_content"
           layout="@layout/warning_car_accident_demo_call_top_layout" />
  <TextView android:textSize="@dimen/dp_14"
            android:textStyle="bold"
            android:textColor="@color/car_accident_demo_slide_text_color"
            android:gravity="center"
            android:id="@id/autonomous"
            android:background="@drawable/warning_car_accident_demo_call_self_background"
            android:layout_width="@dimen/dp_192"
            android:layout_height="@dimen/dp_40"
            android:layout_marginBottom="@dimen/dp_131"
            android:text="@string/warning_car_accident_demo_call_self"
            android:fontFamily="sans-serif-medium"
            app:layout_constraintBottom_toTopOf="@id/autonomous_hang_up"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />
  <ImageView android:id="@id/autonomous_hang_up"
             android:layout_width="wrap_content"
             android:layout_height="wrap_content"
             android:layout_marginBottom="@dimen/dp_55"
             android:src="@drawable/warning_car_accident_demo_hangup"
             android:contentDescription="@string/warning_car_accident_demo_hang_up"
             app:layout_constraintBottom_toBottomOf="parent"
             app:layout_constraintEnd_toEndOf="parent"
             app:layout_constraintStart_toStartOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>