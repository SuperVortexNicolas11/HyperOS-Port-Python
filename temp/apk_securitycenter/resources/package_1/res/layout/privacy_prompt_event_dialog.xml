<?xml version='1.0' encoding='utf-8' ?>
<ScrollView android:layout_width="fill_parent"
            android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android">
  <LinearLayout android:orientation="vertical"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:paddingStart="@dimen/privacy_prompt_event_dialog_padding"
                android:paddingEnd="@dimen/privacy_prompt_event_dialog_padding">
    <ImageView android:layout_gravity="center_horizontal"
               android:id="@id/permission_group_icon"
               android:layout_width="@dimen/permission_group_icon_size"
               android:layout_height="@dimen/permission_group_icon_size" />
    <TextView android:textSize="@dimen/permission_group_title_text_size"
              android:textColor="@color/color_permission_group_title"
              android:gravity="center_horizontal"
              android:layout_gravity="center_horizontal"
              android:id="@id/permission_group_title"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/permission_group_title_margin_top"
              android:fontFamily="miui-bold" />
    <TextView android:textSize="@dimen/permission_tips_text_size"
              android:textColor="@color/color_permission_tips"
              android:id="@id/permission_tips"
              android:scrollbars="vertical"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/permission_tips_margin_top"
              android:layout_marginBottom="@dimen/permission_tips_margin_bottom"
              android:maxHeight="@dimen/permission_tips_max_height" />
  </LinearLayout>
</ScrollView>