<?xml version='1.0' encoding='utf-8' ?>
<androidx.constraintlayout.widget.ConstraintLayout android:background="@android:color/transparent"
                      android:layout_width="fill_parent"
                      android:layout_height="@dimen/dp_53" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <TextView android:textSize="@dimen/dp_14"
            android:textStyle="bold"
            android:textColor="@color/whitealpha90"
            android:ellipsize="end"
            android:gravity="start"
            android:id="@id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_18_50"
            android:text="@string/conversation_title"
            android:maxLines="1"
            android:maxEms="9"
            android:textAlignment="viewStart"
            android:layout_marginStart="@dimen/dp_18"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
  <ImageView android:id="@id/tv_setting"
             android:layout_width="@dimen/dp_30"
             android:layout_height="@dimen/dp_30"
             android:src="@drawable/vtb_icon_main_settings"
             android:scaleType="center"
             android:contentDescription="@null"
             android:layout_marginEnd="@dimen/dp_15"
             app:layout_constraintBottom_toBottomOf="@id/tv_title"
             app:layout_constraintEnd_toEndOf="parent"
             app:layout_constraintTop_toTopOf="@id/tv_title" />
</androidx.constraintlayout.widget.ConstraintLayout>