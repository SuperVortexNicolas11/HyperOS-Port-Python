<?xml version='1.0' encoding='utf-8' ?>
<androidx.constraintlayout.widget.ConstraintLayout android:layout_width="fill_parent"
                      android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <ImageView android:id="@id/device"
             android:layout_width="@dimen/dp_78"
             android:layout_height="@dimen/dp_78"
             app:layout_constraintEnd_toEndOf="parent"
             app:layout_constraintStart_toStartOf="parent"
             app:layout_constraintTop_toTopOf="parent" />
  <TextView android:textSize="@dimen/sp_24"
            android:textStyle="bold"
            android:textColor="#fffa311b"
            android:ellipsize="end"
            android:gravity="center"
            android:id="@id/message_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_18"
            android:maxLines="2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/device"
            app:layout_constraintWidth_max="@dimen/dp_304" />
  <TextView android:textSize="@dimen/sp_17"
            android:textColor="@android:color/white"
            android:id="@id/home_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_27"
            android:text="@string/warningcenter_alert_home"
            android:alpha="0.5"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/message_title" />
  <TextView android:textSize="@dimen/sp_17"
            android:textColor="@android:color/white"
            android:ellipsize="end"
            android:gravity="center"
            android:id="@id/home_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:maxEms="6"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="1.0"
            app:layout_constraintStart_toStartOf="@id/home_title"
            app:layout_constraintTop_toTopOf="@id/home_title"
            app:layout_constraintWidth_max="@dimen/dp_100" />
  <TextView android:textSize="@dimen/sp_17"
            android:textColor="@android:color/white"
            android:id="@id/room_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_24"
            android:text="@string/warningcenter_alert_room"
            android:alpha="0.5"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/home_title" />
  <TextView android:textSize="@dimen/sp_17"
            android:textColor="@android:color/white"
            android:ellipsize="end"
            android:gravity="center"
            android:id="@id/room_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:maxEms="6"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="1.0"
            app:layout_constraintStart_toStartOf="@id/room_title"
            app:layout_constraintTop_toTopOf="@id/room_title"
            app:layout_constraintWidth_max="@dimen/dp_82" />
  <TextView android:textSize="@dimen/sp_17"
            android:textColor="@android:color/white"
            android:id="@id/time_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_24"
            android:text="@string/warningcenter_alert_time"
            android:alpha="0.5"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/room_title" />
  <TextView android:textSize="@dimen/sp_17"
            android:textColor="@android:color/white"
            android:id="@id/time_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="1.0"
            app:layout_constraintStart_toStartOf="@id/time_title"
            app:layout_constraintTop_toTopOf="@id/time_title" />
</androidx.constraintlayout.widget.ConstraintLayout>