<?xml version='1.0' encoding='utf-8' ?>
<RelativeLayout android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:paddingStart="@dimen/am_line_margin_lr"
                android:paddingEnd="@dimen/am_line_margin_lr"
                style="@style/Widget.DropdownSelector.Spinner" xmlns:android="http://schemas.android.com/apk/res/android">
  <TextView android:id="@id/textview_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            style="@style/Miuix.AppCompat.TextAppearance.List.GroupHeader" />
  <TextView android:id="@id/textview_traffic_purchase"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/lock_screen_traffic_purchase_textview"
            android:layout_centerVertical="true"
            android:drawableEnd="@drawable/right_arrow_black"
            android:layout_alignParentEnd="true"
            style="@style/Miuix.AppCompat.TextAppearance.List.Secondary" />
</RelativeLayout>