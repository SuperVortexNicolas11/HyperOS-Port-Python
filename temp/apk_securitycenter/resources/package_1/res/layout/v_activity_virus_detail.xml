<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:id="@id/root"
              android:layout_width="fill_parent"
              android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <miuix.springback.view.SpringBackLayout android:id="@id/content"
                        android:layout_width="fill_parent"
                        android:layout_height="0.0dp"
                        android:layout_weight="1.0"
                        app:scrollableView="@id/scroll_view">
    <miuix.core.widget.NestedScrollView android:id="@id/scroll_view"
                          android:layout_width="fill_parent"
                          android:layout_height="fill_parent">
      <LinearLayout android:orientation="vertical"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">
        <ImageView android:layout_gravity="center"
                   android:id="@id/icon"
                   android:layout_width="@dimen/view_dimen_196"
                   android:layout_height="@dimen/view_dimen_196"
                   android:layout_marginTop="@dimen/view_dimen_80" />
        <TextView android:textSize="@dimen/text_font_size_50"
                  android:textColor="@color/v_title_color"
                  android:layout_gravity="center"
                  android:id="@id/name"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="@dimen/view_dimen_10"
                  android:fontFamily="mipro-medium" />
        <TextView android:textSize="@dimen/text_font_size_42"
                  android:textColor="#ff5500"
                  android:layout_gravity="center"
                  android:id="@id/type"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="@dimen/view_dimen_32" />
        <com.google.android.flexbox.FlexboxLayout android:layout_gravity="center"
                              android:orientation="horizontal"
                              android:layout_width="wrap_content"
                              android:layout_height="wrap_content"
                              android:layout_marginTop="@dimen/view_dimen_10"
                              app:alignContent="flex_start"
                              app:alignItems="flex_start"
                              app:flexWrap="wrap">
          <TextView android:textSize="@dimen/text_font_size_42"
                    android:textColor="@color/v_scan_support_text_color"
                    android:layout_gravity="center"
                    android:id="@id/version"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
          <TextView android:textSize="@dimen/text_font_size_42"
                    android:textColor="@color/v_scan_support_text_color"
                    android:layout_gravity="center"
                    android:focusableInTouchMode="false"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/virus_detail_split_line_text"
                    android:importantForAccessibility="no"
                    android:layout_marginStart="@dimen/view_dimen_8"
                    android:layout_marginEnd="@dimen/view_dimen_8" />
          <TextView android:textSize="@dimen/text_font_size_42"
                    android:textColor="@color/v_scan_support_text_color"
                    android:layout_gravity="center"
                    android:id="@id/size"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
          <TextView android:textSize="@dimen/text_font_size_42"
                    android:textColor="@color/v_scan_support_text_color"
                    android:layout_gravity="center"
                    android:focusableInTouchMode="false"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/virus_detail_split_line_text"
                    android:importantForAccessibility="no"
                    android:layout_marginStart="@dimen/view_dimen_8"
                    android:layout_marginEnd="@dimen/view_dimen_8" />
          <TextView android:textSize="@dimen/text_font_size_42"
                    android:textColor="@color/v_scan_support_text_color"
                    android:layout_gravity="center"
                    android:id="@id/file"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
        </com.google.android.flexbox.FlexboxLayout>
        <LinearLayout android:orientation="vertical"
                      android:paddingTop="@dimen/view_dimen_45"
                      android:paddingBottom="@dimen/view_dimen_45"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content"
                      android:layout_marginTop="@dimen/view_dimen_140"
                      android:paddingStart="@dimen/view_dimen_80"
                      android:paddingEnd="@dimen/view_dimen_80">
          <TextView android:textSize="@dimen/text_font_size_50"
                    android:textColor="@color/v_title_color"
                    android:id="@id/virus_type_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="mipro-medium" />
          <TextView android:textSize="@dimen/text_font_size_38"
                    android:textColor="#ff5500"
                    android:id="@id/virus_type_content"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/view_dimen_4" />
        </LinearLayout>
        <LinearLayout android:orientation="vertical"
                      android:paddingTop="@dimen/view_dimen_45"
                      android:paddingBottom="@dimen/view_dimen_45"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content"
                      android:paddingStart="@dimen/view_dimen_80"
                      android:paddingEnd="@dimen/view_dimen_80">
          <TextView android:textSize="@dimen/text_font_size_50"
                    android:textColor="@color/v_title_color"
                    android:id="@id/virus_info_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="mipro-medium" />
          <TextView android:textSize="@dimen/text_font_size_38"
                    android:textColor="@color/v_scan_support_text_color"
                    android:id="@id/virus_info_content"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/view_dimen_4" />
        </LinearLayout>
        <LinearLayout android:orientation="vertical"
                      android:id="@id/virus_news_container"
                      android:background="@color/v_list_header_background_tint"
                      android:paddingTop="@dimen/view_dimen_45"
                      android:paddingBottom="@dimen/view_dimen_45"
                      android:visibility="gone"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content"
                      android:paddingStart="@dimen/view_dimen_80"
                      android:paddingEnd="@dimen/view_dimen_80">
          <TextView android:textSize="@dimen/text_font_size_50"
                    android:textColor="@color/v_title_color"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/virus_news_title"
                    android:fontFamily="mipro-medium" />
          <TextView android:textSize="@dimen/text_font_size_38"
                    android:textColor="@color/v_scan_support_text_color"
                    android:id="@id/virus_news_content"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/view_dimen_4" />
        </LinearLayout>
      </LinearLayout>
    </miuix.core.widget.NestedScrollView>
  </miuix.springback.view.SpringBackLayout>
  <TextView android:textSize="@dimen/text_font_size_36"
            android:textColor="@color/v_scan_support_text_color"
            android:layout_gravity="center"
            android:id="@id/sign"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
  <LinearLayout android:orientation="horizontal"
                android:id="@id/bottom_container"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="28.0dp"
                android:layout_marginTop="12.0dp"
                android:layout_marginRight="28.0dp"
                android:layout_marginBottom="28.0dp"
                android:layout_marginHorizontal="28.0dp">
    <Button android:id="@id/ignore"
            android:layout_width="0.0dp"
            android:layout_height="wrap_content"
            android:text="@string/virus_app_ignore"
            android:layout_weight="1.0" />
    <Button android:id="@id/uninstall"
            android:layout_width="0.0dp"
            android:layout_height="wrap_content"
            android:text="@string/apps_item_virus_cleanup_text"
            android:layout_weight="1.0"
            android:layout_marginStart="@dimen/view_dimen_40"
            style="@style/Widget.Button.Warning" />
  </LinearLayout>
</LinearLayout>