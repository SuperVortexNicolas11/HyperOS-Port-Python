<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="horizontal"
              android:paddingTop="16.0dp"
              android:paddingBottom="16.0dp"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:paddingVertical="16.0dp"
              android:screenReaderFocusable="true" xmlns:android="http://schemas.android.com/apk/res/android">
  <ImageView android:layout_gravity="center_vertical"
             android:id="@android:id/icon"
             android:importantForAccessibility="no"
             style="@style/ResultListIconStyle" />
  <TextView android:ellipsize="end"
            android:layout_gravity="center_vertical"
            android:id="@android:id/title"
            android:focusable="false"
            android:layout_width="0.0dp"
            android:maxLines="2"
            android:layout_weight="1.0"
            android:layout_marginEnd="16.0dp"
            style="@style/ListItemTitle" />
  <Button android:layout_gravity="center_vertical"
          android:id="@android:id/button1"
          android:focusable="false"
          android:maxWidth="128.0dp"
          android:text="@string/apps_item_sign_install_button_text"
          style="@style/ResultBlueButtonStyle" />
</LinearLayout>