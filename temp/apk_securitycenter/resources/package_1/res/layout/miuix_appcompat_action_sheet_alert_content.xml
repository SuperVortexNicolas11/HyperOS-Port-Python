<?xml version='1.0' encoding='utf-8' ?>
<miuix.internal.widget.AlertActionSheetPanel android:orientation="vertical"
                      android:id="@id/action_sheet_content_panel"
                      android:background="@color/miuix_appcompat_transparent"
                      android:focusable="true"
                      android:clickable="true"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <miuix.smooth.SmoothFrameLayout2 android:id="@id/action_sheet_content"
                        android:background="?attr/colorSurfaceHigh"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:radius="@dimen/miuix_appcompat_dialog_bg_corner_radius">
    <LinearLayout android:orientation="vertical"
                  android:id="@id/action_sheet_content_container"
                  android:background="?attr/colorSurfaceHigh"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content">
      <androidx.appcompat.widget.AppCompatTextView android:textSize="@dimen/miuix_appcompat_action_sheet_content_message_font_size"
                            android:textColor="?attr/colorOnSurfaceTertiary"
                            android:ellipsize="end"
                            android:gravity="center"
                            android:id="@id/action_sheet_message"
                            android:background="?attr/colorSurfaceHigh"
                            android:paddingTop="@dimen/miuix_appcompat_action_sheet_alert_message_padding_top"
                            android:paddingBottom="@dimen/miuix_appcompat_action_sheet_alert_message_padding_bottom"
                            android:focusable="true"
                            android:focusableInTouchMode="true"
                            android:clickable="false"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content"
                            android:maxLines="3"
                            android:textDirection="locale"
                            android:textAlignment="center"
                            android:paddingStart="@dimen/miuix_appcompat_action_sheet_content_message_horizontal_padding"
                            android:paddingEnd="@dimen/miuix_appcompat_action_sheet_content_message_horizontal_padding" />
      <miuix.core.widget.NestedScrollView android:id="@id/actionSheetScrollView"
                            android:visibility="gone"
                            android:layout_width="fill_parent"
                            android:layout_height="fill_parent" />
      <LinearLayout android:orientation="vertical"
                    android:id="@id/alertContentWrapper"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">
        <miuix.springback.view.SpringBackLayout android:id="@id/actionSheetSpringBack"
                              android:layout_width="fill_parent"
                              android:layout_height="0.0dp"
                              android:layout_weight="1.0"
                              app:scrollOrientation="vertical"
                              app:scrollableView="@id/action_sheet_list_view">
          <include layout="@layout/miuix_appcompat_action_sheet_list_view" />
        </miuix.springback.view.SpringBackLayout>
        <miuix.internal.widget.GroupButton android:textSize="@dimen/miuix_appcompat_action_sheet_content_list_item_font_size"
                              android:layout_gravity="center_horizontal"
                              android:id="@id/action_sheet_cancel_button"
                              android:layout_width="fill_parent"
                              android:layout_height="wrap_content"
                              android:layout_marginTop="@dimen/miuix_appcompat_action_sheet_cancel_button_top_margin"
                              android:layout_marginBottom="@dimen/miuix_appcompat_action_sheet_cancel_button_bottom_margin"
                              android:minHeight="@dimen/miuix_appcompat_action_sheet_content_list_item_min_height"
                              android:fontFamily="@string/miuix_font_weight_headline1"
                              android:textAlignment="center"
                              android:layout_marginStart="@dimen/miuix_appcompat_action_sheet_cancel_button_horizontal_margin"
                              android:layout_marginEnd="@dimen/miuix_appcompat_action_sheet_cancel_button_horizontal_margin"
                              style="?android:attr/buttonBarNegativeButtonStyle" />
      </LinearLayout>
    </LinearLayout>
  </miuix.smooth.SmoothFrameLayout2>
</miuix.internal.widget.AlertActionSheetPanel>