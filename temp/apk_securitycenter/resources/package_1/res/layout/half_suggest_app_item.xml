<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:gravity="center_horizontal"
              android:orientation="vertical"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <ImageView android:id="@id/app_icon"
             android:layout_width="@dimen/view_dimen_168"
             android:layout_height="@dimen/view_dimen_168" />
  <TextView android:textSize="@dimen/view_dimen_34"
            android:textColor="@color/app_predict_app_classification_name_text_color"
            android:ellipsize="end"
            android:gravity="center"
            android:id="@id/app_name"
            android:layout_width="fill_parent"
            android:layout_height="@dimen/dp_20"
            android:layout_marginTop="@dimen/view_dimen_2"
            android:maxLines="1"
            android:singleLine="true"
            android:fontFamily="mipro-medium"
            android:fallbackLineSpacing="false"
            app:autoSizeMaxTextSize="@dimen/view_dimen_34"
            app:autoSizeMinTextSize="@dimen/sp_8"
            app:autoSizeStepGranularity="@dimen/text_font_size_1"
            app:autoSizeTextType="uniform" />
</LinearLayout>