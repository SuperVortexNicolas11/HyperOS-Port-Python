<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:background="?attr/preferenceItemBackground"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              style="@style/Widget.ListView.Item.DoubleLine" xmlns:android="http://schemas.android.com/apk/res/android">
  <RelativeLayout android:layout_gravity="center_vertical"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_weight="1.0">
    <TextView android:textAppearance="@style/Miuix.AppCompat.TextAppearance.PreferenceList"
              android:textSize="@dimen/sp_18"
              android:ellipsize="marquee"
              android:id="@android:id/title"
              android:fadingEdge="horizontal"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content" />
    <TextView android:textAppearance="@style/Miuix.AppCompat.TextAppearance.List.Secondary"
              android:textSize="@dimen/sp_14"
              android:id="@android:id/summary"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:maxLines="10"
              android:layout_below="@android:id/title"
              android:layout_alignStart="@android:id/title" />
  </RelativeLayout>
  <ImageView android:layout_gravity="center|right"
             android:id="@id/action"
             android:layout_width="@dimen/permission_icon_size"
             android:layout_height="@dimen/permission_icon_size" />
</LinearLayout>