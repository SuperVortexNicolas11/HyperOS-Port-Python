<?xml version='1.0' encoding='utf-8' ?>
<androidx.constraintlayout.widget.ConstraintLayout android:id="@id/content_view"
                      android:paddingLeft="@dimen/miuix_theme_margin_horizontal_common"
                      android:paddingRight="@dimen/miuix_theme_margin_horizontal_common"
                      android:layout_width="fill_parent"
                      android:layout_height="fill_parent"
                      android:paddingHorizontal="@dimen/miuix_theme_margin_horizontal_common" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <LinearLayout android:orientation="vertical"
                android:id="@id/bottom_layout"
                android:paddingTop="@dimen/dp_15"
                android:layout_width="0.0dp"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/content">
    <TextView android:textSize="@dimen/sp_17"
              android:textColor="@color/fob_result_process_tip"
              android:id="@id/progress_tip"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              style="@style/ItemPadding" />
    <miuix.androidbasewidget.widget.ProgressBar android:id="@id/progress_bar"
                          android:layout_width="fill_parent"
                          android:layout_height="wrap_content"
                          android:max="100"
                          android:progress="50"
                          android:layout_marginStart="@dimen/miuix_theme_content_padding_start"
                          android:layout_marginEnd="@dimen/miuix_theme_content_padding_start"
                          style="?attr/progressBarHorizontalStyle" />
    <androidx.appcompat.widget.AppCompatTextView android:textSize="@dimen/sp_14"
                          android:textColor="@color/storage_list_item_desc"
                          android:id="@id/finish_tip"
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:layout_marginBottom="@dimen/dp_15"
                          android:drawablePadding="@dimen/dp_6"
                          app:drawableStartCompat="@drawable/ic_finish_tip"
                          style="@style/ItemPadding" />
    <Button android:gravity="center"
            android:layout_gravity="center_horizontal"
            android:id="@id/btn_start"
            android:text="@string/storage_fbo_btn"
            android:onClick="onClick"
            style="@style/FboResultBtnStyle" />
  </LinearLayout>
  <miuix.springback.view.SpringBackLayout android:id="@id/content"
                        android:layout_width="0.0dp"
                        android:layout_height="0.0dp"
                        app:layout_constraintBottom_toTopOf="@id/bottom_layout"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:scrollableView="@id/root_layout">
    <com.miui.optimizecenter.storage.view.NoSpringBackNestedScrollView android:id="@id/root_layout"
                          android:layout_width="fill_parent"
                          android:layout_height="fill_parent">
      <LinearLayout android:orientation="vertical"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">
        <androidx.constraintlayout.widget.ConstraintLayout android:id="@id/constraint_layout"
                              android:background="@drawable/fbo_bg"
                              android:visibility="gone"
                              android:layout_width="fill_parent"
                              android:layout_height="wrap_content">
          <TextView android:textSize="@dimen/sp_13"
                    android:textColor="@color/storage_list_item_name"
                    android:id="@id/number"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
          <TextView android:textSize="@dimen/sp_14"
                    android:textColor="@color/storage_list_item_desc"
                    android:id="@id/number_tip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintStart_toStartOf="@id/number"
                    app:layout_constraintTop_toBottomOf="@id/number" />
          <Space android:id="@id/fbo_table_layout"
                 android:layout_width="fill_parent"
                 android:layout_height="263.0dp"
                 app:layout_constraintStart_toStartOf="parent"
                 app:layout_constraintTop_toBottomOf="@id/number_tip" />
          <TextView android:id="@id/value_5"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:importantForAccessibility="no"
                    app:layout_constraintBottom_toTopOf="@id/dotted_line_5"
                    app:layout_constraintTop_toTopOf="@id/dotted_line_5"
                    style="@style/StorageFboValue" />
          <TextView android:id="@id/value_4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:importantForAccessibility="no"
                    app:layout_constraintBottom_toTopOf="@id/dotted_line_4"
                    app:layout_constraintTop_toTopOf="@id/dotted_line_4"
                    style="@style/StorageFboValue" />
          <TextView android:id="@id/value_3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:importantForAccessibility="no"
                    app:layout_constraintBottom_toTopOf="@id/dotted_line_3"
                    app:layout_constraintTop_toTopOf="@id/dotted_line_3"
                    style="@style/StorageFboValue" />
          <TextView android:id="@id/value_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:importantForAccessibility="no"
                    app:layout_constraintBottom_toTopOf="@id/dotted_line_2"
                    app:layout_constraintTop_toTopOf="@id/dotted_line_2"
                    style="@style/StorageFboValue" />
          <TextView android:id="@id/value_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/dp_40"
                    android:importantForAccessibility="no"
                    app:layout_constraintBottom_toTopOf="@id/dotted_line_1"
                    app:layout_constraintTop_toTopOf="@id/dotted_line_1"
                    style="@style/StorageFboValue" />
          <com.miui.optimizecenter.storage.view.DottedLineView android:id="@id/dotted_line_5"
                                android:layout_marginTop="@dimen/storage_fbo_table_margin_top"
                                app:layout_constraintBottom_toTopOf="@id/dotted_line_4"
                                app:layout_constraintStart_toStartOf="@id/fbo_table_layout"
                                app:layout_constraintTop_toTopOf="@id/fbo_table_layout"
                                app:layout_constraintVertical_chainStyle="spread_inside"
                                style="@style/StorageFboValueDottedLine" />
          <com.miui.optimizecenter.storage.view.DottedLineView android:id="@id/dotted_line_4"
                                app:layout_constraintBottom_toTopOf="@id/dotted_line_3"
                                app:layout_constraintStart_toStartOf="@id/fbo_table_layout"
                                app:layout_constraintTop_toBottomOf="@id/dotted_line_5"
                                style="@style/StorageFboValueDottedLine" />
          <com.miui.optimizecenter.storage.view.DottedLineView android:id="@id/dotted_line_3"
                                app:layout_constraintBottom_toTopOf="@id/dotted_line_2"
                                app:layout_constraintStart_toStartOf="@id/fbo_table_layout"
                                app:layout_constraintTop_toBottomOf="@id/dotted_line_4"
                                style="@style/StorageFboValueDottedLine" />
          <com.miui.optimizecenter.storage.view.DottedLineView android:id="@id/dotted_line_2"
                                app:layout_constraintBottom_toTopOf="@id/dotted_line_1"
                                app:layout_constraintStart_toStartOf="@id/fbo_table_layout"
                                app:layout_constraintTop_toBottomOf="@id/dotted_line_3"
                                style="@style/StorageFboValueDottedLine" />
          <com.miui.optimizecenter.storage.view.DottedLineView android:id="@id/dotted_line_1"
                                android:layout_marginBottom="@dimen/storage_fbo_table_margin_bottom"
                                app:layout_constraintBottom_toBottomOf="@id/fbo_table_layout"
                                app:layout_constraintStart_toStartOf="@id/fbo_table_layout"
                                app:layout_constraintTop_toBottomOf="@id/dotted_line_2"
                                style="@style/StorageFboValueDottedLine" />
          <androidx.constraintlayout.widget.Barrier android:id="@id/value_barrier"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                app:barrierDirection="start"
                                app:constraint_referenced_ids="value_1,value_2,value_3,value_4,value_5" />
          <View android:id="@id/item_1"
                android:importantForAccessibility="no"
                android:layout_marginStart="@dimen/dp_10"
                app:layout_constraintBottom_toBottomOf="@id/dotted_line_1"
                app:layout_constraintEnd_toStartOf="@id/item_2"
                app:layout_constraintHorizontal_chainStyle="spread_inside"
                app:layout_constraintStart_toStartOf="@id/fbo_table_layout"
                style="@style/StorageFboItemView" />
          <View android:id="@id/item_2"
                android:importantForAccessibility="no"
                app:layout_constraintBottom_toBottomOf="@id/dotted_line_1"
                app:layout_constraintEnd_toStartOf="@id/item_3"
                app:layout_constraintStart_toEndOf="@id/item_1"
                style="@style/StorageFboItemView" />
          <View android:id="@id/item_3"
                android:importantForAccessibility="no"
                app:layout_constraintBottom_toBottomOf="@id/dotted_line_1"
                app:layout_constraintEnd_toStartOf="@id/item_4"
                app:layout_constraintStart_toEndOf="@id/item_2"
                style="@style/StorageFboItemView" />
          <View android:id="@id/item_4"
                android:importantForAccessibility="no"
                app:layout_constraintBottom_toBottomOf="@id/dotted_line_1"
                app:layout_constraintEnd_toStartOf="@id/item_5"
                app:layout_constraintStart_toEndOf="@id/item_3"
                style="@style/StorageFboItemView" />
          <View android:id="@id/item_5"
                android:importantForAccessibility="no"
                app:layout_constraintBottom_toBottomOf="@id/dotted_line_1"
                app:layout_constraintEnd_toStartOf="@id/item_6"
                app:layout_constraintStart_toEndOf="@id/item_4"
                style="@style/StorageFboItemView" />
          <View android:id="@id/item_6"
                android:importantForAccessibility="no"
                app:layout_constraintBottom_toBottomOf="@id/dotted_line_1"
                app:layout_constraintEnd_toStartOf="@id/item_7"
                app:layout_constraintStart_toEndOf="@id/item_5"
                style="@style/StorageFboItemView" />
          <View android:id="@id/item_7"
                android:importantForAccessibility="no"
                android:layout_marginEnd="@dimen/dp_14"
                app:layout_constraintBottom_toBottomOf="@id/dotted_line_1"
                app:layout_constraintEnd_toStartOf="@id/value_5"
                app:layout_constraintStart_toEndOf="@id/item_6"
                style="@style/StorageFboItemView" />
          <TextView android:id="@id/date_1"
                    android:layout_marginTop="@dimen/dp_12"
                    app:layout_constraintEnd_toEndOf="@id/item_1"
                    app:layout_constraintStart_toStartOf="@id/item_1"
                    app:layout_constraintTop_toBottomOf="@id/item_1"
                    style="@style/StorageFboDate" />
          <TextView android:id="@id/date_2"
                    android:layout_marginTop="@dimen/dp_12"
                    android:accessibilityTraversalAfter="@id/date_1"
                    app:layout_constraintEnd_toEndOf="@id/item_2"
                    app:layout_constraintStart_toStartOf="@id/item_2"
                    app:layout_constraintTop_toBottomOf="@id/item_2"
                    style="@style/StorageFboDate" />
          <TextView android:id="@id/date_3"
                    android:layout_marginTop="@dimen/dp_12"
                    android:accessibilityTraversalAfter="@id/date_2"
                    app:layout_constraintEnd_toEndOf="@id/item_3"
                    app:layout_constraintStart_toStartOf="@id/item_3"
                    app:layout_constraintTop_toBottomOf="@id/item_3"
                    style="@style/StorageFboDate" />
          <TextView android:id="@id/date_4"
                    android:layout_marginTop="@dimen/dp_12"
                    android:accessibilityTraversalAfter="@id/date_3"
                    app:layout_constraintEnd_toEndOf="@id/item_4"
                    app:layout_constraintStart_toStartOf="@id/item_4"
                    app:layout_constraintTop_toBottomOf="@id/item_4"
                    style="@style/StorageFboDate" />
          <TextView android:id="@id/date_5"
                    android:layout_marginTop="@dimen/dp_12"
                    android:accessibilityTraversalAfter="@id/date_4"
                    app:layout_constraintEnd_toEndOf="@id/item_5"
                    app:layout_constraintStart_toStartOf="@id/item_5"
                    app:layout_constraintTop_toBottomOf="@id/item_5"
                    style="@style/StorageFboDate" />
          <TextView android:id="@id/date_6"
                    android:layout_marginTop="@dimen/dp_12"
                    android:accessibilityTraversalAfter="@id/date_5"
                    app:layout_constraintEnd_toEndOf="@id/item_6"
                    app:layout_constraintStart_toStartOf="@id/item_6"
                    app:layout_constraintTop_toBottomOf="@id/item_6"
                    style="@style/StorageFboDate" />
          <TextView android:id="@id/date_7"
                    android:layout_marginTop="@dimen/dp_12"
                    android:accessibilityTraversalAfter="@id/date_6"
                    app:layout_constraintEnd_toEndOf="@id/item_7"
                    app:layout_constraintStart_toStartOf="@id/item_7"
                    app:layout_constraintTop_toBottomOf="@id/item_7"
                    style="@style/StorageFboDate" />
          <androidx.constraintlayout.widget.Group android:id="@id/data_group"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                app:constraint_referenced_ids="number,number_tip,unit,dotted_line_1,dotted_line_2,                 dotted_line_3,dotted_line_4,dotted_line_5,value_1,value_2,value_3,value_4,value_5,                 date_1,date_2,date_3,date_4,date_5,date_6,date_7,item_1,item_2,item_3,                 item_4,item_5,item_6,item_7,fbo_table_layout" />
        </androidx.constraintlayout.widget.ConstraintLayout>
        <LinearLayout android:orientation="vertical"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content"
                      style="@style/ItemPadding">
          <TextView android:textSize="@dimen/sp_13"
                    android:textColor="@color/storage_list_item_desc"
                    android:id="@id/bottom_tip_tv"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_20"
                    android:text="@string/storage_fbo_des"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/fbo_table_layout" />
          <TextView android:textSize="@dimen/sp_13"
                    android:textColor="@color/storage_list_item_desc"
                    android:id="@id/action_tip_tv"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/storage_fbo_action_des"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/bottom_tip_tv" />
        </LinearLayout>
      </LinearLayout>
    </com.miui.optimizecenter.storage.view.NoSpringBackNestedScrollView>
  </miuix.springback.view.SpringBackLayout>
</androidx.constraintlayout.widget.ConstraintLayout>