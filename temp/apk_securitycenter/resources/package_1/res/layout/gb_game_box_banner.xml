<?xml version='1.0' encoding='utf-8' ?>
<androidx.constraintlayout.widget.ConstraintLayout android:id="@id/cl_container"
                      android:background="@color/transparent"
                      android:layout_width="fill_parent"
                      android:layout_height="@dimen/dp_101" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <ImageView android:id="@id/iv_background"
             android:layout_width="fill_parent"
             android:layout_height="fill_parent" />
  <TextView android:textSize="@dimen/dp_7"
            android:textColor="@color/gb_casual_game_description_color"
            android:id="@id/tv_description"
            android:layout_width="0.0dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/dp_6"
            android:layout_marginStart="@dimen/dp_6"
            android:layout_marginEnd="@dimen/dp_6"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tv_download"
            app:layout_constraintStart_toStartOf="parent" />
  <ImageView android:id="@id/iv_application_icon"
             android:layout_width="@dimen/dp_33"
             android:layout_height="@dimen/dp_33"
             android:layout_marginTop="@dimen/dp_11"
             android:layout_marginEnd="@dimen/dp_14"
             app:layout_constraintEnd_toEndOf="parent"
             app:layout_constraintTop_toTopOf="parent" />
  <TextView android:textSize="@dimen/dp_10"
            android:textColor="#ffffff"
            android:id="@id/tv_application_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toTopOf="@id/tv_download"
            app:layout_constraintEnd_toEndOf="@id/iv_application_icon"
            app:layout_constraintStart_toStartOf="@id/iv_application_icon"
            app:layout_constraintTop_toBottomOf="@id/iv_application_icon" />
  <TextView android:textSize="@dimen/dp_10"
            android:textColor="#ffffff"
            android:gravity="center"
            android:id="@id/tv_download"
            android:background="@drawable/gb_casual_app_download_bg"
            android:layout_width="@dimen/dp_44"
            android:layout_height="@dimen/dp_21"
            android:layout_marginBottom="@dimen/dp_14"
            android:text="安装"
            android:layout_marginEnd="@dimen/dp_8_5"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />
  <com.miui.common.widgets.gif.GifImageView android:id="@id/iv_loading"
                        android:layout_width="fill_parent"
                        android:layout_height="fill_parent"
                        android:src="@drawable/ic_casual_game_loading_banner" />
</androidx.constraintlayout.widget.ConstraintLayout>