<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:gravity="center_vertical"
              android:orientation="horizontal"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android">
  <TextView android:textSize="@dimen/miui_keyguard_view_eca_text_size"
            android:textColor="@color/miui_keyguard_view_eca_text_color"
            android:ellipsize="marquee"
            android:gravity="center"
            android:id="@id/tv_forgetpwd"
            android:focusable="true"
            android:layout_width="0.0dp"
            android:layout_height="@dimen/miui_keyguard_pattern_view_eca_height"
            android:text="@string/app_lock_pwd_forget"
            android:singleLine="true"
            android:layout_weight="1.0"
            android:marqueeRepeatLimit="marquee_forever"
            android:textAlignment="center" />
  <Space android:id="@id/empty_space"
         android:layout_width="0.0px"
         android:layout_height="@dimen/miui_keyguard_pattern_view_eca_height"
         android:layout_weight="1.0" />
  <TextView android:textSize="@dimen/miui_keyguard_view_eca_text_size"
            android:textColor="@color/miui_keyguard_view_eca_text_color"
            android:ellipsize="marquee"
            android:gravity="center"
            android:id="@id/bottom_native_layout"
            android:layout_width="0.0dp"
            android:layout_height="@dimen/miui_keyguard_pattern_view_eca_height"
            android:text="@string/btn_back"
            android:singleLine="true"
            android:layout_weight="1.0"
            android:marqueeRepeatLimit="marquee_forever"
            android:fontFamily="mipro-medium"
            android:textAlignment="center" />
</LinearLayout>