<?xml version='1.0' encoding='utf-8' ?>
<RelativeLayout android:background="@drawable/storage_app_detail_item_bg"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/storage_app_list_item_h"
                android:paddingStart="@dimen/device_common_margin_start"
                android:paddingEnd="@dimen/device_common_margin_start" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <androidx.constraintlayout.utils.widget.ImageFilterView android:id="@id/app_icon"
                        android:layout_width="@dimen/dp_40"
                        android:layout_height="@dimen/dp_40"
                        android:layout_centerVertical="true"
                        android:layout_alignParentStart="true"
                        app:roundPercent="0.6" />
  <LinearLayout android:orientation="vertical"
                android:id="@id/name_container"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/storage_app_list_item_name_h"
                android:layout_alignTop="@id/app_icon"
                android:layout_centerVertical="true"
                android:layout_marginStart="@dimen/storage_app_list_item_name_ms"
                android:layout_marginEnd="@dimen/dp_48"
                android:layout_toStartOf="@id/arrow"
                android:layout_toEndOf="@id/app_icon">
    <TextView android:textSize="@dimen/storage_app_list_item_name_text"
              android:textStyle="bold"
              android:textColor="@color/storage_list_item_name"
              android:ellipsize="end"
              android:id="@id/app_name"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:maxWidth="@dimen/storage_app_list_name_w"
              android:maxLines="3" />
    <TextView android:textSize="@dimen/storage_app_list_item_name_desc"
              android:textColor="@color/storage_list_item_desc"
              android:ellipsize="end"
              android:id="@id/app_desc"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/dp_2"
              android:maxLines="4" />
  </LinearLayout>
  <ImageView android:id="@id/arrow"
             android:layout_width="wrap_content"
             android:layout_height="wrap_content"
             android:src="@drawable/miuix_appcompat_arrow_right"
             android:layout_centerVertical="true"
             android:layout_alignParentEnd="true" />
</RelativeLayout>