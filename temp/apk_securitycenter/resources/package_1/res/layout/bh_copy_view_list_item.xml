<?xml version='1.0' encoding='utf-8' ?>
<RelativeLayout android:orientation="horizontal"
                android:layout_width="fill_parent"
                android:layout_height="57.0dp" xmlns:android="http://schemas.android.com/apk/res/android">
  <TextView android:textSize="16.27sp"
            android:textStyle="bold"
            android:textColor="@color/record_list_detail_text_title_color"
            android:id="@id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="title"
            android:layout_centerVertical="true"
            android:alpha="0.9"
            android:layout_alignParentStart="true" />
  <TextView android:textSize="13.91sp"
            android:textColor="@color/record_list_detail_text_content_color"
            android:gravity="end"
            android:id="@id/tv_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="value"
            android:maxLines="2"
            android:layout_centerVertical="true"
            android:layout_marginStart="10.0dp"
            android:layout_marginEnd="7.27dp"
            android:layout_toStartOf="@id/copy_btn"
            android:layout_toEndOf="@id/tv_title" />
  <ImageView android:textSize="11.64dp"
             android:id="@id/copy_btn"
             android:layout_width="26.9dp"
             android:layout_height="26.9dp"
             android:src="@drawable/click_to_copy"
             android:text="@string/copy"
             android:layout_centerVertical="true"
             android:layout_alignParentEnd="true" />
</RelativeLayout>