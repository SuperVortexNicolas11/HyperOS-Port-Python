<?xml version='1.0' encoding='utf-8' ?>
<FrameLayout android:background="@color/pc_battery_item_normal_color"
             android:paddingBottom="@dimen/view_dimen_36"
             android:layout_width="fill_parent"
             android:layout_height="wrap_content"
             android:paddingStart="@dimen/privacy_detection_card_margin"
             android:paddingEnd="@dimen/privacy_detection_card_margin" xmlns:android="http://schemas.android.com/apk/res/android">
  <RelativeLayout android:background="@drawable/shape_pc_main_card_border_whole"
                  android:paddingTop="@dimen/view_dimen_39"
                  android:paddingBottom="@dimen/view_dimen_45"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content">
    <TextView android:textSize="@dimen/sp_14"
              android:textColor="@color/first_aid_box_summary_textcolor2"
              android:id="@id/risk_tip"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:importantForAccessibility="no"
              android:paddingStart="@dimen/view_dimen_44"
              android:paddingEnd="@dimen/view_dimen_44" />
    <LinearLayout android:orientation="horizontal"
                  android:id="@id/risk_app_layout"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="@dimen/view_dimen_114"
                  android:weightSum="5.0"
                  android:paddingStart="@dimen/view_dimen_35"
                  android:paddingEnd="@dimen/view_dimen_35">
      <FrameLayout android:layout_width="0.0dp"
                   android:layout_height="@dimen/view_dimen_110"
                   android:layout_weight="1.0">
        <ImageView android:layout_gravity="center_horizontal"
                   android:id="@id/risk_image_1"
                   android:scaleType="fitCenter"
                   style="@style/ListIconNoMargin" />
      </FrameLayout>
      <FrameLayout android:layout_width="0.0dp"
                   android:layout_height="@dimen/view_dimen_110"
                   android:layout_weight="1.0">
        <ImageView android:layout_gravity="center_horizontal"
                   android:id="@id/risk_image_2"
                   android:scaleType="fitCenter"
                   style="@style/ListIconNoMargin" />
      </FrameLayout>
      <FrameLayout android:layout_width="0.0dp"
                   android:layout_height="@dimen/view_dimen_110"
                   android:layout_weight="1.0">
        <ImageView android:layout_gravity="center_horizontal"
                   android:id="@id/risk_image_3"
                   android:scaleType="fitCenter"
                   style="@style/ListIconNoMargin" />
      </FrameLayout>
      <FrameLayout android:layout_width="0.0dp"
                   android:layout_height="@dimen/view_dimen_110"
                   android:layout_weight="1.0">
        <ImageView android:layout_gravity="center_horizontal"
                   android:id="@id/risk_image_4"
                   android:scaleType="fitCenter"
                   style="@style/ListIconNoMargin" />
      </FrameLayout>
      <FrameLayout android:layout_width="0.0dp"
                   android:layout_height="@dimen/view_dimen_110"
                   android:layout_weight="1.0">
        <ImageView android:layout_gravity="center_horizontal"
                   android:id="@id/risk_image_5"
                   android:scaleType="fitCenter"
                   style="@style/ListIconNoMargin" />
      </FrameLayout>
    </LinearLayout>
    <Button android:id="@id/privacy_set_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/view_dimen_60"
            android:layout_below="@id/risk_app_layout"
            android:importantForAccessibility="yes"
            android:paddingStart="@dimen/view_dimen_44"
            android:paddingEnd="@dimen/view_dimen_44"
            android:layout_marginEnd="@dimen/view_dimen_36"
            android:layout_alignParentEnd="true"
            style="@style/ListButton" />
    <TextView android:textSize="@dimen/sp_14"
              android:textColor="@color/color_link_text"
              android:id="@id/privacy_cancel_tv"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/privacy_risk_result_ignore_btn"
              android:layout_alignBaseline="@id/privacy_set_btn"
              android:importantForAccessibility="yes"
              android:fontFamily="mipro-medium"
              android:paddingStart="@dimen/view_dimen_70"
              android:paddingEnd="@dimen/view_dimen_70"
              android:layout_toStartOf="@id/privacy_set_btn" />
  </RelativeLayout>
</FrameLayout>