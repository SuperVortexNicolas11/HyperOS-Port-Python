<?xml version='1.0' encoding='utf-8' ?>
<androidx.constraintlayout.widget.ConstraintLayout android:paddingLeft="@dimen/dp_56"
                      android:paddingRight="@dimen/dp_56"
                      android:paddingBottom="@dimen/dp_36"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content"
                      android:paddingHorizontal="@dimen/dp_56" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <ImageView android:id="@id/device"
             android:layout_width="@dimen/dp_60"
             android:layout_height="@dimen/dp_60"
             android:layout_marginTop="@dimen/dp_12"
             app:layout_constraintEnd_toStartOf="@id/message_title"
             app:layout_constraintStart_toStartOf="parent"
             app:layout_constraintTop_toTopOf="parent" />
  <TextView android:textSize="@dimen/sp_22"
            android:textStyle="bold"
            android:textColor="#ff0000"
            android:id="@id/message_title"
            android:layout_width="0.0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_20"
            app:layout_constraintBottom_toTopOf="@id/group_area"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/device"
            app:layout_constraintTop_toTopOf="parent" />
  <TextView android:textSize="@dimen/sp_14"
            android:textColor="@android:color/white"
            android:ellipsize="end"
            android:id="@id/home_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_6"
            android:maxLines="1"
            android:maxEms="6"
            android:alpha="0.9"
            app:layout_constraintWidth_max="@dimen/dp_82" />
  <View android:id="@id/spacer1"
        android:background="@android:color/white"
        android:layout_width="@dimen/dp_1"
        android:layout_height="@dimen/dp_12"
        android:alpha="0.4" />
  <TextView android:textSize="@dimen/sp_14"
            android:textColor="@android:color/white"
            android:ellipsize="end"
            android:id="@id/room_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:maxEms="6"
            android:alpha="0.9"
            app:layout_constraintWidth_max="@dimen/dp_63" />
  <View android:id="@id/spacer2"
        android:background="@android:color/white"
        android:layout_width="@dimen/dp_1"
        android:layout_height="@dimen/dp_12"
        android:alpha="0.4" />
  <TextView android:textSize="@dimen/sp_14"
            android:textColor="@android:color/white"
            android:id="@id/time_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0.9" />
  <androidx.constraintlayout.helper.widget.Flow android:id="@id/group_area"
                        android:layout_width="0.0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dp_6"
                        app:constraint_referenced_ids="home_name,spacer1,room_name,spacer2,time_value"
                        app:flow_firstHorizontalBias="0.0"
                        app:flow_firstHorizontalStyle="packed"
                        app:flow_horizontalGap="@dimen/dp_8"
                        app:flow_wrapMode="chain"
                        app:layout_constraintEnd_toEndOf="@id/message_title"
                        app:layout_constraintHorizontal_bias="0.0"
                        app:layout_constraintStart_toStartOf="@id/message_title"
                        app:layout_constraintTop_toBottomOf="@id/message_title" />
  <View android:id="@id/divider"
        android:background="@android:color/white"
        android:layout_width="0.0dp"
        android:layout_height="@dimen/dp_1"
        android:layout_marginTop="@dimen/dp_36"
        android:alpha="0.2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/group_area" />
</androidx.constraintlayout.widget.ConstraintLayout>