<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:id="@id/second_main_root"
              android:background="@android:color/transparent"
              android:layout_width="fill_parent"
              android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android">
  <LinearLayout android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="fill_parent"
                android:layout_height="@dimen/view_dimen_132"
                android:layout_marginBottom="@dimen/view_dimen_30">
    <com.miui.gamebooster.videobox.view.MarqueeTextView android:textSize="@dimen/vb_advance_settings_title_txt_size"
                          android:textColor="@color/color_vb_srs_item_title"
                          android:ellipsize="marquee"
                          android:layout_width="0.0dp"
                          android:layout_height="wrap_content"
                          android:text="@string/vb_video_effects_dolby"
                          android:singleLine="true"
                          android:layout_weight="1.0"
                          android:marqueeRepeatLimit="marquee_forever"
                          android:textAlignment="viewStart"
                          android:layout_marginEnd="@dimen/vb_advance_settings_txt_me" />
    <com.miui.gamebooster.customview.SlidingButtonWithoutPressState android:id="@id/sb_switch2"
                          android:layout_width="@dimen/vb_advance_settings_sliding_btn_w"
                          android:layout_height="@dimen/vb_advance_settings_sliding_btn_h"
                          android:contentDescription="@string/vb_video_effects_dolby"
                          android:layout_marginStart="@dimen/vb_advance_settings_sliding_btn_ms"
                          style="@style/Widget.SlidingButton.Dark" />
  </LinearLayout>
  <TextView android:textSize="@dimen/view_dimen_30"
            android:textColor="@color/color_vtb_dolby_headset"
            android:id="@id/tv_dolby_tips"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/dp_10"
            android:text="@string/vb_video_effects_dolby_tips" />
  <FrameLayout android:id="@id/item1"
               android:layout_width="fill_parent"
               android:layout_height="@dimen/vtb_srs_settings_item_h">
    <ImageView android:id="@id/img1"
               android:layout_width="fill_parent"
               android:layout_height="fill_parent"
               android:src="@drawable/vtb_srs_vocal_img"
               android:scaleType="centerCrop" />
    <TextView android:textSize="@dimen/vb_srs_item_title_size"
              android:textColor="@color/color_vb_srs_item_title"
              android:ellipsize="end"
              android:layout_gravity="center|start|top"
              android:id="@id/tv_title1"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/vtb_srs_settings_item_title_mt"
              android:text="@string/vb_video_effects_dolby_dialog_enhancer"
              android:maxLines="1"
              android:layout_marginStart="@dimen/vtb_srs_settings_item_title_ms_me"
              android:layout_marginEnd="@dimen/vtb_srs_settings_item_title_ms_me" />
    <com.miui.gamebooster.videobox.view.SrsLevelSeekBarPro android:layout_gravity="bottom|center"
                          android:id="@id/seekbar_level1"
                          android:layout_width="@dimen/vtb_srs_seekbar_w"
                          android:layout_height="@dimen/vtb_srs_seekbar_h"
                          android:layout_marginBottom="@dimen/vtb_srs_settings_item_seekbar_mb" />
  </FrameLayout>
  <FrameLayout android:id="@id/item2"
               android:layout_width="fill_parent"
               android:layout_height="@dimen/vtb_srs_settings_item_h"
               android:layout_marginTop="@dimen/vtb_srs_settings_item_m"
               android:layout_marginBottom="@dimen/view_dimen_43">
    <ImageView android:id="@id/img2"
               android:layout_width="fill_parent"
               android:layout_height="fill_parent"
               android:src="@drawable/vtb_srs_surround_img"
               android:scaleType="centerCrop" />
    <LinearLayout android:layout_gravity="center|start|top"
                  android:orientation="vertical"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="@dimen/vtb_srs_settings_item_title_mt"
                  android:paddingStart="@dimen/vtb_srs_settings_item_title_ms_me">
      <TextView android:textSize="@dimen/vb_srs_item_title_size"
                android:textColor="@color/color_vb_srs_item_title"
                android:ellipsize="end"
                android:id="@id/tv_title2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/vb_video_effects_dolby_stereo_expansion"
                android:maxLines="1" />
      <TextView android:textSize="@dimen/vb_dolby_item_title_mt"
                android:textColor="@color/color_vtb_dolby_headset"
                android:ellipsize="end"
                android:id="@id/tv_title3"
                android:background="@drawable/shape_dolby_headset"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/vb_video_effects_dolby_headset"
                android:maxLines="1" />
    </LinearLayout>
    <com.miui.gamebooster.videobox.view.SrsLevelSeekBarPro android:layout_gravity="bottom|center"
                          android:id="@id/seekbar_level2"
                          android:layout_width="@dimen/vtb_srs_seekbar_w"
                          android:layout_height="@dimen/vtb_srs_seekbar_h"
                          android:layout_marginBottom="@dimen/vtb_srs_settings_item_seekbar_mb1" />
  </FrameLayout>
</LinearLayout>