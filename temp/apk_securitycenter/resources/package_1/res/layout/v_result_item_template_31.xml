<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:paddingTop="@dimen/card_layout_line_height_half"
              android:paddingBottom="@dimen/card_layout_line_height_half"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android">
  <LinearLayout android:orientation="vertical"
                android:id="@id/inner_layout"
                android:background="@drawable/shape_result_card_border_whole"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent">
    <LinearLayout android:orientation="horizontal"
                  android:padding="10.0dp"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content">
      <ImageView android:id="@id/icon"
                 android:layout_width="@dimen/icon_size"
                 android:layout_height="@dimen/icon_size"
                 android:src="@drawable/icon_def"
                 android:scaleType="centerCrop" />
      <TextView android:textSize="@dimen/result_title_text"
                android:ellipsize="end"
                android:gravity="start"
                android:layout_gravity="center_vertical"
                android:id="@id/title"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:maxLines="2"
                android:drawablePadding="8.0dp"
                android:drawableEnd="@drawable/miuix_appcompat_arrow_right"
                android:layout_marginStart="8.0dp" />
    </LinearLayout>
  </LinearLayout>
  <View android:id="@id/divider"
        android:background="#e5e5e5"
        android:layout_width="fill_parent"
        android:layout_height="1.0px" />
</LinearLayout>