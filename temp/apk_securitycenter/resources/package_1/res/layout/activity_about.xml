<?xml version='1.0' encoding='utf-8' ?>
<miuix.springback.view.SpringBackLayout android:paddingBottom="@dimen/dp_40"
                      android:layout_width="fill_parent"
                      android:layout_height="fill_parent"
                      android:paddingStart="@dimen/dp_28"
                      android:paddingEnd="@dimen/dp_28"
                      app:scrollOrientation="vertical"
                      app:scrollableView="@id/scroll_view" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <ScrollView android:id="@id/scroll_view"
              android:layout_width="fill_parent"
              android:layout_height="fill_parent">
    <LinearLayout android:gravity="center_horizontal"
                  android:orientation="vertical"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content">
      <androidx.appcompat.widget.AppCompatTextView android:textSize="@dimen/sp_16"
                            android:textColor="@color/about_security_title_color"
                            android:id="@id/tv_app_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/activity_about_app_name_top_margin"
                            android:text="@string/app_name_phone"
                            android:drawablePadding="@dimen/dp_10"
                            app:drawableTopCompat="@drawable/app_icon_securitycenter" />
      <TextView android:textSize="@dimen/sp_14"
                android:textColor="@color/about_security_text_color"
                android:id="@id/tv_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_7" />
      <TextView android:textSize="@dimen/sp_12"
                android:textColor="@color/about_ipc_color"
                android:id="@id/tv_icp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_100"
                android:layout_marginBottom="@dimen/dp_12"
                android:text="@string/about_securitycenter_icp" />
      <TextView android:textSize="@dimen/sp_12"
                android:textColor="@color/about_security_text_color"
                android:id="@id/tv_phone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/about_securitycenter_phne" />
    </LinearLayout>
  </ScrollView>
</miuix.springback.view.SpringBackLayout>