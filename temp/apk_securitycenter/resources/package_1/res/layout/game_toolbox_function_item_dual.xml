<?xml version='1.0' encoding='utf-8' ?>
<androidx.constraintlayout.widget.ConstraintLayout android:background="@drawable/game_toolbox_function_dual_bg"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content"
                      android:layout_marginTop="@dimen/game_toolbox_function_item_margin_top" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <com.miui.gamebooster.videobox.view.MarqueeTextView android:textSize="@dimen/game_toolbox_function_dual_title_text_size"
                        android:textColor="@color/game_toolbox_function_dual_title_color"
                        android:ellipsize="marquee"
                        android:id="@id/function_title"
                        android:layout_width="0.0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/game_toolbox_function_dual_title_margin_top"
                        android:maxEms="6"
                        android:singleLine="true"
                        android:layout_marginStart="@dimen/game_toolbox_function_dual_title_margin_start"
                        app:layout_constraintEnd_toStartOf="@id/function_icon"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
  <com.miui.gamebooster.videobox.view.MarqueeTextView android:textSize="@dimen/game_toolbox_function_dual_desc_text_size"
                        android:textColor="@color/game_toolbox_function_dual_desc_color"
                        android:ellipsize="marquee"
                        android:id="@id/function_desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/game_toolbox_function_dual_desc_margin_top"
                        android:layout_marginBottom="@dimen/game_toolbox_function_dual_desc_margin_bottom"
                        android:maxWidth="@dimen/game_toolbox_function_dual_desc_max_width"
                        android:singleLine="true"
                        android:layout_marginStart="@dimen/game_toolbox_function_dual_title_margin_start"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/function_title" />
  <ImageView android:id="@id/function_icon"
             android:layout_width="@dimen/game_toolbox_function_dual_icon_edge"
             android:layout_height="@dimen/game_toolbox_function_dual_icon_edge"
             android:scaleType="fitXY"
             android:layout_marginEnd="@dimen/game_toolbox_function_dual_icon_margin_end"
             app:layout_constraintBottom_toBottomOf="parent"
             app:layout_constraintEnd_toEndOf="parent"
             app:layout_constraintTop_toTopOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>