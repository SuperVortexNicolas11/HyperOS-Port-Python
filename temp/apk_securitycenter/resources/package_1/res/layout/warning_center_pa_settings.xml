<?xml version='1.0' encoding='utf-8' ?>
<androidx.constraintlayout.widget.ConstraintLayout android:layout_width="fill_parent"
                      android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <FrameLayout android:id="@id/content"
               android:layout_width="0.0dp"
               android:layout_height="0.0dp"
               app:layout_constraintBottom_toTopOf="@id/container_bottom"
               app:layout_constraintEnd_toEndOf="parent"
               app:layout_constraintStart_toStartOf="parent"
               app:layout_constraintTop_toTopOf="parent" />
  <androidx.constraintlayout.widget.ConstraintLayout android:id="@id/container_bottom"
                        android:layout_width="0.0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/dp_28"
                        android:layout_marginRight="@dimen/dp_28"
                        android:layout_marginHorizontal="@dimen/dp_28"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/content">
    <LinearLayout android:gravity="center"
                  android:orientation="horizontal"
                  android:id="@id/privacy_container"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content"
                  android:layout_marginBottom="@dimen/ew_pa_setting_check_box_margin_bottom"
                  app:layout_constraintBottom_toTopOf="@id/barrier"
                  app:layout_constraintEnd_toEndOf="parent"
                  app:layout_constraintStart_toStartOf="parent" />
    <Button android:gravity="center"
            android:layout_gravity="center"
            android:id="@id/open_police_assist"
            android:visibility="gone"
            android:layout_width="0.0dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/dp_44"
            android:text="@string/warningcenter_policeassist_open_btn"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintWidth_max="@dimen/dp_336"
            style="@style/Widget.Button.Warning" />
    <Button android:layout_gravity="center"
            android:id="@id/close_police_assist"
            android:visibility="gone"
            android:layout_width="0.0dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/dp_44"
            android:text="@string/warningcenter_policeassist_close_btn"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintWidth_max="@dimen/dp_336" />
    <androidx.constraintlayout.widget.Barrier android:id="@id/barrier"
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          app:barrierDirection="top"
                          app:constraint_referenced_ids="close_police_assist,open_police_assist" />
  </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>