<?xml version='1.0' encoding='utf-8' ?>
<com.miui.gamebooster.beauty.conversation.view.LightView android:orientation="vertical"
                      android:layout_width="fill_parent"
                      android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <include layout="@layout/conversation_second_titlebar" />
  <androidx.core.widget.NestedScrollView android:layout_width="fill_parent"
                        android:layout_height="fill_parent">
    <LinearLayout android:orientation="vertical"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content">
      <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="fill_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="@dimen/dp_45"
                            android:layout_marginStart="@dimen/dp_20"
                            android:layout_marginEnd="@dimen/dp_20">
        <TextView android:textSize="@dimen/dp_14"
                  android:textColor="@color/whitealpha90"
                  android:id="@id/tv_title"
                  android:layout_width="0.0dp"
                  android:layout_height="wrap_content"
                  android:text="@string/beauty_fun_light"
                  android:textAlignment="viewStart"
                  android:layout_marginEnd="@dimen/dp_3"
                  app:layout_constraintBottom_toBottomOf="parent"
                  app:layout_constraintEnd_toStartOf="@id/gb_switch"
                  app:layout_constraintStart_toStartOf="parent"
                  app:layout_constraintTop_toTopOf="parent" />
        <miuix.slidingwidget.widget.SlidingButton android:id="@id/gb_switch"
                              android:layout_width="@dimen/dp_36_37"
                              android:layout_height="@dimen/dp_20_18"
                              android:contentDescription="@string/beauty_fun_light"
                              app:layout_constraintBottom_toBottomOf="parent"
                              app:layout_constraintEnd_toEndOf="parent"
                              app:layout_constraintTop_toTopOf="parent"
                              style="@style/Widget.SlidingButton.Dark" />
      </androidx.constraintlayout.widget.ConstraintLayout>
      <View android:background="@color/whitealpha10"
            android:layout_width="fill_parent"
            android:layout_height="@dimen/dp_1"
            android:layout_marginTop="@dimen/dp_8"
            android:layout_marginBottom="@dimen/dp_8"
            android:layout_marginStart="@dimen/dp_18"
            android:layout_marginEnd="@dimen/dp_18" />
      <LinearLayout android:orientation="vertical"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">
        <androidx.constraintlayout.widget.ConstraintLayout android:id="@id/fl_auto_light"
                              android:layout_width="fill_parent"
                              android:layout_height="wrap_content"
                              android:minHeight="@dimen/dp_45"
                              android:layout_marginStart="@dimen/dp_20"
                              android:layout_marginEnd="@dimen/dp_20">
          <TextView android:textSize="@dimen/dp_14"
                    android:textColor="@color/conversation_light_label_selector"
                    android:id="@id/tv_auto_light_title"
                    android:layout_width="0.0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/beauty_fc_auto_brightness"
                    android:textAlignment="viewStart"
                    android:layout_marginEnd="@dimen/dp_3"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/gb_auto_light_switch"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
          <miuix.slidingwidget.widget.SlidingButton android:id="@id/gb_auto_light_switch"
                                android:layout_width="@dimen/dp_36_37"
                                android:layout_height="@dimen/dp_20_18"
                                android:contentDescription="@string/beauty_fc_auto_brightness"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                style="@style/Widget.SlidingButton.Dark" />
        </androidx.constraintlayout.widget.ConstraintLayout>
        <TextView android:textSize="@dimen/dp_14"
                  android:textColor="@color/conversation_light_label_selector"
                  android:gravity="center_vertical"
                  android:id="@id/title_seekbar"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:minHeight="@dimen/dp_45"
                  android:text="@string/beauty_fun_settings_light"
                  android:drawablePadding="@dimen/dp_6"
                  android:drawableStart="@drawable/conversation_settings_light"
                  android:layout_marginStart="@dimen/dp_20"
                  android:layout_marginEnd="@dimen/dp_20" />
        <miuix.androidbasewidget.widget.SeekBar android:id="@id/gb_seekbar"
                              android:layout_width="fill_parent"
                              android:layout_height="wrap_content"
                              android:max="100"
                              android:contentDescription="@string/beauty_fun_settings_light"
                              android:layout_marginStart="@dimen/dp_18"
                              android:layout_marginEnd="@dimen/dp_18"
                              style="@style/ConversationBoxLightSeekbarStyle" />
      </LinearLayout>
      <LinearLayout android:orientation="vertical"
                    android:id="@id/light_content"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">
        <View android:background="@color/whitealpha10"
              android:layout_width="fill_parent"
              android:layout_height="@dimen/dp_1"
              android:layout_marginTop="@dimen/dp_22"
              android:layout_marginBottom="@dimen/dp_12"
              android:layout_marginStart="@dimen/dp_18"
              android:layout_marginEnd="@dimen/dp_18" />
        <TextView android:textSize="@dimen/dp_14"
                  android:textColor="@color/conversation_light_label_selector"
                  android:layout_gravity="center|left"
                  android:id="@id/tv_title_light"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:text="@string/cs_light_enhance_physical_options"
                  android:layout_marginStart="@dimen/dp_20" />
        <androidx.recyclerview.widget.RecyclerView android:id="@id/light_list"
                              android:layout_width="fill_parent"
                              android:layout_height="wrap_content"
                              android:layout_marginTop="@dimen/dp_9" />
      </LinearLayout>
    </LinearLayout>
  </androidx.core.widget.NestedScrollView>
</com.miui.gamebooster.beauty.conversation.view.LightView>