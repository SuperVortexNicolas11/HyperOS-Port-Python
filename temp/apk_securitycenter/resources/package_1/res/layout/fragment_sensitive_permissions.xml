<?xml version='1.0' encoding='utf-8' ?>
<miuix.springback.view.SpringBackLayout android:background="@color/first_aid_kit_bgcolor"
                      android:layout_width="fill_parent"
                      android:layout_height="fill_parent"
                      app:scrollableView="@id/center_layout" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <androidx.core.widget.NestedScrollView android:id="@id/center_layout"
                        android:layout_width="fill_parent"
                        android:layout_height="fill_parent">
    <LinearLayout android:gravity="center"
                  android:orientation="vertical"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content">
      <TextView android:textSize="@dimen/text_font_size_40"
                android:textColor="@color/bg_location_occupy"
                android:background="@drawable/shape_sensitive_permission_top_bg"
                android:paddingTop="@dimen/view_dimen_48"
                android:paddingBottom="@dimen/view_dimen_48"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/miuix_preference_item_padding_bottom"
                android:text="@string/privacy_risk_sensitive_top_tip"
                android:paddingStart="@dimen/view_dimen_44"
                android:paddingEnd="@dimen/view_dimen_44"
                android:layout_marginStart="@dimen/miuix_preference_item_padding_start"
                android:layout_marginEnd="@dimen/miuix_preference_item_padding_end" />
      <miuix.smooth.SmoothFrameLayout android:gravity="center"
                            android:orientation="vertical"
                            android:background="@color/pc_main_card_item_background"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content"
                            android:radius="20.0dp"
                            android:layout_marginStart="@dimen/miuix_preference_item_padding_start"
                            android:layout_marginEnd="@dimen/miuix_preference_item_padding_end">
        <LinearLayout android:gravity="center"
                      android:orientation="vertical"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content"
                      android:paddingStart="@dimen/view_dimen_44"
                      android:paddingEnd="@dimen/view_dimen_44">
          <LinearLayout android:gravity="center"
                        android:orientation="horizontal"
                        android:id="@id/container_call"
                        android:paddingTop="@dimen/view_dimen_45"
                        android:paddingBottom="@dimen/view_dimen_45"
                        android:visibility="gone"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content">
            <LinearLayout android:orientation="vertical"
                          android:layout_width="0.0dp"
                          android:layout_height="wrap_content"
                          android:layout_weight="1.0">
              <TextView android:id="@id/title_call"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/privacy_permission_call"
                        style="@style/privacy_main_title" />
              <TextView android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/privacy_risk_sensitive_call_records"
                        style="@style/privacy_main_summary" />
            </LinearLayout>
            <TextView android:textSize="@dimen/text_font_size_42"
                      android:textColor="@color/na_nd_text_sub"
                      android:gravity="center_vertical"
                      android:id="@id/call_num"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:drawablePadding="@dimen/view_dimen_20"
                      android:drawableEnd="@drawable/ic_arrow_right" />
          </LinearLayout>
          <LinearLayout android:gravity="center"
                        android:orientation="horizontal"
                        android:id="@id/container_contacts"
                        android:paddingTop="@dimen/view_dimen_45"
                        android:paddingBottom="@dimen/view_dimen_45"
                        android:visibility="gone"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content">
            <LinearLayout android:orientation="vertical"
                          android:layout_width="0.0dp"
                          android:layout_height="wrap_content"
                          android:layout_weight="1.0">
              <TextView android:id="@id/title_contacts"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/privacy_permission_contacts"
                        style="@style/privacy_main_title" />
              <TextView android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/privacy_risk_sensitive_contact"
                        style="@style/privacy_main_summary" />
            </LinearLayout>
            <TextView android:textSize="@dimen/text_font_size_42"
                      android:textColor="@color/na_nd_text_sub"
                      android:gravity="center_vertical"
                      android:id="@id/contact_num"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:drawablePadding="@dimen/view_dimen_20"
                      android:drawableEnd="@drawable/ic_arrow_right" />
          </LinearLayout>
          <LinearLayout android:gravity="center"
                        android:orientation="horizontal"
                        android:id="@id/container_storage"
                        android:paddingTop="@dimen/view_dimen_45"
                        android:paddingBottom="@dimen/view_dimen_45"
                        android:visibility="gone"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content">
            <LinearLayout android:orientation="vertical"
                          android:layout_width="0.0dp"
                          android:layout_height="wrap_content"
                          android:layout_weight="1.0">
              <TextView android:id="@id/title_storage"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/group_file"
                        style="@style/privacy_main_title" />
              <TextView android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/privacy_risk_sensitive_storage"
                        style="@style/privacy_main_summary" />
            </LinearLayout>
            <TextView android:textSize="@dimen/text_font_size_42"
                      android:textColor="@color/na_nd_text_sub"
                      android:gravity="center_vertical"
                      android:id="@id/storage_num"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:drawablePadding="@dimen/view_dimen_20"
                      android:drawableEnd="@drawable/ic_arrow_right" />
          </LinearLayout>
          <LinearLayout android:gravity="center"
                        android:orientation="horizontal"
                        android:id="@id/images_video_storage"
                        android:paddingTop="@dimen/view_dimen_45"
                        android:paddingBottom="@dimen/view_dimen_45"
                        android:visibility="gone"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content">
            <LinearLayout android:orientation="vertical"
                          android:layout_width="0.0dp"
                          android:layout_height="wrap_content"
                          android:layout_weight="1.0">
              <TextView android:id="@id/im_vi_storage"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/group_image_video"
                        style="@style/privacy_main_title" />
              <TextView android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/HIPS_Perm_External_READ_MEDIA_PIC_VIDEO_Desc"
                        style="@style/privacy_main_summary" />
            </LinearLayout>
            <TextView android:textSize="@dimen/text_font_size_42"
                      android:textColor="@color/na_nd_text_sub"
                      android:gravity="center_vertical"
                      android:id="@id/images_video_num"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:drawablePadding="@dimen/view_dimen_20"
                      android:drawableEnd="@drawable/ic_arrow_right" />
          </LinearLayout>
          <LinearLayout android:gravity="center"
                        android:orientation="horizontal"
                        android:id="@id/audio_storage"
                        android:paddingTop="@dimen/view_dimen_45"
                        android:paddingBottom="@dimen/view_dimen_45"
                        android:visibility="gone"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content">
            <LinearLayout android:orientation="vertical"
                          android:layout_width="0.0dp"
                          android:layout_height="wrap_content"
                          android:layout_weight="1.0">
              <TextView android:id="@id/au_storage"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/group_audio"
                        style="@style/privacy_main_title" />
              <TextView android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/HIPS_Perm_External_READ_MEDIA_AUDIO_Desc"
                        style="@style/privacy_main_summary" />
            </LinearLayout>
            <TextView android:textSize="@dimen/text_font_size_42"
                      android:textColor="@color/na_nd_text_sub"
                      android:gravity="center_vertical"
                      android:id="@id/audio_num"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:drawablePadding="@dimen/view_dimen_20"
                      android:drawableEnd="@drawable/ic_arrow_right" />
          </LinearLayout>
          <LinearLayout android:gravity="center"
                        android:orientation="horizontal"
                        android:id="@id/container_record"
                        android:paddingTop="@dimen/view_dimen_45"
                        android:paddingBottom="@dimen/view_dimen_45"
                        android:visibility="gone"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content">
            <LinearLayout android:orientation="vertical"
                          android:layout_width="0.0dp"
                          android:layout_height="wrap_content"
                          android:layout_weight="1.0">
              <TextView android:id="@id/title_record"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/privacy_permission_record"
                        style="@style/privacy_main_title" />
              <TextView android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/privacy_risk_sensitive_record"
                        style="@style/privacy_main_summary" />
            </LinearLayout>
            <TextView android:textSize="@dimen/text_font_size_42"
                      android:textColor="@color/na_nd_text_sub"
                      android:gravity="center_vertical"
                      android:id="@id/record_num"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:drawablePadding="@dimen/view_dimen_20"
                      android:drawableEnd="@drawable/ic_arrow_right" />
          </LinearLayout>
          <LinearLayout android:gravity="center"
                        android:orientation="horizontal"
                        android:id="@id/container_location"
                        android:paddingTop="@dimen/view_dimen_45"
                        android:paddingBottom="@dimen/view_dimen_45"
                        android:visibility="gone"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="1.0dp">
            <LinearLayout android:orientation="vertical"
                          android:layout_width="0.0dp"
                          android:layout_height="wrap_content"
                          android:layout_weight="1.0">
              <TextView android:id="@id/title_location"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/privacy_permission_location"
                        style="@style/privacy_main_title" />
              <TextView android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/view_dimen_5"
                        android:text="@string/privacy_risk_sensitive_location"
                        style="@style/privacy_main_summary" />
            </LinearLayout>
            <TextView android:textSize="@dimen/text_font_size_42"
                      android:textColor="@color/na_nd_text_sub"
                      android:gravity="center_horizontal"
                      android:id="@id/location_count"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:drawablePadding="@dimen/view_dimen_20"
                      android:drawableEnd="@drawable/ic_arrow_right" />
          </LinearLayout>
        </LinearLayout>
      </miuix.smooth.SmoothFrameLayout>
    </LinearLayout>
  </androidx.core.widget.NestedScrollView>
</miuix.springback.view.SpringBackLayout>