<?xml version='1.0' encoding='utf-8' ?>
<androidx.constraintlayout.widget.ConstraintLayout android:background="@drawable/shape_result_card_border_whole"
                      android:padding="16.0dp"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content"
                      android:screenReaderFocusable="true" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <ImageView android:id="@android:id/icon"
             android:focusable="false"
             android:layout_width="@dimen/dp_40"
             android:layout_height="@dimen/dp_40"
             android:scaleType="centerCrop"
             app:layout_constraintStart_toStartOf="parent"
             app:layout_constraintTop_toTopOf="parent" />
  <TextView android:ellipsize="end"
            android:id="@android:id/title"
            android:focusable="false"
            android:layout_width="0.0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16.0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@android:id/icon"
            app:layout_constraintTop_toTopOf="parent"
            style="@style/ListItemTitle" />
  <TextView android:id="@android:id/summary"
            android:focusable="false"
            android:layout_width="0.0dp"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@android:id/title"
            app:layout_constraintTop_toBottomOf="@android:id/title"
            style="@style/ListItemSubTitle" />
  <Button android:id="@android:id/button1"
          android:focusable="false"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginTop="16.0dp"
          app:layout_constraintBottom_toBottomOf="parent"
          app:layout_constraintEnd_toEndOf="parent"
          app:layout_constraintTop_toBottomOf="@android:id/summary"
          style="@style/ResultBlueButtonStyle" />
</androidx.constraintlayout.widget.ConstraintLayout>