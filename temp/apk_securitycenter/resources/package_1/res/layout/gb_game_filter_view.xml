<?xml version='1.0' encoding='utf-8' ?>
<merge android:orientation="vertical"
       android:layout_width="fill_parent"
       android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <com.miui.gamebooster.windowmanager.GBTopbarLayout android:id="@id/topview"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        app:turboTitleCenter="@string/gamebox_mem_filter" />
  <com.miui.gamebooster.videobox.view.MarqueeTextView android:textSize="@dimen/dp_11"
                        android:textColor="@color/whitealpha50"
                        android:ellipsize="marquee"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/gamebox_filter_tip"
                        android:singleLine="true"
                        android:marqueeRepeatLimit="marquee_forever"
                        android:paddingStart="@dimen/dp_22"
                        android:paddingEnd="@dimen/dp_22" />
  <androidx.recyclerview.widget.RecyclerView android:orientation="vertical"
                        android:id="@id/recycler"
                        android:paddingTop="@dimen/dp_10"
                        android:layout_width="fill_parent"
                        android:layout_height="fill_parent"
                        android:paddingStart="@dimen/dp_16"
                        android:paddingEnd="@dimen/dp_16"
                        app:fastScrollEnabled="false"
                        app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                        app:spanCount="3" />
</merge>