<?xml version='1.0' encoding='utf-8' ?>
<RelativeLayout android:paddingTop="@dimen/dp_1"
                android:paddingBottom="@dimen/dp_2"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:paddingStart="@dimen/dp_3"
                android:paddingEnd="@dimen/dp_3" xmlns:android="http://schemas.android.com/apk/res/android">
  <RelativeLayout android:layout_width="fill_parent"
                  android:layout_height="wrap_content"
                  android:layout_centerVertical="true"
                  android:layout_toStartOf="@id/notification_button"
                  android:layout_alignParentStart="true">
    <ImageView android:id="@id/notification_icon"
               android:layout_width="@dimen/dp_32"
               android:layout_height="@dimen/dp_32"
               android:layout_marginTop="@dimen/dp_2"
               android:src="@drawable/app_icon_securitycenter" />
    <TextView android:textSize="@dimen/sp_15"
              android:textColor="@color/notification_memory_text"
              android:ellipsize="end"
              android:id="@id/notification_text"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:maxLines="1"
              android:fontFamily="mipro-demibold"
              android:textAlignment="viewStart"
              android:layout_marginStart="@dimen/dp_12"
              android:layout_toEndOf="@id/notification_icon" />
    <TextView android:textSize="@dimen/text_font_size_40"
              android:textColor="@color/notification_memory_summary"
              android:ellipsize="end"
              android:id="@id/notification_summary"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/dp_2"
              android:text="@string/notification_garbage_clean_hint"
              android:maxLines="2"
              android:layout_below="@id/notification_text"
              android:textAlignment="viewStart"
              android:layout_marginStart="@dimen/dp_12"
              android:layout_toEndOf="@id/notification_icon" />
  </RelativeLayout>
  <TextView android:textSize="@dimen/text_font_size_36"
            android:textColor="@color/notification_common_action_btn"
            android:gravity="center"
            android:id="@id/notification_button"
            android:background="@drawable/shape_notification_common_button"
            android:paddingTop="@dimen/dp_4"
            android:paddingBottom="@dimen/dp_4"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:clickable="false"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/dp_28"
            android:layout_centerVertical="true"
            android:layout_alignWithParentIfMissing="true"
            android:textAllCaps="true"
            android:fontFamily="mipro-medium"
            android:paddingStart="@dimen/dp_14"
            android:paddingEnd="@dimen/dp_14"
            android:layout_marginStart="@dimen/dp_2"
            android:layout_toStartOf="@id/large_icon" />
  <ImageView android:id="@id/large_icon"
             android:visibility="gone"
             android:layout_width="@dimen/dp_32"
             android:layout_height="@dimen/dp_32"
             android:src="@drawable/app_icon_securitycenter"
             android:layout_centerVertical="true"
             android:layout_marginStart="@dimen/dp_2"
             android:layout_marginEnd="@dimen/dp_4"
             android:layout_alignParentEnd="true" />
</RelativeLayout>