<?xml version='1.0' encoding='utf-8' ?>
<RelativeLayout android:orientation="vertical"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android">
  <ListView android:id="@id/listView"
            android:paddingLeft="@dimen/dp_30"
            android:paddingRight="@dimen/dp_30"
            android:scrollbars="none"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:overScrollMode="always" />
  <LinearLayout android:gravity="center"
                android:orientation="vertical"
                android:id="@id/ll_no_data"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true">
    <ImageView android:layout_width="@dimen/dp_54"
               android:layout_height="@dimen/dp_54"
               android:src="@drawable/ic_gb_wonderful_video_record" />
    <TextView android:textSize="@dimen/sp_13"
              android:textColor="@color/tb_white_percent_30"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/dp_14"
              android:text="@string/gb_game_video_page_null" />
  </LinearLayout>
  <LinearLayout android:gravity="center"
                android:orientation="horizontal"
                android:id="@id/ll_share_del"
                android:background="@color/gb_color_0d1421"
                android:visibility="gone"
                android:layout_width="fill_parent"
                android:layout_height="@dimen/gb_wonderful_main_page_bottom_function_height"
                android:layout_alignParentBottom="true">
    <TextView android:textSize="@dimen/gb_wonderful_tab_page_item_desc_textsize"
              android:textColor="@drawable/gb_record_video_checked_all_textcolor_selector"
              android:gravity="center"
              android:id="@id/btn_checkall"
              android:layout_width="@dimen/gb_wonderful_main_page_bottom_button_width"
              android:layout_height="wrap_content"
              android:text="@string/gb_wonderful_video_checkall"
              android:drawableTop="@drawable/selector_gb_wonderful_video_checked_all"
              android:drawablePadding="@dimen/dp_1"
              android:layout_marginEnd="@dimen/gb_wonderful_main_page_bottom_margin" />
    <TextView android:textSize="@dimen/gb_wonderful_tab_page_item_desc_textsize"
              android:textColor="@color/gb_wonderful_moment_tips_text_color"
              android:gravity="center"
              android:id="@id/btn_del"
              android:clickable="true"
              android:layout_width="@dimen/gb_wonderful_main_page_bottom_button_width"
              android:layout_height="wrap_content"
              android:text="@string/gb_wonderful_video_delete"
              android:drawableTop="@drawable/ic_gb_wonderful_video_del"
              android:drawablePadding="@dimen/dp_1"
              android:layout_marginEnd="@dimen/gb_wonderful_main_page_bottom_margin" />
    <TextView android:textSize="@dimen/gb_wonderful_tab_page_item_desc_textsize"
              android:textColor="@color/gb_wonderful_moment_tips_text_color"
              android:gravity="center"
              android:id="@id/btn_cancel"
              android:clickable="true"
              android:layout_width="@dimen/gb_wonderful_main_page_bottom_button_width"
              android:layout_height="wrap_content"
              android:text="@string/gb_wonderful_video_cancel"
              android:drawableTop="@drawable/ic_gb_wonderful_video_cancel"
              android:drawablePadding="@dimen/dp_1" />
  </LinearLayout>
</RelativeLayout>