<?xml version='1.0' encoding='utf-8' ?>
<miuix.springback.view.SpringBackLayout android:layout_width="fill_parent"
                      android:layout_height="fill_parent"
                      app:scrollableView="@id/scroll" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <androidx.core.widget.NestedScrollView android:id="@id/scroll"
                        android:layout_width="fill_parent"
                        android:layout_height="fill_parent">
    <LinearLayout android:gravity="center_horizontal"
                  android:orientation="vertical"
                  android:id="@id/pc_main_root"
                  android:background="@color/pc_main_activity_background_color"
                  android:layout_width="fill_parent"
                  android:layout_height="fill_parent"
                  android:layout_marginTop="56.7dp"
                  android:layout_marginStart="@dimen/view_dimen_80"
                  android:layout_marginEnd="@dimen/view_dimen_80">
      <ImageView android:layout_width="wrap_content"
                 android:layout_height="wrap_content"
                 android:src="@drawable/ic_pc_night_charge_protection"
                 android:scaleType="fitCenter"
                 android:adjustViewBounds="true"
                 android:importantForAccessibility="no" />
      <RelativeLayout android:id="@id/rl_night_charge_protection"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:layout_marginTop="38.9dp"
                      android:layout_weight="1.0"
                      android:layout_centerVertical="true">
        <LinearLayout android:orientation="vertical"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:layout_centerVertical="true"
                      android:layout_toStartOf="@id/slide_night_charge_protection"
                      android:layout_alignParentStart="true">
          <TextView android:textSize="@dimen/text_font_size_48"
                    android:textStyle="bold"
                    android:textColor="@color/pc_main_power_card_text_color"
                    android:paddingTop="@dimen/view_dimen_7"
                    android:focusable="true"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/power_center_night_charge_protection" />
        </LinearLayout>
        <miuix.slidingwidget.widget.SlidingButton android:id="@id/slide_night_charge_protection"
                              android:clickable="true"
                              android:layout_width="wrap_content"
                              android:layout_height="wrap_content"
                              android:layout_centerVertical="true"
                              android:layout_alignParentEnd="true" />
        <CheckBox android:id="@android:id/checkbox"
                  android:focusable="false"
                  android:visibility="gone"
                  android:clickable="false"
                  android:duplicateParentState="true"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_centerVertical="true"
                  android:layout_alignParentEnd="true" />
      </RelativeLayout>
      <TextView android:textSize="@dimen/text_font_size_36"
                android:textColor="@color/pc_night_charge_summary_text_color"
                android:focusable="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/view_dimen_15"
                android:text="@string/power_center_night_charge_protection_summary"
                android:textAlignment="viewStart" />
    </LinearLayout>
  </androidx.core.widget.NestedScrollView>
</miuix.springback.view.SpringBackLayout>