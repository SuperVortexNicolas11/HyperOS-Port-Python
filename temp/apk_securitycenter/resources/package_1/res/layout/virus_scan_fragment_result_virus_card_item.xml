<?xml version='1.0' encoding='utf-8' ?>
<androidx.constraintlayout.widget.ConstraintLayout android:paddingTop="16.0dp"
                      android:paddingBottom="16.0dp"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content"
                      android:paddingVertical="16.0dp"
                      android:screenReaderFocusable="true" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <CheckBox android:id="@android:id/checkbox"
            android:focusable="false"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/view_split"
            app:layout_constraintTop_toTopOf="parent" />
  <ImageView android:id="@android:id/icon"
             android:focusable="false"
             android:layout_width="@dimen/dp_40"
             android:layout_height="@dimen/dp_40"
             android:scaleType="centerCrop"
             android:importantForAccessibility="no"
             app:layout_constraintBottom_toBottomOf="parent"
             app:layout_constraintStart_toStartOf="parent"
             app:layout_constraintTop_toTopOf="parent" />
  <TextView android:ellipsize="end"
            android:id="@id/title"
            android:focusable="false"
            android:layout_width="0.0dp"
            android:layout_marginStart="16.0dp"
            app:layout_constraintBottom_toTopOf="@id/summary"
            app:layout_constraintEnd_toStartOf="@id/title_summary_barrier"
            app:layout_constraintStart_toEndOf="@android:id/icon"
            app:layout_constraintTop_toTopOf="parent"
            style="@style/ListItemTitle" />
  <TextView android:ellipsize="end"
            android:id="@id/summary"
            android:focusable="false"
            android:layout_width="0.0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_2"
            android:maxLines="2"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/title_summary_barrier"
            app:layout_constraintStart_toStartOf="@id/title"
            app:layout_constraintTop_toBottomOf="@id/title"
            style="@style/ListItemSubTitle" />
  <androidx.constraintlayout.widget.Barrier android:id="@id/title_summary_barrier"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:barrierDirection="end"
                        app:constraint_referenced_ids="title,summary" />
  <TextView android:textSize="@dimen/text_font_size_42"
            android:textColor="@color/result_card_item_summary_color"
            android:id="@id/size"
            android:focusable="false"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@android:id/checkbox"
            app:layout_constraintStart_toEndOf="@id/title_summary_barrier"
            app:layout_constraintTop_toTopOf="parent" />
  <View android:id="@id/view_split"
        android:background="@color/app_manager_card_separate_line_bg"
        android:focusable="false"
        android:layout_width="@dimen/view_dimen_2"
        android:layout_height="@dimen/view_dimen_70"
        android:layout_marginStart="@dimen/view_dimen_30"
        android:layout_marginEnd="@dimen/view_dimen_40"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@android:id/checkbox"
        app:layout_constraintStart_toEndOf="@id/size"
        app:layout_constraintTop_toTopOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>