<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <com.miui.gamebooster.widget.CheckBoxSettingItemView android:id="@id/checkbox_setting_item"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        app:gbsiCustomLayout="@layout/gb_ai_helper_item_view"
                        app:gbsiSubtitle="@string/gs_game_shortcut"
                        app:gbsiTitle="@string/game_booster" />
  <TextView android:textSize="@dimen/game_toolbox_ai_helper_unavailable_text_size"
            android:textColor="@color/game_toolbox_ai_helper_unavailable_text_color"
            android:id="@id/tv_unavailable"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:text="不可用" />
  <LinearLayout android:orientation="vertical"
                android:id="@id/subitem_container"
                android:visibility="gone"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
    <LinearLayout android:orientation="vertical"
                  android:id="@id/mutex_selectable_container"
                  android:visibility="gone"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content"
                  android:layout_marginBottom="@dimen/dp_12"
                  android:divider="@drawable/game_toolbox_ai_helper_mutex_selectable_divider"
                  android:showDividers="middle" />
    <LinearLayout android:orientation="vertical"
                  android:id="@id/subitem_with_seekbar_container"
                  android:focusable="false"
                  android:focusableInTouchMode="false"
                  android:visibility="gone"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content"
                  android:importantForAccessibility="no">
      <com.miui.gamebooster.widget.CheckBoxSettingItemView android:id="@id/seekbar_item"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content"
                            app:gbsiCustomLayout="@layout/gb_ai_helper_item_view"
                            app:gbsiSubtitle="@string/gs_game_shortcut"
                            app:gbsiTitle="@string/game_booster" />
      <TextView android:textSize="@dimen/gb_wonderful_record_way_dialog_subtitle_textsize"
                android:textColor="@color/gb_record_dialog_subtitle_color"
                android:id="@id/seekbar_title"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:importantForAccessibility="no"
                style="@style/GBSettingItemSubtitle" />
      <miuix.androidbasewidget.widget.SeekBar android:id="@id/seekbar"
                            android:visibility="gone"
                            android:layout_width="fill_parent"
                            android:layout_height="50.0dp"
                            android:max="100"
                            android:progress="80"
                            android:progressDrawable="@drawable/miuix_appcompat_seekbar_progress_light"
                            style="@style/Widget.SeekBar.Light" />
    </LinearLayout>
  </LinearLayout>
</LinearLayout>