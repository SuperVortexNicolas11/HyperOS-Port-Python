<?xml version='1.0' encoding='utf-8' ?>
<FrameLayout android:id="@id/root_lin"
             android:layout_width="fill_parent"
             android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <LinearLayout android:orientation="vertical"
                android:id="@id/top_view_lin"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
    <ImageView android:layout_gravity="center_horizontal"
               android:id="@id/sim_icon"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:layout_marginTop="@dimen/dp_143"
               android:src="@drawable/simlock_set_pin_simcard"
               android:importantForAccessibility="no" />
    <TextView android:textSize="@dimen/font_size_40"
              android:textColor="@color/task_summary_color"
              android:layout_gravity="center_horizontal"
              android:id="@id/sim_info"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/dp_23_64"
              android:fontFamily="mipro-regular" />
    <TextView android:textSize="@dimen/dp_15"
              android:textColor="@color/task_summary_color"
              android:id="@id/message"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/view_dimen_30"
              android:text="@string/sim_lock_pin_message"
              android:fontFamily="mipro-regular"
              android:layout_marginStart="@dimen/view_dimen_80"
              android:layout_marginEnd="@dimen/view_dimen_80" />
    <EditText android:textColorHint="@color/sim_lock_hint_color"
              android:id="@id/text_input"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/view_dimen_70"
              android:hint="@string/sim_lock_pin_hint"
              android:maxLength="8"
              android:inputType="numberPassword"
              android:importantForAccessibility="no"
              android:fontFamily="mipro-medium"
              android:layout_marginStart="@dimen/view_dimen_30"
              android:layout_marginEnd="@dimen/view_dimen_30" />
    <TextView android:textSize="@dimen/dp_14"
              android:textColor="@color/sim_lock_set_remind_color"
              android:id="@id/remind"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/view_dimen_10"
              android:fontFamily="mipro-medium"
              android:layout_marginStart="@dimen/view_dimen_80" />
  </LinearLayout>
  <Button android:enabled="false"
          android:textColor="@color/task_default_add_task_text_color_unable"
          android:layout_gravity="bottom|center"
          android:id="@id/confirm"
          android:layout_width="@dimen/dp_336"
          android:layout_height="wrap_content"
          android:layout_marginBottom="@dimen/view_dimen_80"
          android:text="@string/sim_lock_pin_confirm"
          style="@style/Widget.Button.Primary" />
</FrameLayout>