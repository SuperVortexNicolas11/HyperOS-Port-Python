<?xml version='1.0' encoding='utf-8' ?>
<com.miui.securitycenter.ad.view.AdDownloadView android:id="@id/ad_load_25"
                      android:background="@drawable/shape_ad_template25"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <include layout="@layout/layout_ad_head01" />
  <com.miui.securitycenter.ad.view.RoundResizeFrameLayout android:id="@id/image_layout"
                        android:layout_width="0.0dp"
                        android:layout_height="0.0dp"
                        android:layout_marginTop="@dimen/v_dimens_38"
                        android:contentDescription="@null"
                        app:layout_constraintDimensionRatio="920:440"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_developer"
                        app:roundCornerRadius="@dimen/v_dimens_26">
    <com.miui.securitycenter.ad.view.AdImageView android:id="@id/iv_img_big"
                          android:layout_width="fill_parent"
                          android:layout_height="fill_parent"
                          android:scaleType="fitXY"
                          android:contentDescription="@null" />
  </com.miui.securitycenter.ad.view.RoundResizeFrameLayout>
  <TextView android:id="@id/tv_btn"
            android:layout_marginTop="@dimen/v_dimens_40"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/image_layout"
            style="@style/AdButtonTextStyle" />
  <TextView android:id="@id/tv_cancel"
            app:layout_constraintBaseline_toBaselineOf="@id/tv_btn"
            app:layout_constraintEnd_toStartOf="@id/tv_btn"
            style="@style/AdCancelButton" />
</com.miui.securitycenter.ad.view.AdDownloadView>