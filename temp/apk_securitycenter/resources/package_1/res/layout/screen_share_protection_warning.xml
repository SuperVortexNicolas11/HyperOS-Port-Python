<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:layout_width="fill_parent"
              android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android">
  <TextView android:textSize="@dimen/sp_18"
            android:textColor="@color/screen_share_protection_title_color"
            android:gravity="center"
            android:id="@id/title"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:text="@string/screen_share_protection_title"
            android:fontFamily="mipro-medium" />
  <ScrollView android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:nestedScrollingEnabled="true">
    <RelativeLayout android:layout_width="fill_parent"
                    android:layout_height="wrap_content">
      <TextView android:textSize="@dimen/sp_17"
                android:textColor="@color/screen_share_protection_summary_color"
                android:id="@id/summary"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_16"
                android:text="@string/screen_share_protection_summary"
                android:paddingStart="@dimen/dp_36"
                android:paddingEnd="@dimen/dp_36" />
      <RelativeLayout android:gravity="center_horizontal"
                      android:orientation="horizontal"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content"
                      android:layout_marginTop="@dimen/dp_17"
                      android:layout_below="@id/summary">
        <ImageView android:id="@id/icon"
                   android:layout_width="wrap_content"
                   android:layout_height="wrap_content"
                   android:src="@drawable/screen_share_protection_icon"
                   android:layout_alignTop="@id/icon_title"
                   android:layout_alignBottom="@id/icon_title" />
        <TextView android:textSize="@dimen/sp_14"
                  android:id="@id/icon_title"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:text="@string/screen_share_protection_warning_icon_title"
                  android:layout_marginStart="@dimen/dp_6"
                  android:layout_toEndOf="@id/icon" />
      </RelativeLayout>
    </RelativeLayout>
  </ScrollView>
</LinearLayout>