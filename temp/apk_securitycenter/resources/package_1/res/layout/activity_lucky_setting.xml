<?xml version='1.0' encoding='utf-8' ?>
<RelativeLayout android:orientation="vertical"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <FrameLayout android:layout_width="fill_parent"
               android:layout_height="@dimen/lucky_setting_top_height"
               android:layout_alignParentTop="true">
    <View android:background="@drawable/setting_header_bg"
          android:layout_width="fill_parent"
          android:layout_height="wrap_content" />
  </FrameLayout>
  <View android:orientation="vertical"
        android:id="@id/no_luckymoney_view"
        android:visibility="visible"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/lucky_setting_top_height"
        android:layout_alignParentTop="true" />
  <RelativeLayout android:layout_width="fill_parent"
                  android:layout_height="@dimen/lucky_setting_top_height">
    <RelativeLayout android:id="@id/layout_lucky_title"
                    android:layout_width="fill_parent"
                    android:layout_height="@dimen/lucky_alarm_appbar_height"
                    android:layout_marginTop="@dimen/lucky_alarm_appbar_topmargin"
                    android:paddingStart="@dimen/lucky_setting_layout_lucky_title_padding_horizontal"
                    android:paddingEnd="@dimen/lucky_setting_layout_lucky_title_padding_horizontal">
      <TextView android:id="@id/btn_back"
                android:background="@drawable/miuix_action_icon_back_dark"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:contentDescription="@string/btn_back"
                android:layout_alignParentStart="true"
                style="@style/Miuix.AppCompat.TextAppearance.WindowTitle" />
    </RelativeLayout>
    <RelativeLayout android:id="@id/layoutNoLuckyMoney"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/lucky_setting_no_luck_money_layout_margin_top"
                    android:layout_centerHorizontal="true">
      <ImageView android:id="@id/imgNoLuckyMoney"
                 android:layout_width="wrap_content"
                 android:layout_height="wrap_content"
                 android:src="@drawable/icon_no_luckymoney"
                 android:layout_centerHorizontal="true" />
      <TextView android:textSize="@dimen/lucky_setting_title_no_lucky_money_txtsize"
                android:textColor="@color/whiltealpha80"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/lucky_setting_no_luck_money_text_margin_top"
                android:text="@string/no_lucky_money"
                android:layout_below="@id/imgNoLuckyMoney"
                android:layout_centerHorizontal="true" />
    </RelativeLayout>
    <RelativeLayout android:id="@id/layoutHasLuckyMoney"
                    android:padding="@dimen/dp_10"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/lucky_alarm_rl_number_of_lucky_money_margin_tip"
                    android:layout_centerHorizontal="true"
                    android:importantForAccessibility="yes">
      <TextView android:textSize="@dimen/lucky_setting_tv_number_text_size"
                android:textColor="#ffffff"
                android:id="@id/txvNumberOfLuckyMoney"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/demo_number"
                android:includeFontPadding="false"
                android:layout_centerHorizontal="true"
                android:importantForAccessibility="no" />
      <TextView android:textSize="@dimen/lucky_alarm_tip_text_size"
                android:textColor="#ccffffff"
                android:id="@id/txv_number_of_lucky_money_summary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="-3.0dp"
                android:text="@string/number_of_lucky_money"
                android:layout_below="@id/txvNumberOfLuckyMoney"
                android:layout_centerHorizontal="true"
                android:importantForAccessibility="no" />
      <TextView android:textSize="@dimen/lucky_alarm_tip_text_size"
                android:textColor="#ffffff"
                android:id="@id/tv_indivual"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/lucky_alarm_tv_lucky_money_number_margin_top"
                android:text="@string/ge"
                android:layout_toRightOf="@id/txvNumberOfLuckyMoney"
                android:importantForAccessibility="no"
                android:layout_marginStart="@dimen/lucky_alarm_tv_lucky_money_number_margin_start" />
    </RelativeLayout>
    <TextView android:textSize="@dimen/lucky_alarm_txv_banner_summary_desc_text_size"
              android:textColor="@color/whiltealpha80"
              android:gravity="center"
              android:id="@id/tv_banner_summary_desc"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:layout_marginBottom="@dimen/lucky_setting_banner_summary_desc_margin_bottom"
              android:text="@string/lucky_assistant_description"
              android:layout_alignParentBottom="true"
              android:layout_centerHorizontal="true" />
  </RelativeLayout>
  <ScrollView android:id="@id/scrollview_main"
              android:scrollbars="none"
              android:clipToPadding="false"
              android:layout_width="fill_parent"
              android:layout_height="fill_parent"
              android:layout_marginTop="@dimen/lucky_setting_top_height">
    <LinearLayout android:orientation="vertical"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content">
      <LinearLayout android:orientation="vertical"
                    android:background="@drawable/na_shape_list_wrapper_white_corner"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/na_main_horizontal_margin"
                    android:layout_marginTop="@dimen/na_main_horizontal_margin"
                    android:layout_marginRight="@dimen/na_main_horizontal_margin"
                    android:layout_marginHorizontal="@dimen/na_main_horizontal_margin">
        <RelativeLayout android:id="@id/layout_master_switch"
                        android:background="@drawable/lucky_selector_up_press"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="@dimen/lucky_setting_item_min_height"
                        android:paddingStart="@dimen/am_main_item_padding_se"
                        android:paddingEnd="@dimen/am_main_item_padding_se">
          <LinearLayout android:gravity="start"
                        android:orientation="vertical"
                        android:paddingTop="@dimen/lucky_twolinetxt_padding_top"
                        android:paddingBottom="@dimen/lucky_twolinetxt_padding_bottom"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="@dimen/lucky_alarm_master_switch_margin_end"
                        android:layout_toStartOf="@id/sliding_button_all_control"
                        android:layout_alignParentStart="true">
            <TextView android:textSize="@dimen/lucky_setting_title_txtsize"
                      android:textStyle="bold"
                      android:textColor="@color/lucky_settings_item_title_color"
                      android:id="@id/txv_open_all"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:text="@string/hongbao_name" />
            <TextView android:textSize="@dimen/lucky_setting_summary_txtsize"
                      android:textColor="@color/lucky_settings_item_summary_color"
                      android:id="@id/txv_open_all_desc"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:layout_marginTop="@dimen/lucky_twolinetxt_margin"
                      android:text="@string/text_all_control_summary"
                      android:fontFamily="mipro-regular" />
          </LinearLayout>
          <miuix.slidingwidget.widget.SlidingButton android:id="@id/sliding_button_all_control"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerVertical="true"
                                android:layout_alignParentEnd="true" />
        </RelativeLayout>
        <RelativeLayout android:id="@id/layout_fast_open"
                        android:background="@drawable/lucky_selector_mid_press"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="@dimen/lucky_setting_item_min_height"
                        android:paddingStart="@dimen/am_main_item_padding_se"
                        android:paddingEnd="@dimen/am_main_item_padding_se">
          <LinearLayout android:gravity="start"
                        android:orientation="vertical"
                        android:paddingTop="@dimen/lucky_twolinetxt_padding_top"
                        android:paddingBottom="@dimen/lucky_twolinetxt_padding_bottom"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="@dimen/lucky_alarm_layout_fast_open_margin_end"
                        android:layout_toStartOf="@id/layout_fastopen_settings"
                        android:layout_alignParentStart="true">
            <TextView android:textSize="@dimen/lucky_setting_title_txtsize"
                      android:textStyle="bold"
                      android:textColor="@color/lucky_settings_item_title_color"
                      android:id="@id/txv_fast_open"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:text="@string/fast_open" />
            <TextView android:textSize="@dimen/lucky_setting_summary_txtsize"
                      android:textColor="@color/lucky_settings_item_summary_color"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:layout_marginTop="@dimen/lucky_twolinetxt_margin"
                      android:text="@string/fast_open_summary"
                      android:fontFamily="mipro-regular" />
          </LinearLayout>
          <LinearLayout android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:id="@id/layout_fastopen_settings"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_alignParentEnd="true">
            <TextView android:textSize="@dimen/lucky_setting_tip_txtsize"
                      android:textColor="@color/lucky_settings_item_summary_color"
                      android:id="@id/txv_fast_open_status"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content" />
            <ImageView android:layout_width="wrap_content"
                       android:layout_height="wrap_content"
                       android:src="@drawable/miuix_appcompat_arrow_right"
                       android:layout_marginStart="@dimen/lucky_arrow_margin" />
          </LinearLayout>
        </RelativeLayout>
        <RelativeLayout android:id="@id/layout_more_setting"
                        android:background="@drawable/lucky_selector_down_press"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="@dimen/lucky_setting_item_min_height"
                        android:paddingStart="@dimen/am_main_item_padding_se"
                        android:paddingEnd="@dimen/am_main_item_padding_se">
          <LinearLayout android:gravity="start"
                        android:orientation="vertical"
                        android:paddingTop="@dimen/lucky_twolinetxt_padding_top"
                        android:paddingBottom="@dimen/lucky_twolinetxt_padding_bottom"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="@dimen/lucky_alarm_layout_more_setting_margin_end"
                        android:layout_toStartOf="@id/layout_more_settings"
                        android:layout_alignParentStart="true">
            <TextView android:textSize="@dimen/lucky_setting_title_txtsize"
                      android:textStyle="bold"
                      android:textColor="@color/lucky_settings_item_title_color"
                      android:id="@id/open_more_setting"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:text="@string/title_more_setting" />
            <TextView android:textSize="@dimen/lucky_setting_summary_txtsize"
                      android:textColor="@color/lucky_settings_item_summary_color"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:layout_marginTop="@dimen/lucky_twolinetxt_margin"
                      android:text="@string/more_setting_summary"
                      android:fontFamily="mipro-regular" />
          </LinearLayout>
          <ImageView android:id="@id/layout_more_settings"
                     android:layout_width="wrap_content"
                     android:layout_height="fill_parent"
                     android:src="@drawable/miuix_appcompat_arrow_right"
                     android:layout_centerVertical="true"
                     android:layout_alignParentEnd="true" />
        </RelativeLayout>
      </LinearLayout>
      <RelativeLayout android:id="@id/rl_warning_summary"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content"
                      android:layout_marginTop="@dimen/lucky_setting_warning_margintop"
                      android:layout_marginBottom="@dimen/lucky_setting_warning_marginbottom"
                      android:layout_marginStart="@dimen/am_main_item_padding_se"
                      android:layout_marginEnd="@dimen/am_main_item_padding_se">
        <TextView android:textSize="@dimen/lucky_setting_warning_txtsize"
                  android:textColor="@color/lucky_settings_item_summary_color"
                  android:id="@id/warning_summary"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content"
                  android:text="@string/best_warning_dialog_message" />
        <TextView android:textSize="@dimen/lucky_setting_warning_txtsize"
                  android:textColor="#f30018"
                  android:id="@id/tv_function_no_work"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="@dimen/lucky_alarm_tv_function_no_work_margin_top"
                  android:layout_below="@id/warning_summary"
                  android:layout_alignParentEnd="true" />
      </RelativeLayout>
    </LinearLayout>
  </ScrollView>
</RelativeLayout>