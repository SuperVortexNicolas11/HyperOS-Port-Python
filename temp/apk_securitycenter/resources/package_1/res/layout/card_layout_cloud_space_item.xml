<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:gravity="center_vertical"
              android:orientation="horizontal"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:minHeight="@dimen/dp_26" xmlns:android="http://schemas.android.com/apk/res/android">
  <com.miui.securityscan.ui.main.ColorfulDotView android:id="@id/dot"
                        android:layout_width="@dimen/micloud_storage_dot_view_size"
                        android:layout_height="@dimen/micloud_storage_dot_view_size"
                        android:contentDescription="@null"
                        android:layout_marginEnd="@dimen/micloud_storage_dot_view_margin_right" />
  <LinearLayout android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
    <TextView android:textSize="@dimen/micloud_space_item_title_size"
              android:textColor="@color/micloud_storage_item_text_color"
              android:id="@id/tv_title"
              android:fadingEdge="horizontal"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:singleLine="true"
              android:layout_marginEnd="@dimen/dp_5" />
    <TextView android:textSize="@dimen/micloud_space_item_title_size"
              android:textColor="@color/micloud_storage_item_text_color"
              android:ellipsize="marquee"
              android:id="@id/tv_summary"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:singleLine="true" />
  </LinearLayout>
</LinearLayout>