<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:paddingTop="@dimen/view_dimen_40"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android">
  <RelativeLayout android:id="@id/container"
                  android:background="@drawable/warning_center_disaster_bg_blue"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content"
                  android:minHeight="@dimen/view_dimen_402">
    <com.miui.warningcenter.disasterwarning.view.DrawBitmapView android:id="@id/iv_type"
                          android:layout_width="@dimen/dp_74"
                          android:layout_height="@dimen/dp_74"
                          android:layout_alignParentBottom="true"
                          android:alpha="0.6"
                          android:layout_marginEnd="@dimen/view_dimen_40"
                          android:layout_alignParentEnd="true" />
    <TextView android:textSize="@dimen/wc_disaster_text_title_1"
              android:textStyle="bold"
              android:textColor="@color/wc_disaster_list_text_color"
              android:id="@id/tv_title"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/view_dimen_50"
              android:layout_alignParentTop="true"
              android:layout_marginStart="@dimen/view_dimen_80"
              android:layout_marginEnd="@dimen/view_dimen_80" />
    <TextView android:textSize="@dimen/wc_text_summary_text_size"
              android:textColor="@color/wc_disaster_list_summary_color"
              android:id="@id/tv_date"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/view_dimen_22"
              android:layout_below="@id/tv_title"
              android:layout_marginStart="@dimen/view_dimen_80"
              android:layout_marginEnd="@dimen/view_dimen_80" />
    <TextView android:textSize="@dimen/wc_text_summary_text_size"
              android:textColor="@color/wc_disaster_list_summary_color"
              android:id="@id/tv_location"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/view_dimen_12"
              android:layout_below="@id/tv_date"
              android:layout_marginStart="@dimen/view_dimen_80"
              android:layout_toStartOf="@id/iv_type" />
    <TextView android:textSize="@dimen/wc_card_type_text_size"
              android:textColor="@color/wc_disaster_list_summary_color"
              android:id="@id/tv_first"
              android:background="@drawable/warning_center_disaster_shape_publish"
              android:paddingTop="@dimen/view_dimen_10"
              android:paddingBottom="@dimen/view_dimen_10"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/view_dimen_36"
              android:layout_marginBottom="@dimen/view_dimen_50"
              android:layout_below="@id/tv_location"
              android:paddingStart="@dimen/view_dimen_24"
              android:paddingEnd="@dimen/view_dimen_24"
              android:layout_marginStart="@dimen/view_dimen_80"
              android:layout_marginEnd="@dimen/view_dimen_80" />
  </RelativeLayout>
</LinearLayout>