<?xml version='1.0' encoding='utf-8' ?>
<RelativeLayout android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:paddingStart="@dimen/dp_36"
                android:paddingEnd="@dimen/dp_36" xmlns:android="http://schemas.android.com/apk/res/android">
  <ImageView android:id="@id/img"
             android:layout_width="@dimen/dp_32"
             android:layout_height="@dimen/dp_32"
             android:src="@drawable/perm_notification_icon"
             android:layout_centerHorizontal="true" />
  <TextView android:textSize="@dimen/sp_18"
            android:textColor="@color/color_permission_group_title"
            android:id="@id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_14"
            android:layout_below="@id/img"
            android:layout_centerHorizontal="true"
            android:fontFamily="miui-bold" />
  <TextView android:textSize="@dimen/sp_17"
            android:textColor="@color/color_permission_tips"
            android:id="@id/content"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_14"
            android:layout_marginBottom="@dimen/dp_16"
            android:layout_below="@id/title"
            android:layout_centerHorizontal="true" />
</RelativeLayout>