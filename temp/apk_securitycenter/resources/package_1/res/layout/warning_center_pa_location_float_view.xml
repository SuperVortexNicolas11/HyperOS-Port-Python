<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:gravity="center"
              android:orientation="vertical"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android">
  <LinearLayout android:gravity="center"
                android:id="@id/ll_flow_tips"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
    <TextView android:textSize="@dimen/dp_17"
              android:textColor="@color/pa_float_view_tip_text_color"
              android:id="@id/flow_tips"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/warningcenter_policeassist_flow_tips"
              android:fontFamily="mipro-medium"
              android:layout_marginStart="@dimen/view_dimen_18" />
  </LinearLayout>
  <LinearLayout android:gravity="center"
                android:orientation="vertical"
                android:id="@id/ll_flow_location"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="3.5dp"
                android:layout_marginRight="3.5dp"
                android:layout_marginHorizontal="3.5dp">
    <TextView android:textSize="@dimen/dp_14"
              android:textColor="#ffffff"
              android:id="@id/location_status"
              android:visibility="gone"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginBottom="@dimen/view_dimen_10"
              android:fontFamily="mipro-medium" />
    <RelativeLayout android:gravity="center"
                    android:id="@id/ll_location"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
      <ImageView android:id="@id/location_icon"
                 android:layout_width="@dimen/dp_18"
                 android:layout_height="@dimen/dp_18"
                 android:src="@drawable/warning_center_pa_gray_location"
                 android:layout_alignParentTop="true" />
      <TextView android:textSize="@dimen/dp_14"
                android:textColor="@color/pa_float_view_location_text_color"
                android:id="@id/location_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dp_6"
                android:layout_toEndOf="@id/location_icon" />
    </RelativeLayout>
  </LinearLayout>
</LinearLayout>