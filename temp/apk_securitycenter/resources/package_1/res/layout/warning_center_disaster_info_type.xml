<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dp_16"
                        android:layout_marginBottom="@dimen/dp_16"
                        android:layout_marginStart="?attr/preferenceItemPaddingStart"
                        android:layout_marginEnd="?attr/preferenceItemPaddingEnd"
                        android:layout_marginVertical="@dimen/dp_16">
    <LinearLayout android:gravity="center"
                  android:orientation="vertical"
                  android:id="@id/container1"
                  android:layout_width="0.0dp"
                  android:layout_height="wrap_content"
                  app:layout_constraintEnd_toStartOf="@id/container2"
                  app:layout_constraintHorizontal_chainStyle="spread_inside"
                  app:layout_constraintHorizontal_weight="1.0"
                  app:layout_constraintStart_toStartOf="parent"
                  app:layout_constraintTop_toTopOf="parent">
      <ImageView android:id="@id/image1"
                 android:layout_width="@dimen/view_dimen_88"
                 android:layout_height="@dimen/view_dimen_88"
                 android:src="@drawable/warningcenter_disaster_icon_meteorological" />
      <TextView android:textSize="@dimen/wc_text_summary_text_size"
                android:textColor="@color/ew_text_black_color"
                android:id="@id/text1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/view_dimen_18"
                android:text="@string/warningcenter_disaster_receive_type_meteorological" />
    </LinearLayout>
    <LinearLayout android:gravity="center"
                  android:orientation="vertical"
                  android:id="@id/container2"
                  android:layout_width="0.0dp"
                  android:layout_height="wrap_content"
                  app:layout_constraintEnd_toStartOf="@id/container3"
                  app:layout_constraintHorizontal_weight="1.0"
                  app:layout_constraintStart_toEndOf="@id/container1"
                  app:layout_constraintTop_toTopOf="parent">
      <ImageView android:id="@id/image2"
                 android:layout_width="@dimen/view_dimen_88"
                 android:layout_height="@dimen/view_dimen_88"
                 android:src="@drawable/warningcenter_disaster_icon_geology" />
      <TextView android:textSize="@dimen/wc_text_summary_text_size"
                android:textColor="@color/ew_text_black_color"
                android:id="@id/text2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/view_dimen_18"
                android:text="@string/warningcenter_disaster_receive_type_geology" />
    </LinearLayout>
    <LinearLayout android:gravity="center"
                  android:orientation="vertical"
                  android:id="@id/container3"
                  android:layout_width="0.0dp"
                  android:layout_height="wrap_content"
                  app:layout_constraintEnd_toStartOf="@id/container4"
                  app:layout_constraintHorizontal_weight="1.0"
                  app:layout_constraintStart_toEndOf="@id/container2"
                  app:layout_constraintTop_toTopOf="parent">
      <ImageView android:id="@id/image3"
                 android:layout_width="@dimen/view_dimen_88"
                 android:layout_height="@dimen/view_dimen_88"
                 android:src="@drawable/warningcenter_disaster_icon_sea" />
      <TextView android:textSize="@dimen/wc_text_summary_text_size"
                android:textColor="@color/ew_text_black_color"
                android:id="@id/text3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/view_dimen_18"
                android:text="@string/warningcenter_disaster_receive_type_sea" />
    </LinearLayout>
    <LinearLayout android:gravity="center"
                  android:orientation="vertical"
                  android:id="@id/container4"
                  android:layout_width="0.0dp"
                  android:layout_height="wrap_content"
                  app:layout_constraintEnd_toStartOf="@id/container5"
                  app:layout_constraintHorizontal_weight="1.0"
                  app:layout_constraintStart_toEndOf="@id/container3"
                  app:layout_constraintTop_toTopOf="parent">
      <ImageView android:id="@id/image4"
                 android:layout_width="@dimen/view_dimen_88"
                 android:layout_height="@dimen/view_dimen_88"
                 android:src="@drawable/warningcenter_disaster_icon_forest" />
      <TextView android:textSize="@dimen/wc_text_summary_text_size"
                android:textColor="@color/ew_text_black_color"
                android:id="@id/text4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/view_dimen_18"
                android:text="@string/warningcenter_disaster_receive_type_forest" />
    </LinearLayout>
    <LinearLayout android:gravity="center"
                  android:orientation="vertical"
                  android:id="@id/container5"
                  android:layout_width="0.0dp"
                  android:layout_height="wrap_content"
                  app:layout_constraintEnd_toEndOf="parent"
                  app:layout_constraintHorizontal_weight="1.0"
                  app:layout_constraintStart_toEndOf="@id/container4"
                  app:layout_constraintTop_toTopOf="parent">
      <ImageView android:id="@id/image5"
                 android:layout_width="@dimen/view_dimen_88"
                 android:layout_height="@dimen/view_dimen_88"
                 android:src="@drawable/warningcenter_disaster_icon_biological" />
      <TextView android:textSize="@dimen/wc_text_summary_text_size"
                android:textColor="@color/ew_text_black_color"
                android:id="@id/text5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/view_dimen_18"
                android:text="@string/warningcenter_disaster_receive_type_biological" />
    </LinearLayout>
  </androidx.constraintlayout.widget.ConstraintLayout>
</LinearLayout>