<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:background="@drawable/card_bg_no_shadow_selector"
              android:paddingTop="@dimen/scan_result_bm_card_padding_top"
              android:paddingBottom="@dimen/scan_result_bm_card_pad_bottom"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:paddingStart="@dimen/dp_16"
              android:paddingEnd="@dimen/dp_16" xmlns:android="http://schemas.android.com/apk/res/android">
  <include android:id="@id/system_title"
           layout="@layout/card_layout_scan_result_title" />
  <LinearLayout android:orientation="vertical"
                android:id="@id/ll_container_system"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/result_bottom_card_item_margin_top" />
  <FrameLayout android:layout_width="fill_parent"
               android:layout_height="@dimen/scan_result_item_seprate_height"
               android:paddingStart="@dimen/scan_result_bottom_title_item_margin_l"
               android:paddingEnd="@dimen/scan_result_bottom_title_item_margin_r">
    <View android:layout_gravity="center_vertical"
          android:background="@color/app_manager_card_separate_line_bg"
          android:layout_width="fill_parent"
          android:layout_height="@dimen/scan_result_item_line_height"
          android:layout_marginTop="@dimen/scan_result_bm_card_line_padding_btm" />
  </FrameLayout>
  <include android:id="@id/cleanup_title"
           layout="@layout/card_layout_scan_result_title" />
  <LinearLayout android:orientation="vertical"
                android:id="@id/ll_container_cleanup"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/result_bottom_card_item_margin_top" />
  <FrameLayout android:layout_width="fill_parent"
               android:layout_height="@dimen/scan_result_item_seprate_height"
               android:paddingStart="@dimen/scan_result_bottom_title_item_margin_l"
               android:paddingEnd="@dimen/scan_result_bottom_title_item_margin_r">
    <View android:layout_gravity="center_vertical"
          android:background="@color/app_manager_card_separate_line_bg"
          android:layout_width="fill_parent"
          android:layout_height="@dimen/scan_result_item_line_height"
          android:layout_marginTop="@dimen/scan_result_bm_card_line_padding_btm" />
  </FrameLayout>
  <include android:id="@id/security_title"
           layout="@layout/card_layout_scan_result_title" />
  <LinearLayout android:orientation="vertical"
                android:id="@id/ll_container_security"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/result_bottom_card_item_margin_top" />
</LinearLayout>