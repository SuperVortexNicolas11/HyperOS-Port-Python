<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:layout_gravity="top"
              android:orientation="horizontal"
              android:background="@drawable/am_card_bg_selector"
              android:descendantFocusability="blocksDescendants"
              android:layout_width="fill_parent"
              android:layout_height="@dimen/qr_list_item_height"
              android:paddingStart="@dimen/qr_margin_left"
              android:paddingEnd="@dimen/qr_margin_right" xmlns:android="http://schemas.android.com/apk/res/android">
  <ImageView android:layout_gravity="center"
             android:id="@id/app_icon"
             android:layout_width="@dimen/qr_list_icon_size"
             android:layout_height="@dimen/qr_list_icon_size" />
  <TextView android:textSize="@dimen/qr_title_text_size"
            android:textColor="@color/qr_title_text_color"
            android:layout_gravity="center"
            android:id="@id/app_name"
            android:layout_width="0.0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.0"
            android:textAlignment="viewStart"
            android:layout_marginStart="@dimen/qr_list_title_margin_left" />
  <CheckBox android:layout_gravity="center"
            android:id="@id/reply_switch"
            android:focusable="false"
            android:clickable="false"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:scaleType="center" />
</LinearLayout>