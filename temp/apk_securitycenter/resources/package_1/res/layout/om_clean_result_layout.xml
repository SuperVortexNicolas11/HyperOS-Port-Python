<?xml version='1.0' encoding='utf-8' ?>
<RelativeLayout android:orientation="vertical"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <LinearLayout android:orientation="vertical"
                android:id="@id/clean_finish_layout"
                android:layout_width="fill_parent"
                android:layout_height="@dimen/om_main_top_height">
    <ImageView android:layout_gravity="center_horizontal"
               android:id="@id/clean_little_icon"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:layout_marginTop="@dimen/om_result_score_icon_margin_top"
               android:src="@drawable/optimizemanage_result_icon" />
    <TextView android:textSize="@dimen/om_result_top_finish_text_size"
              android:textStyle="bold"
              android:textColor="@color/om_result_finish_text_color"
              android:ellipsize="end"
              android:gravity="center_horizontal"
              android:layout_gravity="center_horizontal"
              android:id="@id/clean_finish_text"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/om_result_top_finish_text_margin_top"
              android:maxLines="3"
              android:layout_marginStart="@dimen/om_result_text_margin_se"
              android:layout_marginEnd="@dimen/om_result_text_margin_se" />
    <TextView android:textSize="@dimen/om_clean_memory_tip_text_size"
              android:textColor="@color/om_clean_memory_size_tip_color"
              android:ellipsize="end"
              android:layout_gravity="center_horizontal"
              android:id="@id/clean_memory_text"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/om_result_memory_text_margin_top"
              android:singleLine="true"
              android:layout_below="@id/clean_finish_text"
              android:layout_marginStart="@dimen/om_result_text_margin_se"
              android:layout_marginEnd="@dimen/om_result_text_margin_se" />
  </LinearLayout>
  <miuix.springback.view.SpringBackLayout android:id="@id/spring_back_layout"
                        android:layout_width="fill_parent"
                        android:layout_height="fill_parent"
                        app:scrollableView="@id/clean_result">
    <com.miui.common.customview.AutoPasteListView android:orientation="vertical"
                          android:id="@id/clean_result"
                          android:scrollbars="none"
                          android:clipToPadding="false"
                          android:layout_width="fill_parent"
                          android:layout_height="fill_parent"
                          android:layout_alignParentTop="true" />
  </miuix.springback.view.SpringBackLayout>
</RelativeLayout>