<?xml version='1.0' encoding='utf-8' ?>
<RelativeLayout android:paddingTop="@dimen/card_layout_line_height_half"
                android:paddingBottom="@dimen/card_layout_line_height_half"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:antivirus="http://schemas.android.com/apk/res-auto">
  <com.miui.antivirus.ui.RoundCornerRelativeLayout android:id="@id/inner_layout"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        antivirus:roundCornerRadius="@dimen/card_bg_no_shadow_radius">
    <com.miui.antivirus.ui.ResizeFrameLayout android:layout_width="fill_parent"
                          android:layout_height="@dimen/result_activity_round_image_height_7"
                          antivirus:ratioXY="0.435">
      <com.miui.securitycenter.ad.view.AdImageView android:id="@id/img"
                            android:layout_width="fill_parent"
                            android:layout_height="fill_parent"
                            android:scaleType="centerCrop" />
    </com.miui.antivirus.ui.ResizeFrameLayout>
    <LinearLayout android:layout_gravity="center|start"
                  android:orientation="horizontal"
                  android:background="@drawable/card_title_bg_activity_template_7"
                  android:paddingTop="@dimen/dp_14"
                  android:paddingBottom="@dimen/dp_14"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content"
                  android:layout_alignParentBottom="true"
                  android:paddingStart="@dimen/dp_12"
                  android:paddingEnd="@dimen/dp_12"
                  android:layout_alignParentEnd="true">
      <TextView android:textSize="@dimen/sp_15"
                android:textColor="@color/result_activity_template_7_title_color"
                android:id="@id/title"
                android:layout_width="0.0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.0" />
      <include android:visibility="gone"
               layout="@layout/adv_close_layout_light" />
    </LinearLayout>
    <TextView android:id="@id/summary"
              android:visibility="gone"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content" />
  </com.miui.antivirus.ui.RoundCornerRelativeLayout>
</RelativeLayout>