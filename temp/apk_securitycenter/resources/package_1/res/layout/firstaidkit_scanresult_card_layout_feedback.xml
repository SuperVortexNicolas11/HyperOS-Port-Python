<?xml version='1.0' encoding='utf-8' ?>
<androidx.constraintlayout.widget.ConstraintLayout android:orientation="vertical"
                      android:background="@drawable/card_bg_no_shadow_normal"
                      android:paddingTop="@dimen/result_func_item_padding_top"
                      android:paddingBottom="@dimen/result_func_item_padding_bottom"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content"
                      android:paddingStart="@dimen/result_card_margin_left"
                      android:paddingEnd="@dimen/result_card_margin_left" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <ImageView android:layout_gravity="center"
             android:id="@id/tv_icon"
             android:layout_width="@dimen/card_main_list_banner_iv_banner_size"
             android:layout_height="@dimen/card_main_list_banner_iv_banner_size"
             android:scaleType="centerInside"
             android:layout_centerVertical="true"
             android:contentDescription="@null"
             app:layout_constraintStart_toStartOf="parent"
             app:layout_constraintTop_toTopOf="parent" />
  <TextView android:id="@id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:textAlignment="viewStart"
            android:layout_marginStart="@dimen/result_icon_padding_end"
            app:layout_constraintStart_toEndOf="@id/tv_icon"
            app:layout_constraintTop_toTopOf="parent"
            style="@style/CardTitleTextViewStyle" />
  <TextView android:id="@id/tv_summary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/view_dimen_4"
            android:layout_below="@id/tv_title"
            android:textAlignment="viewStart"
            android:layout_marginStart="@dimen/result_icon_padding_end"
            app:layout_constrainedWidth="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toEndOf="@id/tv_icon"
            app:layout_constraintTop_toBottomOf="@id/tv_title"
            style="@style/CardSummaryTextViewStyle" />
  <Button android:gravity="center"
          android:layout_gravity="bottom|center|end"
          android:id="@id/btn_action"
          android:layout_marginTop="@dimen/result_button_padding_top"
          android:text="@string/btn_text_goto_setup"
          android:singleLine="true"
          app:layout_constraintEnd_toEndOf="parent"
          app:layout_constraintTop_toBottomOf="@id/tv_summary"
          style="@style/ResultBlueButtonStyle" />
</androidx.constraintlayout.widget.ConstraintLayout>