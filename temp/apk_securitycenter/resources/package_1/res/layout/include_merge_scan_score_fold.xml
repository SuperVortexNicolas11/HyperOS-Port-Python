<?xml version='1.0' encoding='utf-8' ?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">
  <RelativeLayout android:id="@id/content_main"
                  android:layout_width="@dimen/hp_content_main_size"
                  android:layout_height="@dimen/hp_content_main_size"
                  android:layout_marginTop="@dimen/hp_score_view_margin_top_large"
                  android:layout_centerHorizontal="true">
    <com.miui.common.customview.ScoreTextView android:textSize="@dimen/main_card_score_textview_textsize_fold"
                          android:textColor="@color/m_activity_main_score"
                          android:id="@id/score"
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:layout_marginTop="@dimen/view_dimen_69"
                          android:singleLine="true"
                          android:layout_centerHorizontal="true"
                          android:fontFamily="mitype-demibold" />
    <TextView android:textSize="@dimen/status_bar_textsize"
              android:textColor="@color/card_summary_text_color"
              android:id="@id/status_bar"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/hp_staus_bar_text_margin_top"
              android:singleLine="true"
              android:layout_below="@id/score"
              android:layout_centerHorizontal="true" />
    <ViewStub android:id="@id/btn_action_stub"
              android:layout="@layout/m_securityscan_btn_action_viewstub_layout"
              android:layout_width="@dimen/hp_action_btn_width_fold"
              android:layout_height="@dimen/hp_action_btn_height_fold"
              android:layout_marginTop="@dimen/hp_button_margin_top_large"
              android:layout_below="@id/status_bar"
              android:layout_centerHorizontal="true" />
  </RelativeLayout>
</merge>