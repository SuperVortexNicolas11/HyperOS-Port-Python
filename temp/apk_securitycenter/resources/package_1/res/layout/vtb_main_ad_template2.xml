<?xml version='1.0' encoding='utf-8' ?>
<androidx.constraintlayout.widget.ConstraintLayout android:layout_gravity="center"
                      android:orientation="vertical"
                      android:id="@id/ad_root"
                      android:background="@drawable/shape_vtb_item_ad_bg"
                      android:layout_width="fill_parent"
                      android:layout_height="@dimen/vb_main_item_ad_h" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <ImageView android:id="@id/img_icon"
             android:layout_width="@dimen/dp_px_83_5"
             android:layout_height="@dimen/dp_px_83_5"
             android:contentDescription="@null"
             android:layout_marginStart="@dimen/dp_px_24_21"
             app:layout_constraintBottom_toBottomOf="parent"
             app:layout_constraintStart_toStartOf="parent"
             app:layout_constraintTop_toTopOf="parent" />
  <TextView android:textSize="@dimen/dp_px_36"
            android:textStyle="bold"
            android:textColor="@color/vtb_main_ad_item_title2"
            android:ellipsize="end"
            android:id="@id/tv_title"
            android:layout_width="0.0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/view_dimen_24"
            android:maxLines="1"
            android:layout_marginStart="@dimen/view_dimen_20"
            app:layout_constrainedWidth="true"
            app:layout_constraintEnd_toStartOf="@id/tv_ad_x"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toEndOf="@id/img_icon"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_default="wrap" />
  <TextView android:textSize="@dimen/view_dimen_32"
            android:textColor="@color/vtb_main_ad_item_summary2"
            android:ellipsize="end"
            android:gravity="start"
            android:id="@id/tv_summary"
            android:layout_width="0.0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/vb_main_item_ad_summary_mt"
            android:maxLines="1"
            android:textAlignment="viewStart"
            android:layout_marginStart="@dimen/view_dimen_20"
            app:layout_constrainedWidth="true"
            app:layout_constraintEnd_toStartOf="@id/btn_action"
            app:layout_constraintStart_toEndOf="@id/img_icon"
            app:layout_constraintTop_toBottomOf="@id/tv_title"
            app:layout_constraintVertical_chainStyle="packed" />
  <TextView android:gravity="center"
            android:id="@id/tv_ad_x"
            android:layout_marginStart="@dimen/dp_px_16"
            android:layout_marginEnd="@dimen/dp_px_26"
            app:layout_constraintBottom_toBottomOf="@id/tv_title"
            app:layout_constraintEnd_toStartOf="@id/btn_action"
            app:layout_constraintStart_toEndOf="@id/tv_title"
            app:layout_constraintTop_toTopOf="@id/tv_title"
            style="@style/ActiveAdXTextView" />
  <Button android:textSize="@dimen/dp_px_26"
          android:textStyle="bold"
          android:textColor="@color/vtb_main_ad_item_btn2"
          android:gravity="center"
          android:id="@id/btn_action"
          android:background="@drawable/shape_vtb_item_ad_btn_bg2"
          android:layout_width="@dimen/view_dimen_128"
          android:layout_height="@dimen/view_dimen_64"
          android:paddingStart="@dimen/view_dimen_24"
          android:paddingEnd="@dimen/view_dimen_24"
          android:layout_marginEnd="@dimen/dp_px_26"
          app:layout_constraintBottom_toBottomOf="parent"
          app:layout_constraintEnd_toEndOf="parent"
          app:layout_constraintTop_toTopOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>