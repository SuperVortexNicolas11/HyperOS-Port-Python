<?xml version='1.0' encoding='utf-8' ?>
<miuix.springback.view.SpringBackLayout android:orientation="vertical"
                      android:layout_width="fill_parent"
                      android:layout_height="fill_parent"
                      app:scrollableView="@id/scrollview_main" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <androidx.core.widget.NestedScrollView android:id="@id/scrollview_main"
                        android:clipToPadding="false"
                        android:layout_width="fill_parent"
                        android:layout_height="fill_parent"
                        android:layout_alignParentTop="true"
                        android:layout_alignParentStart="true">
    <LinearLayout android:orientation="vertical"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content">
      <LinearLayout android:orientation="vertical"
                    android:background="@drawable/na_shape_list_wrapper_white_corner"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/na_main_horizontal_margin"
                    android:layout_marginRight="@dimen/na_main_horizontal_margin"
                    android:layout_marginHorizontal="@dimen/na_main_horizontal_margin">
        <RelativeLayout android:id="@id/wechat_lucky_warning"
                        android:background="@drawable/lucky_selector_up_press"
                        android:layout_width="fill_parent"
                        android:layout_height="@dimen/lucky_settingitem_appline_height"
                        android:paddingStart="@dimen/am_main_item_padding_se"
                        android:paddingEnd="@dimen/am_main_item_padding_se">
          <ImageView android:id="@id/imgview_wechat"
                     android:layout_width="@dimen/lucky_settingitem_appicon_size"
                     android:layout_height="@dimen/lucky_settingitem_appicon_size"
                     android:src="@drawable/warning_wechat"
                     android:layout_centerVertical="true"
                     android:layout_alignParentStart="true" />
          <TextView android:textSize="@dimen/lucky_settingitem_app_titlesize"
                    android:textColor="@color/lucky_settings_item_title_color"
                    android:id="@id/tv_wechat_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/wechat_lucky_warning"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="@dimen/lucky_settingitem_appicon_marginleft"
                    android:layout_toEndOf="@id/imgview_wechat" />
          <miuix.slidingwidget.widget.SlidingButton android:id="@id/sliding_button_lucky_warning"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:button="@drawable/selector_sliding_btn"
                                android:layout_centerVertical="true"
                                android:importantForAccessibility="no"
                                android:layout_alignParentEnd="true" />
        </RelativeLayout>
        <RelativeLayout android:id="@id/qq_lucky_warning"
                        android:background="@drawable/lucky_selector_down_press"
                        android:layout_width="fill_parent"
                        android:layout_height="@dimen/lucky_settingitem_appline_height"
                        android:paddingStart="@dimen/am_main_item_padding_se"
                        android:paddingEnd="@dimen/am_main_item_padding_se">
          <ImageView android:id="@id/imgview_qq"
                     android:layout_width="@dimen/lucky_settingitem_appicon_size"
                     android:layout_height="@dimen/lucky_settingitem_appicon_size"
                     android:src="@drawable/warning_qq"
                     android:layout_centerVertical="true"
                     android:layout_alignParentStart="true" />
          <TextView android:textSize="@dimen/lucky_settingitem_app_titlesize"
                    android:textColor="@color/lucky_settings_item_title_color"
                    android:id="@id/tv_qq_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/qq_lucky_warning"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="@dimen/lucky_settingitem_appicon_marginleft"
                    android:layout_toEndOf="@id/imgview_qq" />
          <miuix.slidingwidget.widget.SlidingButton android:id="@id/sliding_button_qq_lucky_warning"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:button="@drawable/selector_sliding_btn"
                                android:layout_centerVertical="true"
                                android:importantForAccessibility="no"
                                android:layout_alignParentEnd="true" />
        </RelativeLayout>
      </LinearLayout>
      <View android:background="@color/lucky_sencondsettings_line_color"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="@dimen/lucky_secondsetting_divider_line_height"
            android:layout_marginLeft="@dimen/am_main_item_padding_se"
            android:layout_marginTop="@dimen/lucky_secondsetting_line_vertical_padding"
            android:layout_marginRight="@dimen/am_main_item_padding_se"
            android:layout_marginBottom="@dimen/lucky_secondsetting_line_vertical_padding" />
      <LinearLayout android:orientation="vertical"
                    android:background="@drawable/na_shape_list_wrapper_white_corner"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/na_main_horizontal_margin"
                    android:layout_marginTop="@dimen/na_main_horizontal_margin"
                    android:layout_marginRight="@dimen/na_main_horizontal_margin"
                    android:layout_marginHorizontal="@dimen/na_main_horizontal_margin">
        <RelativeLayout android:id="@id/layout_lucky_money_group"
                        android:background="@drawable/lucky_selector_up_press"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="@dimen/lucky_secondsetting_layout_lucky_group_min_height"
                        android:paddingStart="@dimen/am_main_item_padding_se"
                        android:paddingEnd="@dimen/am_main_item_padding_se">
          <LinearLayout android:gravity="start"
                        android:orientation="vertical"
                        android:paddingTop="@dimen/lucky_onelinetxt_padding_top"
                        android:paddingBottom="@dimen/lucky_onelinetxt_padding_bottom"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:paddingEnd="@dimen/lucky_secondsetting_ll_lucky_money_group_padding_end">
            <TextView android:textSize="@dimen/lucky_setting_title_txtsize"
                      android:textColor="@color/lucky_settings_item_title_color"
                      android:id="@id/txv_lucky_money_group"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:text="@string/txv_lucky_money_group_text" />
            <TextView android:textSize="@dimen/lucky_setting_summary_txtsize"
                      android:textColor="@color/lucky_settings_item_summary_color"
                      android:id="@id/tv_lucky_tips_desc"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:layout_marginTop="@dimen/lucky_twolinetxt_margin"
                      android:text="@string/lucky_money_group_summary" />
          </LinearLayout>
          <miuix.slidingwidget.widget.SlidingButton android:id="@id/sliding_lucky_money_group"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerVertical="true"
                                android:importantForAccessibility="no"
                                android:layout_alignParentEnd="true" />
        </RelativeLayout>
        <RelativeLayout android:id="@id/layout_lucky_sound"
                        android:background="@drawable/lucky_selector_down_press"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="@dimen/lucky_secondsetting_layout_lucky_sound_min_height"
                        android:paddingStart="@dimen/am_main_item_padding_se"
                        android:paddingEnd="@dimen/am_main_item_padding_se">
          <TextView android:textSize="@dimen/lucky_setting_title_txtsize"
                    android:textColor="@color/lucky_settings_item_title_color"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="@dimen/dp_5dp"
                    android:text="@string/lucky_sound_warn"
                    android:layout_toLeftOf="@id/layout_lucky_sound_mode"
                    android:layout_alignParentStart="true" />
          <LinearLayout android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:id="@id/layout_lucky_sound_mode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_alignParentEnd="true">
            <TextView android:textSize="@dimen/lucky_setting_summary_txtsize"
                      android:textColor="@color/lucky_settings_item_summary_color"
                      android:id="@id/txv_lucky_sound"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:text="@string/lucky_sound_mode_lucky" />
            <ImageView android:layout_width="wrap_content"
                       android:layout_height="wrap_content"
                       android:src="@drawable/miuix_appcompat_arrow_right"
                       android:layout_marginStart="@dimen/lucky_secondsetting_arrow_right_margin_start" />
          </LinearLayout>
        </RelativeLayout>
      </LinearLayout>
      <View android:background="@color/lucky_sencondsettings_line_color"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="0.7dp"
            android:layout_marginLeft="@dimen/am_main_item_padding_se"
            android:layout_marginTop="@dimen/lucky_secondsetting_line_vertical_padding"
            android:layout_marginRight="@dimen/am_main_item_padding_se"
            android:layout_marginBottom="@dimen/lucky_secondsetting_line_vertical_padding" />
      <LinearLayout android:orientation="vertical"
                    android:background="@drawable/na_shape_list_wrapper_white_corner"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/na_main_horizontal_margin"
                    android:layout_marginTop="@dimen/na_main_horizontal_margin"
                    android:layout_marginRight="@dimen/na_main_horizontal_margin"
                    android:layout_marginHorizontal="@dimen/na_main_horizontal_margin">
        <RelativeLayout android:gravity="center_vertical"
                        android:id="@id/layout_donotdistrub_mode"
                        android:background="@drawable/lucky_selector_up_press"
                        android:paddingTop="@dimen/lucky_onelinetxt_padding_top"
                        android:paddingBottom="@dimen/lucky_onelinetxt_padding_bottom"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:paddingStart="@dimen/am_main_item_padding_se"
                        android:paddingEnd="@dimen/am_main_item_padding_se">
          <TextView android:textSize="@dimen/lucky_setting_title_txtsize"
                    android:textColor="@color/lucky_settings_item_title_color"
                    android:id="@id/txv_open_dnd_mode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/open_dnd_mode" />
          <miuix.slidingwidget.widget.SlidingButton android:id="@id/sliding_button_open_dnd_mode"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerVertical="true"
                                android:importantForAccessibility="no"
                                android:layout_alignParentEnd="true" />
          <TextView android:textSize="@dimen/lucky_setting_summary_txtsize"
                    android:textColor="@color/lucky_settings_item_summary_color"
                    android:id="@id/tv_open_dnd_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/lucky_onelinetxt_margin"
                    android:text="@string/open_dnd_mode_summary"
                    android:layout_below="@id/txv_open_dnd_mode"
                    android:layout_marginEnd="@dimen/lucky_secondsetting_txv_open_dnd_mode_tips_margin_end" />
        </RelativeLayout>
        <RelativeLayout android:gravity="center_vertical"
                        android:id="@id/layout_dnd_start_time"
                        android:background="@drawable/lucky_selector_mid_press"
                        android:paddingTop="@dimen/lucky_zerolinetxt_padding_top"
                        android:paddingBottom="@dimen/lucky_zerolinetxt_padding_bottom"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="@dimen/lucky_settingitem_singleline_height"
                        android:paddingStart="@dimen/am_main_item_padding_se"
                        android:paddingEnd="@dimen/am_main_item_padding_se">
          <TextView android:textSize="@dimen/lucky_setting_title_txtsize"
                    android:textColor="@color/lucky_settings_item_title_color"
                    android:id="@id/tv_dnd_start_time_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/txv_dnd_start_time_title" />
          <LinearLayout android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentTop="true"
                        android:layout_alignParentEnd="true">
            <TextView android:textSize="@dimen/lucky_setting_summary_txtsize"
                      android:textColor="@color/lucky_settings_item_summary_color"
                      android:id="@id/tv_dnd_start_time"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:text="@string/txv_dnd_start_time" />
            <ImageView android:id="@id/iv_dnd_start_time_ico"
                       android:layout_width="wrap_content"
                       android:layout_height="wrap_content"
                       android:src="@drawable/miuix_appcompat_arrow_right"
                       android:layout_marginStart="@dimen/lucky_secondsetting_arrow_right_margin_start" />
          </LinearLayout>
        </RelativeLayout>
        <RelativeLayout android:gravity="center_vertical"
                        android:id="@id/layout_dnd_end_time"
                        android:background="@drawable/lucky_selector_mid_press"
                        android:paddingTop="@dimen/lucky_zerolinetxt_padding_top"
                        android:paddingBottom="@dimen/lucky_zerolinetxt_padding_bottom"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="@dimen/lucky_settingitem_singleline_height"
                        android:paddingStart="@dimen/am_main_item_padding_se"
                        android:paddingEnd="@dimen/am_main_item_padding_se">
          <TextView android:textSize="@dimen/lucky_setting_title_txtsize"
                    android:textColor="@color/lucky_settings_item_title_color"
                    android:id="@id/tv_dnd_end_time_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/txv_dnd_end_time_title" />
          <LinearLayout android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentTop="true"
                        android:layout_alignParentEnd="true">
            <TextView android:textSize="@dimen/lucky_setting_summary_txtsize"
                      android:textColor="@color/lucky_settings_item_summary_color"
                      android:id="@id/tv_dnd_end_time"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:text="@string/txv_dnd_start_time" />
            <ImageView android:id="@id/iv_dnd_end_time_ico"
                       android:layout_width="wrap_content"
                       android:layout_height="wrap_content"
                       android:src="@drawable/miuix_appcompat_arrow_right"
                       android:layout_marginStart="@dimen/lucky_secondsetting_arrow_right_margin_start" />
          </LinearLayout>
        </RelativeLayout>
        <RelativeLayout android:gravity="center_vertical"
                        android:id="@id/layout_dnd_type"
                        android:background="@drawable/lucky_selector_down_press"
                        android:paddingTop="@dimen/lucky_zerolinetxt_padding_top"
                        android:paddingBottom="@dimen/lucky_zerolinetxt_padding_bottom"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="@dimen/lucky_settingitem_singleline_height"
                        android:paddingStart="@dimen/am_main_item_padding_se"
                        android:paddingEnd="@dimen/am_main_item_padding_se">
          <TextView android:textSize="@dimen/lucky_setting_title_txtsize"
                    android:textColor="@color/lucky_settings_item_title_color"
                    android:id="@id/tv_dnd_type_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/txv_dnd_type_title" />
          <LinearLayout android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentTop="true"
                        android:layout_alignParentEnd="true">
            <TextView android:textSize="@dimen/lucky_setting_summary_txtsize"
                      android:textColor="@color/lucky_settings_item_summary_color"
                      android:id="@id/tv_dnd_type"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:text="@string/txv_dnd_type_demo" />
            <ImageView android:id="@id/iv_dnd_type_ico"
                       android:layout_width="wrap_content"
                       android:layout_height="wrap_content"
                       android:src="@drawable/miuix_appcompat_arrow_right"
                       android:layout_marginStart="@dimen/lucky_secondsetting_arrow_right_margin_start" />
          </LinearLayout>
        </RelativeLayout>
      </LinearLayout>
    </LinearLayout>
  </androidx.core.widget.NestedScrollView>
</miuix.springback.view.SpringBackLayout>