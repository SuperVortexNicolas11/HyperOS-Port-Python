<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="horizontal"
              android:id="@id/multi_sim_layout"
              android:background="@drawable/multi_sim_bg"
              android:paddingLeft="4.0dp"
              android:paddingTop="4.0dp"
              android:paddingRight="4.0dp"
              android:paddingBottom="4.0dp"
              android:focusable="false"
              android:focusableInTouchMode="false"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:importantForAccessibility="no"
              android:paddingHorizontal="4.0dp"
              android:paddingVertical="4.0dp" xmlns:android="http://schemas.android.com/apk/res/android">
  <include android:id="@id/sim_1"
           android:layout_width="0.0dp"
           android:layout_height="wrap_content"
           android:layout_marginLeft="4.0dp"
           android:layout_marginTop="4.0dp"
           android:layout_marginBottom="4.0dp"
           android:layout_weight="1.0"
           android:layout_marginVertical="4.0dp"
           layout="@layout/multi_sim_info" />
  <include android:id="@id/sim_2"
           android:layout_width="0.0dp"
           android:layout_height="wrap_content"
           android:layout_marginTop="4.0dp"
           android:layout_marginRight="4.0dp"
           android:layout_marginBottom="4.0dp"
           android:layout_weight="1.0"
           android:layout_marginVertical="4.0dp"
           layout="@layout/multi_sim_info" />
</LinearLayout>