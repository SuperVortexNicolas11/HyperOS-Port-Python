<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:id="@id/first_item"
              android:paddingTop="@dimen/view_dimen_16"
              android:paddingBottom="@dimen/gb_vc_record_content_layout_padding_bottom"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android">
  <RelativeLayout android:id="@id/rl_header"
                  android:layout_width="fill_parent"
                  android:layout_height="@dimen/view_dimen_74"
                  android:paddingStart="@dimen/view_dimen_40"
                  android:layout_marginStart="@dimen/view_dimen_60"
                  android:layout_marginEnd="@dimen/view_dimen_60">
    <TextView android:textSize="@dimen/gb_voice_changer_vip_textsize"
              android:gravity="center"
              android:id="@id/tv_member_tips"
              android:visibility="gone"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_centerVertical="true"
              android:layout_alignParentEnd="true" />
    <TextView android:textSize="@dimen/gb_voice_changer_vip_textsize"
              android:textColor="@color/gb_member_vip_text_color"
              android:ellipsize="marquee"
              android:id="@id/tv_member_status"
              android:focusable="true"
              android:focusableInTouchMode="true"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:singleLine="true"
              android:drawablePadding="@dimen/view_dimen_8"
              android:layout_centerVertical="true"
              android:marqueeRepeatLimit="marquee_forever"
              android:layout_toStartOf="@id/tv_member_tips" />
    <ImageView android:id="@id/iv_loading"
               android:focusable="true"
               android:focusableInTouchMode="true"
               android:visibility="gone"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:layout_marginRight="@dimen/view_dimen_30"
               android:src="@drawable/gb_voice_loading"
               android:layout_alignParentRight="true"
               android:layout_centerVertical="true"
               android:contentDescription="@string/gb_voice_changer_user_vip_loading"
               android:importantForAccessibility="yes" />
  </RelativeLayout>
  <miuix.recyclerview.widget.RecyclerView android:id="@id/gridView_recommend"
                        android:layout_width="fill_parent"
                        android:layout_height="@dimen/game_toolbox_voice_changer_rv_height"
                        android:layout_marginLeft="@dimen/dp_16"
                        android:layout_marginTop="@dimen/gt_voice_main_mt"
                        android:layout_marginRight="@dimen/dp_16"
                        android:layout_marginHorizontal="@dimen/dp_16" />
  <com.miui.gamebooster.customview.AuditionView android:id="@id/audition_view"
                        android:layout_width="fill_parent"
                        android:layout_height="@dimen/game_toolbox_voice_changer_audition_height" />
</LinearLayout>