<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:layout_gravity="center_vertical"
              android:id="@id/close"
              android:background="@drawable/am_adv_close_bg"
              android:focusable="true"
              android:layout_width="@dimen/am_adv_close_width"
              android:layout_height="@dimen/am_adv_close_height"
              android:layout_marginStart="@dimen/am_adv_close_margin_left" xmlns:android="http://schemas.android.com/apk/res/android">
  <TextView android:textSize="@dimen/am_adv_close_text_size"
            android:textColor="#66ffffff"
            android:layout_gravity="center_vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/promotion"
            android:layout_marginStart="@dimen/am_adv_close_text_margin_left"
            android:layout_alignParentEnd="true" />
  <ImageView android:layout_gravity="center|end"
             android:layout_width="wrap_content"
             android:layout_height="wrap_content"
             android:src="@drawable/am_ads_close_light"
             android:layout_marginStart="@dimen/am_adv_colose_icon_margin_left" />
</LinearLayout>