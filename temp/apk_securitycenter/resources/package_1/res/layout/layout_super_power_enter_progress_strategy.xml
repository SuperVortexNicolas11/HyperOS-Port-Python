<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android">
  <RelativeLayout android:layout_width="fill_parent"
                  android:layout_height="wrap_content">
    <TextView android:textSize="@dimen/superpower_text_loading_textsize"
              android:textColor="@color/superpower_progress_loading_text_color"
              android:id="@id/txt_turnoff_items"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/superpower_progress_turnoff_items"
              android:textAlignment="viewStart"
              android:layout_marginEnd="@dimen/superpower_text_loading_text_margin_end" />
    <ImageView android:id="@id/iv_turnoff_items"
               android:layout_width="@dimen/superpower_imageview_loading_size"
               android:layout_height="@dimen/superpower_imageview_loading_size"
               android:src="@drawable/superpower_ic_loading"
               android:layout_centerVertical="true"
               android:layout_alignParentEnd="true" />
  </RelativeLayout>
  <RelativeLayout android:layout_gravity="center_vertical"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="@dimen/superpower_text_loading_margin">
    <TextView android:textSize="@dimen/superpower_text_loading_textsize"
              android:textColor="@color/superpower_progress_loading_text_color"
              android:id="@id/txt_turnoff_process"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/superpower_progress_turnoff_process"
              android:textAlignment="viewStart"
              android:layout_marginEnd="@dimen/superpower_text_loading_text_margin_end" />
    <ImageView android:id="@id/iv_turnoff_process"
               android:layout_width="@dimen/superpower_imageview_loading_size"
               android:layout_height="@dimen/superpower_imageview_loading_size"
               android:src="@drawable/superpower_ic_loading"
               android:layout_centerVertical="true"
               android:layout_alignParentEnd="true" />
  </RelativeLayout>
  <RelativeLayout android:layout_gravity="center_vertical"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="@dimen/superpower_text_loading_margin">
    <TextView android:textSize="@dimen/superpower_text_loading_textsize"
              android:textColor="@color/superpower_progress_loading_text_color"
              android:id="@id/txt_turndown_brightness"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/superpower_progress_turndown_brightness"
              android:textAlignment="viewStart"
              android:layout_marginEnd="@dimen/superpower_text_loading_text_margin_end" />
    <ImageView android:id="@id/iv_turndown_brightness"
               android:layout_width="@dimen/superpower_imageview_loading_size"
               android:layout_height="@dimen/superpower_imageview_loading_size"
               android:src="@drawable/superpower_ic_loading"
               android:layout_centerVertical="true"
               android:layout_alignParentEnd="true" />
  </RelativeLayout>
  <RelativeLayout android:layout_gravity="center_vertical"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="@dimen/superpower_text_loading_margin">
    <TextView android:textSize="@dimen/superpower_text_loading_textsize"
              android:textColor="@color/superpower_progress_loading_text_color"
              android:id="@id/txt_switch_home"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/superpower_progress_switch_home"
              android:textAlignment="viewStart"
              android:layout_marginEnd="@dimen/superpower_text_loading_text_margin_end" />
    <ImageView android:id="@id/iv_switch_home"
               android:layout_width="@dimen/superpower_imageview_loading_size"
               android:layout_height="@dimen/superpower_imageview_loading_size"
               android:src="@drawable/superpower_ic_loading"
               android:layout_centerVertical="true"
               android:layout_alignParentEnd="true" />
  </RelativeLayout>
</LinearLayout>