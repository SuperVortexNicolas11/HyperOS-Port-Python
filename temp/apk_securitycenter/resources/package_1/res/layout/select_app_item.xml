<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:gravity="center_vertical"
              android:orientation="horizontal"
              style="@style/auto_task_item_padding" xmlns:android="http://schemas.android.com/apk/res/android">
  <ImageView android:id="@id/app_icon"
             style="@style/ListIconNoMargin" />
  <TextView android:ellipsize="end"
            android:id="@id/app_name"
            android:maxLines="1"
            android:layout_weight="1.0"
            android:fontFamily="mipro-medium"
            android:textAlignment="viewStart"
            android:layout_marginStart="@dimen/view_dimen_41"
            android:layout_marginEnd="@dimen/view_dimen_31"
            style="@style/ListItemTitle" />
  <RadioButton android:id="@id/app_radio_button"
               android:visibility="gone"
               android:clickable="false"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:button="@drawable/auto_task_radio_button_bg"
               android:importantForAccessibility="no" />
  <CheckBox android:id="@id/app_check_box"
            android:visibility="gone"
            android:clickable="false"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:importantForAccessibility="no" />
</LinearLayout>