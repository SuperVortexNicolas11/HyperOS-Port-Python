<?xml version='1.0' encoding='utf-8' ?>
<RelativeLayout android:background="@drawable/pc_normal_item_selector"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/miuix_appcompat_list_preferred_item_height"
                android:paddingStart="@dimen/auto_task_list_item_padding"
                android:paddingEnd="@dimen/auto_task_list_item_padding" xmlns:android="http://schemas.android.com/apk/res/android">
  <ImageView android:id="@id/icon"
             android:layout_width="@dimen/auto_task_list_item_icon_size"
             android:layout_height="@dimen/auto_task_list_item_icon_size"
             android:src="@drawable/battery_selector"
             android:scaleType="center"
             android:layout_centerVertical="true"
             android:paddingEnd="@dimen/auto_task_list_item_icon_padding_end" />
  <RelativeLayout android:paddingTop="@dimen/auto_task_list_item_content_padding_top"
                  android:paddingBottom="@dimen/auto_task_list_item_content_padding_top"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_weight="1.0"
                  android:layout_centerVertical="true"
                  android:layout_toEndOf="@id/icon">
    <LinearLayout android:orientation="vertical"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_centerVertical="true"
                  android:layout_toStartOf="@id/widget"
                  android:layout_alignParentStart="true">
      <TextView android:textSize="@dimen/text_font_size_48"
                android:textStyle="bold"
                android:id="@id/title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
      <TextView android:textSize="@dimen/font_size_38"
                android:textColor="@color/pc_autotask_preference_summary_text_color"
                android:id="@id/summary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
    </LinearLayout>
    <FrameLayout android:id="@id/widget"
                 android:layout_width="wrap_content"
                 android:layout_height="wrap_content"
                 android:layout_centerVertical="true"
                 android:layout_alignParentEnd="true">
      <com.miui.common.ui.HoverSlidingSwitch android:id="@id/slide"
                            android:focusable="true"
                            android:clickable="true"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
      <CheckBox android:id="@android:id/checkbox"
                android:focusable="false"
                android:visibility="gone"
                android:clickable="false"
                android:duplicateParentState="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
    </FrameLayout>
  </RelativeLayout>
</RelativeLayout>