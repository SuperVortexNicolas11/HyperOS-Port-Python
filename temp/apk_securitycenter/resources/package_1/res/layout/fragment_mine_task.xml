<?xml version='1.0' encoding='utf-8' ?>
<FrameLayout android:id="@id/task_center_layout"
             android:layout_width="fill_parent"
             android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <miuix.springback.view.SpringBackLayout android:layout_width="fill_parent"
                        android:layout_height="fill_parent"
                        app:scrollableView="@id/default_task_list">
    <miuix.recyclerview.widget.RecyclerView android:orientation="vertical"
                          android:id="@id/default_task_list"
                          android:paddingBottom="@dimen/view_dimen_273"
                          android:scrollbars="none"
                          android:clipToPadding="false"
                          android:layout_width="fill_parent"
                          android:layout_height="fill_parent"
                          android:overScrollMode="never"
                          android:importantForAccessibility="no"
                          app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
  </miuix.springback.view.SpringBackLayout>
  <include android:id="@id/empty_view"
           android:visibility="gone"
           layout="@layout/empty_view_maml" />
  <ImageView android:layout_gravity="bottom|center|end"
             android:id="@id/add_task"
             android:layout_width="wrap_content"
             android:layout_height="wrap_content"
             android:src="@drawable/auto_task_icon_add_new_task_big"
             android:contentDescription="@null" />
</FrameLayout>