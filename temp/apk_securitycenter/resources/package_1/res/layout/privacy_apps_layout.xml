<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:id="@id/container"
              android:background="@color/pa_apps_page_bg"
              android:layout_width="fill_parent"
              android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android">
  <LinearLayout android:orientation="vertical"
                android:id="@id/center_layout"
                android:paddingBottom="@dimen/dp_28"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:paddingStart="@dimen/dp_12"
                android:paddingEnd="@dimen/dp_12">
    <miuix.recyclerview.widget.RecyclerView android:id="@id/privacy_apps_gridview"
                          android:paddingTop="@dimen/view_dimen_44"
                          android:paddingBottom="@dimen/view_dimen_44"
                          android:scrollbars="none"
                          android:clipToPadding="false"
                          android:layout_width="fill_parent"
                          android:layout_height="0.0dp"
                          android:layout_weight="1.0"
                          android:overScrollMode="never"
                          android:paddingVertical="@dimen/view_dimen_44" />
    <com.miui.privacyapps.view.PrivacyBottomSlideView android:id="@id/hide_notification"
                          android:visibility="gone"
                          android:layout_width="fill_parent"
                          android:layout_height="wrap_content" />
    <com.miui.privacyapps.view.PrivacyBottomSlideView android:id="@id/password_enable"
                          android:visibility="gone"
                          android:layout_width="fill_parent"
                          android:layout_height="wrap_content" />
  </LinearLayout>
</LinearLayout>