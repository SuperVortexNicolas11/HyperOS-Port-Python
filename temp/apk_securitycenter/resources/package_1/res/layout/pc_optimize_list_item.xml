<?xml version='1.0' encoding='utf-8' ?>
<RelativeLayout android:id="@id/root_view"
                android:background="@drawable/pc_card_bg"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:importantForAccessibility="yes" xmlns:android="http://schemas.android.com/apk/res/android">
  <LinearLayout android:orientation="vertical"
                android:id="@id/item_layout"
                android:paddingLeft="@dimen/miuix_item_padding_start"
                android:paddingRight="@dimen/miuix_item_padding_start"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:layout_marginTop="@dimen/ew_alert_card_title_margin_top"
                android:layout_marginBottom="@dimen/ew_alert_card_from_margin_top"
                android:paddingHorizontal="@dimen/miuix_item_padding_start">
    <LinearLayout android:orientation="horizontal"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content">
      <LinearLayout android:orientation="vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0">
        <TextView android:textSize="@dimen/text_font_size_48"
                  android:textStyle="bold"
                  android:textColor="@color/pc_main_item_title_color"
                  android:id="@id/title"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:paddingEnd="@dimen/am_adv_close_text_margin_left" />
        <TextView android:textSize="@dimen/text_font_size_38"
                  android:textColor="@color/pc_scan_result_summary_black_color"
                  android:id="@id/summary"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content" />
      </LinearLayout>
      <TextView android:textSize="@dimen/text_font_size_38"
                android:textColor="#43b84f"
                android:layout_gravity="center_vertical"
                android:id="@id/time_flag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
      <FrameLayout android:layout_gravity="center_vertical"
                   android:layout_width="wrap_content"
                   android:layout_height="wrap_content"
                   android:paddingStart="10.0dp">
        <CheckBox android:id="@id/select"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:checked="true"
                  android:importantForAccessibility="no" />
        <ImageView android:id="@id/status"
                   android:visibility="gone"
                   android:layout_width="wrap_content"
                   android:layout_height="wrap_content"
                   android:singleLine="true" />
      </FrameLayout>
    </LinearLayout>
    <com.miui.powercenter.view.AutoHeightGridView android:id="@id/child_list"
                          android:duplicateParentState="true"
                          android:layout_width="fill_parent"
                          android:layout_height="wrap_content"
                          android:horizontalSpacing="@dimen/view_dimen_52"
                          android:verticalSpacing="@dimen/view_dimen_44"
                          android:stretchMode="spacingWidth"
                          android:columnWidth="@dimen/power_gridview_item_column_width"
                          android:numColumns="auto_fit" />
  </LinearLayout>
</RelativeLayout>