<?xml version='1.0' encoding='utf-8' ?>
<RelativeLayout android:id="@id/white_list_view"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <Button android:layout_gravity="center"
          android:id="@id/v_white_list_cleanup_btn"
          android:layout_width="fill_parent"
          android:layout_height="wrap_content"
          android:layout_marginLeft="23.0dp"
          android:layout_marginTop="18.0dp"
          android:layout_marginRight="23.0dp"
          android:layout_marginBottom="18.0dp"
          android:text="@string/button_text_delete_from_virus_white_list"
          android:layout_alignParentBottom="true"
          android:layout_marginHorizontal="23.0dp"
          android:layout_marginVertical="18.0dp" />
  <miuix.springback.view.SpringBackLayout android:layout_width="fill_parent"
                        android:layout_height="fill_parent"
                        android:layout_above="@id/v_white_list_cleanup_btn"
                        app:scrollableView="@id/v_white_list">
    <miuix.recyclerview.widget.RecyclerView android:orientation="vertical"
                          android:id="@id/v_white_list"
                          android:layout_width="fill_parent"
                          android:layout_height="fill_parent"
                          android:screenReaderFocusable="true"
                          app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
  </miuix.springback.view.SpringBackLayout>
  <include android:id="@id/empty_view"
           android:visibility="gone"
           android:layout_width="fill_parent"
           android:layout_height="fill_parent"
           android:layout_centerInParent="true"
           layout="@layout/empty_view_maml" />
</RelativeLayout>