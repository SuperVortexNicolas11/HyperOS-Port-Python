<?xml version='1.0' encoding='utf-8' ?>
<com.miui.gamebooster.customview.ConstrainLayoutWithCoolTime android:id="@id/item_bg"
                      android:focusable="true"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <androidx.constraintlayout.widget.ConstraintLayout android:id="@id/cl_box"
                        android:background="@drawable/selector_pickup_item_style"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/dp_12"
                        android:layout_marginEnd="@dimen/dp_12"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">
    <ImageView android:id="@id/img_check"
               android:background="@drawable/selector_pickup_checked_style"
               android:layout_width="@dimen/dp_20"
               android:layout_height="@dimen/dp_20"
               android:layout_marginStart="@dimen/dp_16"
               app:layout_constraintBottom_toBottomOf="parent"
               app:layout_constraintStart_toStartOf="parent"
               app:layout_constraintTop_toTopOf="parent" />
    <com.miui.gamebooster.videobox.view.MarqueeTextView android:textSize="@dimen/dp_14"
                          android:textColor="@color/conversation_pickup_title_selector"
                          android:ellipsize="marquee"
                          android:id="@id/tv_title"
                          android:layout_width="0.0dp"
                          android:layout_height="wrap_content"
                          android:layout_marginTop="@dimen/dp_12"
                          android:singleLine="true"
                          android:layout_marginStart="@dimen/dp_8"
                          android:layout_marginEnd="@dimen/dp_16"
                          app:layout_constraintBottom_toTopOf="@id/tv_desc"
                          app:layout_constraintEnd_toEndOf="parent"
                          app:layout_constraintStart_toEndOf="@id/img_check"
                          app:layout_constraintTop_toTopOf="parent"
                          app:layout_constraintVertical_chainStyle="packed" />
    <com.miui.gamebooster.videobox.view.MarqueeTextView android:textSize="@dimen/dp_12"
                          android:textColor="@color/conversation_pickup_desc_selector"
                          android:ellipsize="marquee"
                          android:gravity="start"
                          android:id="@id/tv_desc"
                          android:layout_width="0.0dp"
                          android:layout_height="wrap_content"
                          android:layout_marginBottom="@dimen/dp_12"
                          android:singleLine="true"
                          android:layout_marginStart="@dimen/dp_8"
                          android:layout_marginEnd="@dimen/dp_16"
                          app:layout_constraintBottom_toBottomOf="parent"
                          app:layout_constraintEnd_toEndOf="parent"
                          app:layout_constraintStart_toEndOf="@id/img_check"
                          app:layout_constraintTop_toBottomOf="@id/tv_title" />
  </androidx.constraintlayout.widget.ConstraintLayout>
</com.miui.gamebooster.customview.ConstrainLayoutWithCoolTime>