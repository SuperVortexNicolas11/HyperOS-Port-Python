<?xml version='1.0' encoding='utf-8' ?>
<RelativeLayout android:orientation="vertical"
                android:id="@id/column"
                android:background="@drawable/hp_card_bg_no_shadow_normal"
                android:paddingTop="@dimen/six_pices_card_item_column_padding_top"
                android:clickable="true"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:minHeight="@dimen/six_pices_card_item_height"
                android:layout_weight="1.0"
                android:paddingStart="@dimen/six_pices_card_item_column_padding_start"
                android:paddingEnd="@dimen/six_pices_card_item_column_padding_end" xmlns:android="http://schemas.android.com/apk/res/android">
  <com.miui.securityscan.ui.main.FuncGrid6ImageView android:id="@id/iv_icon"
                        android:layout_width="@dimen/six_pices_card_item_icon_width"
                        android:layout_height="@dimen/six_pices_card_item_icon_height"
                        android:layout_marginTop="@dimen/dp_7_5"
                        android:layout_alignParentTop="true"
                        android:layout_alignParentStart="true" />
  <ImageView android:id="@id/iv_red_point"
             android:background="@drawable/grid_six_red_point_bg"
             android:visibility="gone"
             android:layout_width="wrap_content"
             android:layout_height="wrap_content"
             android:layout_marginTop="@dimen/dp_5_5"
             android:layout_alignParentTop="true"
             android:layout_marginStart="@dimen/dp_4"
             android:layout_toEndOf="@id/iv_icon" />
  <TextView android:textSize="@dimen/sp_17"
            android:textStyle="bold"
            android:textColor="@color/six_pices_card_item_title_textcolor"
            android:id="@id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/six_pices_card_item_title_margin_top"
            android:layout_below="@id/iv_icon" />
  <LinearLayout android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/tv_title">
    <ViewStub android:id="@id/small_icons_stub"
              android:layout="@layout/grid_small_icons_layout"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content" />
    <TextView android:textSize="@dimen/six_pices_card_summry_size"
              android:textColor="@color/six_pices_card_item_summary_textcolor"
              android:id="@id/tv_summary"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content" />
  </LinearLayout>
</RelativeLayout>