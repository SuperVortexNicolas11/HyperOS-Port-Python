<?xml version='1.0' encoding='utf-8' ?>
<androidx.constraintlayout.widget.ConstraintLayout android:layout_width="fill_parent"
                      android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <com.miui.gamebooster.videobox.view.MarqueeTextView android:textSize="@dimen/vb_advance_settings_title_txt_size"
                        android:textColor="@color/color_vb_srs_item_title"
                        android:ellipsize="marquee"
                        android:gravity="center_vertical"
                        android:id="@id/visual_tv"
                        android:layout_width="0.0dp"
                        android:layout_height="@dimen/dp_48"
                        android:text="@string/videobox_double_core_visual"
                        android:singleLine="true"
                        android:marqueeRepeatLimit="marquee_forever"
                        android:textAlignment="viewStart"
                        android:layout_marginEnd="@dimen/vb_advance_settings_txt_me"
                        app:layout_constraintLeft_toLeftOf="parent"
                        app:layout_constraintRight_toLeftOf="@id/visual_switch"
                        app:layout_constraintTop_toTopOf="parent" />
  <com.miui.gamebooster.customview.SlidingButtonWithoutPressState android:id="@id/visual_switch"
                        android:layout_width="@dimen/vb_advance_settings_sliding_btn_w"
                        android:layout_height="@dimen/vb_advance_settings_sliding_btn_h"
                        android:contentDescription="@string/videobox_double_core_visual"
                        android:layout_marginStart="@dimen/vb_advance_settings_sliding_btn_ms"
                        app:layout_constraintBottom_toBottomOf="@id/visual_tv"
                        app:layout_constraintLeft_toRightOf="@id/visual_tv"
                        app:layout_constraintRight_toRightOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        style="@style/Widget.SlidingButton.Dark" />
  <TextView android:textSize="@dimen/view_dimen_30"
            android:textColor="@color/color_vtb_dolby_headset"
            android:id="@id/tv_description1"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:text="@string/videobox_double_core_visual_description1"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toBottomOf="@id/visual_tv" />
  <ImageView android:id="@id/iv_visual"
             android:layout_width="fill_parent"
             android:layout_height="@dimen/dp_84"
             android:layout_marginTop="10.0dp"
             android:src="@drawable/iv_visaul_bg"
             android:scaleType="centerCrop"
             app:layout_constraintTop_toBottomOf="@id/tv_description1" />
  <TextView android:textSize="@dimen/view_dimen_30"
            android:textColor="@color/color_vtb_dolby_headset"
            android:id="@id/tv_description2"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10.0dp"
            android:text="@string/videobox_double_core_visual_description2"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toBottomOf="@id/iv_visual" />
</androidx.constraintlayout.widget.ConstraintLayout>