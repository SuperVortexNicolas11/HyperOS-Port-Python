<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:gravity="center"
              android:id="@id/root"
              android:background="@drawable/security_view_clip_backgroud"
              android:paddingTop="@dimen/dp_5"
              android:paddingBottom="@dimen/dp_5"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:paddingStart="@dimen/dp_9"
              android:paddingEnd="@dimen/dp_9" xmlns:android="http://schemas.android.com/apk/res/android">
  <ImageView android:layout_gravity="center_vertical"
             android:id="@id/security_view_icon"
             android:layout_width="@dimen/dp_28"
             android:layout_height="@dimen/dp_28"
             android:src="@drawable/security_paste_icon_1" />
  <TextView android:textSize="@dimen/sp_14"
            android:textColor="@color/black"
            android:gravity="center"
            android:layout_gravity="center_vertical"
            android:id="@id/security_view_text"
