<?xml version='1.0' encoding='utf-8' ?>
<androidx.constraintlayout.widget.ConstraintLayout android:layout_width="fill_parent"
                      android:layout_height="wrap_content"
                      android:minHeight="@dimen/view_dimen_130" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <ImageView android:id="@id/game_turbo_top_line_bg"
             android:layout_width="@dimen/game_toolbox_width"
             android:layout_height="@dimen/game_toolbox_height"
             android:src="@drawable/game_turbo_top_line_balance"
             android:scaleType="fitStart"
             app:layout_constraintStart_toStartOf="parent"
             app:layout_constraintTop_toTopOf="parent" />
  <com.airbnb.lottie.LottieAnimationView android:id="@id/game_turbo_top_line_lottie"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:scaleType="fitStart"
                        app:layout_constraintStart_toStartOf="@id/game_turbo_top_line_bg"
                        app:layout_constraintTop_toTopOf="@id/game_turbo_top_line_bg" />
  <ImageView android:id="@id/game_turbo_logo"
             android:layout_width="wrap_content"
             android:layout_height="wrap_content"
             android:layout_marginTop="@dimen/game_toolbox_logo_margin_top"
             android:src="@drawable/ic_game_turbo_title"
             android:layout_marginStart="@dimen/game_toolbox_logo_margin_start"
             app:layout_constraintStart_toStartOf="parent"
             app:layout_constraintTop_toTopOf="parent" />
  <TextView android:textSize="@dimen/gt_pannel_time_fontsize"
            android:textColor="@color/gb_game_turbo_box_top_title_light"
            android:id="@id/game_turbo_panel_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/game_toolbox_time_margin_start"
            app:layout_constraintBottom_toBottomOf="@id/game_turbo_logo"
            app:layout_constraintStart_toEndOf="@id/game_turbo_logo"
            app:layout_constraintTop_toTopOf="@id/game_turbo_logo" />
  <com.miui.gamebooster.windowmanager.newbox.NewToolBatteryView android:id="@id/game_turbo_panel_battery"
                        android:layout_width="@dimen/game_toolbox_battery_width"
                        android:layout_height="@dimen/game_toolbox_battery_height"
                        android:layout_marginStart="@dimen/game_toolbox_battery_margin_start"
                        app:battery_content_corner="@dimen/view_dimen_1"
                        app:battery_content_margin="@dimen/view_dimen_4"
                        app:battery_min_progress="0.05"
                        app:layout_constraintBottom_toBottomOf="@id/game_turbo_logo"
                        app:layout_constraintStart_toEndOf="@id/game_turbo_panel_time"
                        app:layout_constraintTop_toTopOf="@id/game_turbo_logo" />
  <com.miui.gamebooster.widget.LightningTextView android:textSize="@dimen/game_toolbox_game_mode_text_size"
                        android:textColor="@color/gb_color_performance_balance_selected"
                        android:ellipsize="marquee"
                        android:id="@id/tv_game_mode"
                        android:visibility="invisible"
                        android:layout_width="@dimen/game_toolbox_game_mode_text_width"
                        android:layout_height="wrap_content"
                        android:text="@string/gb_performance_balance"
                        android:singleLine="true"
                        android:drawablePadding="@dimen/game_turbo_game_mode_text_drawable_padding"
                        android:marqueeRepeatLimit="marquee_forever"
                        android:drawableEnd="@drawable/gb_ic_arrow_right"
                        android:layout_marginEnd="@dimen/game_toolbox_game_mode_text_margin_end"
                        app:layout_constraintBottom_toBottomOf="@id/game_turbo_logo"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/game_turbo_logo" />
  <com.miui.gamebooster.windowmanager.newbox.NewToolBatteryView android:id="@id/game_turbo_battery"
                        android:layout_width="@dimen/game_toolbox_battery_width"
                        android:layout_height="@dimen/game_toolbox_battery_height"
                        android:layout_marginTop="@dimen/dp_7"
                        app:battery_content_corner="@dimen/view_dimen_1"
                        app:battery_content_margin="@dimen/view_dimen_4"
                        app:battery_min_progress="0.05"
                        app:layout_constraintStart_toStartOf="@id/game_turbo_logo"
                        app:layout_constraintTop_toBottomOf="@id/game_turbo_logo" />
  <TextView android:textSize="@dimen/gt_pannel_time_fontsize"
            android:textColor="@color/gb_game_turbo_box_top_title_light"
            android:id="@id/game_turbo_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_7"
            app:layout_constraintBottom_toBottomOf="@id/game_turbo_battery"
            app:layout_constraintStart_toEndOf="@id/game_turbo_battery"
            app:layout_constraintTop_toTopOf="@id/game_turbo_battery" />
  <TextView android:textSize="@dimen/gt_pannel_time_fontsize"
            android:textColor="@color/gb_game_turbo_box_top_title_light"
            android:id="@id/game_turbo_battery_surplus"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_7"
            app:layout_constraintBottom_toBottomOf="@id/game_turbo_battery"
            app:layout_constraintStart_toEndOf="@id/game_turbo_time"
            app:layout_constraintTop_toTopOf="@id/game_turbo_battery" />
  <LinearLayout android:id="@id/layout_system_usage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/game_toolbox_system_usage_margin_top"
                app:layout_constraintStart_toStartOf="@id/game_turbo_battery"
                app:layout_constraintTop_toBottomOf="@id/game_turbo_battery">
    <ImageView android:layout_gravity="center_vertical"
               android:id="@id/wild_engine_logo"
               android:layout_width="@dimen/dp_26"
               android:layout_height="@dimen/dp_13"
               android:src="@drawable/ic_max_performance_engine_logo"
               android:scaleType="centerInside"
               android:layout_marginEnd="@dimen/dp_8" />
    <TextView android:textSize="@dimen/game_toolbox_system_usage_text_size"
              android:textColor="@color/gb_game_turbo_box_top_title_light"
              android:gravity="center"
              android:id="@id/cpu_parameter"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:drawablePadding="@dimen/game_toolbox_system_usage_drawable_padding"
              android:drawableStart="@drawable/ic_game_turbo_cpu"
              android:textAlignment="center" />
    <TextView android:textSize="@dimen/game_toolbox_system_usage_text_size"
              android:textColor="@color/gb_game_turbo_box_top_title_light"
              android:gravity="center"
              android:id="@id/gpu_parameter"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:drawablePadding="@dimen/game_toolbox_system_usage_drawable_padding"
              android:drawableStart="@drawable/ic_game_turbo_gpu"
              android:textAlignment="center"
              android:layout_marginStart="@dimen/game_toolbox_system_usage_margin_start" />
    <TextView android:textSize="@dimen/game_toolbox_system_usage_text_size"
              android:textColor="@color/gb_game_turbo_box_top_title_light"
              android:gravity="center"
              android:id="@id/fps_parameter"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:drawablePadding="@dimen/game_toolbox_system_usage_drawable_padding"
              android:drawableStart="@drawable/ic_game_turbo_fps"
              android:textAlignment="center"
              android:layout_marginStart="@dimen/game_toolbox_system_usage_margin_start" />
    <ImageView android:layout_gravity="center_vertical"
               android:id="@id/iv_vision_enhance"
               android:visibility="gone"
               android:layout_width="@dimen/dp_10"
               android:layout_height="@dimen/dp_9"
               android:src="@drawable/gameturbo_vision_enhance_small"
               android:layout_marginStart="@dimen/dp_4" />
  </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>