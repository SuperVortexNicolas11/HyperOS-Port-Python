<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="horizontal"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              style="@style/Widget.ListView.Item.SingleLine" xmlns:android="http://schemas.android.com/apk/res/android">
  <TextView android:layout_gravity="center_vertical"
            android:id="@id/name"
            android:layout_width="0.0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.0"
            android:textAlignment="viewStart"
            android:layout_marginStart="36.0dp"
            style="@style/Miuix.AppCompat.TextAppearance.List.Primary" />
  <CheckBox android:layout_gravity="center_vertical"
            android:id="@android:id/checkbox"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:clickable="false"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
</LinearLayout>