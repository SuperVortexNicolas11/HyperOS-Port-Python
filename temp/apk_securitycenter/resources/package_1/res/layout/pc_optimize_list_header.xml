<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:background="@color/pc_battery_item_normal_color"
              android:focusable="true"
              android:clickable="true"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:importantForAccessibility="yes" xmlns:android="http://schemas.android.com/apk/res/android">
  <include android:id="@id/separator_bar"
           layout="@layout/pc_list_separator_bar" />
  <LinearLayout android:id="@id/header_corner"
                android:background="@color/pc_battery_item_normal_color"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
    <TextView android:textSize="@dimen/pc_batteryhealth_title_textsize"
              android:textColor="@color/pc_optimize_result_title_color"
              android:id="@id/header_title"
              android:paddingTop="@dimen/am_search_promotion_margin_top"
              android:paddingBottom="@dimen/pc_deep_list_item_margin"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:layout_marginStart="@dimen/pc_content_container_padding" />
  </LinearLayout>
</LinearLayout>