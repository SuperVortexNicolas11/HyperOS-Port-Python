<?xml version='1.0' encoding='utf-8' ?>
<RelativeLayout android:padding="@dimen/dp_16"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android">
  <ImageView android:id="@id/task_icon"
             android:layout_width="@dimen/view_dimen_77"
             android:layout_height="@dimen/view_dimen_77"
             android:layout_centerVertical="true" />
  <TextView android:id="@id/task_title"
            android:layout_marginStart="@dimen/view_dimen_35"
            android:layout_toEndOf="@id/task_icon"
            style="@style/ListItemTitle" />
  <TextView android:id="@id/task_summary"
            android:layout_marginTop="@dimen/view_dimen_10"
            android:layout_below="@id/task_title"
            android:layout_marginStart="@dimen/view_dimen_35"
            android:layout_toEndOf="@id/task_icon"
            style="@style/ListItemSubTitle" />
</RelativeLayout>