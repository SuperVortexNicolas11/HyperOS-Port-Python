<?xml version='1.0' encoding='utf-8' ?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <com.miui.gamebooster.windowmanager.GBTopbarLayout android:id="@id/topview"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        app:turboTitleCenter="@string/gamebox_collimator" />
  <FrameLayout android:id="@id/switch_layout"
               android:layout_width="fill_parent"
               android:layout_height="@dimen/gt_pannel_second_title_height"
               android:layout_marginStart="@dimen/view_dimen_60"
               android:layout_marginEnd="@dimen/view_dimen_60">
    <TextView android:textSize="@dimen/view_dimen_38"
              android:textColor="@color/gb_member_vip_text_color"
              android:layout_gravity="center|left"
              android:id="@id/tv_title"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/gamebox_collimator" />
    <miuix.slidingwidget.widget.SlidingButton android:layout_gravity="center|right"
                          android:id="@id/gb_switch"
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:importantForAccessibility="no"
                          style="@style/Widget.SlidingButton.Dark" />
  </FrameLayout>
  <LinearLayout android:orientation="vertical"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/gt_voice_aution_title_mb"
                android:layout_marginStart="@dimen/view_dimen_60">
    <TextView android:textSize="@dimen/view_dimen_30"
              android:textColor="@color/whitealpha50"
              android:gravity="center_vertical"
              android:layout_gravity="left"
              android:focusable="true"
              android:focusableInTouchMode="true"
              android:layout_width="wrap_content"
              android:layout_height="@dimen/gt_collimator_subtitle_height"
              android:text="@string/gb_collimator_style"
              android:importantForAccessibility="yes" />
    <LinearLayout android:orientation="horizontal"
                  android:id="@id/container_style"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content" />
  </LinearLayout>
  <LinearLayout android:orientation="vertical"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/gt_voice_aution_title_mb"
                android:layout_marginStart="@dimen/view_dimen_52">
    <TextView android:textSize="@dimen/view_dimen_30"
              android:textColor="@color/whitealpha50"
              android:gravity="center_vertical"
              android:layout_gravity="left"
              android:focusable="true"
              android:focusableInTouchMode="true"
              android:layout_width="wrap_content"
              android:layout_height="@dimen/gt_collimator_subtitle_height"
              android:text="@string/gb_collimator_color"
              android:importantForAccessibility="yes"
              android:layout_marginStart="@dimen/view_dimen_8" />
    <LinearLayout android:orientation="horizontal"
                  android:id="@id/container_color"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content" />
  </LinearLayout>
  <LinearLayout android:orientation="vertical"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/view_dimen_60"
                android:layout_marginEnd="@dimen/view_dimen_60">
    <TextView android:textSize="@dimen/view_dimen_30"
              android:textColor="@color/whitealpha50"
              android:gravity="center_vertical"
              android:layout_gravity="left"
              android:focusable="false"
              android:focusableInTouchMode="false"
              android:layout_width="wrap_content"
              android:layout_height="@dimen/gt_collimator_subtitle_height"
              android:text="@string/gb_collimator_size"
              android:importantForAccessibility="no" />
    <miuix.androidbasewidget.widget.SeekBar android:id="@id/gb_seekbar"
                          android:focusable="true"
                          android:focusableInTouchMode="true"
                          android:layout_width="fill_parent"
                          android:layout_height="wrap_content"
                          android:max="100"
                          android:contentDescription="@string/gb_collimator_size"
                          android:importantForAccessibility="yes"
                          style="@style/CollimatorSeekbarStyle" />
  </LinearLayout>
</merge>