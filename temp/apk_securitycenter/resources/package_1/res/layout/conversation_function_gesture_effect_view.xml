<?xml version='1.0' encoding='utf-8' ?>
<com.miui.gamebooster.beauty.conversation.view.GestureEffectView android:orientation="vertical"
                      android:layout_width="fill_parent"
                      android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <androidx.constraintlayout.widget.ConstraintLayout android:paddingLeft="@dimen/dp_20"
                        android:paddingRight="@dimen/dp_20"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content">
    <ImageView android:id="@id/iv_back"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:src="@drawable/vtb_action_bar_back_dark"
               android:scaleType="centerCrop"
               android:contentDescription="@string/back_description_securitycenter"
               app:layout_constraintBottom_toBottomOf="@id/tv_title"
               app:layout_constraintStart_toStartOf="parent"
               app:layout_constraintTop_toTopOf="@id/tv_title" />
    <TextView android:textSize="@dimen/dp_14"
              android:textColor="@color/whitealpha90"
              android:gravity="center_horizontal"
              android:id="@id/tv_title"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:layout_marginLeft="@dimen/dp_30"
              android:layout_marginTop="@dimen/dp_18"
              android:layout_marginRight="@dimen/dp_30"
              android:layout_marginHorizontal="@dimen/dp_30"
              app:layout_constraintLeft_toLeftOf="parent"
              app:layout_constraintRight_toRightOf="parent"
              app:layout_constraintTop_toTopOf="parent" />
    <TextView android:textSize="@dimen/dp_14"
              android:textColor="@color/whitealpha90"
              android:id="@id/tv_subtitle"
              android:layout_width="0.0dp"
              android:layout_height="wrap_content"
              android:layout_marginRight="8.0dp"
              android:text="@string/cs_gesture_effect_title"
              app:layout_constraintBottom_toBottomOf="@id/gb_switch"
              app:layout_constraintLeft_toLeftOf="parent"
              app:layout_constraintRight_toLeftOf="@id/gb_switch"
              app:layout_constraintTop_toTopOf="@id/gb_switch" />
    <miuix.slidingwidget.widget.SlidingButton android:id="@id/gb_switch"
                          android:layout_width="@dimen/dp_36_37"
                          android:layout_height="@dimen/dp_20_18"
                          android:layout_marginTop="@dimen/dp_22"
                          app:layout_constraintRight_toRightOf="parent"
                          app:layout_constraintTop_toBottomOf="@id/tv_title"
                          style="@style/Widget.SlidingButton.Dark" />
    <androidx.constraintlayout.widget.Barrier android:id="@id/barrier"
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          app:barrierDirection="bottom"
                          app:constraint_referenced_ids="tv_subtitle,gb_switch" />
    <TextView android:textSize="@dimen/dp_11"
              android:textColor="@color/whitealpha40"
              android:id="@id/tv_summary"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/dp_6"
              android:text="@string/cs_gesture_effect_title_summry"
              app:layout_constraintLeft_toLeftOf="parent"
              app:layout_constraintTop_toBottomOf="@id/barrier" />
    <View android:id="@id/line"
          android:background="@color/whitealpha10"
          android:layout_width="fill_parent"
          android:layout_height="@dimen/dp_1"
          android:layout_marginTop="@dimen/dp_20"
          app:layout_constraintLeft_toLeftOf="parent"
          app:layout_constraintRight_toRightOf="parent"
          app:layout_constraintTop_toBottomOf="@id/tv_summary" />
    <TextView android:textSize="@dimen/dp_14"
              android:textColor="@color/whitealpha90"
              android:id="@id/tv_hint"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/dp_20"
              android:text="@string/cs_gesture_effect_title_hint"
              app:layout_constraintLeft_toLeftOf="parent"
              app:layout_constraintTop_toBottomOf="@id/line" />
  </androidx.constraintlayout.widget.ConstraintLayout>
  <androidx.constraintlayout.widget.ConstraintLayout android:id="@id/img_content"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dp_12"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_hint">
    <ImageView android:id="@id/iv1"
               android:layout_width="@dimen/dp_29"
               android:layout_height="@dimen/dp_29"
               android:src="@drawable/img_gesture_effect_1"
               app:layout_constraintLeft_toLeftOf="parent"
               app:layout_constraintTop_toTopOf="parent" />
    <ImageView android:id="@id/iv2"
               android:layout_width="@dimen/dp_29"
               android:layout_height="@dimen/dp_29"
               android:src="@drawable/img_gesture_effect_2"
               app:layout_constraintLeft_toRightOf="@id/iv1"
               app:layout_constraintTop_toTopOf="parent" />
    <ImageView android:id="@id/iv3"
               android:layout_width="@dimen/dp_29"
               android:layout_height="@dimen/dp_29"
               android:src="@drawable/img_gesture_effect_3"
               app:layout_constraintLeft_toRightOf="@id/iv2"
               app:layout_constraintTop_toTopOf="parent" />
    <ImageView android:id="@id/iv4"
               android:layout_width="@dimen/dp_29"
               android:layout_height="@dimen/dp_29"
               android:src="@drawable/img_gesture_effect_4"
               app:layout_constraintLeft_toRightOf="@id/iv3"
               app:layout_constraintTop_toTopOf="parent" />
    <ImageView android:id="@id/iv5"
               android:layout_width="@dimen/dp_29"
               android:layout_height="@dimen/dp_29"
               android:src="@drawable/img_gesture_effect_5"
               app:layout_constraintLeft_toRightOf="@id/iv4"
               app:layout_constraintTop_toTopOf="parent" />
  </androidx.constraintlayout.widget.ConstraintLayout>
</com.miui.gamebooster.beauty.conversation.view.GestureEffectView>