<?xml version='1.0' encoding='utf-8' ?>
<RelativeLayout android:orientation="vertical"
                android:background="@drawable/privacy_protection_item_big_bg_normal"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android">
  <ImageView android:id="@id/icon"
             android:layout_width="@dimen/dp_24"
             android:layout_height="@dimen/dp_24"
             android:layout_marginTop="@dimen/dp_20"
             android:scaleType="fitXY"
             android:layout_marginStart="@dimen/dp_16" />
  <TextView android:textSize="@dimen/sp_17"
            android:textColor="@color/sp_website_check_title_color"
            android:ellipsize="end"
            android:id="@id/title"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_10"
            android:singleLine="true"
            android:layout_below="@id/icon"
            android:fontFamily="mipro-medium"
            android:textAlignment="viewStart"
            android:layout_marginStart="@dimen/dp_16"
            android:layout_marginEnd="@dimen/dp_16" />
  <TextView android:textSize="@dimen/sp_12"
            android:textColor="@color/color_black_trans_40"
            android:ellipsize="end"
            android:id="@id/summary"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/dp_18"
            android:singleLine="true"
            android:layout_below="@id/title"
            android:textAlignment="viewStart"
            android:layout_marginStart="@dimen/dp_16"
            android:layout_marginEnd="@dimen/dp_16" />
  <TextView android:textSize="10.0dp"
            android:textColor="@color/pm_security_protection_status_color"
            android:id="@id/status"
            android:background="@drawable/pm_setting_item_security_function_status"
            android:paddingTop="@dimen/dp_2"
            android:paddingBottom="@dimen/dp_2"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_22"
            android:text="@string/sp_security_check_status_off"
            android:paddingStart="@dimen/dp_6"
            android:paddingEnd="@dimen/dp_6"
            android:layout_marginEnd="@dimen/dp_16"
            android:layout_alignParentEnd="true" />
</RelativeLayout>