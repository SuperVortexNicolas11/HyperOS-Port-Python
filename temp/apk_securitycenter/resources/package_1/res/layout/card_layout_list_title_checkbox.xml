<?xml version='1.0' encoding='utf-8' ?>
<androidx.constraintlayout.widget.ConstraintLayout android:id="@id/ll_list_title_checkbox"
                      android:background="@drawable/card_bg_no_shadow_selector"
                      android:paddingTop="@dimen/dp_19"
                      android:paddingBottom="@dimen/result_func_item_padding_bottom"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content"
                      android:minHeight="@dimen/dp_50" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <TextView android:textColor="@color/color_deep_orange_primary_default"
            android:id="@id/title"
            android:layout_width="0.0dp"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:layout_marginStart="@dimen/result_card_margin_left"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            style="@style/ResultCardListTitleTextiViewStyle" />
  <ImageView android:id="@id/iv_right_of_title"
             android:layout_width="wrap_content"
             android:layout_height="wrap_content"
             android:layout_marginStart="@dimen/dp_2"
             android:layout_marginEnd="@dimen/result_card_margin_left"
             app:layout_constraintBottom_toBottomOf="@id/title"
             app:layout_constraintEnd_toEndOf="parent"
             app:layout_constraintHorizontal_bias="0.0"
             app:layout_constraintStart_toEndOf="@id/title"
             app:layout_constraintTop_toTopOf="@id/title" />
  <TextView android:textSize="@dimen/scan_result_card_title_size"
            android:textColor="@color/result_checkbox_summry_color"
            android:id="@id/summary"
            android:visibility="visible"
            android:layout_width="0.0dp"
            android:layout_height="wrap_content"
            android:textAlignment="viewStart"
            android:layout_marginStart="@dimen/result_card_margin_left"
            android:layout_marginEnd="@dimen/result_card_margin_left"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/title" />
</androidx.constraintlayout.widget.ConstraintLayout>