<?xml version='1.0' encoding='utf-8' ?>
<RelativeLayout android:id="@id/layout_show"
                android:background="@color/na_main_activity_background"
                android:paddingTop="0.0dp"
                android:paddingBottom="0.0dp"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:paddingStart="0.0dp"
                android:paddingEnd="16.0dp"
                android:paddingVertical="0.0dp"
                style="@style/Widget.DropdownSelector.Spinner" xmlns:android="http://schemas.android.com/apk/res/android">
  <TextView android:textColor="@color/na_traffic_list_group_text_color"
            android:ellipsize="marquee"
            android:id="@id/list_spinner_title"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:duplicateParentState="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/miuix_appcompat_spinner_dropdown_selector_padding_top"
            android:layout_marginBottom="@dimen/miuix_appcompat_spinner_dropdown_selector_padding_bottom"
            android:maxWidth="300.0dp"
            android:singleLine="true"
            android:layout_centerVertical="true"
            android:marqueeRepeatLimit="1"
            android:fontFamily="sans-serif"
            android:layout_marginStart="?android:attr/listPreferredItemPaddingLeft"
            android:layout_alignParentStart="true"
            style="@style/Miuix.AppCompat.TextAppearance.List.GroupHeader" />
  <ImageView android:id="@id/imageview_open"
             android:layout_width="wrap_content"
             android:layout_height="wrap_content"
             android:src="@drawable/na_sort_drop_icon"
             android:layout_centerVertical="true"
             android:layout_marginStart="4.0dp"
             android:layout_marginEnd="-12.0dp"
             android:layout_toEndOf="@id/list_spinner_title" />
  <View android:id="@id/anchor_view"
        android:layout_width="wrap_content"
        android:layout_height="0.0dp"
        android:layout_marginTop="-5.0dp"
        android:layout_below="@id/list_spinner_title" />
  <View android:id="@id/ent_anchor_view"
        android:layout_width="1.0dp"
        android:layout_height="0.0dp"
        android:layout_alignParentEnd="true" />
</RelativeLayout>