<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:background="@drawable/card_bg_no_shadow_selector"
              android:paddingTop="@dimen/result_func_item_padding_top"
              android:paddingBottom="@dimen/result_func_item_padding_bottom"
              android:layout_width="fill_parent"
              android:layout_height="fill_parent"
              android:paddingStart="@dimen/result_card_margin_left"
              android:paddingEnd="@dimen/result_card_margin_left" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <miuix.flexible.view.HyperCellLayout android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        app:template="standard_button">
    <ImageView android:id="@id/icon"
               android:layout_width="@dimen/om_result_icon_size"
               android:layout_height="@dimen/om_result_icon_size"
               android:scaleType="centerInside"
               android:layout_marginEnd="@dimen/result_icon_padding_end"
               app:area_id="@id/area_head" />
    <TextView android:id="@id/title"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              app:area_id="@id/area_title"
              style="@style/ResultItemAdTitleStyle" />
    <TextView android:id="@id/summary"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/am_running_text_padding_tp"
              app:area_id="@id/area_content"
              app:custom_params="marginTop"
              style="@style/ResultItemAdSummaryStyle" />
  </miuix.flexible.view.HyperCellLayout>
  <FrameLayout android:layout_gravity="bottom|center|end"
               android:paddingTop="@dimen/result_button_padding_top"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content">
    <Button android:gravity="center"
            android:id="@id/button"
            android:text="@string/btn_text_goto_setup"
            android:singleLine="true"
            style="@style/ListButton" />
  </FrameLayout>
</LinearLayout>