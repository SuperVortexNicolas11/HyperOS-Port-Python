<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:padding="15.0dp"
              android:layout_width="fill_parent"
              android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android">
  <LinearLayout android:orientation="horizontal"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
    <ImageView android:id="@id/icon"
               android:layout_width="43.0dp"
               android:layout_height="43.0dp" />
    <LinearLayout android:layout_gravity="center_vertical"
                  android:orientation="vertical"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content"
                  android:layout_marginStart="12.0dp">
      <TextView android:textAppearance="@style/Miuix.AppCompat.TextAppearance.WindowTitle"
                android:id="@id/title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true" />
      <TextView android:textAppearance="@style/Miuix.AppCompat.TextAppearance.WindowTitle.Subtitle"
                android:id="@id/summary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true" />
    </LinearLayout>
  </LinearLayout>
  <LinearLayout android:orientation="vertical"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12.0dp">
    <TextView android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/hints_risk_name_title"
              style="@style/Miuix.AppCompat.TextAppearance.List.Primary" />
    <TextView android:id="@id/risk_name"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              style="@style/Miuix.AppCompat.TextAppearance.List.Secondary" />
  </LinearLayout>
  <LinearLayout android:orientation="vertical"
                android:layout_width="fill_parent"
                android:layout_height="0.0dp"
                android:layout_marginTop="12.0dp"
                android:layout_weight="1.0">
    <TextView android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/hints_risk_descx_title"
              style="@style/Miuix.AppCompat.TextAppearance.List.Primary" />
    <TextView android:id="@id/risk_descx"
              android:layout_width="wrap_content"
              android:layout_height="0.0dp"
              android:layout_weight="1.0"
              style="@style/Miuix.AppCompat.TextAppearance.List.Secondary" />
  </LinearLayout>
  <FrameLayout android:paddingTop="18.0dp"
               android:paddingBottom="3.0dp"
               android:layout_width="fill_parent"
               android:layout_height="wrap_content"
               android:paddingStart="8.0dp"
               android:paddingEnd="8.0dp">
    <Button android:layout_gravity="center"
            android:id="@id/clear"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:text="@string/button_text_clear" />
  </FrameLayout>
</LinearLayout>