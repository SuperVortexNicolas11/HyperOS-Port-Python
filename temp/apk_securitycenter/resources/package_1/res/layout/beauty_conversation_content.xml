<?xml version='1.0' encoding='utf-8' ?>
<FrameLayout android:id="@id/root"
             android:background="@android:color/transparent"
             android:layout_width="@dimen/dp_220"
             android:layout_height="@dimen/dp_362" xmlns:android="http://schemas.android.com/apk/res/android">
  <FrameLayout android:layout_gravity="center_vertical"
               android:id="@id/main_content"
               android:background="@drawable/shape_conversation_box_bg"
               android:layout_width="fill_parent"
               android:layout_height="fill_parent">
    <LinearLayout android:orientation="vertical"
                  android:id="@id/main_pannel"
                  android:layout_width="fill_parent"
                  android:layout_height="fill_parent" xmlns:app="http://schemas.android.com/apk/res-auto">
      <androidx.constraintlayout.widget.ConstraintLayout android:background="@android:color/transparent"
                            android:layout_width="fill_parent"
                            android:layout_height="fill_parent">
        <TextView android:textSize="@dimen/dp_14"
                  android:textStyle="bold"
                  android:textColor="@color/whitealpha90"
                  android:ellipsize="end"
                  android:gravity="start"
                  android:id="@id/tv_title"
                  android:layout_width="0.0dp"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="@dimen/dp_18_50"
                  android:text="@string/conversation_title"
                  android:textAlignment="viewStart"
                  android:layout_marginStart="@dimen/dp_18"
                  app:layout_constraintEnd_toStartOf="@id/tv_setting"
                  app:layout_constraintStart_toStartOf="parent"
                  app:layout_constraintTop_toTopOf="parent" />
        <ImageView android:id="@id/tv_setting"
                   android:layout_width="@dimen/dp_30"
                   android:layout_height="@dimen/dp_30"
                   android:src="@drawable/vtb_icon_main_settings"
                   android:scaleType="center"
                   android:contentDescription="@string/vb_settings"
                   android:layout_marginEnd="@dimen/dp_15"
                   app:layout_constraintBottom_toBottomOf="@id/tv_title"
                   app:layout_constraintEnd_toEndOf="parent"
                   app:layout_constraintTop_toTopOf="@id/tv_title" />
        <androidx.recyclerview.widget.RecyclerView android:id="@id/lv_main_container"
                              android:paddingBottom="@dimen/dp_25"
                              android:clipToPadding="false"
                              android:layout_width="fill_parent"
                              android:layout_height="0.0dp"
                              android:layout_marginTop="@dimen/dp_15_50"
                              android:layout_marginStart="@dimen/dp_6"
                              android:layout_marginEnd="@dimen/dp_6"
                              app:layout_constraintBottom_toBottomOf="parent"
                              app:layout_constraintTop_toBottomOf="@id/tv_title" />
      </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>
    <FrameLayout android:id="@id/second_view"
                 android:layout_width="fill_parent"
                 android:layout_height="fill_parent" />
  </FrameLayout>
</FrameLayout>