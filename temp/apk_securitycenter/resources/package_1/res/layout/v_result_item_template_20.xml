<?xml version='1.0' encoding='utf-8' ?>
<RelativeLayout android:paddingTop="@dimen/card_layout_line_height_half"
                android:paddingBottom="@dimen/card_layout_line_height_half"
                android:descendantFocusability="blocksDescendants"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:clean="http://schemas.android.com/apk/res/com.miui.securitycenter">
  <LinearLayout android:gravity="center_vertical"
                android:orientation="vertical"
                android:id="@id/inner_layout"
                android:background="@drawable/shape_result_card_border_whole"
                android:paddingTop="@dimen/dp_18"
                android:paddingBottom="@dimen/dp_18"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:paddingStart="@dimen/dp_16"
                android:paddingEnd="@dimen/dp_16">
    <LinearLayout android:gravity="center_vertical"
                  android:orientation="horizontal"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content">
      <com.miui.optimizemanage.view.OMRoundResizeFrameLayout android:layout_width="@dimen/dp_108"
                            android:layout_height="@dimen/dp_74"
                            clean:ratioXY="0.685"
                            clean:roundCornerRadius="@dimen/dp_8">
        <ImageView android:id="@id/img"
                   android:layout_width="fill_parent"
                   android:layout_height="fill_parent"
                   android:scaleType="centerCrop" />
      </com.miui.optimizemanage.view.OMRoundResizeFrameLayout>
      <RelativeLayout android:orientation="vertical"
                      android:layout_width="0.0dp"
                      android:layout_height="fill_parent"
                      android:layout_weight="1.0"
                      android:layout_marginStart="@dimen/dp_20">
        <TextView android:textSize="@dimen/sp_15"
                  android:ellipsize="end"
                  android:id="@id/title"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content"
                  android:maxLines="2" />
        <LinearLayout android:orientation="horizontal"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content"
                      android:layout_alignParentBottom="true"
                      android:layout_alignParentStart="true">
          <TextView android:textSize="@dimen/sp_11"
                    android:layout_gravity="center_vertical"
                    android:id="@id/summary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0"
                    style="@style/ResultBottomText" />
          <include android:visibility="invisible"
                   layout="@layout/adv_close_layout" />
        </LinearLayout>
      </RelativeLayout>
    </LinearLayout>
    <Button android:layout_gravity="end"
            android:id="@id/button"
            android:layout_marginTop="@dimen/dp_14"
            style="@style/ResultBlueButtonStyle" />
  </LinearLayout>
</RelativeLayout>