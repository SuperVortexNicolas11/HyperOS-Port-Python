<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:paddingTop="@dimen/card_layout_line_height_half"
              android:paddingBottom="@dimen/card_layout_line_height_half"
              android:descendantFocusability="blocksDescendants"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android">
  <LinearLayout android:orientation="vertical"
                android:id="@id/inner_layout"
                android:background="@drawable/shape_result_card_border_whole"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
    <TextView android:textSize="@dimen/sp_14"
              android:textColor="@color/app_manager_category_title_color"
              android:gravity="center_vertical"
              android:id="@id/title"
              android:paddingTop="@dimen/antivirus_header_padding_top"
              android:paddingBottom="@dimen/antivirus_header_padding_bottom"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:singleLine="true"
              android:paddingStart="@dimen/antivirus_header_padding_top" />
    <LinearLayout android:orientation="horizontal"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="@dimen/view_dimen_40">
      <View android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1.0" />
      <ImageView android:id="@id/icon1"
                 android:layout_width="@dimen/antivirus_pay_protection_icon_size"
                 android:layout_height="@dimen/antivirus_pay_protection_icon_size"
                 android:src="@drawable/icon_def"
                 android:scaleType="centerCrop" />
      <View android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1.0" />
      <ImageView android:id="@id/icon2"
                 android:layout_width="@dimen/antivirus_pay_protection_icon_size"
                 android:layout_height="@dimen/antivirus_pay_protection_icon_size"
                 android:src="@drawable/icon_def"
                 android:scaleType="centerCrop" />
      <View android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1.0" />
      <ImageView android:id="@id/icon3"
                 android:layout_width="@dimen/antivirus_pay_protection_icon_size"
                 android:layout_height="@dimen/antivirus_pay_protection_icon_size"
                 android:src="@drawable/icon_def"
                 android:scaleType="centerCrop" />
      <View android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1.0" />
      <ImageView android:id="@id/icon4"
                 android:layout_width="@dimen/antivirus_pay_protection_icon_size"
                 android:layout_height="@dimen/antivirus_pay_protection_icon_size"
                 android:src="@drawable/icon_def"
                 android:scaleType="centerCrop" />
      <View android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1.0" />
    </LinearLayout>
    <FrameLayout android:paddingTop="@dimen/result_ad_item_padding_bottom"
                 android:paddingBottom="@dimen/result_ad_item_padding_bottom"
                 android:layout_width="fill_parent"
                 android:layout_height="wrap_content"
                 android:paddingStart="@dimen/result_card_margin_left"
                 android:paddingEnd="@dimen/result_card_margin_left">
      <Button android:layout_gravity="end"
              android:id="@id/button"
              style="@style/ResultBlueButtonStyle" />
    </FrameLayout>
  </LinearLayout>
</LinearLayout>