<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:id="@id/rl_traff"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:layout_marginLeft="28.36dp" xmlns:android="http://schemas.android.com/apk/res/android">
  <TextView android:textSize="17.45sp"
            android:textStyle="bold"
            android:textColor="@color/bh_color_main_title_text_black"
            android:gravity="center|start"
            android:layout_gravity="center_vertical"
            android:id="@id/buy_traffic_title"
            android:layout_width="wrap_content"
            android:layout_height="fill_parent"
            android:text="@string/bh_charge_traffic"
            android:layout_centerVertical="true" />
  <LinearLayout android:layout_gravity="center"
                android:orientation="horizontal"
                android:id="@id/layout_title"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14.54dp">
    <LinearLayout android:gravity="center_vertical"
                  android:orientation="horizontal"
                  android:id="@id/click_to_set"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content">
      <TextView android:textSize="17.45sp"
                android:textStyle="normal"
                android:textColor="@color/transparent_40_bh_black_ff"
                android:gravity="center|start"
                android:layout_gravity="center_vertical"
                android:id="@id/buy_traffic_phone_number"
                android:layout_width="wrap_content"
                android:layout_height="fill_parent"
                android:text="@string/bh_home_to_set_phone_number"
                android:layout_centerVertical="true" />
      <ImageView android:id="@id/set_phone_iv"
                 android:layout_width="wrap_content"
                 android:layout_height="fill_parent"
                 android:layout_marginLeft="5.81dp"
                 android:layout_marginTop="1.0dp"
                 android:src="@drawable/click_to_edit_number" />
    </LinearLayout>
    <TextView android:textSize="14.54sp"
              android:textColor="@color/bh_blue_ff"
              android:gravity="center|end"
              android:layout_gravity="center_vertical"
              android:id="@id/tv_other_charge"
              android:paddingLeft="3.0dp"
              android:paddingRight="3.0dp"
              android:layout_width="0.0dp"
              android:layout_height="fill_parent"
              android:layout_marginRight="29.09dp"
              android:text="@string/bh_charge_for_more"
              android:drawablePadding="3.0dp"
              android:layout_weight="1.0"
              android:layout_centerVertical="true"
              android:drawableTint="@color/bh_color_main_text_black_40"
              android:paddingHorizontal="3.0dp" />
  </LinearLayout>
  <LinearLayout android:orientation="vertical"
                android:id="@id/ll_traffic"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content" />
</LinearLayout>