<?xml version='1.0' encoding='utf-8' ?>
<FrameLayout android:id="@id/content_layout"
             android:layout_width="fill_parent"
             android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <miuix.springback.view.SpringBackLayout android:id="@id/layout_spring_back"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:layout_width="fill_parent"
                        android:layout_height="fill_parent"
                        app:scrollableView="@id/rv_record">
    <miuix.recyclerview.widget.RecyclerView android:orientation="vertical"
                          android:id="@id/rv_record"
                          android:layout_width="fill_parent"
                          android:layout_height="fill_parent" />
  </miuix.springback.view.SpringBackLayout>
  <include layout="@layout/bh_order_no_net" />
  <include layout="@layout/bh_order_empty" />
  <include layout="@layout/bh_order_loading" />
</FrameLayout>