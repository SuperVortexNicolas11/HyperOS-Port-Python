<?xml version='1.0' encoding='utf-8' ?>
<ScrollView android:id="@id/padding"
            android:paddingLeft="@dimen/miuix_appcompat_dialog_panel_horizontal_padding"
            android:paddingRight="@dimen/miuix_appcompat_dialog_panel_horizontal_padding"
            android:scrollbars="none"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:overScrollMode="never"
            android:paddingHorizontal="@dimen/miuix_appcompat_dialog_panel_horizontal_padding" xmlns:android="http://schemas.android.com/apk/res/android">
  <LinearLayout android:gravity="center"
                android:orientation="vertical"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
    <TextView android:textSize="@dimen/view_dimen_48"
              android:id="@id/txtview_powersave_title"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:text="@string/power_center_dialog_msg_title" />
    <TextView android:textSize="16.73dp"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/view_dimen_40"
              android:text="@string/power_save_ps_limit"
              android:drawablePadding="9.45dp"
              android:drawableStart="@drawable/pc_dialogdes_itemnumber" />
    <TextView android:textSize="16.73dp"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:text="@string/power_save_ps_freeze"
              android:drawablePadding="9.45dp"
              android:drawableStart="@drawable/pc_dialogdes_itemnumber" />
    <TextView android:textSize="16.73dp"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:text="@string/power_save_ps_clean"
              android:drawablePadding="9.45dp"
              android:drawableStart="@drawable/pc_dialogdes_itemnumber" />
    <LinearLayout android:orientation="horizontal"
                  android:id="@id/ll_power_save_content4"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content">
      <ImageView android:layout_width="wrap_content"
                 android:layout_height="wrap_content"
                 android:layout_marginTop="9.0dp"
                 android:src="@drawable/pc_dialogdes_itemnumber" />
      <TextView android:textSize="16.73dp"
                android:id="@id/pc_main_dialog_power_save_content"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="9.45dp" />
    </LinearLayout>
    <TextView android:id="@id/pc_main_dialog_power_save_last"
              android:visibility="gone"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/pc_main_power_save_dialog_padding_size"
              android:text="@string/power_center_dialog_msg_bottom" />
  </LinearLayout>
</ScrollView>