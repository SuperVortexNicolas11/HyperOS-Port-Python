<?xml version='1.0' encoding='utf-8' ?>
<RelativeLayout android:id="@id/actionBar"
                android:layout_width="fill_parent"
                android:layout_height="@dimen/gb_action_bar_height_land" xmlns:android="http://schemas.android.com/apk/res/android">
  <ImageView android:id="@id/backBtn"
             android:padding="@dimen/dp_6"
             android:layout_width="@dimen/dp_36"
             android:layout_height="@dimen/dp_36"
             android:src="@drawable/gb_action_bar_back_light_land_selector"
             android:scaleType="fitCenter"
             android:layout_centerVertical="true"
             android:contentDescription="@string/game_toolbox_btn_back_talkback"
             android:layout_marginStart="@dimen/dp_6_35"
             android:layout_alignParentStart="true" />
  <TextView android:textSize="@dimen/sp_17_45"
            android:textColor="@color/gb_settings_second_title_color"
            android:ellipsize="end"
            android:id="@id/titleTv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:layout_centerVertical="true"
            android:textDirection="locale"
            android:layout_toEndOf="@id/backBtn" />
</RelativeLayout>