<?xml version='1.0' encoding='utf-8' ?>
<com.google.android.flexbox.FlexboxLayout android:id="@id/flex_layout"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      app:alignContent="flex_start"
                      app:alignItems="flex_start"
                      app:flexWrap="wrap" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <TextView android:id="@id/tv_dsp"
            style="@style/AdInfoTextStyle" />
