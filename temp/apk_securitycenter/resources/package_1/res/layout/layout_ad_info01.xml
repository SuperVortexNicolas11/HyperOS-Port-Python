            style="@style/AdInfoTextStyle" />
  <TextView android:id="@id/tv_version"
            style="@style/AdInfoTextStyle" />
  <TextView android:id="@id/tv_introduce"
            android:text="@string/ad_text_introduce"
            style="@style/AdInfoTextStyle" />
  <TextView android:id="@id/tv_privacy"
            android:text="@string/ad_text_privacy"
            style="@style/AdInfoTextStyle" />
