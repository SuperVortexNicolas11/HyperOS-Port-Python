<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android">
  <TextView android:layout_gravity="center_horizontal"
            android:id="@id/confirm_fingerprint_view_title"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/fingerprint_identify_msg"
            style="?android:attr/textAppearanceLarge" />
  <ImageView android:layout_gravity="center_horizontal"
             android:layout_width="wrap_content"
             android:layout_height="wrap_content"
             android:src="@drawable/confirm_fingerprint_img" />
  <TextView android:textSize="@dimen/text_font_size_48"
            android:textColor="@color/account_info_text_color"
            android:layout_gravity="center_horizontal"
            android:id="@id/confirm_fingerprint_view_msg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/view_dimen_20"
            android:text="@string/confirm_fingerprint_msg"
            style="?android:attr/textAppearanceMedium" />
</LinearLayout>