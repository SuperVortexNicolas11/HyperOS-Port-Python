<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:paddingLeft="@dimen/miuix_theme_padding_horizontal_common"
              android:paddingRight="@dimen/miuix_theme_padding_horizontal_common"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:paddingHorizontal="@dimen/miuix_theme_padding_horizontal_common" xmlns:android="http://schemas.android.com/apk/res/android">
  <ImageView android:layout_gravity="center_horizontal"
             android:id="@id/top_pic"
             android:layout_width="@dimen/privacy_thumbnail_blur_top_pic_width"
             android:layout_height="@dimen/privacy_thumbnail_blur_top_pic_height"
             android:layout_marginTop="@dimen/dp_12"
             android:src="@drawable/privacy_thumbnail_blur_top_pic_v3" />
  <TextView android:textSize="@dimen/sp_15"
            android:textColor="@color/tip_subtitle"
            android:layout_gravity="center_horizontal"
            android:id="@id/top_title"
            android:paddingTop="@dimen/dp_8"
            android:paddingBottom="@dimen/dp_8"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_4"
            android:layout_marginBottom="@dimen/dp_12"
            android:text="@string/privacy_thumbnail_blur_top_tip"
            android:paddingVertical="@dimen/dp_8" />
</LinearLayout>