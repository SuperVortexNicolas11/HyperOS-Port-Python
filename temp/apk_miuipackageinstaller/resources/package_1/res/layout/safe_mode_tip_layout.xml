<?xml version='1.0' encoding='utf-8' ?>
<FrameLayout android:id="@id/root"
             android:layout_width="fill_parent"
             android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <androidx.constraintlayout.widget.ConstraintLayout android:id="@id/cl_content"
                        android:background="@drawable/bg_security_mode_suggestion"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content">
    <ImageView android:id="@id/icon"
               android:paddingTop="@dimen/dp_9.09"
               android:paddingBottom="@dimen/dp_9.09"
               android:layout_width="@dimen/dp_18"
               android:layout_height="@dimen/dp_36.36"
               android:src="@drawable/safe_mode_tip_icon"
               android:layout_marginStart="@dimen/dp_18"
               app:layout_constraintBottom_toBottomOf="@id/tv_title"
               app:layout_constraintStart_toStartOf="parent"
               app:layout_constraintTop_toTopOf="@id/tv_title" />
    <TextView android:textSize="@dimen/sp_14"
              android:textColor="@color/black"
              android:id="@id/tv_title"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/dp_10.15"
              android:text="@string/safe_mode_title_text"
              android:fontFamily="mipro-demibold"
              android:layout_marginStart="@dimen/dp_7"
              app:layout_constraintStart_toEndOf="@id/icon"
              app:layout_constraintTop_toTopOf="parent"
              app:layout_goneMarginStart="@dimen/dp_18" />
    <TextView android:textSize="@dimen/dp_10"
              android:textColor="@color/risk_title_text_color"
              android:gravity="center"
              android:id="@id/tv_suggestion"
              android:background="@drawable/security_mode_off_suggestion_bg"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/dp_1.4"
              android:minWidth="@dimen/dp_58"
              android:minHeight="@dimen/dp_19.6"
              android:text="@string/security_mode_off_suggestion_msg"
              android:paddingStart="@dimen/dp_3"
              android:paddingEnd="@dimen/dp_3"
              android:layout_marginStart="@dimen/dp_3.6"
              app:layout_constraintBottom_toBottomOf="@id/icon"
              app:layout_constraintStart_toEndOf="@id/tv_title"
              app:layout_constraintTop_toTopOf="@id/icon" />
    <TextView android:textSize="@dimen/sp_13"
              android:textColor="@color/black_60"
              android:id="@id/tv_des"
              android:layout_width="0.0dp"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/dp_5.45"
              android:text="@string/pure_mode_title"
              android:layout_marginEnd="@dimen/dp_72.6"
              app:layout_constraintEnd_toEndOf="parent"
              app:layout_constraintStart_toStartOf="@id/icon"
              app:layout_constraintTop_toBottomOf="@id/tv_title"
              app:layout_goneMarginStart="@dimen/dp_18" />
    <TextView android:textSize="@dimen/sp_13"
              android:textColor="@color/color_0D84FF"
              android:id="@id/tv_learn_more"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/dp_3.6"
              android:layout_marginBottom="@dimen/dp_18"
              android:text="@string/learn_more"
              android:drawableEnd="@drawable/green_right_arrow"
              app:layout_constraintBottom_toBottomOf="parent"
              app:layout_constraintStart_toStartOf="@id/tv_des"
              app:layout_constraintTop_toBottomOf="@id/tv_des" />
    <miuix.slidingwidget.widget.SlidingButton android:gravity="center"
                          android:id="@id/bt_open"
                          android:focusable="true"
                          android:clickable="true"
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:layout_marginEnd="@dimen/dp_18"
                          app:layout_constraintBottom_toBottomOf="parent"
                          app:layout_constraintEnd_toEndOf="parent"
                          app:layout_constraintTop_toTopOf="parent" />
    <Button android:textSize="@dimen/sp_13"
            android:textColor="@color/white"
            android:gravity="center"
            android:id="@id/bt_open_style_btn"
            android:background="@drawable/bg_security_mode_btn_open"
            android:visibility="gone"
            android:layout_width="@dimen/dp_61.82"
            android:layout_height="@dimen/dp_26"
            android:text="@string/open"
            android:fontFamily="mipro-demibold"
            android:layout_marginEnd="@dimen/dp_13"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    <View android:gravity="center"
          android:id="@id/arrow"
          android:background="@drawable/ic_right_arrow_style_1"
          android:visibility="gone"
          android:layout_width="@dimen/dp_36.36"
          android:layout_height="@dimen/dp_36.36"
          android:contentDescription="@string/safe_mode_tip_arrow_talkback"
          android:layout_marginEnd="@dimen/dp_18"
          app:layout_constraintBottom_toBottomOf="parent"
          app:layout_constraintEnd_toEndOf="parent"
          app:layout_constraintTop_toTopOf="parent" />
  </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>