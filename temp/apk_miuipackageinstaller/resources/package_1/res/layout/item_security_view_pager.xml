<?xml version='1.0' encoding='utf-8' ?>
<RelativeLayout android:id="@id/root_layout"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <androidx.core.widget.NestedScrollView android:layout_width="fill_parent"
                        android:layout_height="fill_parent"
                        android:layout_above="@id/bottom_layout">
    <FrameLayout android:id="@id/content_layout"
                 android:clipChildren="false"
                 android:layout_width="fill_parent"
                 android:layout_height="fill_parent">
      <com.airbnb.lottie.LottieAnimationView android:layout_gravity="center_horizontal"
                            android:id="@id/lottie_logo"
                            android:layout_width="@dimen/dp_164"
                            android:layout_height="@dimen/dp_164"
                            android:layout_marginTop="@dimen/dp_91"
                            android:scaleX="2.0"
                            android:scaleY="2.0"
                            app:lottie_fileName="safe_logo.json"
                            app:lottie_imageAssetsFolder="images/" />
      <androidx.appcompat.widget.LinearLayoutCompat android:orientation="vertical"
                            android:id="@id/ll_status_layout"
                            android:layout_width="fill_parent"
                            android:layout_height="fill_parent">
        <TextView android:textSize="@dimen/sp_32"
                  android:textColor="@color/black"
                  android:id="@id/security_mode_title"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="@dimen/dp_4"
                  android:text="@string/safe_mode"
                  android:layout_marginStart="@dimen/dp_26" />
        <TextView android:textSize="@dimen/sp_14"
                  android:textColor="@color/black"
                  android:id="@id/security_mode_status"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="@dimen/dp_4"
                  android:layout_marginStart="@dimen/dp_26" />
        <androidx.recyclerview.widget.RecyclerView android:id="@id/security_mode_service_list"
                              android:layout_width="fill_parent"
                              android:layout_height="0.0dp"
                              android:layout_marginTop="224.0dp"
                              android:layout_weight="1.0"
                              android:overScrollMode="never"
                              android:layout_marginHorizontal="@dimen/dp_28" />
      </androidx.appcompat.widget.LinearLayoutCompat>
    </FrameLayout>
  </androidx.core.widget.NestedScrollView>
  <androidx.appcompat.widget.LinearLayoutCompat android:orientation="vertical"
                        android:id="@id/bottom_layout"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        app:layout_constraintBottom_toBottomOf="parent">
    <miuix.miuixbasewidget.widget.PageIndicator android:layout_gravity="center_horizontal"
                          android:id="@id/page_indicator"
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          app:totalCount="3" />
    <Button android:layout_gravity="center_horizontal"
            android:id="@id/action_button"
            android:layout_width="@dimen/dp_336"
            android:layout_height="@dimen/dp_51"
            android:layout_marginTop="@dimen/dp_34"
            android:layout_marginBottom="@dimen/dp_30"
            style="@style/Widget.Button.Primary" />
  </androidx.appcompat.widget.LinearLayoutCompat>
  <FrameLayout android:id="@id/anim_content"
               android:layout_width="fill_parent"
               android:layout_height="fill_parent"
               android:layout_alignParentBottom="true" />
</RelativeLayout>