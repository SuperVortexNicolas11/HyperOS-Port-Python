<?xml version='1.0' encoding='utf-8' ?>
<androidx.core.widget.NestedScrollView android:layout_width="fill_parent"
                      android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <androidx.constraintlayout.widget.ConstraintLayout android:paddingBottom="@dimen/dp_16"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content">
    <androidx.constraintlayout.widget.ConstraintLayout android:id="@id/safe_guard_customize_layout1"
                          android:background="@drawable/enhance_safe_guard_bg"
                          android:padding="@dimen/dp_12"
                          android:layout_width="fill_parent"
                          android:layout_height="wrap_content"
                          android:layout_marginHorizontal="@dimen/dp_28"
                          app:layout_constraintTop_toTopOf="parent">
      <androidx.appcompat.widget.AppCompatImageView android:id="@id/market_logo"
                            android:layout_width="@dimen/dp_54"
                            android:layout_height="@dimen/dp_54"
                            android:src="@drawable/mi_market_logo"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
      <androidx.constraintlayout.widget.ConstraintLayout android:id="@id/description1"
                            android:layout_width="0.0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/dp_12"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@id/market_logo"
                            app:layout_constraintTop_toTopOf="parent">
        <androidx.appcompat.widget.AppCompatImageView android:id="@id/icon1"
                              android:layout_width="wrap_content"
                              android:layout_height="wrap_content"
                              android:src="@drawable/enhance_safe_guard_icon_1"
                              app:layout_constraintBottom_toBottomOf="@id/text1"
                              app:layout_constraintStart_toStartOf="parent"
                              app:layout_constraintTop_toTopOf="@id/text1" />
        <androidx.appcompat.widget.AppCompatTextView android:textSize="@dimen/sp_13"
                              android:textColor="@color/black_60"
                              android:id="@id/text1"
                              android:layout_width="0.0dp"
                              android:layout_height="wrap_content"
                              android:text="@string/four_automatic_detection"
                              android:layout_marginStart="@dimen/dp_5"
                              app:layout_constraintBottom_toBottomOf="parent"
                              app:layout_constraintEnd_toStartOf="@id/layout1"
                              app:layout_constraintStart_toEndOf="@id/icon1"
                              app:layout_constraintTop_toTopOf="parent" />
        <FrameLayout android:id="@id/layout1"
                     android:layout_width="@dimen/dp_18"
                     android:layout_height="@dimen/dp_18"
                     app:layout_constraintBottom_toBottomOf="parent"
                     app:layout_constraintEnd_toEndOf="parent"
                     app:layout_constraintTop_toTopOf="parent">
          <ProgressBar android:id="@id/status_progress_indicator"
                       android:layout_width="@dimen/dp_18"
                       android:layout_height="@dimen/dp_18"
                       android:indeterminate="true"
                       android:indeterminateDrawable="@drawable/progress_bar_progressing_anim_style_2"
                       android:layout_marginEnd="@dimen/dp_7" />
          <com.airbnb.lottie.LottieAnimationView android:id="@id/status_done_indicator"
                                android:visibility="gone"
                                android:layout_width="@dimen/dp_18"
                                android:layout_height="@dimen/dp_18" />
        </FrameLayout>
      </androidx.constraintlayout.widget.ConstraintLayout>
      <androidx.constraintlayout.widget.ConstraintLayout android:id="@id/description2"
                            android:layout_width="0.0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/dp_12"
                            android:layout_marginStart="@dimen/dp_12"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@id/market_logo"
                            app:layout_constraintTop_toBottomOf="@id/description1">
        <androidx.appcompat.widget.AppCompatImageView android:id="@id/icon2"
                              android:layout_width="wrap_content"
                              android:layout_height="wrap_content"
                              android:src="@drawable/enhance_safe_guard_icon2"
                              app:layout_constraintBottom_toBottomOf="@id/text2"
                              app:layout_constraintStart_toStartOf="parent"
                              app:layout_constraintTop_toTopOf="@id/text2" />
        <androidx.appcompat.widget.AppCompatTextView android:textSize="@dimen/sp_13"
                              android:textColor="@color/black_60"
                              android:id="@id/text2"
                              android:layout_width="0.0dp"
                              android:layout_height="wrap_content"
                              android:text="@string/professional_review"
                              android:layout_marginStart="@dimen/dp_5"
                              app:layout_constraintBottom_toBottomOf="parent"
                              app:layout_constraintEnd_toStartOf="@id/layout2"
                              app:layout_constraintStart_toEndOf="@id/icon2"
                              app:layout_constraintTop_toTopOf="parent" />
        <FrameLayout android:id="@id/layout2"
                     android:layout_width="@dimen/dp_18"
                     android:layout_height="@dimen/dp_18"
                     app:layout_constraintBottom_toBottomOf="@id/text2"
                     app:layout_constraintEnd_toEndOf="parent"
                     app:layout_constraintTop_toTopOf="@id/text2">
          <ProgressBar android:id="@id/status_progress_indicator2"
                       android:layout_width="@dimen/dp_18"
                       android:layout_height="@dimen/dp_18"
                       android:indeterminate="true"
                       android:indeterminateDrawable="@drawable/progress_bar_progressing_anim_style_2"
                       android:layout_marginEnd="@dimen/dp_7" />
          <com.airbnb.lottie.LottieAnimationView android:id="@id/status_done_indicator2"
                                android:visibility="gone"
                                android:layout_width="@dimen/dp_18"
                                android:layout_height="@dimen/dp_18" />
        </FrameLayout>
      </androidx.constraintlayout.widget.ConstraintLayout>
      <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="0.0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/dp_12"
                            android:layout_marginStart="@dimen/dp_12"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@id/market_logo"
                            app:layout_constraintTop_toBottomOf="@id/description2">
        <androidx.appcompat.widget.AppCompatImageView android:id="@id/icon3"
                              android:layout_width="wrap_content"
                              android:layout_height="wrap_content"
                              android:src="@drawable/enhance_safe_guard_icon3"
                              app:layout_constraintBottom_toBottomOf="@id/text3"
                              app:layout_constraintStart_toStartOf="parent"
                              app:layout_constraintTop_toTopOf="@id/text3" />
        <androidx.appcompat.widget.AppCompatTextView android:textSize="@dimen/sp_13"
                              android:textColor="@color/black_60"
                              android:id="@id/text3"
                              android:layout_width="0.0dp"
                              android:layout_height="wrap_content"
                              android:text="@string/protect_privacy_and_security"
                              android:layout_marginStart="@dimen/dp_5"
                              app:layout_constraintBottom_toBottomOf="parent"
                              app:layout_constraintEnd_toStartOf="@id/layout3"
                              app:layout_constraintStart_toEndOf="@id/icon3"
                              app:layout_constraintTop_toTopOf="parent" />
        <FrameLayout android:id="@id/layout3"
                     android:layout_width="@dimen/dp_18"
                     android:layout_height="@dimen/dp_18"
                     app:layout_constraintBottom_toBottomOf="parent"
                     app:layout_constraintEnd_toEndOf="parent"
                     app:layout_constraintTop_toTopOf="parent">
          <ProgressBar android:id="@id/status_progress_indicator3"
                       android:layout_width="@dimen/dp_18"
                       android:layout_height="@dimen/dp_18"
                       android:indeterminate="true"
                       android:indeterminateDrawable="@drawable/progress_bar_progressing_anim_style_2"
                       android:layout_marginEnd="@dimen/dp_7" />
          <com.airbnb.lottie.LottieAnimationView android:id="@id/status_done_indicator3"
                                android:visibility="gone"
                                android:layout_width="@dimen/dp_18"
                                android:layout_height="@dimen/dp_18" />
        </FrameLayout>
      </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.widget.ConstraintLayout android:background="@drawable/enhance_safe_guard_bg"
                          android:layout_width="fill_parent"
                          android:layout_height="wrap_content"
                          android:layout_marginTop="@dimen/dp_16"
                          android:layout_marginBottom="@dimen/dp_16"
                          android:layout_marginHorizontal="@dimen/dp_28"
                          android:paddingVertical="@dimen/dp_10"
                          app:layout_constraintTop_toBottomOf="@id/safe_guard_customize_layout1">
      <androidx.appcompat.widget.AppCompatImageView android:id="@id/safe_tip_icon"
                            android:layout_width="@dimen/dp_20"
                            android:layout_height="@dimen/dp_20"
                            android:src="@drawable/safe_mode_tip_icon"
                            android:layout_marginStart="@dimen/dp_12"
                            app:layout_constraintBottom_toBottomOf="@id/enhance_tip_text"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="@id/enhance_tip_text" />
      <androidx.appcompat.widget.AppCompatTextView android:textSize="@dimen/sp_14"
                            android:textColor="@color/black"
                            android:id="@id/enhance_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/enhance_safe_mode"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginStart="@dimen/dp_4"
                            app:layout_constraintBottom_toBottomOf="@id/enhance_tip_text"
                            app:layout_constraintStart_toEndOf="@id/safe_tip_icon"
                            app:layout_constraintTop_toTopOf="@id/enhance_tip_text" />
      <androidx.appcompat.widget.AppCompatTextView android:textSize="@dimen/sp_11"
                            android:textColor="@color/color_F22424"
                            android:id="@id/enhance_tip_text"
                            android:background="@drawable/red_round_transparent_bg"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/security_mode_off_suggestion_msg"
                            android:layout_marginStart="@dimen/dp_8"
                            android:paddingHorizontal="@dimen/dp_8"
                            android:paddingVertical="@dimen/dp_4"
                            app:layout_constraintStart_toEndOf="@id/enhance_title"
                            app:layout_constraintTop_toTopOf="parent" />
      <androidx.appcompat.widget.AppCompatTextView android:textSize="@dimen/sp_13"
                            android:textColor="@color/black_60"
                            android:id="@id/enhance_safe_mode_open_description"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/dp_8"
                            android:text="@string/enhance_safe_mode_open_description"
                            android:layout_marginHorizontal="@dimen/dp_12"
                            app:layout_constraintTop_toBottomOf="@id/enhance_tip_text" />
    </androidx.constraintlayout.widget.ConstraintLayout>
  </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>