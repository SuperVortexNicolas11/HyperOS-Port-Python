<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:gravity="center_vertical"
              android:orientation="horizontal"
              android:paddingTop="@dimen/dp_10"
              android:paddingBottom="@dimen/dp_10"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:paddingStart="@dimen/dp_30"
              android:paddingEnd="@dimen/dp_30" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <com.miui.packageInstaller.view.RoundImageView android:id="@id/app_icon"
                        android:layout_width="@dimen/dp_40"
                        android:layout_height="@dimen/dp_40"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:round_corner="@dimen/dp_9.45" />
  <TextView android:textSize="@dimen/sp_17"
            android:textColor="@color/black"
            android:ellipsize="end"
            android:id="@id/app_name"
            android:layout_width="0.0dp"
            android:layout_height="wrap_content"
            android:lines="1"
            android:layout_weight="1.0"
            android:fontFamily="mipro-demibold"
            android:layout_marginStart="@dimen/dp_16" />
  <TextView android:textSize="@dimen/sp_17"
            android:textColor="@color/black_40"
            android:ellipsize="end"
            android:id="@id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:lines="1"
            android:drawableRight="@drawable/ic_risk_trust_arrow_right"
            android:drawablePadding="@dimen/dp_8.7" />
</LinearLayout>