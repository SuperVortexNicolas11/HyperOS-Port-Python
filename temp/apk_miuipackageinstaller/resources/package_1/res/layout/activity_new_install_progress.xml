<?xml version='1.0' encoding='utf-8' ?>
<androidx.constraintlayout.widget.ConstraintLayout android:id="@id/root"
                      android:layout_width="fill_parent"
                      android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <FrameLayout android:id="@id/fragment_container"
               android:layout_width="fill_parent"
               android:layout_height="0.0dp"
               app:layout_constraintBottom_toBottomOf="parent"
               app:layout_constraintTop_toTopOf="parent">
    <androidx.constraintlayout.widget.ConstraintLayout android:id="@id/root_layout"
                          android:layout_width="fill_parent"
                          android:layout_height="fill_parent">
      <androidx.recyclerview.widget.RecyclerView android:scrollbarSize="@dimen/dp_8"
                            android:scrollbarStyle="outsideInset"
                            android:id="@id/main_content"
                            android:scrollbars="vertical"
                            android:layout_width="fill_parent"
                            android:layout_height="fill_parent"
                            android:fadeScrollbars="true"
                            android:paddingStart="@dimen/dp_20"
                            android:paddingEnd="@dimen/dp_12" />
      <LinearLayout android:orientation="vertical"
                    android:id="@id/bottom_layout"
                    android:background="@drawable/bottom_action_shadow"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="parent">
        <androidx.recyclerview.widget.RecyclerView android:id="@id/bottom_content"
                              android:layout_width="fill_parent"
                              android:layout_height="wrap_content"
                              android:layout_marginHorizontal="@dimen/dp_20" />
        <com.miui.packageInstaller.ui.InstallerActionBar android:layout_gravity="center"
                              android:orientation="vertical"
                              android:id="@id/installer_action_bar"
                              android:background="@drawable/bottom_action_shadow"
                              android:layout_width="@dimen/dp_336"
                              android:layout_height="wrap_content" />
      </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
  </FrameLayout>
  <FrameLayout android:id="@id/anim_container"
               android:layout_width="fill_parent"
               android:layout_height="0.0dp"
               app:layout_constraintBottom_toBottomOf="parent"
               app:layout_constraintTop_toTopOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>