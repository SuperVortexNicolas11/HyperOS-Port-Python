<?xml version='1.0' encoding='utf-8' ?>
<androidx.appcompat.widget.LinearLayoutCompat android:orientation="horizontal"
                      android:id="@id/ll_service_anim_item"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content"
                      android:paddingHorizontal="@dimen/dp_28"
                      android:paddingVertical="@dimen/dp_18" xmlns:android="http://schemas.android.com/apk/res/android">
  <androidx.appcompat.widget.AppCompatTextView android:textSize="@dimen/sp_15.9"
                        android:textColor="@color/black_60"
                        android:id="@id/service_title"
                        android:layout_width="0.0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.0" />
  <FrameLayout android:layout_width="@dimen/dp_18"
               android:layout_height="@dimen/dp_18">
    <ProgressBar android:id="@id/status_progress_indicator"
                 android:layout_width="@dimen/dp_18"
                 android:layout_height="@dimen/dp_18"
                 android:indeterminate="true"
                 android:indeterminateDrawable="@drawable/progress_bar_progressing_anim_style_2"
                 android:layout_marginEnd="@dimen/dp_7" />
    <com.airbnb.lottie.LottieAnimationView android:id="@id/status_done_indicator"
                          android:visibility="gone"
                          android:layout_width="@dimen/dp_18"
                          android:layout_height="@dimen/dp_18" />
  </FrameLayout>
</androidx.appcompat.widget.LinearLayoutCompat>