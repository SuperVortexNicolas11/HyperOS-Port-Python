<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:id="@id/root_layout"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="fill_parent"
                        android:layout_height="wrap_content">
    <com.miui.packageInstaller.view.RoundImageView android:id="@id/app_icon"
                          android:layout_width="@dimen/dp_60"
                          android:layout_height="@dimen/dp_60"
                          android:layout_marginTop="@dimen/dp_18"
                          android:layout_marginStart="@dimen/dp_18"
                          app:layout_constraintStart_toStartOf="parent"
                          app:layout_constraintTop_toTopOf="parent"
                          app:round_corner="@dimen/dp_16"
                          app:stroke_color="@color/transparent" />
    <androidx.appcompat.widget.AppCompatTextView android:textSize="@dimen/sp_16"
                          android:textColor="@color/black"
                          android:id="@id/app_title"
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:layout_marginTop="@dimen/dp_24.36"
                          android:layout_marginStart="@dimen/dp_10"
                          app:layout_constraintStart_toEndOf="@id/app_icon"
                          app:layout_constraintTop_toTopOf="parent" />
    <androidx.appcompat.widget.AppCompatTextView android:textSize="@dimen/sp_11"
                          android:textColor="@color/color_F43B3B"
                          android:id="@id/risk_label"
                          android:background="@drawable/risk_app_tips_bg"
                          android:paddingTop="@dimen/dp_1.4"
                          android:paddingBottom="@dimen/dp_1.4"
                          android:visibility="gone"
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:text="@string/risk_app"
                          android:paddingStart="@dimen/dp_6.55"
                          android:paddingEnd="@dimen/dp_6.55"
                          android:layout_marginStart="@dimen/dp_7"
                          app:layout_constraintBottom_toBottomOf="@id/app_title"
                          app:layout_constraintStart_toEndOf="@id/app_title"
                          app:layout_constraintTop_toTopOf="@id/app_title" />
    <androidx.appcompat.widget.AppCompatTextView android:textSize="@dimen/sp_13"
                          android:textColor="@color/black_60"
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:layout_marginTop="@dimen/dp_1.4"
                          android:text="@string/install_source"
                          android:layout_marginStart="@dimen/dp_10"
                          app:layout_constraintStart_toEndOf="@id/app_icon"
                          app:layout_constraintTop_toBottomOf="@id/app_title" />
    <View android:id="@id/vi_line"
          android:background="@color/black_c1"
          android:layout_width="fill_parent"
          android:layout_height="@dimen/dp_0.4"
          android:layout_marginTop="@dimen/dp_18"
          android:layout_marginStart="@dimen/dp_18"
          android:layout_marginEnd="@dimen/dp_18"
          app:layout_constraintTop_toBottomOf="@id/app_icon" />
    <androidx.appcompat.widget.AppCompatTextView android:textSize="@dimen/sp_14"
                          android:id="@id/tv_risk_tip"
                          android:layout_width="fill_parent"
                          android:layout_height="wrap_content"
                          android:layout_marginTop="@dimen/dp_18"
                          android:layout_marginBottom="@dimen/dp_18"
                          android:text="@string/install_source_dialog_tip"
                          android:layout_marginStart="@dimen/dp_18"
                          android:layout_marginEnd="@dimen/dp_18"
                          app:layout_constraintBottom_toBottomOf="parent"
                          app:layout_constraintTop_toBottomOf="@id/vi_line" />
  </androidx.constraintlayout.widget.ConstraintLayout>
</LinearLayout>