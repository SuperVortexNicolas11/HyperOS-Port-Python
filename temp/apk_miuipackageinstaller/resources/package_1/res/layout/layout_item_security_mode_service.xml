<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="horizontal"
              android:id="@id/root"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:baselineAligned="false"
              android:paddingVertical="@dimen/dp_14" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <androidx.constraintlayout.widget.ConstraintLayout android:clipChildren="false"
                        android:layout_width="0.0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.0">
    <androidx.appcompat.widget.AppCompatTextView android:textSize="@dimen/sp_16"
                          android:textColor="@color/black"
                          android:id="@id/service_title"
                          android:layout_width="0.0dp"
                          android:layout_height="wrap_content"
                          android:fontFamily="mipro-medium"
                          app:layout_constraintEnd_toEndOf="parent"
                          app:layout_constraintStart_toStartOf="parent"
                          app:layout_constraintTop_toTopOf="parent" />
    <androidx.appcompat.widget.AppCompatTextView android:textSize="@dimen/sp_12"
                          android:textColor="@color/black_40"
                          android:id="@id/service_desc"
                          android:layout_width="0.0dp"
                          android:layout_height="wrap_content"
                          app:layout_constraintEnd_toEndOf="parent"
                          app:layout_constraintStart_toStartOf="@id/service_title"
                          app:layout_constraintTop_toBottomOf="@id/service_title" />
  </androidx.constraintlayout.widget.ConstraintLayout>
  <FrameLayout android:layout_gravity="center_vertical"
               android:id="@id/service_icon"
               android:visibility="gone"
               android:layout_width="@dimen/dp_18"
               android:layout_height="@dimen/dp_18">
    <ProgressBar android:id="@id/status_progress_indicator"
                 android:layout_width="@dimen/dp_18"
                 android:layout_height="@dimen/dp_18"
                 android:indeterminate="true"
                 android:indeterminateDrawable="@drawable/progress_bar_progressing_anim_style_2"
                 android:layout_marginEnd="@dimen/dp_7" />
    <com.airbnb.lottie.LottieAnimationView android:id="@id/status_done_indicator"
                          android:visibility="gone"
                          android:layout_width="@dimen/dp_18"
                          android:layout_height="@dimen/dp_18" />
  </FrameLayout>
</LinearLayout>