<?xml version='1.0' encoding='utf-8' ?>
<RelativeLayout android:background="@color/floating_window_background_white"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android">
  <FrameLayout android:textStyle="bold"
               android:id="@id/title_layout"
               android:layout_width="fill_parent"
               android:layout_height="wrap_content"
               android:layout_marginTop="@dimen/dp_32">
    <ImageView android:layout_gravity="end"
               android:id="@id/close"
               android:layout_width="@dimen/dp_32"
               android:layout_height="@dimen/dp_32"
               android:src="@drawable/ic_system_close"
               android:contentDescription="@string/cb_back"
               android:layout_marginEnd="@dimen/dp_16"
               android:accessibilityTraversalBefore="@id/introductionHeader"
               android:accessibilityTraversalAfter="@id/displayName" />
    <TextView android:textSize="@dimen/sp_18"
              android:textStyle="bold"
              android:textColor="@color/black"
              android:ellipsize="end"
              android:layout_gravity="center_horizontal"
              android:id="@id/displayName"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/dp_8"
              android:layout_marginBottom="@dimen/dp_24"
              android:maxLines="1"
              android:accessibilityTraversalBefore="@id/close"
              android:layout_marginHorizontal="@dimen/dp_50" />
  </FrameLayout>
  <TextView android:id="@id/line"
            android:background="@color/black_10"
            android:layout_width="fill_parent"
            android:layout_height="@dimen/dp_0.74"
            android:layout_below="@id/title_layout"
            android:layout_marginHorizontal="@dimen/dp_28" />
  <androidx.core.widget.NestedScrollView android:layout_width="fill_parent"
                        android:layout_height="@dimen/dp_466"
                        android:fillViewport="true"
                        android:layout_below="@id/line">
    <LinearLayout android:orientation="vertical"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="@dimen/dp_23.63"
                  android:layout_marginHorizontal="@dimen/dp_28">
      <TextView android:textSize="@dimen/sp_17"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:id="@id/introductionHeader"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:text="@string/app_detail_introduction"
                android:accessibilityTraversalBefore="@id/brief"
                android:accessibilityTraversalAfter="@id/close" />
      <TextView android:textSize="@dimen/sp_14"
                android:textColor="@color/black_60"
                android:id="@id/brief"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_8"
                android:accessibilityTraversalBefore="@id/introduction"
                android:accessibilityTraversalAfter="@id/introductionHeader" />
      <TextView android:textSize="@dimen/sp_14"
                android:textColor="@color/black_60"
                android:id="@id/introduction"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_8"
                android:lineSpacingExtra="@dimen/dp_2"
                android:accessibilityTraversalBefore="@id/changeLogHeader"
                android:accessibilityTraversalAfter="@id/brief" />
      <TextView android:textSize="@dimen/sp_17"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:id="@id/changeLogHeader"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_24"
                android:text="@string/app_detail_change_log"
                android:accessibilityTraversalBefore="@id/changeLog"
                android:accessibilityTraversalAfter="@id/introduction" />
      <TextView android:textSize="@dimen/sp_14"
                android:textColor="@color/black_60"
                android:id="@id/changeLog"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_8"
                android:lineSpacingExtra="@dimen/dp_2" />
      <TextView android:textSize="@dimen/sp_17"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_24"
                android:text="@string/app_detail_other_info" />
      <TextView android:textSize="@dimen/sp_14"
                android:textColor="@color/black_60"
                android:id="@id/publisherName"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_8" />
      <TextView android:textSize="@dimen/sp_14"
                android:textColor="@color/black_60"
                android:id="@id/updateTime"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_2" />
      <TextView android:textSize="@dimen/sp_14"
                android:textColor="@color/black_60"
                android:id="@id/versionName"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_2" />
    </LinearLayout>
  </androidx.core.widget.NestedScrollView>
</RelativeLayout>