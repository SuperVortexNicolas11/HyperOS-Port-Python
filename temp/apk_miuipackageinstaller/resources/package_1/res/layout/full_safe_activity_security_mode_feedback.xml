<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:id="@id/root_layout"
              android:background="@color/advantage_color_F7F7F7"
              android:fitsSystemWindows="true"
              android:layout_width="fill_parent"
              android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <miuix.springback.view.SpringBackLayout android:id="@id/spring_back_layout"
                        android:layout_width="fill_parent"
                        android:layout_height="0.0dp"
                        android:layout_marginTop="@dimen/dp_56"
                        android:layout_weight="1.0"
                        app:scrollOrientation="vertical|angle"
                        app:scrollableView="@id/feedback_layout">
    <miuix.core.widget.NestedScrollView android:id="@id/feedback_layout"
                          android:layout_width="fill_parent"
                          android:layout_height="fill_parent"
                          android:fillViewport="true">
      <LinearLayout android:orientation="vertical"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">
        <TextView android:textSize="@dimen/sp_32"
                  android:textColor="@color/black_80"
                  android:id="@id/tv_title"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:text="@string/security_mode_feedback_title"
                  android:fontFamily="sans-serif"
                  android:layout_marginHorizontal="@dimen/dp_26" />
        <LinearLayout android:orientation="vertical"
                      android:id="@id/ll_reason"
                      android:background="@drawable/safe_mode_feedback_reason_bg"
                      android:padding="@dimen/dp_28"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content"
                      android:layout_marginTop="@dimen/dp_22"
                      android:layout_marginHorizontal="@dimen/dp_28">
          <TextView android:textSize="15.2sp"
                    android:textColor="@color/black"
                    android:id="@id/tv_question"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/security_mode_feedback_reason"
                    android:fontFamily="mipro-demibold" />
          <View android:id="@id/line_question"
                android:background="@color/black_15"
                android:layout_width="fill_parent"
                android:layout_height="@dimen/dp_0.4"
                android:layout_marginTop="@dimen/dp_18"
                android:layout_marginBottom="@dimen/dp_7" />
          <androidx.recyclerview.widget.RecyclerView android:id="@id/rv_reason_list"
                                android:layout_width="fill_parent"
                                android:layout_height="fill_parent"
                                android:overScrollMode="never" />
          <CheckBox android:id="@id/cb_reason_other"
                    android:layout_marginTop="12.0dp"
                    android:text="@string/security_mode_feedback_reason_other"
                    style="@style/FeedbackCheckBox" />
          <com.airbnb.lottie.LottieAnimationView android:layout_gravity="center"
                                android:id="@id/lottieImage"
                                android:visibility="gone"
                                android:layout_width="@dimen/dp_58"
                                android:layout_height="@dimen/dp_58"
                                android:layout_marginTop="30.0dp"
                                app:lottie_fileName="loading.json"
                                app:lottie_imageAssetsFolder="images/" />
          <TextView android:textSize="@dimen/sp_13"
                    android:textColor="@color/black_40"
                    android:layout_gravity="center"
                    android:id="@id/loadingText"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_10"
                    android:text="@string/default_net_loading" />
          <FrameLayout android:orientation="vertical"
                       android:id="@id/fl_input"
                       android:background="@drawable/safe_mode_feedback_reason_input_bg"
                       android:layout_width="fill_parent"
                       android:layout_height="@dimen/dp_83.64">
            <EditText android:textSize="@dimen/sp_14"
                      android:textColor="@color/black"
                      android:textColorHint="@color/black_40"
                      android:gravity="top"
                      android:id="@id/reason_edit_text"
                      android:background="@null"
                      android:layout_width="fill_parent"
                      android:layout_height="fill_parent"
                      android:layout_margin="@dimen/dp_14"
                      android:minHeight="@dimen/dp_19.6"
                      android:hint="@string/security_mode_feedback_reason_input_hint"
                      android:maxLength="50"
                      android:inputType="textMultiLine"
                      android:fontFamily="mipro-medium" />
            <TextView android:textSize="@dimen/sp_10"
                      android:textColor="@color/black_40"
                      android:layout_gravity="bottom|center|end"
                      android:id="@id/tv_input_count"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:layout_marginBottom="@dimen/dp_10"
                      android:layout_marginEnd="@dimen/dp_10" />
          </FrameLayout>
        </LinearLayout>
      </LinearLayout>
    </miuix.core.widget.NestedScrollView>
  </miuix.springback.view.SpringBackLayout>
  <LinearLayout android:orientation="vertical"
                android:id="@id/bottom_layout"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
    <Button android:enabled="false"
            android:layout_gravity="bottom|center"
            android:id="@id/btn_submit"
            android:layout_width="@dimen/dp_336"
            android:layout_height="@dimen/dp_51"
            android:layout_marginTop="@dimen/dp_30"
            android:layout_marginBottom="@dimen/dp_30"
            android:text="@string/security_mode_feedback_commit"
            style="@style/Widget.Button.Primary" />
  </LinearLayout>
</LinearLayout>