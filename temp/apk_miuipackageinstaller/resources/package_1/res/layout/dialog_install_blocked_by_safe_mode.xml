<?xml version='1.0' encoding='utf-8' ?>
<androidx.constraintlayout.widget.ConstraintLayout android:paddingBottom="16.0dp"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <androidx.constraintlayout.widget.ConstraintLayout android:layout_gravity="center_vertical"
                        android:id="@id/top_bar"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">
    <ImageView android:id="@id/logo"
               android:layout_width="16.0dp"
               android:layout_height="16.0dp"
               android:src="@drawable/security_small_logo_1"
               android:contentDescription="@string/cancel"
               android:layout_marginStart="24.0dp"
               app:layout_constraintBottom_toBottomOf="parent"
               app:layout_constraintStart_toStartOf="parent"
               app:layout_constraintTop_toTopOf="parent" />
    <TextView android:textSize="12.0sp"
              android:textColor="@color/black_60"
              android:gravity="center|start"
              android:id="@id/tv_protecting"
              android:layout_width="0.0dp"
              android:layout_height="wrap_content"
              android:text="@string/blocked_by_advanced_mode_dialog_tip"
              android:layout_marginStart="4.0dp"
              app:layout_constraintBottom_toBottomOf="parent"
              app:layout_constraintEnd_toStartOf="@id/close"
              app:layout_constraintStart_toEndOf="@id/logo"
              app:layout_constraintTop_toTopOf="parent" />
    <ImageView android:id="@id/close"
               android:layout_width="28.0dp"
               android:layout_height="28.0dp"
               android:src="@drawable/close"
               android:layout_marginEnd="20.0dp"
               app:layout_constraintBottom_toBottomOf="parent"
               app:layout_constraintEnd_toEndOf="parent"
               app:layout_constraintTop_toTopOf="parent" />
  </androidx.constraintlayout.widget.ConstraintLayout>
  <TextView android:textSize="18.0sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:gravity="center"
            android:id="@id/title"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14.0dp"
            android:text="@string/blocked_by_advanced_mode_dialog_title"
            android:layout_marginHorizontal="28.0dp"
            app:layout_constraintTop_toBottomOf="@id/top_bar" />
  <TextView android:textSize="16.0sp"
            android:textColor="@color/black_80"
            android:gravity="center_vertical"
            android:id="@id/content"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16.0dp"
            android:text="@string/blocked_by_advanced_mode_dialog_content"
            android:layout_marginHorizontal="28.0dp"
            app:layout_constraintTop_toBottomOf="@id/title" />
</androidx.constraintlayout.widget.ConstraintLayout>