<?xml version='1.0' encoding='utf-8' ?>
<androidx.constraintlayout.widget.ConstraintLayout android:id="@id/root_layout"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content"
                      android:paddingHorizontal="@dimen/dp_14" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <com.miui.packageInstaller.view.ImageInTheCenterFirstTextLayout android:orientation="horizontal"
                        android:id="@id/title_layout"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        app:layout_constraintTop_toTopOf="parent">
    <androidx.appcompat.widget.AppCompatImageView android:id="@id/iv_pure_icon"
                          android:layout_width="@dimen/dp_16"
                          android:layout_height="@dimen/dp_16"
                          android:src="@drawable/pure_not_shelf_icon" />
    <androidx.appcompat.widget.AppCompatTextView android:textSize="@dimen/sp_14"
                          android:textColor="@color/color_FF5500"
                          android:id="@id/tv_pure_title"
                          android:layout_width="fill_parent"
                          android:layout_height="wrap_content"
                          android:lineSpacingExtra="@dimen/dp_2"
                          android:fontFamily="sans-serif-medium"
                          android:layout_marginStart="@dimen/dp_7"
                          app:layout_constraintEnd_toEndOf="parent"
                          app:layout_constraintStart_toEndOf="@id/iv_pure_icon"
                          app:layout_constraintTop_toTopOf="parent" />
  </com.miui.packageInstaller.view.ImageInTheCenterFirstTextLayout>
  <TextView android:textSize="@dimen/sp_14"
            android:textColor="@color/black_60"
            android:id="@id/tv_pure_message"
            android:layout_width="0.0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_10"
            android:layout_marginBottom="@dimen/dp_18"
            android:layout_marginStart="@dimen/dp_23.3"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/title_layout" />
</androidx.constraintlayout.widget.ConstraintLayout>