<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:id="@id/root"
              android:background="@drawable/bottom_dialog_top_round_bg"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <ImageView android:layout_gravity="center_horizontal"
             android:background="@drawable/ic_safe_mode_close_tips"
             android:layout_width="@dimen/dp_66"
             android:layout_height="@dimen/dp_66" />
  <TextView android:textSize="@dimen/sp_18"
            android:textColor="@color/black"
            android:gravity="center_horizontal"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_6"
            android:text="@string/safe_mode_introduce_close_tip"
            android:fontFamily="sans-serif-medium" />
  <TextView android:textSize="@dimen/sp_15.9"
            android:textColor="@color/black_80_white_70"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_18"
            android:text="@string/safe_mode_introduce_close_tip_des"
            android:layout_marginHorizontal="@dimen/dp_28" />
  <miuix.core.widget.NestedScrollView android:layout_width="fill_parent"
                        android:layout_height="wrap_content">
    <androidx.constraintlayout.widget.ConstraintLayout android:paddingBottom="@dimen/dp_16"
                          android:layout_width="fill_parent"
                          android:layout_height="wrap_content"
                          android:layout_marginHorizontal="@dimen/dp_28">
      <TextView android:textSize="@dimen/sp_14"
                android:textColor="@color/color_8c93b0"
                android:id="@id/security_mode_service_list_title"
                android:layout_width="0.0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_22"
                android:text="@string/security_mode_close_tips_service_list_title"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
      <androidx.appcompat.widget.AppCompatImageView android:id="@id/icon1"
                            android:layout_width="@dimen/dp_24.36"
                            android:layout_height="@dimen/dp_24.36"
                            android:src="@drawable/ic_security_mode_service_1"
                            app:layout_constraintBottom_toBottomOf="@id/message_1"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="@id/message_1" />
      <androidx.appcompat.widget.AppCompatTextView android:textSize="@dimen/sp_13"
                            android:textColor="@color/black"
                            android:gravity="center_vertical"
                            android:id="@id/message_1"
                            android:layout_width="0.0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/dp_14"
                            android:text="@string/settings_security_mode_service_detailed_msg_1"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginStart="@dimen/dp_4"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@id/icon1"
                            app:layout_constraintTop_toBottomOf="@id/security_mode_service_list_title" />
      <androidx.appcompat.widget.AppCompatImageView android:id="@id/icon2"
                            android:layout_width="@dimen/dp_24.36"
                            android:layout_height="@dimen/dp_24.36"
                            android:src="@drawable/ic_security_mode_service_2"
                            app:layout_constraintBottom_toBottomOf="@id/message_2"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="@id/message_2" />
      <androidx.appcompat.widget.AppCompatTextView android:textSize="@dimen/sp_13"
                            android:textColor="@color/black"
                            android:gravity="center_vertical"
                            android:id="@id/message_2"
                            android:layout_width="0.0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/dp_16"
                            android:text="@string/settings_security_mode_service_detailed_msg_2"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginStart="@dimen/dp_4"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@id/icon2"
                            app:layout_constraintTop_toBottomOf="@id/message_1" />
      <androidx.appcompat.widget.AppCompatImageView android:id="@id/icon3"
                            android:layout_width="@dimen/dp_24.36"
                            android:layout_height="@dimen/dp_24.36"
                            android:src="@drawable/ic_security_mode_service_4"
                            app:layout_constraintBottom_toBottomOf="@id/message_3"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="@id/message_3" />
      <androidx.appcompat.widget.AppCompatTextView android:textSize="@dimen/sp_13"
                            android:textColor="@color/black"
                            android:gravity="center_vertical"
                            android:id="@id/message_3"
                            android:layout_width="0.0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/dp_16"
                            android:text="@string/settings_security_mode_service_detailed_msg_3"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginStart="@dimen/dp_4"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@id/icon3"
                            app:layout_constraintTop_toBottomOf="@id/message_2" />
      <androidx.appcompat.widget.AppCompatImageView android:id="@id/icon4"
                            android:layout_width="@dimen/dp_24.36"
                            android:layout_height="@dimen/dp_24.36"
                            android:src="@drawable/ic_security_mode_service_3"
                            app:layout_constraintBottom_toBottomOf="@id/message_4"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="@id/message_4" />
      <androidx.appcompat.widget.AppCompatTextView android:textSize="@dimen/sp_13"
                            android:textColor="@color/black"
                            android:gravity="center_vertical"
                            android:id="@id/message_4"
                            android:layout_width="0.0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/dp_16"
                            android:text="@string/settings_security_mode_service_detailed_msg_4"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginStart="@dimen/dp_4"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@id/icon4"
                            app:layout_constraintTop_toBottomOf="@id/message_3" />
    </androidx.constraintlayout.widget.ConstraintLayout>
  </miuix.core.widget.NestedScrollView>
</LinearLayout>