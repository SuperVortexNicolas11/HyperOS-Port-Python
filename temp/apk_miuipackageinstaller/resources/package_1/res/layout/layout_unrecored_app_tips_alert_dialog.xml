<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:gravity="center_horizontal"
              android:orientation="vertical"
              android:id="@id/root"
              android:paddingBottom="@dimen/dp_16"
              android:layout_width="fill_parent"
              android:layout_height="fill_parent"
              android:paddingStart="@dimen/dp_36.36"
              android:paddingEnd="@dimen/dp_36.36" xmlns:android="http://schemas.android.com/apk/res/android">
  <ImageView android:id="@id/icon"
             android:layout_width="@dimen/dp_65.45"
             android:layout_height="@dimen/dp_65.45"
             android:src="@drawable/ic_warning_dialog" />
  <TextView android:textAppearance="@style/TextAppearance.DialogTitle"
            android:gravity="center"
            android:id="@id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_14" />
  <androidx.core.widget.NestedScrollView android:layout_width="fill_parent"
                        android:layout_height="0.0dp"
                        android:fillViewport="true"
                        android:layout_weight="1.0"
                        android:overScrollMode="never">
    <LinearLayout android:orientation="vertical"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content">
      <TextView android:textAppearance="@style/TextAppearance.DialogContent"
                android:id="@id/msg"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_16" />
      <TextView android:textSize="@dimen/sp_14"
                android:textColor="@color/black_40"
                android:id="@id/sub_msg"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_16" />
    </LinearLayout>
  </androidx.core.widget.NestedScrollView>
</LinearLayout>