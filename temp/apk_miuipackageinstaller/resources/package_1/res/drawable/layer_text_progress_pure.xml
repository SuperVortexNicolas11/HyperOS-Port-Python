<?xml version='1.0' encoding='utf-8' ?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
  <item android:id="@android:id/background">
    <shape>
      <corners android:radius="@dimen/dp_39" />
      <stroke android:width="0.5dp"
              android:color="@color/color_E2F0FF" />
      <gradient android:startColor="@color/color_E2F0FF"
                android:endColor="@color/color_E2F0FF"
                android:angle="270.0"
                android:centerY="0.75" />
    </shape>
  </item>
  <item android:id="@android:id/progress">
    <clip>
      <shape>
        <corners android:radius="@dimen/dp_39" />
        <gradient android:startColor="@color/color_0D84FF"
                  android:endColor="@color/color_0D84FF"
                  android:angle="270.0"
                  android:centerY="0.75" />
      </shape>
    </clip>
  </item>
</layer-list>