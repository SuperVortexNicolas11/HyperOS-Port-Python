<?xml version='1.0' encoding='utf-8' ?>
<com.android.settings.chip.FullRelativeLayout android:paddingBottom="15.0dp"
                      android:layout_width="fill_parent"
                      android:layout_height="fill_parent"
                      android:paddingStart="@dimen/miuix_theme_margin_horizontal_common"
                      android:paddingEnd="@dimen/miuix_theme_margin_horizontal_common" xmlns:android="http://schemas.android.com/apk/res/android">
  <RelativeLayout android:id="@id/title_layout"
                  android:paddingTop="14.5dp"
                  android:paddingBottom="14.5dp"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content"
                  android:paddingStart="20.0dp"
                  android:paddingEnd="20.0dp">
    <ImageView android:id="@id/close"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:src="@drawable/chip_edit_close"
               android:layout_centerVertical="true"
               android:contentDescription="@string/miuix_appcompat_cancel_description" />
    <ImageView android:id="@id/save"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:src="@drawable/chip_edit_save"
               android:layout_centerVertical="true"
               android:contentDescription="@string/miuix_appcompat_confirm_description"
               android:layout_alignParentEnd="true" />
    <androidx.appcompat.widget.AppCompatImageButton android:gravity="center_horizontal"
                          android:id="@id/delete"
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:src="@drawable/miuix_action_icon_delete_dark"
                          android:layout_centerVertical="true"
                          android:contentDescription="@string/miuix_appcompat_delete_description"
                          android:layout_toStartOf="@id/save" />
    <TextView android:textSize="20.0sp"
              android:textColor="@color/chip_white"
              android:gravity="center"
              android:id="@id/tv_title"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:text="@string/chip_add_title"
              android:layout_centerVertical="true"
              android:fontFamily="mipro-medium"
              android:layout_toStartOf="@id/delete"
              android:layout_toEndOf="@id/close" />
  </RelativeLayout>
  <miuix.core.widget.NestedScrollView android:layout_width="fill_parent"
                        android:layout_height="fill_parent"
                        android:layout_below="@id/title_layout" xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout android:orientation="vertical"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content">
      <LinearLayout android:orientation="vertical"
                    android:id="@id/pre_group"
                    android:background="@drawable/chip_group_card"
                    android:padding="16.0dp"
                    android:visibility="gone"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">
        <TextView android:textSize="17.0sp"
                  android:textColor="@color/chip_white_95"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:text="@string/chip_fre_tip"
                  android:fontFamily="mipro-medium" />
        <View android:background="@color/chip_edit_line"
              android:layout_width="fill_parent"
              android:layout_height="0.75dp"
              android:layout_marginTop="16.5dp" />
        <miuix.pickerwidget.widget.NumberPicker android:gravity="center_horizontal"
                              android:layout_gravity="center_horizontal"
                              android:id="@id/fre_picker"
                              android:layout_width="fill_parent"
                              android:layout_height="168.0dp" />
      </LinearLayout>
      <TextView android:textSize="13.0sp"
                android:textColor="@color/chip_edit_bottom_tip"
                android:id="@id/pre_group_tip"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8.0dp"
                android:layout_marginBottom="32.0dp"
                android:text="@string/chip_fre_bottom"
                android:layout_marginStart="16.0dp"
                android:layout_marginEnd="16.0dp" />
      <LinearLayout android:orientation="vertical"
                    android:background="@drawable/chip_group_card"
                    android:padding="16.0dp"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">
        <TextView android:textSize="17.0sp"
                  android:textColor="@color/chip_white_95"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:text="@string/chip_vol_tip"
                  android:fontFamily="mipro-medium" />
        <View android:background="@color/chip_edit_line"
              android:layout_width="fill_parent"
              android:layout_height="0.75dp"
              android:layout_marginTop="16.5dp" />
        <miuix.pickerwidget.widget.NumberPicker android:textColorHighlight="@color/chip_edit_select"
                              android:textColorHint="@color/chip_edit_default"
                              android:gravity="center_horizontal"
                              android:layout_gravity="center_horizontal"
                              android:id="@id/vol_picker"
                              android:layout_width="fill_parent"
                              android:layout_height="168.0dp"
                              app:textSizeHighlight="24.0sp"
                              app:textSizeHint="18.0sp" />
      </LinearLayout>
      <TextView android:textSize="13.0sp"
                android:textColor="@color/chip_edit_bottom_tip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8.0dp"
                android:layout_marginBottom="32.0dp"
                android:text="@string/chip_vol_bottom"
                android:layout_marginStart="16.0dp"
                android:layout_marginEnd="16.0dp" />
    </LinearLayout>
  </miuix.core.widget.NestedScrollView>
</com.android.settings.chip.FullRelativeLayout>