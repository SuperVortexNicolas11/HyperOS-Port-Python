                                        }
                                    ]
                                }
                            ]
                        },
                        {
                            "type": "urn:aiot-spec-v3:com.mi.phones:action:[com.android.settings/mobiledata/getmobiledatamode]:0:1.0",
                            "description": "查询移动数据状态",
                            "in": [],
                            "out": [
                                {
                                    "format": "int32",
                                    "name": "status",
                                    "description": "执行状态",
                                    "value-list": [
                                        {
                                            "value": 0,
                                            "description": "执行成功"
                                        },
                                        {
                                            "value": -1,
                                            "description": "执行失败"
                                        },
                                        {
                                            "value": -2,
                                            "description": "请插入sim卡"
                                        },
                                        {
                                            "value": -11,
                                            "description": "当前设备不支持移动网络"
                                        }
                                    ]
