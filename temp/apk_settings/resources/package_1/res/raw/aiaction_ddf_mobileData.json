                                        {
                                            "value": 1,
                                            "description": "已开启"
                                        }
                                    ]
                                }
                            ]
                        },
                        {
                            "type": "urn:aiot-spec-v3:com.mi.phones:action:[com.android.settings/mobiledata/jumpmobiledata]:0:1.0",
