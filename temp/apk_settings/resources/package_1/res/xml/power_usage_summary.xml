<?xml version='1.0' encoding='utf-8' ?>
<PreferenceScreen android:title="@string/power_usage_summary_title"
                  android:key="power_usage_summary_screen"
                  settings:keywords="@string/keywords_battery" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:settings="http://schemas.android.com/apk/res-auto">
  <com.android.settingslib.widget.UsageProgressBarPreference android:paddingBottom="0.0px"
                        android:title="@string/summary_placeholder"
                        android:selectable="false"
                        android:key="battery_header"
                        settings:controller="com.android.settings.fuelgauge.BatteryHeaderPreferenceController" />
  <com.android.settings.fuelgauge.BatteryHeaderTextPreference android:selectable="false"
                        android:key="battery_header_text"
                        settings:controller="com.android.settings.fuelgauge.BatteryHeaderTextPreferenceController" />
  <com.android.settingslib.widget.LayoutPreference android:layout="@layout/preference_battery_error"
                        android:selectable="false"
                        android:key="battery_help_message"
                        settings:searchable="false" />
  <com.android.settings.widget.TipCardPreference android:title="@string/summary_placeholder"
                        android:key="battery_tip"
                        settings:controller="com.android.settings.fuelgauge.batterytip.BatteryTipPreferenceController" />
  <PreferenceCategory android:layout="@layout/settingslib_preference_category_no_title"
                      android:key="power_usage_summary_category">
    <com.android.settingslib.miuisettings.preference.Preference android:title="@string/advanced_battery_preference_title"
                          android:key="battery_usage_summary"
                          android:fragment="com.android.settings.fuelgauge.batteryusage.PowerUsageAdvanced"
                          settings:keywords="@string/keywords_battery_usage" />
    <com.android.settingslib.miuisettings.preference.Preference android:title="@string/battery_saver"
                          android:key="battery_saver_summary"
                          android:fragment="com.android.settings.fuelgauge.batterysaver.BatterySaverSettings"
                          settings:controller="com.android.settings.fuelgauge.BatterySaverController"
                          settings:keywords="@string/keywords_battery_saver" />
    <com.android.settingslib.miuisettings.preference.Preference android:title="@string/smart_battery_manager_title"
                          android:key="smart_battery_manager"
                          android:fragment="com.android.settings.fuelgauge.SmartBatterySettings"
                          settings:controller="com.android.settings.fuelgauge.batterytip.BatteryManagerPreferenceController"
                          settings:keywords="@string/keywords_battery_adaptive_preferences" />
  </PreferenceCategory>
  <SwitchPreferenceCompat android:title="@string/battery_percentage"
                        android:key="status_bar_show_battery_percent"
                        android:summary="@string/battery_percentage_description"
                        settings:controller="com.android.settings.display.BatteryPercentagePreferenceController" />
  <com.android.settingslib.widget.FooterPreference android:title="@string/battery_footer_summary"
                        android:selectable="false"
                        android:key="power_usage_footer"
                        settings:searchable="false" />
</PreferenceScreen>