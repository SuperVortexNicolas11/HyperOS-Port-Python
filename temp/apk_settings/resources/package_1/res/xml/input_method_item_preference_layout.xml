<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:gravity="center_vertical"
              android:layout_gravity="center_vertical"
              android:clipChildren="false"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:minHeight="@dimen/miuix_preference_app_min_height"
              android:paddingEnd="@dimen/miuix_preference_item_padding_end" xmlns:android="http://schemas.android.com/apk/res/android">
  <LinearLayout android:orientation="horizontal"
                android:id="@id/head"
                android:scrollbars="none"
                android:layout_width="0.0dp"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/miuix_preference_app_min_height"
                android:layout_weight="1.0">
    <ImageView android:layout_gravity="center_vertical"
               android:id="@android:id/icon"
               android:layout_width="@dimen/miuix_preference_app_icon_width"
               android:layout_height="@dimen/miuix_preference_app_icon_height"
               android:scaleType="fitXY"
               android:layout_marginStart="@dimen/miuix_preference_item_padding_start"
               android:layout_marginEnd="@dimen/miuix_preference_item_padding_end" />
    <LinearLayout android:gravity="center_vertical"
                  android:layout_gravity="center_vertical"
                  android:orientation="vertical"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  style="@style/Widget.PreferenceItem">
      <TextView android:textAppearance="@style/Miuix.AppCompat.TextAppearance.PreferenceList"
                android:ellipsize="end"
                android:id="@android:id/title"
                android:fadingEdge="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:textAlignment="viewStart"
                android:hyphenationFrequency="full" />
      <TextView android:textAppearance="@style/Miuix.AppCompat.TextAppearance.List.Secondary.Preference"
                android:id="@android:id/summary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/miuix_preference_summary_margin_top"
                android:layout_below="@android:id/title"
                android:textAlignment="viewStart"
                android:layout_alignStart="@android:id/title" />
    </LinearLayout>
  </LinearLayout>
  <RelativeLayout android:id="@id/end"
                  android:scrollbars="none"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content">
    <View android:background="@color/input_method_manage_line_color"
          android:layout_width="1.0dp"
          android:layout_height="34.0dp" />
    <miuix.slidingwidget.widget.SlidingButton android:id="@id/enable_mode"
                          android:focusable="true"
                          android:focusableInTouchMode="true"
                          android:scrollbars="none"
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:layout_marginStart="22.0dp" />
  </RelativeLayout>
</LinearLayout>