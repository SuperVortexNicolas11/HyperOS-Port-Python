<?xml version='1.0' encoding='utf-8' ?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android">
  <PreferenceCategory android:title="@string/application_scenario"
                      android:key="apply_face_data">
    <CheckBoxPreference android:persistent="false"
                        android:title="@string/lock_screen_unlock"
                        android:key="apply_face_data_lock" />
    <CheckBoxPreference android:persistent="false"
                        android:title="@string/ac_enable_title"
                        android:key="apply_privacy_lock" />
  </PreferenceCategory>
  <PreferenceCategory android:title="@string/other_item"
                      android:key="lock_screen_face_data">
    <CheckBoxPreference android:persistent="false"
                        android:title="@string/face_unlock_success_stay_screen_title"
                        android:key="face_unlock_success_stay_screen"
                        android:summary="@string/face_unlock_success_stay_screen_msg" />
    <CheckBoxPreference android:persistent="false"
                        android:title="@string/face_unlock_success_show_message_title"
                        android:key="face_unlock_success_show_message"
                        android:summary="@string/face_unlock_success_show_message_msg" />
    <CheckBoxPreference android:persistent="false"
                        android:title="@string/miui_tof_screen_on_title"
                        android:key="miui_tof_screen_on"
                        android:summary="@string/miui_tof_screen_on_msg" />
    <CheckBoxPreference android:persistent="false"
                        android:title="@string/face_unlock_by_notification_screen_on_title"
                        android:key="face_unlock_by_notification_screen_on"
                        android:summary="@string/face_unlock_by_notification_screen_on_msg" />
    <com.android.settings.faceunlock.ChildUnlockDropDownPreference android:persistent="false"
                          android:title="@string/child_face_unlock_open_education_center"
                          android:key="child_face_unlock_to_education_center"
                          android:summary="@string/child_face_unlock_open_education_center_summary" />
  </PreferenceCategory>
</PreferenceScreen>