<?xml version='1.0' encoding='utf-8' ?>
<PreferenceScreen android:title="@string/language_picker_title"
                  android:key="system_languages" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:settings="http://schemas.android.com/apk/res-auto">
  <com.android.settingslib.widget.TopIntroPreference android:persistent="false"
                        android:title="@string/desc_introduction_of_language_picker"
                        android:selectable="false" />
  <PreferenceCategory android:title="@string/language_picker_category_title">
    <com.android.settingslib.widget.LayoutPreference android:layout="@layout/locale_order_list"
                          android:key="languages_picker" />
    <com.android.settingslib.miuisettings.preference.Preference android:icon="@drawable/ic_add_24dp"
                          android:title="@string/add_a_language"
                          android:key="add_a_language"
                          settings:fragment="com.android.settings.localepicker.SystemLocalePickerFragment"
                          settings:isPreferenceVisible="false" />
  </PreferenceCategory>
  <PreferenceCategory android:title="@string/category_title_terms_of_address"
                      android:key="key_category_terms_of_address"
                      settings:controller="com.android.settings.localepicker.TermsOfAddressCategoryController">
    <com.android.settingslib.miuisettings.preference.Preference android:title="@string/terms_of_address_title"
                          android:key="key_terms_of_address"
                          android:summary="@string/terms_of_address_summary"
                          settings:controller="com.android.settings.localepicker.TermsOfAddressController" />
  </PreferenceCategory>
  <com.android.settingslib.widget.FooterPreference android:persistent="false"
                        android:title="@string/desc_notice_of_language_picker"
                        android:selectable="false"
                        android:key="footer_languages_picker"
                        settings:controller="com.android.settings.localepicker.LocaleHelperPreferenceController" />
</PreferenceScreen>