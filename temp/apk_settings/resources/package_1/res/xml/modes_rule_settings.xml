<?xml version='1.0' encoding='utf-8' ?>
<PreferenceScreen android:title="@string/zen_modes_list_title" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:settings="http://schemas.android.com/apk/res-auto">
  <com.android.settingslib.widget.LayoutPreference android:layout="@layout/settings_entity_header"
                        android:key="header" />
  <com.android.settings.applications.SpacePreference android:layout_height="16.0dp" />
  <com.android.settings.notification.modes.ZenModeBlurbPreference android:key="mode_blurb" />
  <com.android.settings.applications.SpacePreference android:layout_height="8.0dp" />
  <com.android.settingslib.widget.LayoutPreference android:layout="@layout/modes_activation_button"
                        android:selectable="false"
                        android:key="activate" />
  <com.android.settings.applications.SpacePreference android:layout_height="16.0dp" />
  <PreferenceCategory android:title="@string/zen_mode_automatic_trigger_title"
                      android:key="zen_automatic_trigger_category">
    <com.android.settingslib.PrimarySwitchPreference android:key="zen_automatic_trigger_settings" />
    <com.android.settingslib.miuisettings.preference.Preference android:icon="@drawable/ic_add_24dp"
                          android:title="@string/zen_mode_select_schedule"
                          android:key="zen_add_automatic_trigger" />
  </PreferenceCategory>
  <PreferenceCategory android:title="@string/mode_interruption_filter_title"
                      android:key="modes_filters">
    <SwitchPreferenceCompat android:title="@string/zen_mode_allow_all_notifications"
                          android:key="allow_all" />
    <com.android.settings.notification.modes.CircularIconsPreference android:icon="@drawable/ic_zen_mode_category_people"
                          android:title="@string/zen_category_people"
                          android:key="zen_mode_people" />
    <com.android.settings.notification.modes.CircularIconsPreference android:icon="@drawable/ic_zen_mode_category_apps"
                          android:title="@string/zen_category_apps"
                          android:key="zen_mode_apps" />
    <com.android.settings.notification.modes.CircularIconsPreference android:icon="@drawable/ic_zen_mode_category_other"
                          android:title="@string/zen_category_exceptions"
                          android:key="zen_other_settings" />
  </PreferenceCategory>
  <PreferenceCategory android:title="@string/mode_device_effects_title"
                      android:key="modes_additional_actions">
    <com.android.settingslib.miuisettings.preference.Preference android:icon="@drawable/ic_zen_mode_category_display"
                          android:title="@string/mode_display_settings_title"
                          android:key="mode_display_settings" />
    <com.android.settingslib.miuisettings.preference.Preference android:icon="@drawable/ic_zen_mode_category_duration"
                          android:title="@string/zen_category_duration"
                          android:key="mode_manual_duration" />
  </PreferenceCategory>
</PreferenceScreen>