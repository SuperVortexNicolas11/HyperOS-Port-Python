<?xml version='1.0' encoding='utf-8' ?>
<PreferenceScreen android:title="@string/device_status"
                  android:key="my_device_info_pref_screen" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:settings="http://schemas.android.com/apk/res-auto">
  <PreferenceCategory android:selectable="false">
    <com.android.settings.widget.LTRValuePreference android:persistent="false"
                          android:title="@string/battery_status_title"
                          android:selectable="true"
                          android:key="battery_status" />
    <com.android.settings.widget.LTRValuePreference android:persistent="false"
                          android:title="@string/battery_level_title"
                          android:selectable="true"
                          android:key="battery_level" />
  </PreferenceCategory>
  <PreferenceCategory android:title="@string/my_device_info_basic_info_category_title"
                      android:selectable="false"
                      android:key="basic_info_category">
    <com.android.settingslib.miuisettings.preference.Preference android:title="@string/my_device_info_account_preference_title"
                          android:key="branded_account"
                          android:summary="@string/summary_placeholder"
                          android:order="2"
                          settings:controller="com.android.settings.deviceinfo.BrandedAccountPreferenceController"
                          settings:enableCopying="true" />
    <com.android.settingslib.miuisettings.preference.Preference android:title="@string/status_number"
                          android:selectable="false"
                          android:key="phone_number"
                          android:summary="@string/summary_placeholder"
                          android:order="4"
                          settings:controller="com.android.settings.deviceinfo.PhoneNumberPreferenceController"
                          settings:enableCopying="true"
                          settings:isPreferenceVisible="@bool/config_show_sim_info"
                          style="?attr/preferenceInformationStyle" />
  </PreferenceCategory>
  <PreferenceCategory android:title="@string/my_device_info_device_details_category_title"
                      android:selectable="false"
                      android:key="device_detail_category">
    <com.android.settingslib.miuisettings.preference.Preference android:title="@string/sim_status_title"
                          android:key="sim_status"
                          android:summary="@string/summary_placeholder"
                          android:order="18"
                          settings:allowDividerAbove="true"
                          settings:controller="com.android.settings.deviceinfo.simstatus.SimStatusPreferenceController"
                          settings:isPreferenceVisible="@bool/config_show_sim_info"
                          settings:keywords="@string/keywords_sim_status"
                          settings:showRightArrow="true" />
    <com.android.settingslib.miuisettings.preference.Preference android:title="@string/sim_card_lock"
                          android:key="sim_card_lock">
      <intent android:targetPackage="com.android.phone"
              android:targetClass="com.android.phone.settings.SimLockActivity" />
    </com.android.settingslib.miuisettings.preference.Preference>
    <com.android.settingslib.miuisettings.preference.Preference android:title="@string/model_info"
                          android:key="device_model"
                          android:summary="@string/summary_placeholder"
                          android:order="30"
                          android:fragment="com.android.settings.deviceinfo.hardwareinfo.HardwareInfoFragment"
                          settings:controller="com.android.settings.deviceinfo.HardwareInfoPreferenceController"
                          settings:enableCopying="true"
                          settings:keywords="@string/keywords_model_and_hardware" />
    <com.android.settingslib.miuisettings.preference.Preference android:title="@string/status_eid"
                          android:key="eid_info"
                          android:order="31"
                          settings:controller="com.android.settings.deviceinfo.SimEidPreferenceController"
                          settings:enableCopying="true"
                          settings:isPreferenceVisible="@bool/config_show_sim_info"
                          settings:showRightArrow="true" />
    <com.android.settingslib.miuisettings.preference.Preference android:title="@string/status_imei"
                          android:key="imei_info"
                          android:summary="@string/summary_placeholder"
                          android:order="32"
                          settings:controller="com.android.settings.deviceinfo.imei.ImeiInfoPreferenceController"
                          settings:isPreferenceVisible="@bool/config_show_sim_info"
                          settings:keywords="@string/keywords_imei_info"
                          settings:showRightArrow="true" />
    <com.android.settingslib.miuisettings.preference.Preference android:title="@string/battery_info"
                          android:key="battery_info"
                          android:order="43"
                          android:fragment="com.android.settings.deviceinfo.batteryinfo.BatteryInfoFragment"
                          settings:controller="com.android.settings.deviceinfo.batteryinfo.BatteryInfoPreferenceController"
                          settings:keywords="@string/keywords_battery_info" />
  </PreferenceCategory>
  <PreferenceCategory android:title="@string/my_device_info_device_identifiers_category_title"
                      android:key="device_identifiers_category">
    <com.android.settings.widget.LTRValuePreference android:title="@string/wifi_ip_address"
                          android:selectable="true"
                          android:key="wifi_ip_address"
                          android:summary="@string/summary_placeholder"
                          android:order="35"
                          settings:allowDividerAbove="true"
                          settings:enableCopying="true"
                          style="?attr/preferenceInformationStyle" />
    <com.android.settings.widget.LTRValuePreference android:title="@string/status_device_wifi_mac_address"
                          android:selectable="true"
                          android:key="wifi_mac_address"
                          android:summary="@string/summary_placeholder"
                          android:order="36"
                          settings:enableCopying="true"
                          style="?attr/preferenceInformationStyle" />
    <com.android.settings.widget.LTRValuePreference android:title="@string/status_bt_address"
                          android:selectable="true"
                          android:key="bt_address"
                          android:summary="@string/summary_placeholder"
                          android:order="37"
                          settings:enableCopying="true"
                          style="?attr/preferenceInformationStyle" />
    <com.android.settings.widget.LTRValuePreference android:title="@string/status_up_time"
                          android:selectable="true"
                          android:key="up_time"
                          android:summary="@string/summary_placeholder"
                          android:order="38"
                          style="?attr/preferenceInformationStyle" />
    <com.android.settingslib.miuisettings.preference.Preference android:title="@string/manual"
                          android:key="manual"
                          android:order="50">
      <intent android:targetPackage="${applicationId}"
              android:action="android.settings.SHOW_MANUAL" />
    </com.android.settingslib.miuisettings.preference.Preference>
    <com.android.settingslib.miuisettings.preference.Preference android:title="@string/device_feedback"
                          android:key="device_feedback"
                          android:order="41"
                          settings:keywords="@string/keywords_device_feedback" />
    <com.android.settingslib.miuisettings.preference.Preference android:title="@string/fcc_equipment_id"
                          android:key="fcc_equipment_id"
                          android:summary="@string/summary_placeholder"
                          android:order="42" />
  </PreferenceCategory>
  <com.android.settingslib.miuisettings.preference.Preference android:title="@string/software_version"
                        android:selectable="false"
                        android:key="software_version"
                        android:summary="@string/summary_placeholder"
                        android:order="44"
                        settings:enableCopying="true" />
  <com.android.settingslib.miuisettings.preference.Preference android:title="@string/ram_total_size"
                        android:selectable="false"
                        android:key="key_storage_total_size"
                        android:summary="@string/summary_placeholder"
                        android:order="45"
                        settings:allowDividerAbove="true"
                        settings:enableCopying="true" />
</PreferenceScreen>