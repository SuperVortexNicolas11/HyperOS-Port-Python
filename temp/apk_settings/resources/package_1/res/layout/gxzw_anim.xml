<?xml version='1.0' encoding='utf-8' ?>
<miuix.springback.view.SpringBackLayout android:layout_width="fill_parent"
                      android:layout_height="fill_parent"
                      app:scrollOrientation="vertical"
                      app:scrollableView="@id/scroll_view" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <androidx.core.widget.NestedScrollView android:scrollbarStyle="outsideOverlay"
                        android:gravity="top"
                        android:id="@id/scroll_view"
                        android:layout_width="fill_parent"
                        android:layout_height="fill_parent"
                        android:fillViewport="true">
    <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="fill_parent"
                          android:layout_height="fill_parent">
      <androidx.constraintlayout.widget.ConstraintLayout android:id="@id/gxzw_anim_content"
                            android:paddingLeft="@dimen/miui_gxzw_anim_horizontal_padding"
                            android:paddingTop="@dimen/miui_gxzw_anim_vertical_padding"
                            android:paddingRight="@dimen/miui_gxzw_anim_horizontal_padding"
                            android:paddingBottom="@dimen/miui_gxzw_anim_vertical_padding"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="@dimen/miui_gxzw_anim_content_margin_horizontal"
                            android:layout_marginTop="4.0dp"
                            android:layout_marginRight="@dimen/miui_gxzw_anim_content_margin_horizontal"
                            app:layout_constraintBottom_toTopOf="@id/gxzw_anim_select_view"
                            app:layout_constraintLeft_toLeftOf="parent"
                            app:layout_constraintRight_toRightOf="parent"
                            app:layout_constraintTop_toTopOf="parent">
        <RelativeLayout android:background="@drawable/shape_gxzw_anim_preview_bg"
                        android:paddingBottom="26.0dp"
                        android:layout_width="0.0dp"
                        android:layout_height="0.0dp"
                        app:layout_constraintDimensionRatio="227:486"
                        app:layout_constraintLeft_toLeftOf="parent"
                        app:layout_constraintRight_toRightOf="parent"
                        app:layout_constraintTop_toTopOf="parent">
          <include android:layout_width="wrap_content"
                   android:layout_height="wrap_content"
                   android:layout_marginTop="40.0dp"
                   android:layoutDirection="ltr"
                   android:layout_marginStart="19.54dp"
                   layout="@layout/classic_layout" />
          <com.android.settings.MutedVideoView android:id="@id/gxzw_anim_preview"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentBottom="true"
                                android:layout_centerHorizontal="true"
                                android:importantForAccessibility="no"
                                android:layout_marginStart="15.0dp"
                                android:layout_marginEnd="15.0dp" />
        </RelativeLayout>
      </androidx.constraintlayout.widget.ConstraintLayout>
      <LinearLayout android:id="@id/gxzw_anim_switch_layout"
                    android:background="@drawable/shape_gxzw_anim_preview_outer_bg"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/miui_gxzw_anim_content_margin_horizontal"
                    android:layout_marginHorizontal="@dimen/miui_gxzw_anim_content_margin_horizontal"
                    android:paddingHorizontal="@dimen/miui_gxzw_anim_switch_padding_horizontal"
                    android:paddingVertical="@dimen/miui_gxzw_anim_switch_padding_vertical"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/gxzw_anim_content">
        <TextView android:textSize="@dimen/miui_gxzw_anim_switch_text_size"
                  android:textColor="@color/miui_gxzw_anim_text_color"
                  android:gravity="center_vertical"
                  android:layout_gravity="center|start"
                  android:layout_width="0.0dp"
                  android:layout_height="wrap_content"
                  android:text="@string/gxzw_anim_switch"
                  android:layout_weight="1.0"
                  android:fontFamily="mipro-medium"
                  android:layout_marginEnd="@dimen/miui_gxzw_anim_switch_text_margin_end" />
        <miuix.slidingwidget.widget.SlidingButton android:layout_gravity="center|end"
                              android:id="@id/gxzw_anim_enable"
                              android:layout_width="wrap_content"
                              android:layout_height="wrap_content" />
      </LinearLayout>
      <FrameLayout android:layout_width="fill_parent"
                   android:layout_height="wrap_content"
                   android:layout_marginTop="@dimen/miui_gxzw_anim_content_margin_horizontal"
                   android:layout_marginHorizontal="@dimen/miui_gxzw_anim_content_margin_horizontal"
                   app:layout_constraintLeft_toLeftOf="parent"
                   app:layout_constraintRight_toRightOf="parent"
                   app:layout_constraintTop_toBottomOf="@id/gxzw_anim_switch_layout">
        <miuix.recyclerview.widget.RecyclerView android:id="@id/gxzw_anim_style_view"
                              android:clipToPadding="false"
                              android:layout_width="fill_parent"
                              android:layout_height="wrap_content"
                              android:nestedScrollingEnabled="false" />
      </FrameLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
  </androidx.core.widget.NestedScrollView>
</miuix.springback.view.SpringBackLayout>