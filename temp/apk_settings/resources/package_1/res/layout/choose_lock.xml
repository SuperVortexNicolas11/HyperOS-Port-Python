<?xml version='1.0' encoding='utf-8' ?>
<miuix.springback.view.SpringBackLayout android:layout_width="fill_parent"
                      android:layout_height="fill_parent"
                      app:scrollableView="@id/scrollview" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <miuix.core.widget.NestedScrollView android:id="@id/scrollview"
                        android:layout_width="fill_parent"
                        android:layout_height="fill_parent">
    <LinearLayout android:orientation="vertical"
                  android:layout_width="fill_parent"
                  android:layout_height="fill_parent">
      <View android:id="@id/lock_none"
            android:layout_width="1.0px"
            android:layout_height="1.0px" />
      <View android:id="@id/lock_pin"
            android:layout_width="1.0px"
            android:layout_height="1.0px" />
      <FrameLayout android:scrollbarAlwaysDrawVerticalTrack="true"
                   android:id="@id/prefs_container"
                   android:clipToPadding="false"
                   android:layout_width="fill_parent"
                   android:layout_height="wrap_content"
                   android:layout_marginTop="@dimen/choose_unlock_item_top_margin"
                   android:drawSelectorOnTop="false"
                   android:cacheColorHint="@android:color/transparent" />
      <LinearLayout android:orientation="vertical"
                    android:id="@id/choose_lock_bottom_container"
                    android:paddingBottom="?attr/preferenceItemPaddingBottom"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/miuix_preference_card_group_margin_bottom"
                    android:layout_marginStart="?attr/preferenceCardGroupMarginStart"
                    android:layout_marginEnd="?attr/preferenceCardGroupMarginEnd">
        <TextView android:textSize="@dimen/choose_unlock_hint_text_size"
                  android:textColor="@color/choose_password_forget_text_color_light"
                  android:id="@id/hint_text"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content"
                  android:layout_marginBottom="@dimen/navigation_settings_margin_bottom"
                  android:paddingStart="?attr/preferenceItemPaddingStart"
                  android:paddingEnd="?attr/preferenceItemPaddingEnd" />
        <LinearLayout android:gravity="center_vertical"
                      android:orientation="horizontal"
                      android:id="@id/visible_pattern_layout"
                      android:background="@drawable/choose_unlock_item_background"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content"
                      android:layout_marginBottom="@dimen/navigation_settings_margin_bottom"
                      android:paddingStart="?attr/preferenceItemPaddingStart"
                      android:paddingEnd="?attr/preferenceItemPaddingEnd"
                      android:paddingVertical="@dimen/turn_off_password_padding_vertical">
          <TextView android:textAppearance="@style/Miuix.AppCompat.TextAppearance.PreferenceList"
                    android:textSize="@dimen/keyguard_provision_step_text_size"
                    android:gravity="center_vertical"
                    android:layout_gravity="center|start"
                    android:id="@id/visible_pattern_title"
                    android:layout_width="0.0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/lockpattern_settings_enable_visible_pattern_title"
                    android:layout_weight="1.0"
                    android:importantForAccessibility="no"
                    android:fontFamily="mipro-medium"
                    android:textDirection="locale"
                    android:layout_marginEnd="@dimen/turn_off_password_text_button_margin" />
          <miuix.slidingwidget.widget.SlidingButton android:layout_gravity="center|end"
                                android:id="@id/visible_pattern_button"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:importantForAccessibility="no" />
        </LinearLayout>
        <TextView android:textAppearance="@style/Miuix.AppCompat.TextAppearance.PreferenceList"
                  android:textSize="@dimen/keyguard_provision_step_text_size"
                  android:textColor="@color/turn_off_password_color"
                  android:gravity="center|start"
                  android:id="@id/turn_off_password"
                  android:background="@drawable/choose_unlock_item_background"
                  android:layout_width="fill_parent"
                  android:layout_height="@dimen/turn_off_password_height"
                  android:layout_marginBottom="@dimen/navigation_settings_margin_bottom"
                  android:text="@string/turn_off_keyguard_password_title"
                  android:fontFamily="mipro-medium"
                  android:textDirection="locale"
                  android:paddingStart="?attr/preferenceItemPaddingStart"
                  android:paddingEnd="?attr/preferenceItemPaddingEnd" />
        <TextView android:textSize="@dimen/navigation_settings_size"
                  android:textColor="#ff8c93b0"
                  android:gravity="center|start"
                  android:id="@id/navigation_settings"
                  android:visibility="gone"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:text="@string/navigation_guide_settings"
                  android:fontFamily="mipro-misans"
                  android:paddingStart="?attr/preferenceItemPaddingStart"
                  android:paddingVertical="8.0dp" />
        <LinearLayout android:gravity="center"
                      android:orientation="vertical"
                      android:background="@drawable/choose_unlock_item_background"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content">
          <include android:id="@id/navigation_guide_left"
                   android:visibility="gone"
                   layout="@layout/miui_navigation_guide_item" />
          <include android:id="@id/navigation_guide_center"
                   android:visibility="gone"
                   layout="@layout/miui_navigation_guide_item" />
          <include android:id="@id/navigation_guide_right"
                   android:visibility="gone"
                   layout="@layout/miui_navigation_guide_item" />
        </LinearLayout>
      </LinearLayout>
    </LinearLayout>
  </miuix.core.widget.NestedScrollView>
</miuix.springback.view.SpringBackLayout>