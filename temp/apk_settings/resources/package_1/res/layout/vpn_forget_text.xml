<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:gravity="center_vertical"
              android:layout_gravity="left"
              android:background="?attr/preferenceItemBackground"
              android:paddingLeft="@dimen/vpn_forget_padding_left"
              android:focusable="false"
              android:clickable="false"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <LinearLayout android:gravity="center_vertical"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
    <TextView android:textSize="@dimen/vpn_forget_text_size"
              android:textColor="@color/vpn_forget_text_color"
              android:ellipsize="middle"
              android:id="@id/title"
              android:fadingEdge="horizontal"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/vpn_forget_long"
              android:singleLine="true"
              android:textAllCaps="true" />
  </LinearLayout>
</LinearLayout>