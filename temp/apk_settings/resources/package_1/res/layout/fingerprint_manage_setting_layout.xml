<?xml version='1.0' encoding='utf-8' ?>
<miuix.springback.view.SpringBackLayout android:layout_width="fill_parent"
                      android:layout_height="fill_parent"
                      app:scrollableView="@id/scrollview" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <miuix.core.widget.NestedScrollView android:id="@id/scrollview"
                        android:layout_width="fill_parent"
                        android:layout_height="fill_parent">
    <LinearLayout android:orientation="vertical"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content">
      <FrameLayout android:id="@id/prefs_container"
                   android:layout_width="fill_parent"
                   android:layout_height="wrap_content" />
      <TextView android:textSize="@dimen/add_fingerprint_title_text_size"
                android:id="@id/fingerprint_hint"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/add_fingerprint_page_layout_margin_top"
                android:layout_marginStart="25.0dp"
                android:layout_marginEnd="25.0dp" />
      <com.android.settingslib.widget.LinkTextView android:id="@id/fingerprint_hint_more"
                            android:paddingBottom="8.0dp"
                            android:visibility="gone"
                            android:clickable="true"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/admin_support_more_info"
                            android:layout_marginStart="25.0dp"
                            style="@style/TextAppearance.Footer.Title.SettingsLib" />
    </LinearLayout>
  </miuix.core.widget.NestedScrollView>
</miuix.springback.view.SpringBackLayout>