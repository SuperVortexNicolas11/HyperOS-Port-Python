<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:id="@id/contentPanel"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android">
  <miuix.core.widget.NestedScrollView android:layout_gravity="center_vertical"
                        android:layout_width="0.0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2.4"
                        android:layout_marginStart="@dimen/wifi_assistant_horizontal_margin"
                        android:layout_marginEnd="@dimen/wifi_assistant_horizontal_margin">
    <TextView android:textStyle="bold"
              android:id="@id/assistant_prompt"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:text="@string/wifi_assistant_prompt_checkbox"
              android:textDirection="locale"
              style="?android:attr/textAppearanceLarge" />
  </miuix.core.widget.NestedScrollView>
  <LinearLayout android:layout_width="0.0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.0">
    <miuix.slidingwidget.widget.SlidingButton android:layout_gravity="right"
                          android:id="@id/inquiry"
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:layout_marginEnd="@dimen/wifi_assistant_horizontal_margin" />
  </LinearLayout>
</LinearLayout>