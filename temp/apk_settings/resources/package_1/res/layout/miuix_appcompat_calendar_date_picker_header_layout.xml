<?xml version='1.0' encoding='utf-8' ?>
<FrameLayout android:id="@id/calendar_date_picker_header_layout"
             android:clickable="true"
             android:layout_width="fill_parent"
             android:layout_height="wrap_content"
             android:layout_marginBottom="@dimen/miuix_appcompat_calendar_date_picker_header_margin_bottom"
             android:paddingHorizontal="@dimen/miuix_appcompat_calendar_date_picker_header_horizontal_padding" xmlns:android="http://schemas.android.com/apk/res/android">
  <ImageView android:layout_gravity="center|start"
             android:id="@id/left_arrow"
             android:layout_width="wrap_content"
             android:layout_height="wrap_content"
             android:src="@drawable/miuix_appcompat_calendar_date_picker_arrow_left"
             android:contentDescription="@string/calendar_date_picker_a11y_prev_month" />
  <TextView android:layout_gravity="center"
            android:id="@id/calendar_date_picker_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawablePadding="@dimen/miuix_appcompat_calendar_date_picker_header_drawable_padding"
            android:drawableEnd="@drawable/miuix_appcompat_calendar_date_picker_arrow_down"
            android:textDirection="ltr"
            android:accessibilityLiveRegion="polite"
            style="@style/TextAppearance.CalendarDatePicker.Header" />
  <ImageView android:layout_gravity="center|end"
             android:id="@id/right_arrow"
             android:layout_width="wrap_content"
             android:layout_height="wrap_content"
             android:src="@drawable/miuix_appcompat_calendar_date_picker_arrow_right"
             android:contentDescription="@string/calendar_date_picker_a11y_next_month" />
</FrameLayout>