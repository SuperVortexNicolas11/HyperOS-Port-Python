<?xml version='1.0' encoding='utf-8' ?>
<ScrollView android:orientation="vertical"
            android:background="@color/main_page_background"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:fillViewport="true" xmlns:android="http://schemas.android.com/apk/res/android">
  <LinearLayout android:gravity="center_horizontal"
                android:orientation="vertical"
                android:id="@id/pvc_content"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:layout_weight="1.0">
    <View android:layout_width="0.0dp"
          android:layout_height="0.0dp"
          android:layout_weight="1.0" />
    <ImageView android:id="@id/pvc_icon"
               android:layout_width="@dimen/privacy_password_icon_size"
               android:layout_height="@dimen/privacy_password_icon_size" />
    <TextView android:textSize="@dimen/pvc_account_text_size"
              android:textColor="@color/add_account_text_color"
              android:id="@id/pvc_account_text"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/privacy_password_account_text_margin_top" />
    <TextView android:textSize="@dimen/pvc_account_text_size"
              android:textColor="@color/add_account_text_color"
              android:gravity="center"
              android:id="@id/pvc_add_account_info"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/privacy_password_account_info_margin_top"
              android:text="@string/privacy_password_add_account_info"
              android:fontFamily="mipro-medium"
              android:layout_marginStart="@dimen/privacy_password_common_margin"
              android:layout_marginEnd="@dimen/privacy_password_common_margin" />
    <TextView android:textSize="@dimen/privacy_password_exit_account_info_text_size"
              android:textColor="@color/pvc_exit_account_info_text_color"
              android:gravity="center"
              android:id="@id/pvc_exit_account_info"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/pvc_exit_account_info_margin_top"
              android:text="@string/privacy_password_exit_account_info"
              android:fontFamily="mipro-regular"
              android:layout_marginStart="@dimen/privacy_password_common_margin"
              android:layout_marginEnd="@dimen/privacy_password_common_margin" />
    <View android:layout_width="0.0dp"
          android:layout_height="0.0dp"
          android:layout_weight="1.0" />
  </LinearLayout>
</ScrollView>