<?xml version='1.0' encoding='utf-8' ?>
<androidx.constraintlayout.widget.ConstraintLayout android:id="@id/root"
                      android:background="@android:color/black"
                      android:layout_width="fill_parent"
                      android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <TextView android:textSize="18.0dp"
            android:textColor="@android:color/white"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:id="@id/title"
            android:layout_width="0.0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="21.0dp"
            android:text="@string/miui_sos_emergency_title"
            android:layout_centerVertical="true"
            android:lineSpacingExtra="3.0dp"
            android:layout_marginHorizontal="30.0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
  <TextView android:textSize="17.0dp"
            android:textColor="@android:color/white"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:id="@id/banner"
            android:background="@drawable/sos_exit_dialog_el_bg"
            android:layout_width="0.0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2.0dp"
            android:text="@string/miui_sos_exit_send_location_title"
            android:maxLines="2"
            android:layout_marginHorizontal="20.0dp"
            android:paddingHorizontal="20.0dp"
            android:paddingVertical="9.0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/title" />
  <androidx.recyclerview.widget.RecyclerView android:id="@id/contacts_rv"
                        android:background="@drawable/sos_common_bg"
                        android:layout_width="0.0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8.0dp"
                        android:paddingVertical="8.0dp"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        app:layout_constraintEnd_toEndOf="@id/banner"
                        app:layout_constraintStart_toStartOf="@id/banner"
                        app:layout_constraintTop_toBottomOf="@id/banner" />
  <androidx.constraintlayout.widget.ConstraintLayout android:id="@id/emergencies"
                        android:layout_width="0.0dp"
                        android:layout_height="67.0dp"
                        android:layout_marginTop="8.0dp"
                        app:layout_constraintEnd_toEndOf="@id/contacts_rv"
                        app:layout_constraintStart_toStartOf="@id/contacts_rv"
                        app:layout_constraintTop_toBottomOf="@id/contacts_rv">
    <LinearLayout android:gravity="center"
                  android:orientation="vertical"
                  android:id="@id/emergency_1"
                  android:background="@drawable/sos_common_bg"
                  android:layout_width="0.0dp"
                  android:layout_height="fill_parent">
      <TextView android:textSize="20.0dp"
                android:textColor="@android:color/white"
                android:layout_gravity="center_horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="110" />
    </LinearLayout>
    <LinearLayout android:gravity="center"
                  android:orientation="vertical"
                  android:id="@id/emergency_2"
                  android:background="@drawable/sos_common_bg"
                  android:layout_width="0.0dp"
                  android:layout_height="fill_parent">
      <TextView android:textSize="20.0dp"
                android:textColor="@android:color/white"
                android:layout_gravity="center_horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="120" />
    </LinearLayout>
    <LinearLayout android:gravity="center"
                  android:orientation="vertical"
                  android:id="@id/emergency_3"
                  android:background="@drawable/sos_common_bg"
                  android:layout_width="0.0dp"
                  android:layout_height="fill_parent">
      <TextView android:textSize="20.0dp"
                android:textColor="@android:color/white"
                android:layout_gravity="center_horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="119" />
    </LinearLayout>
    <androidx.constraintlayout.helper.widget.Flow android:layout_width="fill_parent"
                          android:layout_height="wrap_content"
                          app:constraint_referenced_ids="emergency_1,emergency_2,emergency_3"
                          app:flow_horizontalGap="2.0dp"
                          app:layout_constraintBottom_toBottomOf="parent"
                          app:layout_constraintEnd_toEndOf="parent"
                          app:layout_constraintStart_toStartOf="parent"
                          app:layout_constraintTop_toTopOf="parent" />
  </androidx.constraintlayout.widget.ConstraintLayout>
  <Button android:textSize="17.0dp"
          android:textColor="#b3ffffff"
          android:id="@id/exit_btn"
          android:paddingTop="13.5dp"
          android:paddingBottom="13.5dp"
          android:layout_width="0.0dp"
          android:layout_height="wrap_content"
          android:layout_marginBottom="20.0dp"
          android:text="@string/miui_sos_exit_emergency_title"
          android:paddingStart="20.0dp"
          android:paddingEnd="20.0dp"
          android:layout_marginHorizontal="20.0dp"
          app:layout_constraintBottom_toBottomOf="parent"
          app:layout_constraintEnd_toEndOf="parent"
          app:layout_constraintStart_toStartOf="parent"
          app:layout_constraintWidth_max="336.0dp" />
</androidx.constraintlayout.widget.ConstraintLayout>