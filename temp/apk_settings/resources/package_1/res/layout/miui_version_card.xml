<?xml version='1.0' encoding='utf-8' ?>
<RelativeLayout android:layout_width="fill_parent"
                android:layout_height="@dimen/my_device_os_logo_area_height" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <ImageView android:id="@id/miui_logo_view"
             android:layout_width="@dimen/my_device_os_logo_width"
             android:layout_height="@dimen/my_device_os_logo_height"
             android:layout_marginTop="@dimen/my_device_os_logo_margin_top"
             android:scaleType="fitXY"
             android:layout_centerHorizontal="true"
             android:alpha="0.0" />
  <LinearLayout android:orientation="vertical"
                android:id="@id/version_layout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20.0dp"
                android:layout_below="@id/miui_logo_view"
                android:layout_centerHorizontal="true"
                android:alpha="0.0">
    <TextView android:textSize="14.0sp"
              android:textColor="@color/instructions_text_color_append"
              android:id="@id/miui_version_text"
              android:scrollbars="none"
              android:fadingEdge="none"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:includeFontPadding="false"
              android:importantForAccessibility="no"
              android:textAlignment="viewStart"
              android:fallbackLineSpacing="false"
              style="@style/Miuix.AppCompat.TextAppearance.List.Secondary.Preference" />
  </LinearLayout>
  <miuix.cardview.HyperCardView android:id="@id/update_hint_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/my_device_update_btn_margin_bottom"
                        android:maxWidth="312.0dp"
                        android:minWidth="248.0dp"
                        android:minHeight="50.0dp"
                        android:layout_alignParentBottom="true"
                        android:layout_centerHorizontal="true"
                        android:alpha="0.0"
                        android:layout_marginStart="28.0dp"
                        android:layout_marginEnd="28.0dp"
                        style="@style/MyCardView.Border">
    <TextView android:textSize="17.0sp"
              android:textStyle="bold"
              android:textColor="@color/my_device_update_text"
              android:layout_gravity="center"
              android:scrollbars="none"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/device_miui_version_update"
              android:fontFamily="@string/miuix_font_style_misans_demibold_font_family" />
  </miuix.cardview.HyperCardView>
</RelativeLayout>