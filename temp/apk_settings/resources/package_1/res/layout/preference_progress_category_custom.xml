<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:gravity="center_vertical"
              android:orientation="horizontal"
              android:background="?attr/preferenceCategoryBackground"
              android:paddingTop="8.0dp"
              android:paddingBottom="8.0dp"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:paddingStart="28.0dp"
              android:paddingEnd="28.0dp" xmlns:android="http://schemas.android.com/apk/res/android">
  <LinearLayout android:gravity="center|start"
                android:orientation="horizontal"
                android:id="@id/icon_container"
                android:layout_width="56.0dp"
                android:layout_height="wrap_content">
    <com.android.internal.widget.PreferenceImageView android:id="@android:id/icon"
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:maxWidth="18.0dp"
                          android:maxHeight="18.0dp" />
  </LinearLayout>
  <TextView android:textSize="14.0sp"
            android:textColor="?attr/preferenceCategoryTextColor"
            android:id="@android:id/title"
            android:background="@null"
            android:layout_width="0.0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.0"
            android:textAllCaps="true"
            style="@style/Miuix.AppCompat.TextAppearance.PreferenceCategory" />
  <ImageView android:id="@id/scanning_progress"
             android:focusable="true"
             android:visibility="gone"
             android:layout_width="wrap_content"
             android:layout_height="wrap_content"
             android:src="@drawable/nearby_wifi_bt_refresh"
             android:scaleType="centerInside"
             android:importantForAccessibility="yes"
             android:layout_marginStart="14.0dp" />
</LinearLayout>