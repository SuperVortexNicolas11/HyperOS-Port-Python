<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:id="@id/provision_lyt"
              android:layout_width="fill_parent"
              android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android">
  <include layout="@layout/new_provision_actionbar" />
  <Space android:id="@id/provision_title_space"
         android:visibility="gone"
         android:layout_width="fill_parent"
         android:layout_height="@dimen/provision_space_between_actionbar_title" />
  <com.airbnb.lottie.LottieAnimationView android:layout_gravity="center_horizontal"
                        android:id="@id/lottie_animation_view"
                        android:layout_width="@dimen/lottie_view_size"
                        android:layout_height="@dimen/lottie_view_size"
                        android:layout_marginTop="@dimen/lottie_view_margin_top"
                        android:layout_marginBottom="@dimen/lottie_view_margin_bottom" />
  <include layout="@layout/new_provision_lyt_title" />
  <include layout="@layout/new_provision_anim_display" />
  <miuix.provision.CustomDispatchFrameLayout android:layout_gravity="center_horizontal"
                        android:id="@id/provision_container"
                        android:layout_width="fill_parent"
                        android:layout_height="0.0dp"
                        android:layout_weight="1.0"
                        android:paddingHorizontal="@dimen/provision_container_padding_horizontal_common" />
</LinearLayout>