<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:id="@id/root_layout"
              android:layout_width="fill_parent"
              android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <com.miui.support.cardview.CardView android:id="@id/list_card_view"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/screen_margin_left"
                        android:layout_marginTop="@dimen/screen_margin_right"
                        android:layout_marginRight="@dimen/screen_margin_right"
                        app:cardBackgroundColor="@color/locale_cardview_background_color"
                        app:cardCornerRadius="@dimen/miuix_preference_high_light_radius"
                        app:cardElevation="0.0dp">
    <ListView android:id="@id/list_view"
              android:clipToPadding="false"
              android:layout_width="fill_parent"
              android:layout_height="fill_parent" />
  </com.miui.support.cardview.CardView>
  <LinearLayout android:gravity="center_horizontal"
                android:orientation="vertical"
                android:id="@id/search_empty"
                android:paddingTop="@dimen/search_empty_view_margin_top"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent">
    <ImageView android:gravity="center_horizontal"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:src="@drawable/search_list_empty"
               android:contentDescription="@null" />
    <TextView android:textAppearance="@style/Miuix.AppCompat.TextAppearance.BlankPage"
              android:id="@id/empty_text"
              android:paddingTop="@dimen/search_empty_view_margin_element"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/search_empty" />
  </LinearLayout>
</LinearLayout>