<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="horizontal"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:importantForAccessibility="no" xmlns:android="http://schemas.android.com/apk/res/android">
  <ImageView android:layout_width="28.0dp"
             android:layout_height="28.0dp"
             android:src="@drawable/ic_a_small" />
  <com.android.settings.display.FontSizeAdjustView android:layout_gravity="center_vertical"
                        android:id="@id/font_view"
                        android:background="@drawable/shape_corner_matrix"
                        android:layout_width="0.0dp"
                        android:layout_height="@dimen/font_size_view_height"
                        android:layout_weight="1.0"
                        android:layout_marginStart="@dimen/miuix_preference_item_padding_start"
                        android:layout_marginEnd="@dimen/miuix_preference_item_padding_end" />
  <ImageView android:layout_width="28.0dp"
             android:layout_height="28.0dp"
             android:src="@drawable/ic_a_big"
             android:importantForAccessibility="no" />
</LinearLayout>