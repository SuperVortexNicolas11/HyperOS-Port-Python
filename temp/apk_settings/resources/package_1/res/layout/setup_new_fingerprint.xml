<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:id="@id/setup_new_fingerprint_view"
              android:background="@android:color/black"
              android:layout_width="fill_parent"
              android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <LinearLayout android:id="@id/new_fingerprint_cancel"
                android:layout_width="fill_parent"
                android:layout_height="@dimen/add_fingerprint_page_back_height">
    <ImageView android:layout_gravity="center_vertical"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:src="@drawable/miuix_appcompat_action_bar_back_dark"
               android:contentDescription="@string/accessibility_back"
               android:layout_marginStart="@dimen/miuix_appcompat_action_bar_horizontal_padding_start" />
  </LinearLayout>
  <TextView android:textSize="@dimen/setup_choose_password_title_size"
            android:textColor="@color/fingerprint_top_title_color"
            android:gravity="center_horizontal"
            android:id="@id/setup_new_fingerprint_top_title"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/add_fingerprint_page_title_top_margin"
            android:text="@string/add_fingerprint_instruction_title"
            android:maxLines="3"
            android:fontFamily="mipro-light"
            android:layout_marginStart="@dimen/new_fingerprint_top_title_horizontal_margin"
            android:layout_marginEnd="@dimen/new_fingerprint_top_title_horizontal_margin" />
  <TextView android:textSize="@dimen/setup_choose_password_msg_size"
            android:textColor="@color/fingerprint_top_text_color"
            android:gravity="center_horizontal"
            android:id="@id/setup_new_fingerprint_top_text"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="1.0dp"
            android:text="@string/add_back_fingerprint_instruction_msg"
            android:maxLines="3"
            android:layout_marginStart="@dimen/new_fingerprint_top_title_horizontal_margin"
            android:layout_marginEnd="@dimen/new_fingerprint_top_title_horizontal_margin" />
  <FrameLayout android:layout_width="fill_parent"
               android:layout_height="wrap_content"
               android:layout_marginTop="76.0dp">
    <ImageView android:layout_gravity="center"
               android:id="@id/setup_new_fingerprint_instruction_img"
               android:visibility="visible"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content" />
    <com.android.settings.MutedVideoView android:layout_gravity="center_horizontal"
                          android:id="@id/setup_new_fingerprint_guide_video"
                          android:visibility="gone"
                          android:layout_width="@dimen/new_fingerprint_guide_width_phone"
                          android:layout_height="@dimen/new_fingerprint_guide_height_phone" />
    <com.android.settings.MutedVideoView android:layout_gravity="center_horizontal"
                          android:id="@id/setup_new_fingerprint_step_video"
                          android:visibility="gone"
                          android:layout_width="@dimen/new_fingerprint_step_video_width"
                          android:layout_height="@dimen/new_fingerprint_step_video_height"
                          android:importantForAccessibility="no" />
  </FrameLayout>
  <View android:layout_width="wrap_content"
        android:layout_height="0.0dp"
        android:layout_weight="1.0" />
  <include android:visibility="gone"
           android:layout_width="0.0dp"
           android:layout_height="0.0dp"
           layout="@layout/new_fingerprint" />
  <Button android:textSize="@dimen/new_fingerprint_button_text_size"
          android:textColor="@color/new_fingerprint_button_text_color"
          android:layout_gravity="center_horizontal"
          android:id="@id/new_fingerprint_ok"
          android:background="@drawable/btn_bg_warn_dark"
          android:visibility="invisible"
          android:layout_width="@dimen/new_fingerprint_button_width"
          android:layout_height="@dimen/new_fingerprint_button_height"
          android:layout_marginBottom="@dimen/new_fingerprint_button_margin_bottom"
          android:text="@string/add_fingerprint_finished_button_text"
          android:fontFamily="mipro-misans"
          style="@style/Widget.Button.Primary" />
</LinearLayout>