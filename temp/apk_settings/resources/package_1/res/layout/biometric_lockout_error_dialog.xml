<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:paddingLeft="24.0dp"
              android:paddingRight="24.0dp"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android">
  <ImageView android:gravity="center_horizontal"
             android:paddingTop="24.0dp"
             android:layout_width="fill_parent"
             android:layout_height="wrap_content"
             android:src="@drawable/ic_settings_safety_center" />
  <TextView android:textAppearance="?android:attr/textAppearanceLarge"
            android:textColor="?android:attr/textColorPrimary"
            android:gravity="center_horizontal"
            android:id="@id/title"
            android:paddingTop="16.0dp"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content" />
  <TextView android:textAppearance="?android:attr/textAppearanceSmall"
            android:textColor="?android:attr/textColorSecondary"
            android:id="@id/description_1"
            android:paddingTop="16.0dp"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:lineSpacingMultiplier="1.2" />
  <TextView android:textAppearance="?android:attr/textAppearanceSmall"
            android:textColor="?android:attr/textColorSecondary"
            android:id="@id/description_2"
            android:paddingTop="16.0dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:lineSpacingMultiplier="1.2" />
</LinearLayout>