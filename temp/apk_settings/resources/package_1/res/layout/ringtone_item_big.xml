<?xml version='1.0' encoding='utf-8' ?>
<miuix.flexible.view.HyperCellLayout android:background="@drawable/card_shape_corner"
                      android:layout_width="fill_parent"
                      android:layout_height="fill_parent"
                      android:layoutDirection="locale"
                      app:template="ringtone_large_item_ternary" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <ImageView android:layout_gravity="center_vertical"
             android:id="@id/ringtone_icon"
             android:layout_width="@dimen/ringtone_item_icon_large_size"
             android:layout_height="@dimen/ringtone_item_icon_large_size"
             app:area_id="@id/area_head" />
  <TextView android:textSize="@dimen/card_key_words_text_size"
            android:textColor="@color/ringtone_item_title_color"
            android:ellipsize="end"
            android:layout_gravity="center_vertical"
            android:id="@id/ringtone_title"
            android:scrollbars="none"
            android:fadingEdge="none"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:fontFamily="mipro-medium"
            app:area_id="@id/area_title" />
  <TextView android:textSize="@dimen/card_instructions_text_size"
            android:textColor="@color/ringtone_item_value_color"
            android:ellipsize="end"
            android:layout_gravity="center_vertical"
            android:id="@id/ringtone_value"
            android:scrollbars="none"
            android:fadingEdge="none"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="true"
            app:area_id="@id/area_content" />
</miuix.flexible.view.HyperCellLayout>