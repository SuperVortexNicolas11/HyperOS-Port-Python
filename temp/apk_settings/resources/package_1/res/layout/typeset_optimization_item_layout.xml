<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:gravity="center_vertical"
              android:layout_gravity="center_vertical"
              android:id="@id/typeset_optimization"
              android:background="@drawable/new_device_card_back_ground"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/font_hint_view_margin_top"
              android:paddingStart="@dimen/miuix_preference_item_padding_start"
              android:paddingEnd="@dimen/miuix_preference_item_padding_end" xmlns:android="http://schemas.android.com/apk/res/android">
  <RelativeLayout android:gravity="center_vertical"
                  android:layout_gravity="center_vertical"
                  android:id="@id/typeset_optimization_title"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_weight="1.0"
                  style="@style/Widget.PreferenceItem">
    <TextView android:textAppearance="@style/Miuix.AppCompat.TextAppearance.PreferenceList"
              android:ellipsize="end"
              android:id="@id/title"
              android:fadingEdge="horizontal"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/text_layout_optimization_switch_label"
              android:textAlignment="viewStart" />
  </RelativeLayout>
  <LinearLayout android:gravity="center"
                android:orientation="vertical"
                android:clipChildren="false"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="@dimen/miuix_preference_widget_width">
    <miuix.slidingwidget.widget.SlidingSwitch android:layout_gravity="center"
                          android:id="@id/typeset_switch"
                          android:focusable="false"
                          android:clickable="false"
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content" />
  </LinearLayout>
</LinearLayout>