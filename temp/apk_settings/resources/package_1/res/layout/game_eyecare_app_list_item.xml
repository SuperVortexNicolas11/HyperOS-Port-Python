<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:gravity="center_vertical"
              android:id="@id/item"
              android:layout_width="fill_parent"
              android:layout_height="70.0dp" xmlns:android="http://schemas.android.com/apk/res/android">
  <ImageView android:layout_gravity="center"
             android:id="@id/app_icon"
             android:layout_width="40.0dp"
             android:layout_height="40.0dp"
             android:scaleType="centerInside"
             android:contentDescription="@null"
             android:layout_marginStart="@dimen/game_eyecare_preference_margin_start" />
  <TextView android:textAppearance="@style/Miuix.AppCompat.TextAppearance.PreferenceList"
            android:ellipsize="end"
            android:id="@id/app_name"
            android:fadingEdge="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
