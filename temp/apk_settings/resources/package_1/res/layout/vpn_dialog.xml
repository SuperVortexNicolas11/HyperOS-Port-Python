<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:theme="@style/Theme.Network"
              android:orientation="vertical"
              android:paddingLeft="24.0dp"
              android:paddingTop="0.0dp"
              android:paddingRight="24.0dp"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <TextView android:textAppearance="@android:style/TextAppearance.DeviceDefault.Small"
            android:textColor="?android:attr/colorError"
            android:id="@id/dialog_alert_subtitle"
            android:padding="0.0dp"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:text="@string/vpn_insecure_dialog_subtitle"
            android:includeFontPadding="false" />
  <ScrollView android:layout_width="fill_parent"
              android:layout_height="wrap_content">
    <LinearLayout android:orientation="vertical"
                  android:paddingTop="24.0dp"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content">
      <LinearLayout android:orientation="vertical"
                    android:id="@id/editor"
                    android:visibility="gone"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">
        <com.google.android.material.textfield.TextInputLayout android:id="@id/name_layout"
                              android:hint="@string/vpn_name"
                              app:endIconMode="clear_text"
                              app:helperText="@string/vpn_field_required"
                              app:helperTextEnabled="true"
                              style="@style/vpn_input_label">
          <com.google.android.material.textfield.TextInputEditText android:id="@id/name"
                                android:inputType="textCapWords"
                                style="@style/vpn_value" />
        </com.google.android.material.textfield.TextInputLayout>
        <TextView android:text="@string/vpn_type"
                  android:labelFor="@id/type"
                  style="@style/vpn_label" />
        <Spinner android:entries="@array/vpn_types"
                 android:id="@id/type"
                 android:prompt="@string/vpn_type"
                 style="@style/vpn_value" />
        <com.google.android.material.textfield.TextInputLayout android:id="@id/server_layout"
                              android:hint="@string/vpn_server"
                              app:endIconMode="clear_text"
                              app:helperText="@string/vpn_field_required"
                              app:helperTextEnabled="true"
                              style="@style/vpn_input_label">
          <com.google.android.material.textfield.TextInputEditText android:id="@id/server"
                                style="@style/vpn_value" />
        </com.google.android.material.textfield.TextInputLayout>
        <LinearLayout android:orientation="vertical"
                      android:id="@id/options_ipsec_identity"
                      android:visibility="gone"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content">
          <com.google.android.material.textfield.TextInputLayout android:id="@id/ipsec_identifier_layout"
                                android:hint="@string/vpn_ipsec_identifier"
                                app:endIconMode="clear_text"
                                app:helperText="@string/vpn_field_required"
                                app:helperTextEnabled="true"
                                style="@style/vpn_input_label">
            <com.google.android.material.textfield.TextInputEditText android:id="@id/ipsec_identifier"
                                  style="@style/vpn_value" />
          </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>
        <LinearLayout android:orientation="vertical"
                      android:id="@id/ipsec_psk"
                      android:visibility="gone"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content">
          <com.google.android.material.textfield.TextInputLayout android:id="@id/ipsec_secret_layout"
                                android:hint="@string/vpn_ipsec_secret"
                                app:endIconMode="password_toggle"
                                app:helperText="@string/vpn_field_required"
                                app:helperTextEnabled="true"
                                style="@style/vpn_input_label">
            <com.google.android.material.textfield.TextInputEditText android:id="@id/ipsec_secret"
                                  android:inputType="textPassword"
                                  style="@style/vpn_value" />
          </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>
        <LinearLayout android:orientation="vertical"
                      android:id="@id/ipsec_user"
                      android:visibility="gone"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content">
          <TextView android:text="@string/vpn_ipsec_user_cert"
                    android:labelFor="@id/ipsec_user_cert"
                    style="@style/vpn_label" />
          <Spinner android:id="@id/ipsec_user_cert"
                   android:prompt="@string/vpn_ipsec_user_cert"
                   style="@style/vpn_value" />
        </LinearLayout>
        <LinearLayout android:orientation="vertical"
                      android:id="@id/ipsec_peer"
                      android:visibility="gone"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content">
          <TextView android:text="@string/vpn_ipsec_ca_cert"
                    android:labelFor="@id/ipsec_ca_cert"
                    style="@style/vpn_label" />
          <Spinner android:id="@id/ipsec_ca_cert"
                   android:prompt="@string/vpn_ipsec_ca_cert"
                   style="@style/vpn_value" />
          <TextView android:text="@string/vpn_ipsec_server_cert"
                    android:labelFor="@id/ipsec_server_cert"
                    style="@style/vpn_label" />
          <Spinner android:id="@id/ipsec_server_cert"
                   android:prompt="@string/vpn_ipsec_server_cert"
                   style="@style/vpn_value" />
        </LinearLayout>
        <CheckBox android:id="@id/show_options"
                  android:text="@string/vpn_show_options"
                  style="@style/vpn_value" />
      </LinearLayout>
      <LinearLayout android:orientation="vertical"
                    android:id="@id/options"
                    android:visibility="gone"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">
        <TextView android:id="@id/vpn_proxy_settings_title"
                  android:text="@string/proxy_settings_title"
                  android:labelFor="@id/vpn_proxy_settings"
                  style="@style/vpn_label" />
        <Spinner android:entries="@array/vpn_proxy_settings"
                 android:id="@id/vpn_proxy_settings"
                 android:prompt="@string/proxy_settings_title"
                 style="@style/vpn_value" />
        <LinearLayout android:orientation="vertical"
                      android:id="@id/vpn_proxy_fields"
                      android:visibility="gone"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content">
          <com.google.android.material.textfield.TextInputLayout android:id="@id/vpn_proxy_host_layout"
                                android:hint="@string/proxy_hostname_label"
                                app:endIconMode="clear_text"
                                style="@style/vpn_input_label">
            <com.google.android.material.textfield.TextInputEditText android:id="@id/vpn_proxy_host"
                                  android:inputType="textNoSuggestions"
                                  style="@style/vpn_value" />
          </com.google.android.material.textfield.TextInputLayout>
          <com.google.android.material.textfield.TextInputLayout android:id="@id/vpn_proxy_port_layout"
                                android:hint="@string/proxy_port_label"
                                app:endIconMode="clear_text"
                                style="@style/vpn_input_label">
            <com.google.android.material.textfield.TextInputEditText android:id="@id/vpn_proxy_port"
                                  android:inputType="number"
                                  style="@style/vpn_value" />
          </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>
      </LinearLayout>
      <LinearLayout android:orientation="vertical"
                    android:id="@id/userpass"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">
        <com.google.android.material.textfield.TextInputLayout android:id="@id/username_layout"
                              android:hint="@string/vpn_username_optional"
                              app:endIconMode="clear_text"
                              style="@style/vpn_input_label">
          <com.google.android.material.textfield.TextInputEditText android:id="@id/username"
                                style="@style/vpn_value" />
        </com.google.android.material.textfield.TextInputLayout>
        <com.google.android.material.textfield.TextInputLayout android:id="@id/password_layout"
                              android:hint="@string/vpn_password_optional"
                              app:endIconMode="password_toggle"
                              style="@style/vpn_input_label">
          <com.google.android.material.textfield.TextInputEditText android:id="@id/password"
                                android:inputType="textPassword"
                                style="@style/vpn_value" />
        </com.google.android.material.textfield.TextInputLayout>
        <CheckBox android:id="@id/save_login"
                  android:text="@string/vpn_save_login"
                  style="@style/vpn_value" />
      </LinearLayout>
      <LinearLayout android:orientation="vertical"
                    android:id="@id/connect"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:animateLayoutChanges="true">
        <CheckBox android:id="@id/always_on_vpn"
                  android:text="@string/vpn_menu_lockdown"
                  style="@style/vpn_value" />
        <TextView android:id="@id/always_on_invalid_reason"
                  android:visibility="gone"
                  style="@style/vpn_warning" />
      </LinearLayout>
    </LinearLayout>
  </ScrollView>
</LinearLayout>