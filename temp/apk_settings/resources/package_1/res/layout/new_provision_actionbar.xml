<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="horizontal"
              android:id="@id/provision_lyt_actionbar"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/provision_status_bar_height"
              android:minHeight="@dimen/provision_action_bar_height"
              android:paddingHorizontal="@dimen/new_provision_actionbar_padding_horizontal"
              android:paddingVertical="@dimen/new_provision_actionbar_padding_vertical" xmlns:android="http://schemas.android.com/apk/res/android">
  <ImageView android:id="@id/new_back_icon"
             android:layout_width="@dimen/provision_actionbar_icon_size"
             android:layout_height="@dimen/provision_actionbar_icon_size"
             android:src="@drawable/miuix_action_icon_back_light"
             android:contentDescription="@string/provision_back" />
  <View android:layout_width="0.0dp"
        android:layout_height="0.0dp"
        android:layout_weight="1.0" />
  <ImageView android:id="@id/actionbar_end_view"
             android:visibility="gone"
             android:layout_width="@dimen/provision_actionbar_icon_size"
             android:layout_height="@dimen/provision_actionbar_icon_size"
             android:src="@drawable/miuix_action_icon_immersion_more_light" />
</LinearLayout>