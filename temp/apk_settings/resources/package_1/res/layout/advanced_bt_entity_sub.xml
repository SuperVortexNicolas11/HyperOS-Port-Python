<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:focusable="true"
              android:layout_width="0.0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1.0"
              android:layoutDirection="locale" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <FrameLayout android:layout_gravity="center_horizontal"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content">
    <ImageView android:layout_gravity="center"
               android:background="@drawable/bt_header_circle_outline"
               android:layout_width="72.0dp"
               android:layout_height="72.0dp" />
    <com.google.android.material.imageview.ShapeableImageView android:layout_gravity="center"
                          android:id="@id/header_icon"
                          android:padding="8.0dp"
                          android:layout_width="72.0dp"
                          android:layout_height="72.0dp"
                          android:antialias="true"
                          android:scaleType="fitCenter"
                          app:shapeAppearanceOverlay="@style/DeviceIconRoundedCornerStyle" />
    <com.google.android.material.progressindicator.CircularProgressIndicator android:layout_gravity="center"
                          android:id="@id/battery_ring"
                          android:visibility="gone"
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:max="100"
                          android:indeterminate="false"
                          app:indicatorColor="@color/settingslib_materialColorPrimary"
                          app:indicatorInset="0.0dp"
                          app:indicatorSize="76.0dp"
                          app:trackColor="@android:color/transparent"
                          app:trackCornerRadius="2.0dp"
                          app:trackThickness="4.0dp" />
  </FrameLayout>
  <TextView android:textSize="@dimen/advanced_bluetooth_header_title_text_size"
            android:ellipsize="marquee"
            android:gravity="center"
            android:layout_gravity="center_horizontal"
            android:id="@id/header_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24.0dp"
            android:textDirection="locale"
            style="@style/TextAppearance.EntityHeaderTitle" />
  <LinearLayout android:gravity="center"
                android:layout_gravity="center_horizontal"
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="33.0dp"
                android:layout_marginTop="2.0dp">
    <ImageView android:id="@id/bt_battery_icon"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:contentDescription="@string/bluetooth_header_battery_content_description" />
    <TextView android:id="@id/bt_battery_summary"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginStart="4.0dp"
              style="@style/TextAppearance.EntityHeaderSummary" />
  </LinearLayout>
  <TextView android:gravity="center"
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:id="@id/bt_battery_prediction"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2.0dp"
            style="@style/TextAppearance.EntityHeaderSummary" />
</LinearLayout>