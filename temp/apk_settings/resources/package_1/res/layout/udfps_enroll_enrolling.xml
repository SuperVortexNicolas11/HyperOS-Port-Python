<?xml version='1.0' encoding='utf-8' ?>
<com.android.settings.biometrics.fingerprint.UdfpsEnrollEnrollingView android:id="@id/setup_wizard_layout"
                      android:layout_width="fill_parent"
                      android:layout_height="fill_parent"
                      style="?attr/fingerprint_layout_theme" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <androidx.constraintlayout.widget.ConstraintLayout android:clipChildren="false"
                        android:clipToPadding="false"
                        android:layout_width="fill_parent"
                        android:layout_height="fill_parent"
                        style="@style/SudContentFrame">
    <com.airbnb.lottie.LottieAnimationView android:id="@id/illustration_lottie"
                          android:visibility="gone"
                          android:clipChildren="false"
                          android:clipToPadding="false"
                          android:layout_width="fill_parent"
                          android:layout_height="200.0dp"
                          android:scaleType="centerInside"
                          app:layout_constraintTop_toTopOf="@id/udfps_view"
                          app:lottie_autoPlay="true"
                          app:lottie_loop="true"
                          app:lottie_speed="0.85" />
    <LinearLayout android:orientation="vertical"
                  android:id="@id/udfps_view"
                  android:clipChildren="false"
                  android:clipToPadding="false"
                  android:layout_width="fill_parent"
                  android:layout_height="fill_parent"
                  style="@style/SudContentFrame">
      <LinearLayout android:gravity="bottom|center"
                    android:orientation="vertical"
                    android:layout_width="fill_parent"
                    android:layout_height="0.0dp"
                    android:layout_weight="1.0">
        <FrameLayout android:layout_gravity="bottom|center"
                     android:id="@id/layout_container"
                     android:clipChildren="false"
                     android:clipToPadding="false"
                     android:layout_width="fill_parent"
                     android:layout_height="0.0dp">
          <include layout="@layout/udfps_enroll_view" />
        </FrameLayout>
        <TextView android:gravity="center_horizontal"
                  android:layout_gravity="bottom|center"
                  android:id="@id/error_text"
                  android:visibility="invisible"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:accessibilityLiveRegion="polite"
                  style="@style/TextAppearance.ErrorText" />
      </LinearLayout>
    </LinearLayout>
  </androidx.constraintlayout.widget.ConstraintLayout>
</com.android.settings.biometrics.fingerprint.UdfpsEnrollEnrollingView>