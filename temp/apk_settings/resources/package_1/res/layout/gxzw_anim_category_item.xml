<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:background="@drawable/shape_gxzw_anim_preview_outer_bg"
              android:paddingTop="@dimen/miui_gxzw_anim_switch_padding_vertical"
              android:paddingBottom="@dimen/miui_gxzw_anim_content_padding_bottom"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:layout_marginBottom="@dimen/miui_gxzw_anim_content_margin_horizontal"
              android:paddingHorizontal="0.0dp" xmlns:android="http://schemas.android.com/apk/res/android">
  <TextView android:textSize="@dimen/miui_gxzw_anim_title_text_size"
            android:textColor="@color/miui_gxzw_anim_text_color"
            android:id="@id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/miui_gxzw_anim_content_padding_bottom"
            android:maxLines="1"
            android:fontFamily="mipro-medium"
            android:layout_marginStart="@dimen/miui_gxzw_anim_content_padding_bottom" />
  <miuix.recyclerview.widget.RecyclerView android:id="@id/gxzw_anim_select_view"
                        android:clipToPadding="false"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />
</LinearLayout>