<?xml version='1.0' encoding='utf-8' ?>
<miuix.flexible.view.HyperCellLayout android:id="@id/ringtone_settings_card"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content"
                      android:layout_marginBottom="@dimen/card_ringtone_margin_bottom"
                      app:column_spacing="@dimen/ringtone_card_margin_edge"
                      app:row_spacing="@dimen/ringtone_card_margin_edge"
                      app:template="ringtone_card_ternary" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <com.android.settings.sound.coolsound.RingtoneItemNotification android:id="@id/ringtone_notification"
                        android:layout_width="@dimen/match_parent"
                        android:layout_height="fill_parent"
                        app:area_id="@id/area_item1"
                        app:custom_params="node_weight"
                        app:node_weight="1.0" />
  <com.android.settings.sound.coolsound.RingtoneItem android:id="@id/ringtone_call"
                        android:layout_width="fill_parent"
                        android:layout_height="fill_parent"
                        app:area_id="@id/area_item2"
                        app:custom_params="node_weight"
                        app:node_weight="1.0" />
  <com.android.settings.sound.coolsound.RingtoneItem android:layout_gravity="bottom"
                        android:id="@id/ringtone_alarm"
                        android:layout_width="fill_parent"
                        android:layout_height="fill_parent"
                        app:area_id="@id/area_item3"
                        app:custom_params="node_weight"
                        app:node_weight="1.0" />
</miuix.flexible.view.HyperCellLayout>