<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:gravity="center_vertical"
              android:orientation="horizontal"
              android:background="@drawable/locale_item_background"
              android:descendantFocusability="blocksDescendants"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android">
  <LinearLayout android:orientation="vertical"
                android:paddingTop="15.0dp"
                android:paddingBottom="15.0dp"
                android:layout_width="0.0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.0"
                android:layout_marginStart="16.0dp">
    <TextView android:textAppearance="?android:attr/textAppearanceMedium"
              android:textSize="@dimen/new_fingerprint_button_text_size"
              android:textStyle="bold"
              android:id="@id/trusted_credential_subject_primary"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:fontFamily="MiSans"
              android:textAlignment="viewStart" />
    <TextView android:textAppearance="?android:attr/textAppearanceSmall"
              android:textSize="@dimen/finger_detail_name_text_size"
              android:textColor="?android:attr/textColorSecondary"
              android:id="@id/trusted_credential_subject_secondary"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:fontFamily="MiSans"
              android:textAlignment="viewStart" />
  </LinearLayout>
  <miuix.slidingwidget.widget.SlidingSwitch android:id="@id/trusted_credential_status"
                        android:padding="8.0dp"
                        android:visibility="invisible"
                        android:scrollbars="none"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.0"
                        android:layout_marginEnd="16.0dp" />
</LinearLayout>