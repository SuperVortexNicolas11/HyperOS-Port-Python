<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:paddingTop="@dimen/settingslib_illustration_padding"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:androidprv="http://schemas.android.com/apk/prv/res/android">
  <LinearLayout android:orientation="horizontal"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16.0dp">
    <Space android:layout_width="0.0dp"
           android:layout_height="fill_parent"
           android:layout_weight="1.0" />
    <LinearLayout android:orientation="vertical"
                  android:id="@id/button_compact"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content">
      <FrameLayout android:background="@drawable/accessibility_contrast_button_background"
                   android:layout_width="@dimen/contrast_button_total_size"
                   android:layout_height="@dimen/contrast_button_total_size">
        <ImageView android:layout_gravity="center"
                   android:layout_width="wrap_content"
                   android:layout_height="wrap_content"
                   android:src="@drawable/ic_contrast_standard"
                   android:contentDescription="@null" />
      </FrameLayout>
      <TextView android:textSize="@dimen/contrast_button_text_size"
                android:textColor="@android:color/primary_dark_material_light_light_status_bar"
                android:gravity="center|top"
                android:layout_width="@dimen/contrast_button_total_size"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/contrast_button_text_spacing"
                android:text="@string/lock_screen_notifs_show_compact"
                android:singleLine="false" />
    </LinearLayout>
    <Space android:layout_width="@dimen/contrast_button_horizontal_spacing"
           android:layout_height="fill_parent" />
    <LinearLayout android:orientation="vertical"
                  android:id="@id/button_full"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content">
      <FrameLayout android:background="@drawable/accessibility_contrast_button_background"
                   android:layout_width="@dimen/contrast_button_total_size"
                   android:layout_height="@dimen/contrast_button_total_size">
        <ImageView android:layout_gravity="center"
                   android:layout_width="wrap_content"
                   android:layout_height="wrap_content"
                   android:src="@drawable/ic_contrast_high"
                   android:contentDescription="@null" />
      </FrameLayout>
      <TextView android:textSize="@dimen/contrast_button_text_size"
                android:textColor="@android:color/primary_dark_material_light_light_status_bar"
                android:gravity="center|top"
                android:layout_width="@dimen/contrast_button_total_size"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/contrast_button_text_spacing"
                android:text="@string/lock_screen_notifs_show_full_list"
                android:singleLine="false" />
    </LinearLayout>
    <Space android:layout_width="0.0dp"
           android:layout_height="fill_parent"
           android:layout_weight="1.0" />
  </LinearLayout>
</LinearLayout>