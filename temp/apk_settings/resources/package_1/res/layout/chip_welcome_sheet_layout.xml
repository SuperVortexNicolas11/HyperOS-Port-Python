<?xml version='1.0' encoding='utf-8' ?>
<com.android.settings.chip.FullConstraintLayout style="@style/chip_welcome_group" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:android="http://schemas.android.com/apk/res/android">
  <ImageView android:layout_width="0.0dp"
             android:layout_height="0.0dp"
             android:src="@drawable/chip_start_bg"
             android:scaleType="centerCrop"
             android:contentDescription="@null"
             app:layout_constraintDimensionRatio="@string/chip_welcome_ratio"
             app:layout_constraintEnd_toEndOf="parent"
             app:layout_constraintStart_toStartOf="parent"
             app:layout_constraintTop_toTopOf="parent" />
  <androidx.appcompat.widget.AppCompatTextView android:textSize="50.0dp"
                        android:textColor="@color/chip_white"
                        android:layout_width="0.0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="15.0dp"
                        android:text="@string/chip_manager_welcome"
                        android:textAlignment="viewStart"
                        android:layout_marginStart="46.0dp"
                        android:layout_marginEnd="46.0dp"
                        app:autoSizeMaxTextSize="50.0dp"
                        app:autoSizeMinTextSize="16.0dp"
                        app:autoSizeTextType="uniform"
                        app:layout_constraintBottom_toTopOf="@id/tip_tv"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />
  <TextView android:id="@id/tip_tv"
            android:layout_width="0.0dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="92.0dp"
            android:text="@string/chip_welcome_tip_new"
            android:textAlignment="viewStart"
            android:layout_marginStart="46.0dp"
            android:layout_marginEnd="46.0dp"
            app:layout_constraintBottom_toTopOf="@id/start_btn"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            style="@style/startTip" />
  <ImageView android:id="@id/close_iv"
             android:layout_width="wrap_content"
             android:layout_height="wrap_content"
             android:layout_marginTop="15.0dp"
             android:src="@drawable/chip_edit_close"
             android:contentDescription="@string/miuix_appcompat_cancel_description"
             android:layout_marginStart="27.0dp"
             app:layout_constraintStart_toStartOf="parent"
             app:layout_constraintTop_toTopOf="parent" />
  <Button android:id="@id/start_btn"
          android:layout_marginBottom="28.0dp"
          android:text="@string/welcomeBtn"
          app:layout_constraintBottom_toBottomOf="parent"
          app:layout_constraintEnd_toEndOf="parent"
          app:layout_constraintStart_toStartOf="parent"
          style="@style/startBtn" />
</com.android.settings.chip.FullConstraintLayout>