<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:layout_gravity="center"
              android:orientation="horizontal"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android">
  <RelativeLayout android:layout_gravity="center"
                  android:orientation="vertical"
                  android:layout_width="0.0dp"
                  android:layout_height="wrap_content"
                  android:layout_weight="1.0"
                  android:layout_marginStart="@dimen/fimreware_save_update_notification_margin">
    <ImageView android:id="@id/notification_icon"
               android:layout_width="@dimen/fimreware_save_update_notification_icon"
               android:layout_height="@dimen/fimreware_save_update_notification_icon"
               android:layout_marginTop="@dimen/fimreware_save_update_notification_margin" />
    <TextView android:textSize="@dimen/fimreware_save_update_notification_title_text"
              android:textColor="@color/camera_grip_firmware_update_title"
              android:ellipsize="end"
              android:id="@id/notification_text"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/fimreware_save_update_notification_title_end_margin"
              android:maxLines="1"
              android:fontFamily="sans-serif-medium"
              android:textAlignment="viewStart"
              android:layout_marginStart="@dimen/fimreware_save_update_notification_title_start_margin"
              android:layout_toEndOf="@id/notification_icon"
              android:fallbackLineSpacing="false" />
    <TextView android:textSize="@dimen/fimreware_save_update_notification_title_text"
              android:textColor="@color/camera_grip_firmware_update_title_describe"
              android:ellipsize="end"
              android:id="@id/notification_summary"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:layout_marginTop="@dimen/fimreware_save_update_notification_title_end_margin"
              android:layout_marginBottom="@dimen/fimreware_save_update_notification_title_end_margin"
              android:maxLines="2"
              android:layout_below="@id/notification_text"
              android:textAlignment="viewStart"
              android:layout_marginStart="@dimen/fimreware_save_update_notification_title_start_margin"
              android:layout_toEndOf="@id/notification_icon"
              android:fallbackLineSpacing="false" />
  </RelativeLayout>
  <TextView android:textSize="@dimen/fimreware_save_update_notification_button_text"
            android:textColor="@color/camera_grip_firmware_update_title"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@id/notification_button"
            android:background="@drawable/shape_mihandle_save_notification_button"
            android:paddingTop="@dimen/fimreware_save_update_notification_button_padding_top_bottom"
            android:paddingBottom="@dimen/fimreware_save_update_notification_button_padding_top_bottom"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:clickable="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/fimreware_save_update_notification_button_minHeight"
            android:textAllCaps="true"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="@dimen/fimreware_save_update_notification_button_padding_start_end"
            android:paddingEnd="@dimen/fimreware_save_update_notification_button_padding_start_end" />
</LinearLayout>