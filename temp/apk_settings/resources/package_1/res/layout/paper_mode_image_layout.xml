<?xml version='1.0' encoding='utf-8' ?>
<androidx.constraintlayout.widget.ConstraintLayout android:layout_width="fill_parent"
                      android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <ImageView android:id="@id/paper_mode_image"
             android:layout_width="0.0dp"
             android:layout_height="0.0dp"
             android:src="@drawable/paper_mode_image"
             android:scaleType="centerCrop"
             android:importantForAccessibility="no"
             app:layout_constraintBottom_toBottomOf="parent"
             app:layout_constraintDimensionRatio="1.95:1"
             app:layout_constraintEnd_toEndOf="parent"
             app:layout_constraintStart_toStartOf="parent"
             app:layout_constraintTop_toTopOf="parent" />
  <View android:background="@drawable/paper_mode_mask"
        android:layout_width="0.0dp"
        android:layout_height="0.0dp"
        app:layout_constraintBottom_toBottomOf="@id/paper_mode_image"
        app:layout_constraintEnd_toEndOf="@id/paper_mode_image"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="@id/paper_mode_image"
        app:layout_constraintTop_toTopOf="@id/paper_mode_image"
        app:layout_constraintWidth_percent="0.5" />
  <TextView android:textSize="13.0sp"
            android:textColor="@android:color/white"
            android:id="@id/standard_mode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14.0dp"
            android:text="@string/standard_mode"
            android:layout_marginStart="16.0dp"
            app:layout_constraintBottom_toBottomOf="@id/paper_mode_image"
            app:layout_constraintStart_toStartOf="@id/paper_mode_image" />
  <TextView android:textSize="13.0sp"
            android:textColor="@android:color/white"
            android:id="@id/protect_eyes_mode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14.0dp"
            android:text="@string/protect_eyes_mode"
            android:layout_marginEnd="16.0dp"
            app:layout_constraintBottom_toBottomOf="@id/paper_mode_image"
            app:layout_constraintEnd_toEndOf="@id/paper_mode_image" />
</androidx.constraintlayout.widget.ConstraintLayout>