<?xml version='1.0' encoding='utf-8' ?>
<FrameLayout android:layout_width="fill_parent"
             android:layout_height="fill_parent"
             android:paddingHorizontal="@dimen/miuix_theme_padding_horizontal_common" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <include layout="@layout/miui_confirm_lock_background" />
  <LinearLayout android:gravity="center_horizontal"
                android:orientation="vertical"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent">
    <ImageView android:id="@id/cts_icon"
               android:visibility="gone"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content" />
    <LinearLayout android:orientation="vertical"
                  android:id="@id/miui_confirm_lock_title_container"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="@dimen/password_set_picker_scroll_title_view_margin_top"
                  android:layout_marginBottom="@dimen/password_set_picker_title_layout_margin_bottom">
      <TextView android:textSize="@dimen/password_set_picker_title_text_size"
                android:textColor="@color/confirm_password_header_text_color"
                android:gravity="center"
                android:id="@id/headerText"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium" />
      <TextView android:textSize="13.33sp"
                android:textColor="@color/confirm_password_header_message_color"
                android:gravity="center"
                android:id="@id/headerMessage"
                android:visibility="gone"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14.67dp"
                android:text="@string/confirm_frp_credential_message"
                android:layout_marginStart="36.0dp"
                android:layout_marginEnd="36.0dp" />
    </LinearLayout>
    <com.android.settings.view.DigitalPasswordInputView android:layout_gravity="center_horizontal"
                          android:id="@id/digital_entry"
                          android:focusable="true"
                          android:focusableInTouchMode="true"
                          android:visibility="gone"
                          android:longClickable="false"
                          android:layout_width="fill_parent"
                          android:layout_height="@dimen/digital_password_inputView_height"
                          android:singleLine="true"
                          android:maxLength="6"
                          android:inputType="textPassword"
                          android:imeOptions="actionNext|flagNoEnterAction|flagNoExtractUi"
                          android:layout_marginVertical="@dimen/digital_password_inputView_margin_vertical" />
    <miuix.androidbasewidget.widget.StateEditText android:layout_gravity="center"
                          android:id="@id/password_entry"
                          android:visibility="gone"
                          android:layout_width="fill_parent"
                          android:layout_height="wrap_content"
                          android:singleLine="true"
                          android:inputType="textPassword"
                          android:imeOptions="actionNext|flagNoEnterAction|flagNoExtractUi"
                          android:layout_marginStart="@dimen/confirm_password_entry_margin"
                          android:layout_marginEnd="@dimen/confirm_password_entry_margin"
                          style="@style/Widget.EditText.Pure.DayNight" />
    <Button android:id="@id/forgetPassword"
            android:layout_marginTop="@dimen/forget_password_button_top_margin"
            android:fontFamily="sans-serif-medium"
            style="@style/KeyguardForgetPasswordButtonStyle" />
    <Button android:gravity="center"
            android:layout_gravity="center"
            android:id="@id/emergencyCall"
            android:paddingLeft="12.0dp"
            android:paddingRight="12.0dp"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/forget_password_button_top_margin"
            android:text="@0x01040bf6"
            android:singleLine="true"
            android:drawableLeft="@drawable/ic_emergency" />
    <ImageView android:gravity="center"
               android:id="@id/fingerprintIcon"
               android:visibility="gone"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:layout_marginTop="20.0dp"
               android:src="@drawable/fingerprint_icon" />
    <Button android:textSize="12.36dp"
            android:id="@id/useFingerprint"
            android:background="@drawable/confirm_password_use_fingerprint_btn_bg"
            android:paddingLeft="15.0dp"
            android:paddingTop="6.55dp"
            android:paddingRight="15.0dp"
            android:paddingBottom="6.55dp"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="42.18dp"
            android:text="@string/confirm_password_with_fingerprint" />
    <TextView android:textSize="13.33sp"
              android:textColor="@color/frp_skip_password_text_color"
              android:gravity="center"
              android:layout_gravity="center"
              android:id="@id/frpSkipPassword"
              android:visibility="gone"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:layout_marginTop="66.67dp"
              android:layout_marginBottom="@dimen/forget_password_button_top_margin"
              android:text="@string/confirm_frp_credential_skip_txt"
              android:singleLine="true" />
    <View android:layout_width="fill_parent"
          android:layout_height="0.0dp"
          android:layout_weight="1.0" />
    <include android:layout_width="fill_parent"
             android:layout_height="wrap_content"
             android:layout_marginTop="@dimen/choose_unlock_password_footer_margin"
             android:layout_marginBottom="@dimen/choose_unlock_password_footer_button_bottom_margin"
             android:layout_marginStart="@dimen/choose_unlock_password_footer_margin"
             android:layout_marginEnd="@dimen/choose_unlock_password_footer_margin"
             layout="@layout/choose_lock_pattern_button" />
  </LinearLayout>
</FrameLayout>