<?xml version='1.0' encoding='utf-8' ?>
<RelativeLayout android:id="@id/groupDialog"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:layout_centerHorizontal="true" xmlns:android="http://schemas.android.com/apk/res/android">
  <RelativeLayout android:gravity="center_vertical"
                  android:id="@id/imageFindHeadsetLayout"
                  android:focusable="true"
                  android:visibility="visible"
                  android:layout_width="fill_parent"
                  android:layout_height="fill_parent"
                  android:layout_marginTop="0.0dp"
                  android:layout_alignParentTop="true"
                  android:contentDescription="@string/storage_images"
                  android:importantForAccessibility="yes">
    <ImageView android:layout_gravity="center"
               android:id="@id/audio_share_image"
               android:layout_width="160.0dp"
               android:layout_height="160.0dp"
               android:src="@drawable/audio_share_images"
               android:layout_centerInParent="true"
               android:layout_centerHorizontal="true"
               android:layout_centerVertical="true" />
  </RelativeLayout>
</RelativeLayout>