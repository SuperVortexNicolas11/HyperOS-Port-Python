<?xml version='1.0' encoding='utf-8' ?>
<androidx.constraintlayout.widget.ConstraintLayout android:orientation="horizontal"
                      android:background="?attr/preferenceItemBackground"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content"
                      android:paddingStart="?android:attr/listPreferredItemPaddingStart"
                      android:paddingEnd="?android:attr/listPreferredItemPaddingEnd"
                      android:paddingVertical="16.0dp" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <View android:id="@id/spectrum_container"
        android:background="@drawable/spectrum_container"
        android:paddingBottom="7.0dp"
        android:layout_width="fill_parent"
        android:layout_height="0.0dp"
        app:layout_constraintBottom_toBottomOf="@id/bottom_space"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/spectrum" />
  <com.android.settings.display.Spectrum android:id="@id/spectrum"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        app:blueLightColor="@color/blue_light_area_color"
                        app:blueLightLineColor="@color/blue_light_line_color"
                        app:layout_constraintBottom_toTopOf="@id/description_container"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:xLineColor="@color/spectrum_line_color"
                        app:xTextColor="@color/spectrum_axis_color"
                        app:yLineColor="@color/spectrum_line_color"
                        app:yTextColor="@color/spectrum_axis_color" />
  <LinearLayout android:gravity="center_vertical"
                android:orientation="horizontal"
                android:id="@id/description_container"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="11.0dp"
                android:layoutDirection="locale"
                android:paddingStart="14.0dp"
                android:paddingEnd="8.0dp"
                app:layout_constraintBottom_toBottomOf="@id/spectrum_container"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/spectrum">
    <TextView android:textSize="13.0sp"
              android:textColor="@color/description_text_color"
              android:id="@id/blue_light_reduce_description"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content" />
  </LinearLayout>
  <Space android:id="@id/bottom_space"
         android:layout_width="0.0dp"
         android:layout_height="7.0dp"
         app:layout_constraintEnd_toEndOf="parent"
         app:layout_constraintStart_toStartOf="parent"
         app:layout_constraintTop_toBottomOf="@id/description_container" />
  <LinearLayout android:gravity="center_vertical"
                android:orientation="horizontal"
                android:id="@id/title_container"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24.0dp"
                android:layout_marginBottom="12.0dp"
                android:layoutDirection="locale"
                app:layout_constraintBottom_toTopOf="@id/spectrum_seekbar"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/spectrum_container">
    <ImageView android:id="@id/blue_light_icon"
               android:layout_width="23.3dp"
               android:layout_height="23.3dp"
               android:src="@drawable/blue_light_filter" />
    <TextView android:textSize="17.0sp"
              android:textColor="@color/spectrum_main_text_color"
              android:ellipsize="marquee"
              android:id="@id/blue_light_title"
              android:fadingEdge="horizontal"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:singleLine="true"
              android:fontFamily="sans-serif-medium"
              android:layout_marginStart="12.0dp" />
    <ImageView android:id="@id/blue_light_filter_icon"
               android:layout_width="20.0dp"
               android:layout_height="20.0dp"
               android:src="@drawable/spectrum_info_icon" />
  </LinearLayout>
  <miuix.androidbasewidget.widget.SeekBar android:id="@id/spectrum_seekbar"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12.0dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/blue_light_icon"
                        style="?attr/seekBarPreferenceInternalTheme" />
</androidx.constraintlayout.widget.ConstraintLayout>