<?xml version='1.0' encoding='utf-8' ?>
<com.android.settings.aon.scanner.AonScannerSettingsFragment android:gravity="center"
                      android:orientation="vertical"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content"
                      android:layout_marginTop="2.0dp"
                      android:layout_marginBottom="14.0dp" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <LinearLayout android:orientation="vertical"
                android:focusable="false"
                android:clickable="false"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:importantForAccessibility="no">
    <com.android.settings.view.ScanCodeVideoView android:layout_gravity="center_horizontal"
                          android:id="@id/aon_scanner_diagram"
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          app:videoName="aon_scanner_diagram_unfolded_video" />
  </LinearLayout>
  <TextView android:textSize="@dimen/miuix_preference_normal_text_size"
            android:textColor="?android:attr/textColorPrimary"
            android:gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12.0dp"
            android:text="@string/aon_scanner_settings"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="@dimen/miuix_preference_item_padding_start"
            android:paddingEnd="@dimen/miuix_preference_item_padding_end" />
  <TextView android:textSize="@dimen/miuix_preference_secondary_text_size"
            android:textColor="@color/second_text_color"
            android:gravity="center"
            android:id="@id/scanner_before_summary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/miuix_preference_item_padding_start"
            android:layout_marginTop="1.0dp"
            android:layout_marginRight="@dimen/miuix_preference_item_padding_end"
            android:fontFamily="sans-serif" />
</com.android.settings.aon.scanner.AonScannerSettingsFragment>