<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:gravity="center_vertical"
              android:orientation="horizontal"
              android:clickable="false"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:minHeight="?android:attr/listPreferredItemHeightSmall"
              android:paddingStart="?android:attr/listPreferredItemPaddingStart"
              android:paddingEnd="?android:attr/listPreferredItemPaddingEnd" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:androidprv="http://schemas.android.com/apk/prv/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <LinearLayout android:gravity="center"
                android:id="@id/icon_frame"
                android:layout_width="48.0dp"
                android:layout_height="48.0dp"
                android:filterTouchesWhenObscured="false"
                android:layout_marginEnd="@dimen/settingslib_expressive_space_extrasmall6">
    <androidx.preference.internal.PreferenceImageView android:layout_gravity="center"
                          android:id="@android:id/icon"
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          app:maxHeight="48.0dp"
                          app:maxWidth="48.0dp" />
  </LinearLayout>
  <TextView android:textAppearance="?android:attr/textAppearanceListItem"
            android:textColor="?android:attr/textColorPrimary"
            android:ellipsize="marquee"
            android:id="@android:id/title"
            android:fadingEdge="horizontal"
            android:layout_width="0.0dp"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:layout_weight="1.0" />
  <ImageView android:id="@id/expand_icon"
             android:background="@drawable/ambient_expand_icon_background"
             android:padding="10.0dp"
             android:layout_width="48.0dp"
             android:layout_height="48.0dp"
             android:src="@drawable/ic_keyboard_arrow_down"
             android:tint="@android:color/personal_apps_suspension_notification_color"
             android:contentDescription="@null" />
</LinearLayout>