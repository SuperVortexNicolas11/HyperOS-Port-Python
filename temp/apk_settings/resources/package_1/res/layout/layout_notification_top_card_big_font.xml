<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android">
  <LinearLayout android:orientation="horizontal"
                android:id="@id/lock_screen_notification_card"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:contentDescription="@string/status_bar_app_enable_keyguard"
                style="@style/NotificationCard">
    <ImageView android:layout_gravity="center"
               android:id="@id/lock_screen_notification_card_image"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:layout_marginEnd="16.0dp" />
    <TextView android:layout_gravity="center"
              android:id="@id/lock_screen_notification_card_text"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/status_bar_app_enable_keyguard"
              android:hyphenationFrequency="fullFast"
              style="@style/NotificationCardText" />
  </LinearLayout>
  <Space android:layout_width="12.0dp"
         android:layout_height="0.0dp" />
  <LinearLayout android:orientation="horizontal"
                android:id="@id/float_notification_card"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:contentDescription="@string/status_bar_app_enable_floating"
                style="@style/NotificationCard">
    <ImageView android:layout_gravity="center"
               android:id="@id/float_notification_card_image"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:layout_marginEnd="16.0dp" />
    <TextView android:layout_gravity="center"
              android:id="@id/float_notification_card_text"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/status_bar_app_enable_floating"
              style="@style/NotificationCardText" />
  </LinearLayout>
  <Space android:layout_width="12.0dp"
         android:layout_height="0.0dp" />
  <LinearLayout android:orientation="horizontal"
                android:id="@id/show_app_badge_card"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:contentDescription="@string/show_badge_notifications_short"
                style="@style/NotificationCard">
    <ImageView android:layout_gravity="center"
               android:id="@id/show_app_badge_card_image"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:layout_marginEnd="16.0dp" />
    <TextView android:layout_gravity="center"
              android:id="@id/show_app_badge_card_text"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/show_badge_notifications_short"
              style="@style/NotificationCardText" />
  </LinearLayout>
</LinearLayout>