<?xml version='1.0' encoding='utf-8' ?>
<miuix.core.widget.NestedScrollView android:layout_width="fill_parent"
                      android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:androidprv="http://schemas.android.com/apk/prv/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <LinearLayout android:orientation="vertical"
                android:id="@id/layout_wifi_share_qrcode"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
    <include layout="@layout/wifi_share_sheet_head" />
    <com.android.settings.widget.ShadowLayout android:layout_gravity="center_horizontal"
                          android:orientation="vertical"
                          android:id="@id/layout_wifi_share"
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          app:hl_clipInnerShadow="false"
                          app:hl_shadowSymmetry="false"
                          app:layout_constraintEnd_toEndOf="parent"
                          app:layout_constraintStart_toStartOf="parent"
                          app:layout_constraintTop_toTopOf="parent"
                          app:radius="@dimen/wifi_sheet_round_radius">
      <com.android.settings.widget.RoundImageView android:id="@id/tap_share_view_thumb1"
                            android:background="@color/round_image_bg"
                            android:layout_width="@dimen/wifi_sheet_round_width"
                            android:layout_height="@dimen/wifi_sheet_round_height"
                            android:scaleType="centerCrop"
                            android:layerType="software"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:radius="@dimen/wifi_sheet_round_radius" />
      <LinearLayout android:orientation="vertical"
                    android:id="@id/layout_wifi"
                    android:layout_width="@dimen/wifi_sheet_round_width"
                    android:layout_height="@dimen/wifi_sheet_round_height">
        <ImageView android:layout_gravity="center_horizontal"
                   android:id="@id/qrcode"
                   android:layout_width="@dimen/wifi_sheet_qrcode_width"
                   android:layout_height="@dimen/wifi_sheet_qrcode_height"
                   android:layout_marginTop="@dimen/wifi_sheet_qrcode_margintop"
                   android:scaleType="fitCenter"
                   android:contentDescription="@null" />
        <TextView android:textAppearance="@style/Miuix.AppCompat.TextAppearance.List.Secondary.Preference"
                  android:textSize="@dimen/wifi_sheet_id_size"
                  android:textStyle="bold"
                  android:textColor="@color/wifi_share_text"
                  android:gravity="center"
                  android:layout_gravity="center_horizontal"
                  android:id="@id/wifi_share_id"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="@dimen/wifi_sheet_id_margintop"
                  android:fontFamily="MiSans" />
        <TextView android:textAppearance="@style/Miuix.AppCompat.TextAppearance.List.Secondary.Preference"
                  android:textSize="@dimen/wifi_sheet_password_size"
                  android:textColor="@color/wifi_share_text"
                  android:gravity="center"
                  android:layout_gravity="center_horizontal"
                  android:id="@id/wifi_share_password_id"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content"
                  android:text="@string/wifi_share_plain_password_text" />
      </LinearLayout>
    </com.android.settings.widget.ShadowLayout>
  </LinearLayout>
</miuix.core.widget.NestedScrollView>