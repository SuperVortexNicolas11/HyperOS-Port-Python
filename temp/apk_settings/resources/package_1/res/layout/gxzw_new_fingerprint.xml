<?xml version='1.0' encoding='utf-8' ?>
<RelativeLayout android:background="@android:color/transparent"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <TextView android:textStyle="bold"
            android:textColor="@android:color/white"
            android:ellipsize="end"
            android:gravity="bottom|center"
            android:id="@id/new_fingerprint_top_title"
            android:layout_width="fill_parent"
            android:layout_height="@dimen/new_fingerprint_top_title_height"
            android:layout_marginTop="@dimen/fod_swipe_fingerprint_title_margin_top"
            android:maxLines="3"
            android:lineSpacingMultiplier="1.3"
            android:layout_marginStart="@dimen/miui_finger_enroll_title_horizontal_margin"
            android:layout_marginEnd="@dimen/miui_finger_enroll_title_horizontal_margin"
            android:autoSizeTextType="uniform"
            android:autoSizeStepGranularity="2.0sp"
            android:autoSizeMinTextSize="@dimen/new_fingerprint_top_title_mintextsize"
            android:autoSizeMaxTextSize="@dimen/new_fingerprint_top_title_maxtextsize"
            android:fallbackLineSpacing="false" />
  <TextView android:textColor="#a6ffffff"
            android:gravity="center|top"
            android:id="@id/new_fingerprint_top_text"
            android:layout_width="fill_parent"
            android:layout_height="@dimen/new_fingerprint_top_text_height"
            android:layout_marginTop="@dimen/fod_swipe_fingerprint_text_margin_top"
            android:maxLines="3"
            android:layout_below="@id/new_fingerprint_top_title"
            android:layout_marginStart="@dimen/miui_finger_enroll_title_horizontal_margin"
            android:layout_marginEnd="@dimen/miui_finger_enroll_title_horizontal_margin"
            android:autoSizeTextType="uniform"
            android:autoSizeStepGranularity="1.0sp"
            android:autoSizeMinTextSize="@dimen/new_fingerprint_top_text_mintextsize"
            android:autoSizeMaxTextSize="@dimen/new_fingerprint_top_text_maxtextsize" />
  <ImageView android:id="@id/new_fingerprint_instruction_img"
             android:background="@drawable/scan_output_background_white"
             android:visibility="gone"
             android:layout_width="@dimen/gxzw_new_fingerprint_step_width"
             android:layout_height="@dimen/gxzw_new_fingerprint_step_height"
             android:layout_marginTop="@dimen/gxzw_new_fingerprint_video_margin"
             android:layout_centerHorizontal="true" />
  <com.airbnb.lottie.LottieAnimationView android:id="@id/new_fingerprint_guide_video"
                        android:visibility="gone"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/fod_swipe_fingerprint_guide_margin_top"
                        android:layout_marginBottom="@dimen/fod_swipe_fingerprint_guide_margin_bottom"
                        android:layout_above="@id/gxzw_new_fingerprint_ok"
                        android:layout_below="@id/new_fingerprint_top_text"
                        android:layout_marginHorizontal="@dimen/fod_swipe_fingerprint_guide_margin_horizontal"
                        app:lottie_loop="true" />
  <com.android.settings.MutedVideoView android:id="@id/new_fingerprint_step_video"
                        android:visibility="gone"
                        android:layout_width="@dimen/fod_swipe_fingerprint_step_video_wh"
                        android:layout_height="@dimen/fod_swipe_fingerprint_step_video_wh"
                        android:layout_marginTop="@dimen/fod_swipe_fingerprint_step_margin_top"
                        android:layout_below="@id/new_fingerprint_top_text"
                        android:layout_centerHorizontal="true"
                        android:contentDescription="@string/key_operation_diagram"
                        android:importantForAccessibility="no" />
  <Button android:textSize="@dimen/new_fingerprint_button_text_size"
          android:textColor="@color/new_fingerprint_button_text_color"
          android:id="@id/new_fingerprint_button"
          android:background="@drawable/btn_bg_warn_dark"
          android:visibility="invisible"
          android:layout_width="fill_parent"
          android:layout_height="wrap_content"
          android:layout_marginBottom="@dimen/new_fingerprint_button_margin_bottom"
          android:minHeight="@dimen/new_fingerprint_button_height"
          android:text="@string/add_fingerprint_finished_button_text"
          android:layout_alignParentBottom="true"
          android:layout_centerHorizontal="true"
          android:fontFamily="mipro-misans"
          android:layout_marginHorizontal="@dimen/fod_swipe_fingerprint_margin_horizontal"
          android:fallbackLineSpacing="true"
          style="@style/Widget.Button.Primary" />
</RelativeLayout>