<?xml version='1.0' encoding='utf-8' ?>
<ScrollView android:paddingTop="@dimen/bluetooth_dialog_padding_top"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android">
  <LinearLayout android:orientation="vertical"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:paddingStart="24.0dp"
                android:paddingEnd="24.0dp">
    <ImageView android:layout_gravity="center"
               android:layout_width="32.0dp"
               android:layout_height="32.0dp"
               android:src="@drawable/ic_warning_24dp"
               android:tint="@color/settingslib_materialColorOutline"
               android:importantForAccessibility="no" />
    <TextView android:textAppearance="@android:style/TextAppearance.Holo.Light.SearchResult.Subtitle"
              android:gravity="center"
              android:id="@id/bluetooth_key_missing_title"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:layout_marginTop="16.0dp" />
    <TextView android:textAppearance="@android:style/TextAppearance.DeviceDefault.Widget.Toolbar.Title"
              android:gravity="center"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:layout_marginTop="16.0dp"
              android:layout_marginBottom="32.0dp"
              android:text="@string/bluetooth_key_missing_message" />
  </LinearLayout>
</ScrollView>