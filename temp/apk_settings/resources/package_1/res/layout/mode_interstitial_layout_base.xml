<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:orientation="vertical"
              android:id="@id/interstitial_page"
              android:fitsSystemWindows="true"
              android:layout_width="fill_parent"
              android:layout_height="fill_parent"
              android:transitionGroup="true" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <Toolbar android:theme="?android:attr/actionBarTheme"
           android:id="@id/action_bar"
           android:background="@android:color/transparent"
           android:layout_width="fill_parent"
           android:layout_height="wrap_content"
           android:elevation="0.0dp"
           style="?attr/actionBarStyle" />
  <androidx.constraintlayout.widget.ConstraintLayout android:orientation="vertical"
                        android:paddingLeft="24.0dp"
                        android:paddingTop="12.0dp"
                        android:paddingRight="24.0dp"
                        android:paddingBottom="64.0dp"
                        android:layout_width="fill_parent"
                        android:layout_height="fill_parent">
    <FrameLayout android:id="@id/image_frame"
                 android:layout_width="fill_parent"
                 android:layout_height="0.0dp"
                 app:layout_constraintBottom_toTopOf="@id/mode_name_title"
                 app:layout_constraintTop_toTopOf="parent">
      <ImageView android:layout_gravity="center"
                 android:id="@id/image"
                 android:clickable="false"
                 android:layout_width="fill_parent"
                 android:layout_height="fill_parent"
                 android:scaleType="fitCenter"
                 android:adjustViewBounds="true" />
    </FrameLayout>
    <TextView android:textAppearance="@android:style/TextAppearance.Holo.Light.SearchResult.Subtitle"
              android:textSize="36.0sp"
              android:id="@id/mode_name_title"
              android:clickable="false"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:paddingVertical="12.0dp"
              app:layout_constraintBottom_toTopOf="@id/mode_name_subtitle" />
    <TextView android:textAppearance="@android:style/TextAppearance.DeviceDefault.Widget.Toolbar.Title"
              android:textSize="18.0sp"
              android:id="@id/mode_name_subtitle"
              android:paddingBottom="18.0dp"
              android:clickable="false"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:text="@string/zen_mode_setup_page_summary"
              app:layout_constraintBottom_toTopOf="@id/enable_mode_button" />
    <Button android:id="@id/enable_mode_button"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="12.0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintVertical_bias="1.0"
            style="@style/ActionPrimaryButton" />
  </androidx.constraintlayout.widget.ConstraintLayout>
</LinearLayout>