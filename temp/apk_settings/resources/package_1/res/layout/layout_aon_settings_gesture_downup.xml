<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:gravity="center_horizontal"
              android:orientation="vertical"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <com.android.settings.aon.gesture.ScrollLinearlayout android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:id="@id/scroll_root_view"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8.0dp">
    <FrameLayout android:id="@id/first_frame_layout"
                 android:visibility="visible"
                 android:layout_width="fill_parent"
                 android:layout_height="@dimen/aon_gesture_framelayout_height"
                 android:importantForAccessibility="no">
      <com.airbnb.lottie.LottieAnimationView android:layout_gravity="center"
                            android:id="@id/first_animation"
                            android:layout_width="@dimen/aon_gesture_animation_width"
                            android:layout_height="@dimen/aon_gesture_animation_height"
                            android:scaleType="fitCenter"
                            app:lottie_autoPlay="true"
                            app:lottie_loop="true" />
    </FrameLayout>
    <FrameLayout android:id="@id/second_frame_layout"
                 android:visibility="gone"
                 android:layout_width="fill_parent"
                 android:layout_height="@dimen/aon_gesture_framelayout_height"
                 android:importantForAccessibility="no">
      <com.airbnb.lottie.LottieAnimationView android:layout_gravity="center"
                            android:id="@id/second_animation"
                            android:visibility="gone"
                            android:layout_width="@dimen/aon_gesture_animation_width"
                            android:layout_height="@dimen/aon_gesture_animation_height"
                            android:scaleType="fitCenter"
                            app:lottie_autoPlay="true"
                            app:lottie_loop="true" />
    </FrameLayout>
    <TextView android:textSize="@dimen/miuix_preference_normal_text_size"
              android:textColor="?android:attr/textColorPrimary"
              android:gravity="center"
              android:id="@id/tv_title"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginTop="12.0dp"
              android:text="@string/aon_gesture_up_waving_diagram_title"
              android:fontFamily="sans-serif-medium"
              android:paddingStart="@dimen/miuix_preference_item_padding_start"
              android:paddingEnd="@dimen/miuix_preference_item_padding_end" />
    <TextView android:textSize="@dimen/miuix_preference_secondary_text_size"
              android:textColor="@color/second_text_color"
              android:gravity="left"
              android:id="@id/tv_summary"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginLeft="@dimen/miuix_preference_item_padding_start"
              android:layout_marginTop="2.0dp"
              android:layout_marginRight="@dimen/miuix_preference_item_padding_end"
              android:layout_marginBottom="16.0dp"
              android:text="@string/aon_gesture_up_waving_diagram_summary"
              android:fontFamily="sans-serif" />
    <LinearLayout android:gravity="center"
                  android:orientation="horizontal"
                  android:id="@id/dot_root_view"
                  android:visibility="invisible"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content"
                  android:layout_marginBottom="20.0dp">
      <ImageView android:id="@id/image_dot_left"
                 android:layout_width="5.0dp"
                 android:layout_height="5.0dp"
                 android:src="@drawable/point_select" />
      <ImageView android:id="@id/image_dot_right"
                 android:layout_width="5.0dp"
                 android:layout_height="5.0dp"
                 android:src="@drawable/point_unselect"
                 android:layout_marginStart="5.1dp" />
    </LinearLayout>
  </com.android.settings.aon.gesture.ScrollLinearlayout>
</LinearLayout>