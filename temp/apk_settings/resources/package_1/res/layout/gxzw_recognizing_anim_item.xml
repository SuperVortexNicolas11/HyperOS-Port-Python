<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:gravity="center"
              android:orientation="vertical"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android">
  <FrameLayout android:id="@id/gxzw_recognizing_anim_container"
               android:layout_width="112.0dp"
               android:layout_height="140.0dp"
               android:scaleType="center">
    <RelativeLayout android:layout_width="fill_parent"
                    android:layout_height="fill_parent">
      <ImageView android:layout_gravity="center"
                 android:id="@id/gxzw_recognizing_anim_icon"
                 android:background="@drawable/gxzw_recognizing_anim_bg"
                 android:layout_width="fill_parent"
                 android:layout_height="fill_parent"
                 android:layout_margin="8.0dp"
                 android:scaleType="centerInside"
                 android:layerType="hardware" />
      <ImageView android:id="@id/gxzw_download_icon"
                 android:layout_width="@dimen/miui_gxzw_anim_download_icon_size"
                 android:layout_height="@dimen/miui_gxzw_anim_download_icon_size"
                 android:layout_marginBottom="@dimen/miui_gxzw_anim_download_icon_margin_bottom"
                 android:src="@drawable/download_fod_anim"
                 android:layout_alignParentBottom="true"
                 android:layout_marginEnd="@dimen/miui_gxzw_anim_download_icon_margin_end"
                 android:layout_alignParentEnd="true" />
      <ImageView android:id="@id/gxzw_downloading_icon"
                 android:visibility="invisible"
                 android:layout_width="20.0dp"
                 android:layout_height="20.0dp"
                 android:layout_marginBottom="@dimen/miui_gxzw_anim_downloading_icon_margin"
                 android:src="@drawable/downloading_fod_anim"
                 android:layout_alignParentBottom="true"
                 android:layout_marginEnd="@dimen/miui_gxzw_anim_downloading_icon_margin"
                 android:layout_alignParentEnd="true" />
    </RelativeLayout>
    <View android:layout_gravity="center"
          android:id="@id/gxzw_recognizing_anim_frame"
          android:background="@drawable/gxzw_selected_rectangle"
          android:layout_width="fill_parent"
          android:layout_height="fill_parent"
          android:alpha="0.0"
          android:layerType="hardware" />
  </FrameLayout>
</LinearLayout>