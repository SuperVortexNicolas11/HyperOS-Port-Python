<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:gravity="center_horizontal"
              android:orientation="vertical"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
  <com.android.settings.widget.MaxHeightNestedScrollView android:scrollbars="vertical"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:fadeScrollbars="false"
                        app:maxHeight="@dimen/keyguard_sliding_guide_item_text_max_height">
    <LinearLayout android:gravity="center_horizontal"
                  android:orientation="vertical"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content">
      <TextView android:textSize="@dimen/guide_title_text_size"
                android:textColor="@color/guide_color"
                android:id="@id/guide_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/guide_title_margin_top"
                android:fontFamily="mipro-milanpro"
                android:textFontWeight="500" />
      <TextView android:textSize="@dimen/guide_text_size"
                android:textColor="@color/guide_text_color"
                android:gravity="center"
                android:id="@id/guide_text"
                android:focusableInTouchMode="true"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/guide_text_margin_top"
                android:minHeight="@dimen/guide_text_height"
                android:fontFamily="mipro-misans" />
    </LinearLayout>
  </com.android.settings.widget.MaxHeightNestedScrollView>
  <com.airbnb.lottie.LottieAnimationView android:id="@id/lottie_view"
                        android:paddingLeft="@dimen/guide_lottie_padding"
                        android:paddingRight="@dimen/guide_lottie_padding"
                        android:layout_width="@dimen/lottie_view_width_new"
                        android:layout_height="@dimen/lottie_view_height_new"
                        android:layout_marginTop="@dimen/lottie_view_margin_top"
                        app:lottie_fileName="dark-left.json"
                        app:lottie_loop="true" />
</LinearLayout>