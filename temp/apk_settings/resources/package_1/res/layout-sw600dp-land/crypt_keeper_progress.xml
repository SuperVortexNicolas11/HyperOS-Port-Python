<?xml version='1.0' encoding='utf-8' ?>
<LinearLayout android:gravity="center_horizontal"
              android:orientation="vertical"
              android:paddingTop="@dimen/boot_msg_top_padding"
              android:paddingBottom="@dimen/boot_msg_bottom_padding"
              android:layout_width="fill_parent"
              android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android">
  <LinearLayout android:gravity="center_horizontal"
                android:orientation="vertical"
                android:layout_width="fill_parent"
                android:layout_height="0.0dp"
                android:layout_weight="1.0">
    <ImageView android:id="@id/encroid"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:src="@drawable/boot_logo"
               android:contentDescription="@null" />
    <Button android:id="@id/factory_reset"
            android:visibility="invisible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/master_clear_button_text" />
  </LinearLayout>
  <TextView android:textSize="@dimen/crypt_keeper_title_text_size"
            android:id="@id/title"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
  <TextView android:textSize="@dimen/boot_msg_textsize"
            android:textColor="@color/boot_msg_textcolor"
            android:ellipsize="end"
            android:id="@id/status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="15.0dp"
            android:text="@string/encryption_progress_summary" />
  <miuix.androidbasewidget.widget.ProgressBar android:id="@id/progress_bar"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/boot_msg_left_padding"
                        android:layout_marginRight="@dimen/boot_msg_right_padding"
                        android:progressDrawable="@drawable/boot_progressbar"
                        android:minHeight="0.0dp" />
</LinearLayout>